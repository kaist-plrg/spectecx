  "conf-pkg-config" {= "4"}
  "core" {= "v0.17.1"}
  "core_kernel" {= "v0.17.0"}
  "core_unix" {= "v0.17.1"}
  "cppo" {= "1.8.0" & with-doc}
  "crunch" {= "4.0.0" & with-doc}
  "csexp" {= "1.5.2"}
  "dune" {= "3.21.0"}
  "dune-configurator" {= "3.21.0"}
  "expect_test_helpers_core" {= "v0.17.0"}
