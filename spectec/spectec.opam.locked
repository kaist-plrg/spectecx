opam-version: "2.0"
name: "spectec"
version: "0.0.1"
synopsis: "SpecTecX: an executable subset of SpecTec"
maintainer: "kunjeong99@naver.com"
depends: [
  "astring" {= "0.8.5" & with-doc}
  "base" {= "v0.17.3"}
  "base-bigarray" {= "base"}
  "base-domains" {= "base"}
  "base-nnp" {= "base"}
  "base-threads" {= "base"}
  "base-unix" {= "base"}
  "base_bigstring" {= "v0.17.0"}
  "base_quickcheck" {= "v0.17.0"}
  "bignum" {= "v0.17.0"}
