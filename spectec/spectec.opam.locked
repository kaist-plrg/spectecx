  "ptime" {= "1.2.0" & with-doc}
  "re" {= "1.14.0"}
  "seq" {= "base" & with-doc}
  "sexp_pretty" {= "v0.17.0"}
  "sexplib" {= "v0.17.0"}
  "sexplib0" {= "v0.17.0"}
  "spawn" {= "v0.17.0"}
  "splittable_random" {= "v0.17.0"}
  "stdio" {= "v0.17.0"}
  "stdlib-shims" {= "0.3.0"}
  "time_now" {= "v0.17.0"}
  "timezone" {= "v0.17.0"}
  "topkg" {= "1.1.1" & with-doc}
  "typerep" {= "v0.17.1"}
  "tyxml" {= "4.6.0" & with-doc}
  "uopt" {= "v0.17.0"}
  "uutf" {= "1.0.4" & with-doc}
  "variantslib" {= "v0.17.0"}
  "zarith" {= "1.14"}
  "zarith_stubs_js" {= "v0.17.0"}
]
build: [
  ["dune" "subst"] {dev}
  [
    "dune"
    "build"
    "-p"
    name
    "-j"
    jobs
    "@install"
    "@runtest" {with-test}
    "@doc" {with-doc}
  ]
]