;;
;;;; Well-formedness of callable type definitions
;;

rule CallableTypeDef_wf:
  B |- callableTypeDefIR
  -- if (typeParameterIR_expl*, typeParameterIR_impl*)
      = $typeParameterListIR_of_callableTypeDefIR(callableTypeDefIR)
  -- if typeParameterIR*
      = typeParameterIR_expl* ++ typeParameterIR_impl*
  -- if $distinct_<typeId>(typeParameterIR*)
  -- if callableTypeIR_base
      = $callableTypeIR_of_callableTypeDefIR(callableTypeDefIR)
  -- if B_inner
      = $union_set<typeId>(B, `{ typeParameterIR* })
  -- CallableType_wf: B_inner |- callableTypeIR_base

;;
;;;; Well-formedness of constructor paramter types
;;

rule ConstructorParameterType_wf:
  B |- constructorParameterIR
  -- if _ `EMPTY _ _ _ = constructorParameterIR
  -- ParameterType_wf: B |- constructorParameterIR

;;
;;;; Well-formedness of constructor types
;;

dec $nestable_constructor_extern(typeIR) : bool
  hint(prose_true %0 "can be used in an extern constructor type")
  hint(prose_false %0 "cannot be used in an extern constructor type")

def $nestable_constructor_extern(TYPEDEF _ typeIR) = $nestable_constructor_extern(typeIR)
def $nestable_constructor_extern(parserObjectTypeIR) = false
def $nestable_constructor_extern(controlObjectTypeIR) = false
def $nestable_constructor_extern(packageObjectTypeIR) = false
def $nestable_constructor_extern(tableObjectTypeIR) = false
def $nestable_constructor_extern(_) = true

rule ConstructorType_wf/externObjectTypeIR:
  B |- CONSTRUCTOR `( parameterIR* ) `: typeIR_object
  -- (ConstructorParameterType_wf: B |- parameterIR)*
  -- Type_wf: B |- typeIR_object
  -- if externObjectTypeIR = $unroll_typeIR(typeIR_object)
  -- if (_ _ typeIR _ _ = parameterIR)*
  -- if $nestable_constructor_extern(typeIR)*

