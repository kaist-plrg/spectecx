  hint(prose_false %0 "cannot be used in a control constructor type")
def $nestable_constructor_control(TYPEDEF _ typeIR) = $nestable_constructor_control(typeIR)
def $nestable_constructor_control(parserObjectTypeIR) = false
def $nestable_constructor_control(packageObjectTypeIR) = false
def $nestable_constructor_control(tableObjectTypeIR) = false
