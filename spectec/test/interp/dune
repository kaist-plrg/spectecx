;; ============================================================
;; Combined aliases for running all tests
;; ============================================================

(alias
 (name p4-old-il)
 (deps
  (alias p4-old-il-pos)
  (alias p4-old-il-neg)))

(alias
 (name p4-old-sl)
 (deps
  (alias p4-old-sl-pos)
  (alias p4-old-sl-neg)))

(alias
 (name p4-il)
 (deps
  (alias p4-il-pos)
  (alias p4-il-neg)))

(alias
 (name p4-sl)
 (deps
  (alias p4-sl-pos)
  (alias p4-sl-neg)))

(alias
 (name runtest)
 (deps
  (alias p4-old-il)
  (alias p4-old-sl)
  (alias p4-il)
  (alias p4-sl)))
