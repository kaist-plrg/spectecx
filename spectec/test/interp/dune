; Interpreter test executable (unified IL/SL with --sl flag)

(executable
 (name main)
 (preprocess
  (pps ppx_let))
 (libraries test_lib targets_p4 core core_unix core_unix.command_unix))

;; ============================================================
;; p4-old target tests
;; ============================================================

;; IL Positive tests (expect success, default IL mode)

(rule
 (target p4-old-il-pos.actual)
 (deps
  (source_tree ../../examples/p4-concrete-old)
  (source_tree ../../testdata/interp/p4-tests/includes)
  (source_tree ../../testdata/interp/p4-tests/excludes)
  (source_tree ../../testdata/interp/p4-tests/tests/p4_16_samples))
 (action
  (with-stdout-to
   %{target}
   (with-stderr-to
    p4-old-il-pos.err
    (run
     ./main.exe
     --p4-old
     -i
     ../../../../../spectec/testdata/interp/p4-tests/includes
     -e
     ../../../../../spectec/testdata/interp/p4-tests/excludes
     -d
     ../../../../../spectec/testdata/interp/p4-tests/tests/p4_16_samples)))))

(rule
 (alias p4-old-il-pos)
 (deps p4-old-il-pos.err p4-old-il-pos.actual)
 (action
  (diff p4-old-il-pos.expected p4-old-il-pos.actual)))

;; IL Negative tests (expect failure, default IL mode)

(rule
 (target p4-old-il-neg.actual)
 (deps
  (source_tree ../../examples/p4-concrete-old)
  (source_tree ../../testdata/interp/p4-tests/includes)
  (source_tree ../../testdata/interp/p4-tests/excludes)
  (source_tree ../../testdata/interp/p4-tests/tests/p4_16_errors))
