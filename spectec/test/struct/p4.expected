;; ../../../../../spectec/examples/p4-concrete/5-typing/5.11-typing-declaration.spectec:129:1-136:53:
relation ObjectDecl_ok: p, TC_0, typeFrame, externMethodTypeDefEnv, objectDeclaration

1. Case analysis on objectDeclaration

  1. Case (% has type instantiation)

    1. (Let instantiation be (objectDeclaration as instantiation))

    2. (InstDecl_ok: p TC_0 |- instantiation : TC_1 instantiationIR)

    3. (Let (_annotationList _typeIR _constructorTargetIR ( _argumentListIR ) nameIR _objectInitializerOptIR ;) be instantiationIR)

    4. (Let varTypeIR'? be $find_var_t((` nameIR), p, TC_1))

    5. If ((varTypeIR'? matches pattern (_))), then

      1. (Let ?(varTypeIR) be varTypeIR'?)

      2. (Let typeFrame_init be $update_map<id, varTypeIR>(typeFrame, nameIR, varTypeIR))

      3. Result in typeFrame_init, externMethodTypeDefEnv, (instantiationIR as objectDeclarationIR)

    5. Else Phantom#1531

  2. Case (% has type functionDeclaration)

    1. (Let (annotationList (typeOrVoid name typeParameterListOpt ( parameterList )) blockStatement) be (objectDeclaration as functionDeclaration))

    2. (Let TC_1 be TC_0[block.kind = (extern)])

    3. (Let TC_2 be TC_1[block.frame = typeFrame])

    4. (TypeParameterListOpt_ok: (local) TC_2 |- typeParameterListOpt : TC_3 typeId_expl*)

    5. (ParameterList_ok: (local) TC_3 |- parameterList : TC_4 parameterIR* # typeId_impl*)

    6. (Type_ok: (local) TC_3 |- typeOrVoid : typeIR_ret # typeId*)

    7. If ((typeId* matches pattern [])), then

      1. (Let TC_5 be TC_4[local.kind = ((extern_method : typeIR_ret) as localKind)])

      2. (Block_ok: TC_5 (cont) (noloop) |- blockStatement : _typingContext f blockStatementIR)

      3. If (((f = (ret)) \/ (typeIR_ret = ((void) as typeIR)))), then

        1. (Let callableId be $callableId(name, parameterList))

        2. (Let nameIR be $name(name))

        3. (Let externMethodTypeDefIR be (extern_method nameIR < typeId_expl* , typeId_impl* > ( parameterIR* ) : typeIR_ret))

        4. If (CallableTypeDef_wf: $bound(p, TC_0) |- (externMethodTypeDefIR as callableTypeDefIR) holds), then

          1. (Let externMethodTypeDefEnv_init be $update_map<callableId, externMethodTypeDefIR>(externMethodTypeDefEnv, callableId, externMethodTypeDefIR))

          2. (Let functionDeclarationIR be (annotationList (typeIR_ret nameIR < typeId_expl* , typeId_impl* > ( parameterIR* )) blockStatementIR))

          3. Result in typeFrame, externMethodTypeDefEnv_init, (functionDeclarationIR as objectDeclarationIR)

        4. Else Phantom#1532

      3. Else Phantom#1533

    7. Else Phantom#1534

