          1. (Let (w' w i_r) be integerLiteral')

          2. If ((w = w')), then

            1. (Let i' be $int_to_bitstr((w as int), $band(i_l, i_r)))

            2. Return ((w w i') as value)

          2. Else Phantom#360

        2. Else Phantom#361

