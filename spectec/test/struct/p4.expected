dec $find_local_return_type_t(TC)

1. (Let localKind be TC.local.kind)

2. Case analysis on localKind

  1. Case (% has type definedFunctionLocalKind)

    1. (Let (function : typeIR_ret) be (localKind as definedFunctionLocalKind))

    2. Return ?(typeIR_ret)

  2. Case (% has type externFunctionLocalKind)

    1. (Let (extern_function : typeIR_ret) be (localKind as externFunctionLocalKind))

    2. Return ?(typeIR_ret)

  3. Case (% has type externMethodLocalKind)

    1. (Let externMethodLocalKind be (localKind as externMethodLocalKind))

    2. Case analysis on externMethodLocalKind

      1. Case (% matches pattern `EXTERN_METHOD : %`)

        1. (Let (extern_method : typeIR_ret) be externMethodLocalKind)

        2. Return ?(typeIR_ret)

      2. Case (% matches pattern `EXTERN_METHOD ABSTRACT : %`)

        1. (Let (extern_method abstract : typeIR_ret) be externMethodLocalKind)

        2. Return ?(typeIR_ret)

3. If ((((action) as localKind) = TC.local.kind)), then

  1. Return ?(((void) as typeIR))

4. If ((((control_apply_method) as localKind) = TC.local.kind)), then

  1. Return ?(((void) as typeIR))

5. Otherwise

  1. Return ?()

