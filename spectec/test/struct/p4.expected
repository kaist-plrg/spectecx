1. (Type_ok: p TC_0 |- (type as typeOrVoid) : typeIR # typeId*)

2. If ((typeId* matches pattern [])), then

  1. If (Type_wf: $bound(p, TC_0) |- typeIR holds), then

    1. (Expr_ok: p TC_0 |- expression_value : typedExpressionIR_value)

