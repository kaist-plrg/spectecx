  2. Case (% has type variableDeclarationIR)

    1. (Let variableDeclarationIR be (parserStatementIR as variableDeclarationIR))

    2. Result in IC_0', STO', (variableDeclarationIR as parserStatementIR)

  3. Case (% has type emptyStatementIR)

    1. (Let emptyStatementIR be (parserStatementIR as emptyStatementIR))

    2. (Stmt_inst: (local) IC_0' STO' |- (emptyStatementIR as statementIR) : IC_1 STO_1 statementIR)

    3. If ((statementIR has type emptyStatementIR)), then

      1. (Let emptyStatementIR_inst be (statementIR as emptyStatementIR))

      2. Result in IC_1, STO_1, (emptyStatementIR_inst as parserStatementIR)

    3. Else Phantom#1749

  4. Case (% has type assignmentStatementIR)

    1. (Let assignmentStatementIR be (parserStatementIR as assignmentStatementIR))

    2. (Stmt_inst: (local) IC_0' STO' |- (assignmentStatementIR as statementIR) : IC_1 STO_1 statementIR)

    3. If ((statementIR has type assignmentStatementIR)), then

      1. (Let assignmentStatementIR_inst be (statementIR as assignmentStatementIR))

      2. Result in IC_1, STO_1, (assignmentStatementIR_inst as parserStatementIR)

    3. Else Phantom#1750

  5. Case (% has type callStatementIR)

    1. (Let callStatementIR be (parserStatementIR as callStatementIR))

    2. (Stmt_inst: (local) IC_0' STO' |- (callStatementIR as statementIR) : IC_1 STO_1 statementIR)

    3. If ((statementIR has type callStatementIR)), then

      1. (Let callStatementIR_inst be (statementIR as callStatementIR))

      2. Result in IC_1, STO_1, (callStatementIR_inst as parserStatementIR)

    3. Else Phantom#1751

  6. Case (% has type directApplicationStatementIR)

    1. (Let directApplicationStatementIR be (parserStatementIR as directApplicationStatementIR))

    2. (DirectApplicationStmt_inst: (local) IC_0' STO' |- directApplicationStatementIR : STO_1 constantDeclarationIR callStatementIR)

    3. (Let parserBlockStatementIR be (() { [(constantDeclarationIR as parserStatementIR), (callStatementIR as parserStatementIR)] }))

    4. Result in IC_0', STO_1, (parserBlockStatementIR as parserStatementIR)

  7. Case (% has type parserBlockStatementIR)

    1. (Let (annotationList { parserStatementListIR }) be (parserStatementIR as parserBlockStatementIR))

    2. (ParserStmts_inst: IC_0' STO' |- parserStatementListIR : IC_1 STO_1 parserStatementListIR_inst)

    3. (Let parserBlockStatementIR_inst be (annotationList { parserStatementListIR_inst }))

    4. Result in IC_1, STO_1, (parserBlockStatementIR_inst as parserStatementIR)

  8. Case (% has type parserConditionalStatementIR)

    1. (Let parserConditionalStatementIR be (parserStatementIR as parserConditionalStatementIR))

    2. Case analysis on parserConditionalStatementIR

      1. Case (% matches pattern `IF (%) %`)

        1. (Let (if ( typedExpressionIR_cond ) parserStatementIR_then) be parserConditionalStatementIR)

        2. (ParserStmt_inst: IC_0' STO' |- parserStatementIR_then : IC_then STO_1 parserStatementIR_then_inst)

        3. Result in IC_0', STO_1, ((if ( typedExpressionIR_cond ) parserStatementIR_then_inst) as parserStatementIR)

      2. Case (% matches pattern `IF (%) % ELSE %`)

        1. (Let (if ( typedExpressionIR_cond ) parserStatementIR_then else parserStatementIR_else) be parserConditionalStatementIR)

        2. (ParserStmt_inst: IC_0' STO' |- parserStatementIR_then : IC_then STO_1 parserStatementIR_then_inst)

        3. (ParserStmt_inst: IC_0' STO_1 |- parserStatementIR_else : IC_else STO_2 parserStatementIR_else_inst)

        4. Result in IC_0', STO_2, ((if ( typedExpressionIR_cond ) parserStatementIR_then_inst else parserStatementIR_else_inst) as parserStatementIR)

