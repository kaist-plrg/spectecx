;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:12:1-13:85:
builtin dec $shr_arith(int, int', int'')

;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:15:1-16:55:
builtin dec $bneg(int)

;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:17:1-18:50:
builtin dec $band(int, int')

;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:19:1-20:50:
