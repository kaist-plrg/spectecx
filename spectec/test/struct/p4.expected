;; ../../../../../spectec/examples/p4-concrete/5-typing/5.11-typing-declaration.spectec:246:1-249:85:
dec $subst_externMethodTypeDefEnv(externMethodTypeDefEnv_extern, set<pair<callableId, externMethodTypeDefIR>>')

1. If ((set<pair<callableId, externMethodTypeDefIR>>' = ({ [] }))), then

  1. Return externMethodTypeDefEnv_extern

1. Else Phantom#1535

2. (Let ({ pair<callableId, externMethodTypeDefIR>* }) be set<pair<callableId, externMethodTypeDefIR>>')

3. If ((pair<callableId, externMethodTypeDefIR>* matches pattern _ :: _)), then

  1. (Let (callableId_init_h : externMethodTypeDefIR_init_h) :: (callableId_init_t : externMethodTypeDefIR_init_t)* be pair<callableId, externMethodTypeDefIR>*)

  2. (Let (nameIR_init_h ( _id* )) be callableId_init_h)

  3. (Let (callableId, externMethodTypeDefIR)? be $find_non_overloaded<externMethodTypeDefIR>(externMethodTypeDefEnv_extern, nameIR_init_h))

  4. If (((callableId, externMethodTypeDefIR)? matches pattern (_))), then

    1. (Let ?((callableId, externMethodTypeDefIR_abstract)) be (callableId, externMethodTypeDefIR)?)

    2. (Let externMethodTypeDefIR be externMethodTypeDefIR_abstract)

    3. If ((externMethodTypeDefIR matches pattern `EXTERN_METHOD ABSTRACT % <% , %> (%) : %`)), then

      1. (Let (extern_method abstract nameIR < typeId_expl* , typeId_impl* > ( parameterIR* ) : typeIR_ret) be externMethodTypeDefIR)

      2. (Let externMethodTypeDefIR_concrete be (extern_method nameIR < typeId_expl* , typeId_impl* > ( parameterIR* ) : typeIR_ret))

      3. If (ExternMethodTypeDef_alpha: externMethodTypeDefIR_concrete ~~ externMethodTypeDefIR_init_h holds), then

        1. (Let externMethodTypeDefEnv_extern_subst be $update_map<callableId, externMethodTypeDefIR>(externMethodTypeDefEnv_extern, callableId, externMethodTypeDefIR_concrete))

        2. Return $subst_externMethodTypeDefEnv(externMethodTypeDefEnv_extern_subst, ({ (callableId_init_t : externMethodTypeDefIR_init_t)* }))

      3. Else Phantom#1536

    3. Else Phantom#1537

  4. Else Phantom#1538

3. Else Phantom#1539

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.11-typing-declaration.spectec:283:1-289:40:
relation InstDecl_objectInitializer_ok: p, TC_0, annotationList, prefixedTypeName, typeArgumentList, argumentList, name, objectDeclarationList

1. (TypeArgumentList_ok: p TC_0 |- typeArgumentList : typeArgumentIR* # typeId_impl*)

2. (ArgumentList_ok: p TC_0 |- argumentList : argumentIR*)

3. (Let prefixedNameIR be $prefixedTypeName(prefixedTypeName))

4. (Let constructorTargetIR be (prefixedNameIR < typeArgumentIR* >))

5. (ConstructorType_ok: p TC_0 |- constructorTargetIR ( argumentIR* ) : constructorTypeIR < # typeId_inserted* > ( # id_default* # id_optional* ))

6. (Let typeId_infer* be typeId_impl* ++ typeId_inserted*)

7. (Inst_ok: p TC_0 (named) |- constructorTypeIR < typeArgumentIR* # typeId_infer* > ( argumentIR* # id_default* # id_optional* ) : typeIR_object < typeArgumentIR_inferred* > ( argumentIR_cast* ))

8. (Let typeIR be $unroll_typeIR(typeIR_object))

9. If ((typeIR has type externObjectTypeIR)), then

  1. (Let (extern typeId_extern < typeIR_arg* > externMethodTypeDefEnv_extern) be (typeIR as externObjectTypeIR))

  2. (Let TC_1 be $add_var_t((local), TC_0, "this", (() typeIR_object (ctk) ?())))

  3. (ObjectDeclList_ok: p TC_1 |- objectDeclarationList : typeFrame_init externMethodTypeDefEnv_init objectDeclarationIR*)

  4. (Let externMethodTypeDefEnv_init_subst be $subst_externMethodTypeDefEnv(externMethodTypeDefEnv_extern, externMethodTypeDefEnv_init))

  5. (Let typeIR_object_init be ((extern typeId_extern < typeIR_arg* > externMethodTypeDefEnv_init_subst) as typeIR))

  6. If ($is_concrete_extern_object(typeIR_object_init)), then

    1. (Let nameIR be $name(name))

    2. (Let TC_2 be $add_var_t(p, TC_0, nameIR, (() typeIR_object_init (ctk) ?())))

    3. (Let constructorTargetIR_inferred be (prefixedNameIR < typeArgumentIR_inferred* >))

    4. (Let instantiationIR be (annotationList typeIR_object_init constructorTargetIR_inferred ( argumentIR_cast* ) nameIR ?((= { objectDeclarationIR* })) ;))

    5. Result in TC_2, instantiationIR

  6. Else Phantom#1540

9. Else Phantom#1541

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.11-typing-declaration.spectec:539:1-542:58:
dec $split_externConstructorOrMethodPrototypeList(externConstructorOrMethodPrototypeList)

1. (Let externConstructorOrMethodPrototype* be $flatten_externConstructorOrMethodPrototypeList(externConstructorOrMethodPrototypeList))

