3. If ((externConstructorOrMethodPrototype'* has type externConstructorPrototype*)), then

  1. (Let externConstructorPrototype* be (externConstructorOrMethodPrototype'* as externConstructorPrototype*))

  2. (Let externConstructorOrMethodPrototype''* be $filter_<externConstructorOrMethodPrototype>(externConstructorOrMethodPrototype*, $is_externMethodPrototype(externConstructorOrMethodPrototype)*))

  3. If ((externConstructorOrMethodPrototype''* has type externMethodPrototype*)), then

    1. (Let externMethodPrototype* be (externConstructorOrMethodPrototype''* as externMethodPrototype*))

    2. Return (externConstructorPrototype*, externMethodPrototype*)

  3. Else Phantom#1542

3. Else Phantom#1543

