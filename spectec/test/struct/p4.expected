dec $fresh_typeIds(nat')

1. Case analysis on nat'

  1. Case (% = 0)

    1. Return []

  2. Case (% =/= 0)

    1. (Let n' be (nat' - 1))

    2. Return $fresh_typeId :: $fresh_typeIds(n')

