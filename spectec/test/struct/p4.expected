;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.03-inst-relation.spectec:153:1-158:38:
relation TableAction_inst: IC, STO, (annotationList tableActionReferenceIR # ( parameterListIR , parameterListIR_control ) ;)

1. (Let (prefixedNameIR _controlPlaneNameIR ( argumentListIR )) be tableActionReferenceIR)

2. (Let (cursor, callableId, callableDef)? be $find_callableDef_non_overload_i((local), IC, prefixedNameIR))

3. If (((cursor, callableId, callableDef)? matches pattern (_))), then

  1. (Let ?((cursor, _callableId, callableDef)) be (cursor, callableId, callableDef)?)

  2. If ((callableDef has type actionDef)), then

    1. (Let actionDef be (callableDef as actionDef))

    2. (Let (annotationList_actionDef action nameIR ( _parameterListIR ) _blockStatementIR) be actionDef)

    3. (Let nameIR'* be $name_annotation(annotationList_actionDef))

    4. If ((nameIR'* matches pattern [ _/1 ])), then

      1. (Let [nameIR_anno] be nameIR'*)

      2. Case analysis on $starts_with(nameIR_anno, ".")

        1. Case true

          1. (Let controlPlaneNameIR be ?($strip_prefix(nameIR_anno, ".")))

          2. (Let tableActionReferenceIR' be (prefixedNameIR controlPlaneNameIR ( argumentListIR )))

          3. (Let tableActionIR be (annotationList tableActionReferenceIR' # ( parameterListIR , parameterListIR_control ) ;))

          4. Result in STO, tableActionIR

        2. Case false

          1. (Let controlPlaneNameIR be $ite<controlPlaneNameIR>((cursor = (global)), ?(nameIR_anno), ?($join_text(IC.path ++ [nameIR_anno], "."))))

          2. (Let tableActionReferenceIR' be (prefixedNameIR controlPlaneNameIR ( argumentListIR )))

          3. (Let tableActionIR be (annotationList tableActionReferenceIR' # ( parameterListIR , parameterListIR_control ) ;))

          4. Result in STO, tableActionIR

    4. Else Phantom#1754

    5. If (([] = $name_annotation(annotationList_actionDef))), then

      1. (Let controlPlaneNameIR be $ite<controlPlaneNameIR>((cursor = (global)), ?(nameIR), ?($join_text(IC.path ++ [nameIR], "."))))

      2. (Let tableActionReferenceIR' be (prefixedNameIR controlPlaneNameIR ( argumentListIR )))

      3. (Let tableActionIR be (annotationList tableActionReferenceIR' # ( parameterListIR , parameterListIR_control ) ;))

      4. Result in STO, tableActionIR

    5. Else Phantom#1755

  2. Else Phantom#1756

3. Else Phantom#1757

