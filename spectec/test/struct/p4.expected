dec $exists_(bool*)

1. Case analysis on bool*

  1. Case (% matches pattern [])

    1. Return false

  2. Case (% matches pattern _ :: _)

    1. (Let b_h :: b_t* be bool*)

    2. Return (b_h \/ $exists_(b_t*))

