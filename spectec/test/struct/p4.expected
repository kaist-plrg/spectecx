syntax typeFieldListIR = typeFieldIR*

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:589:3-590:50:
syntax structTypeDeclarationIR = 
   | annotationList struct nameIR < typeParameterListIR > { typeFieldListIR } (from structTypeDeclarationIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:593:3-594:50:
syntax headerTypeDeclarationIR = 
   | annotationList header nameIR < typeParameterListIR > { typeFieldListIR } (from headerTypeDeclarationIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:597:3-598:50:
syntax headerUnionTypeDeclarationIR = 
