;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.2-ir-call-overload.spectec:286:1-291:84:
dec $find_overloaded<V>(({ (callableId : V)* }), (nameIR_f ( id_arg?* )), $get_parameterListIR)

1. If ((|id_arg?*| > 0)), then

  1. (Let id? be id_arg?)*

  2. If ((id? matches pattern (_)))*, then

    1. (Let ?(id_arg_inner) be id?)*

    2. If (([] = $find_overloadeds_named<V>(({ (callableId : V)* }), (nameIR_f ( id_arg_inner* )), $get_parameterListIR))), then

      1. Return ?()

    2. Else Phantom#518

    3. (Let callResolution<V>* be $find_overloadeds_named<V>(({ (callableId : V)* }), (nameIR_f ( id_arg_inner* )), $get_parameterListIR))

    4. If ((callResolution<V>* matches pattern [ _/1 ])), then

      1. (Let [(callableId_found : V_found # id_default* # id_optional*)] be callResolution<V>*)

      2. Return ?((callableId_found : V_found # id_default* # id_optional*))

    4. Else Phantom#519

  2. Else Phantom#520

1. Else Phantom#521

2. If ((id_arg? = ?()))*, then

  1. If (([] = $find_overloadeds_unnamed<V>(({ (callableId : V)* }), (nameIR_f ( |id_arg?*| )), $get_parameterListIR))), then

    1. Return ?()

  1. Else Phantom#522

  2. (Let callResolution<V>* be $find_overloadeds_unnamed<V>(({ (callableId : V)* }), (nameIR_f ( |id_arg?*| )), $get_parameterListIR))

  3. If ((callResolution<V>* matches pattern [ _/1 ])), then

    1. (Let [(callableId_found : V_found # id_omitted* # id_optional*)] be callResolution<V>*)

    2. Return ?((callableId_found : V_found # id_omitted* # id_optional*))

  3. Else Phantom#523

2. Else Phantom#524

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.2-ir-call-overload.spectec:351:1-352:21:
dec $find_non_overloaded<V>(({ (callableId : V)* }), nameIR_f)

1. (Let (callableId, V)* be $find_non_overloadeds<V>(({ (callableId : V)* }), nameIR_f))

2. If (((callableId, V)* matches pattern [ _/1 ])), then

  1. (Let [(callableId_found, V_found)] be (callableId, V)*)

  2. Return ?((callableId_found, V_found))

3. Otherwise

  1. Return ?()

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.2-ir-call-overload.spectec:353:1-354:21:
dec $find_non_overloadeds<V>(set<pair<callableId, V>>', nameIR_f)

1. If ((set<pair<callableId, V>>' = ({ [] }))), then

  1. Return []

1. Else Phantom#525

2. (Let ({ pair<callableId, V>* }) be set<pair<callableId, V>>')

3. If ((pair<callableId, V>* matches pattern _ :: _)), then

  1. (Let (callableId_h : V_h) :: (callableId_t : V_t)* be pair<callableId, V>*)

  2. (Let (nameIR ( _id* )) be callableId_h)

  3. Case analysis on nameIR

    1. Case (% = nameIR_f)

      1. (Let (callableId_t_found, V_t_found)* be $find_non_overloadeds<V>(({ (callableId_t : V_t)* }), nameIR_f))

      2. Return (callableId_h, V_h) :: (callableId_t_found, V_t_found)*

    2. Case (% =/= nameIR_f)

      1. (Let (callableId_t_found, V_t_found)* be $find_non_overloadeds<V>(({ (callableId_t : V_t)* }), nameIR_f))

      2. Return (callableId_t_found, V_t_found)*

3. Else Phantom#526

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.3-annotation.spectec:7:1-7:52:
dec $name_annotationToken(annotationToken)

1. Case analysis on annotationToken

  1. Case (% has type identifier)

    1. (Let (text) be (annotationToken as identifier))

    2. Return text

  2. Case (% has type typeIdentifier)

    1. (Let (text) be (annotationToken as typeIdentifier))

    2. Return text

  3. Case (% has type stringLiteral)

    1. (Let (" text ") be (annotationToken as stringLiteral))

    2. Return "\"" ++ text ++ "\""

  4. Case (% has type integerLiteral)

    1. (Let integerLiteral be (annotationToken as integerLiteral))

    2. Case analysis on integerLiteral

      1. Case (% matches pattern `D %`)

        1. (Let (d i) be integerLiteral)

        2. Return $int_to_text(i)

      2. Case (% matches pattern `% W %`)

        1. (Let (n w i) be integerLiteral)

        2. Return $int_to_text((n as int)) ++ "w" ++ $int_to_text(i)

      3. Case (% matches pattern `% S %`)

        1. (Let (n s i) be integerLiteral)

        2. Return $int_to_text((n as int)) ++ "s" ++ $int_to_text(i)

1. Else Phantom#527

2. Case analysis on annotationToken

  1. Case (% matches pattern `UNEXPECTED_TOKEN`)

    1. Return "unexpected_token"

  2. Case (% matches pattern `ABSTRACT`)

    1. Return "abstract"

  3. Case (% matches pattern `ACTION`)

    1. Return "action"

  4. Case (% matches pattern `ACTIONS`)

    1. Return "actions"

  5. Case (% matches pattern `APPLY`)

    1. Return "apply"

