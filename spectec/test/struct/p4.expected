dec $typeIR_of_typeDefIR(typeDefIR)

1. Case analysis on typeDefIR

  1. Case (% has type nameTypeDefIR)

    1. (Let nameTypeDefIR be (typeDefIR as nameTypeDefIR))

    2. Return (nameTypeDefIR as typeIR)

  2. Case (% has type aliasTypeDefIR)

    1. (Let aliasTypeDefIR be (typeDefIR as aliasTypeDefIR))

    2. Return (aliasTypeDefIR as typeIR)

  3. Case (% has type structTypeDefIR)

    1. (Let (struct typeId < typeParameterIR* > { fieldTypeIR* }) be (typeDefIR as structTypeDefIR))

    2. Return ((struct typeId < ((` typeParameterIR) as typeIR)* > { fieldTypeIR* }) as typeIR)

  4. Case (% has type headerTypeDefIR)

    1. (Let (header typeId < typeParameterIR* > { fieldTypeIR* }) be (typeDefIR as headerTypeDefIR))

    2. Return ((header typeId < ((` typeParameterIR) as typeIR)* > { fieldTypeIR* }) as typeIR)

  5. Case (% has type headerUnionTypeDefIR)

    1. (Let (header_union typeId < typeParameterIR* > { fieldTypeIR* }) be (typeDefIR as headerUnionTypeDefIR))

    2. Return ((header_union typeId < ((` typeParameterIR) as typeIR)* > { fieldTypeIR* }) as typeIR)

  6. Case (% has type enumTypeDefIR)

    1. (Let enumTypeDefIR be (typeDefIR as enumTypeDefIR))

    2. Return (enumTypeDefIR as typeIR)

  7. Case (% has type externObjectTypeDefIR)

    1. (Let (extern typeId < typeParameterIR_expl* , typeParameterIR_impl* > ({ (callableId : externMethodTypeDefIR)* })) be (typeDefIR as externObjectTypeDefIR))

    2. (Let typeParameterIR* be typeParameterIR_expl* ++ typeParameterIR_impl*)

    3. Return ((extern typeId < ((` typeParameterIR) as typeIR)* > ({ (callableId : externMethodTypeDefIR)* })) as typeIR)

  8. Case (% has type parserObjectTypeDefIR)

    1. (Let (parser typeId < typeParameterIR_expl* , typeParameterIR_impl* > ( parameterIR* )) be (typeDefIR as parserObjectTypeDefIR))

    2. (Let typeParameterIR* be typeParameterIR_expl* ++ typeParameterIR_impl*)

    3. Return ((parser typeId < ((` typeParameterIR) as typeIR)* > ( parameterIR* )) as typeIR)

  9. Case (% has type controlObjectTypeDefIR)

    1. (Let (control typeId < typeParameterIR_expl* , typeParameterIR_impl* > ( parameterIR* )) be (typeDefIR as controlObjectTypeDefIR))

    2. (Let typeParameterIR* be typeParameterIR_expl* ++ typeParameterIR_impl*)

    3. Return ((control typeId < ((` typeParameterIR) as typeIR)* > ( parameterIR* )) as typeIR)

  10. Case (% has type packageObjectTypeDefIR)

    1. (Let (package typeId < typeParameterIR_expl* , typeParameterIR_impl* > { typeIR* }) be (typeDefIR as packageObjectTypeDefIR))

    2. (Let typeParameterIR* be typeParameterIR_expl* ++ typeParameterIR_impl*)

    3. Return ((package typeId < ((` typeParameterIR) as typeIR)* > { typeIR* }) as typeIR)

  11. Case (% has type tableObjectTypeDefIR)

    1. (Let tableObjectTypeDefIR be (typeDefIR as tableObjectTypeDefIR))

    2. Return (tableObjectTypeDefIR as typeIR)

