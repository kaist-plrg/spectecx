;; ../../../../../spectec/examples/p4-concrete/5-typing/5.04-typing-relation.spectec:20:1-25:21:
relation Argument_eval_lctk: p, TC, argumentIR

1. If ((argumentIR has type typedExpressionIR)), then

  1. (Let typedExpressionIR be (argumentIR as typedExpressionIR))

