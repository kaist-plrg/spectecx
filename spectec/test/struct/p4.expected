;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.01.1-dynamic-env.spectec:6:16-6:30:
syntax frame = map<id, value>

;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.01.1-dynamic-env.spectec:8:1-8:25:
dec $empty_frame

