1. Return $contains'(0, |t|, t, t_c)

;; ../../../../../spectec/examples/p4-concrete/0-aux/0.0-stdlib.spectec:135:1-135:44:
dec $contains'(n_len'', n_len''', t, t_c)

1. If ((n_len'' = n_len''')), then

  1. Return false

1. Else Phantom#7

2. If ((n_len'' < n_len''')), then

  1. Case analysis on t[n_len'']

    1. Case (% = t_c)

      1. Return true

    2. Case (% =/= t_c)

      1. Return $contains'((n_len'' + 1), n_len''', t, t_c)

2. Else Phantom#8

