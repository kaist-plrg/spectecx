2. (Let typeParameterIR* be typeParameterIR_expl* ++ typeParameterIR_impl*)

3. If ((|typeParameterIR_expl*| = |typeArgumentIR*|)), then

  1. (Let typeId_fresh* be $fresh_typeIds(|typeParameterIR_impl*|))

  2. (Let typeArgumentIR_impl be ((` typeId_fresh) as typeIR))*

  3. (Let theta be ({ (typeParameterIR_expl : typeArgumentIR)* ++ (typeParameterIR_impl : typeArgumentIR_impl)* }))

  4. (Let callableTypeIR_base be $callableTypeIR_of_callableTypeDefIR(callableTypeDefIR_base))

  5. (Let callableTypeIR_spec be $subst_callableTypeIR(theta, callableTypeIR_base))

  6. Return (callableTypeIR_spec, typeId_fresh*)

3. Else Phantom#125

4. If (((|typeParameterIR_expl*| > 0) /\ (|typeArgumentIR*| = 0))), then

  1. (Let typeId_fresh* be $fresh_typeIds(|typeParameterIR*|))

  2. (Let typeArgumentIR_fresh be ((` typeId_fresh) as typeIR))*

  3. (Let theta be ({ (typeParameterIR : typeArgumentIR_fresh)* }))

  4. (Let callableTypeIR_base be $callableTypeIR_of_callableTypeDefIR(callableTypeDefIR_base))

  5. (Let callableTypeIR_spec be $subst_callableTypeIR(theta, callableTypeIR_base))

  6. Return (callableTypeIR_spec, typeId_fresh*)

4. Else Phantom#126

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.5.3-type-specialization.spectec:79:1-81:40:
dec $specialize_constructorTypeDefIR((constructor < typeParameterIR_expl* , typeParameterIR_impl* > ( constructorParameterIR* ) : typeIR), typeArgumentIR*)

1. (Let typeParameterIR* be typeParameterIR_expl* ++ typeParameterIR_impl*)

2. If ((|typeParameterIR_expl*| = |typeArgumentIR*|)), then

  1. (Let typeId_fresh* be $fresh_typeIds(|typeParameterIR_impl*|))

  2. (Let typeArgumentIR_impl be ((` typeId_fresh) as typeIR))*

  3. (Let theta be ({ (typeParameterIR_expl : typeArgumentIR)* ++ (typeParameterIR_impl : typeArgumentIR_impl)* }))

  4. (Let constructorTypeIR_spec be $subst_constructorTypeIR(theta, (constructor ( constructorParameterIR* ) : typeIR)))

  5. Return (constructorTypeIR_spec, typeId_fresh*)

2. Else Phantom#127

3. If (((|typeParameterIR_expl*| > 0) /\ (|typeArgumentIR*| = 0))), then

  1. (Let typeId_fresh* be $fresh_typeIds(|typeParameterIR*|))

  2. (Let typeArgumentIR_fresh be ((` typeId_fresh) as typeIR))*

  3. (Let theta be ({ (typeParameterIR : typeArgumentIR_fresh)* }))

  4. (Let constructorTypeIR_spec be $subst_constructorTypeIR(theta, (constructor ( constructorParameterIR* ) : typeIR)))

  5. Return (constructorTypeIR_spec, typeId_fresh*)

3. Else Phantom#128

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.6-type-alpha.spectec:5:1-9:56:
relation Type_alpha: typeIR'', typeIR'''

1. Case analysis on typeIR''

  1. Case (% has type baseTypeIR)

    1. (Let baseTypeIR be (typeIR'' as baseTypeIR))

    2. If ((typeIR''' has type baseTypeIR)), then

      1. (Let baseTypeIR' be (typeIR''' as baseTypeIR))

      2. If ((baseTypeIR = baseTypeIR')), then

        1. The relation holds

      2. Else Phantom#129

    2. Else Phantom#130

  2. Case (% has type nameTypeIR)

