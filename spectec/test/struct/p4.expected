;; ../../../../../spectec/examples/p4-concrete/5-typing/5.04-typing-relation.spectec:428:1-433:40:
relation VarDecl_ok: p, TC_0, (annotationList type name initializerOpt ;)

1. If ((initializerOpt matches pattern ``EMPTY`)), then

  1. (Type_ok: p TC_0 |- (type as typeOrVoid) : typeIR # typeId*)

  2. If ((typeId* matches pattern [])), then

    1. If (Type_wf: $bound(p, TC_0) |- typeIR holds), then

      1. If ($is_assignable_typeIR(typeIR)), then

        1. (Let nameIR be $name(name))

        2. (Let TC_1 be $add_var_t(p, TC_0, nameIR, ((inout) typeIR (dyn) ?())))

