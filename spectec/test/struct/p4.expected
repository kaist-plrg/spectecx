;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.5.1-type-free.spectec:5:16-5:27:
syntax bound = set<typeId>

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.5.1-type-free.spectec:9:1-10:47:
dec $free_typeIR(typeIR'')

1. Case analysis on typeIR''

  1. Case (% has type baseTypeIR)

    1. (Let baseTypeIR be (typeIR'' as baseTypeIR))

    2. Return ({ [] })

  2. Case (% has type nameTypeIR)

    1. (Let (` typeId) be (typeIR'' as nameTypeIR))

    2. Return ({ [typeId] })

  3. Case (% has type typedefTypeIR)

    1. (Let (typedef _typeId typeIR'') be (typeIR'' as typedefTypeIR))

    2. Return $free_typeIR(typeIR'')

  4. Case (% has type newTypeIR)

    1. (Let (type _typeId typeIR'') be (typeIR'' as newTypeIR))

    2. Return $free_typeIR(typeIR'')

  5. Case (% has type listTypeIR)

    1. (Let (list < typeIR'' >) be (typeIR'' as listTypeIR))

    2. Return $free_typeIR(typeIR'')

  6. Case (% has type tupleTypeIR)

    1. (Let (tuple < typeIR''* >) be (typeIR'' as tupleTypeIR))

    2. Return $unions_set<typeId>($free_typeIR(typeIR'')*)

  7. Case (% has type headerStackTypeIR)

    1. (Let (typeIR'' [ _nat ]) be (typeIR'' as headerStackTypeIR))

    2. Return $free_typeIR(typeIR'')

  8. Case (% has type structTypeIR)

    1. (Let (struct _typeId < typeArgumentIR* > { (_annotationList typeIR_field _nameIR ;)* }) be (typeIR'' as structTypeIR))

    2. Return $union_set<typeId>($unions_set<typeId>($free_typeIR(typeArgumentIR)*), $unions_set<typeId>($free_typeIR(typeIR_field)*))

  9. Case (% has type headerTypeIR)

    1. (Let (header _typeId < typeArgumentIR* > { (_annotationList typeIR_field _nameIR ;)* }) be (typeIR'' as headerTypeIR))

    2. Return $union_set<typeId>($unions_set<typeId>($free_typeIR(typeArgumentIR)*), $unions_set<typeId>($free_typeIR(typeIR_field)*))

  10. Case (% has type headerUnionTypeIR)

    1. (Let (header_union _typeId < typeArgumentIR* > { (_annotationList typeIR_field _nameIR ;)* }) be (typeIR'' as headerUnionTypeIR))

    2. Return $union_set<typeId>($unions_set<typeId>($free_typeIR(typeArgumentIR)*), $unions_set<typeId>($free_typeIR(typeIR_field)*))

  11. Case (% has type simpleEnumTypeIR)

    1. (Let (enum _typeId { _nameIR* }) be (typeIR'' as simpleEnumTypeIR))

    2. Return ({ [] })

  12. Case (% has type serializableEnumTypeIR)

    1. (Let (enum _typeId < typeIR'' > { _valueFieldIR* }) be (typeIR'' as serializableEnumTypeIR))

    2. Return $free_typeIR(typeIR'')

  13. Case (% has type externObjectTypeIR)

    1. (Let (extern _typeId < typeArgumentIR* > ({ (_callableId : externMethodTypeDefIR)* })) be (typeIR'' as externObjectTypeIR))

    2. Return $union_set<typeId>($unions_set<typeId>($free_typeIR(typeArgumentIR)*), $unions_set<typeId>($free_callableTypeDefIR((externMethodTypeDefIR as callableTypeDefIR))*))

  14. Case (% has type parserObjectTypeIR)

    1. (Let (parser _typeId < typeArgumentIR* > ( parameterIR* )) be (typeIR'' as parserObjectTypeIR))

    2. Return $union_set<typeId>($unions_set<typeId>($free_typeIR(typeArgumentIR)*), $unions_set<typeId>($free_parameterIR(parameterIR)*))

  15. Case (% has type controlObjectTypeIR)

    1. (Let (control _typeId < typeArgumentIR* > ( parameterIR* )) be (typeIR'' as controlObjectTypeIR))

    2. Return $union_set<typeId>($unions_set<typeId>($free_typeIR(typeArgumentIR)*), $unions_set<typeId>($free_parameterIR(parameterIR)*))

  16. Case (% has type packageObjectTypeIR)

    1. (Let (package _typeId < typeArgumentIR* > { typeIR''* }) be (typeIR'' as packageObjectTypeIR))

    2. Return $union_set<typeId>($unions_set<typeId>($free_typeIR(typeArgumentIR)*), $unions_set<typeId>($free_typeIR(typeIR'')*))

  17. Case (% has type tableObjectTypeIR)

    1. (Let (table _typeId { _tableMetadataStructTypeIR }) be (typeIR'' as tableObjectTypeIR))

    2. Return ({ [] })

  18. Case (% has type defaultTypeIR)

    1. (Let defaultTypeIR be (typeIR'' as defaultTypeIR))

    2. If ((defaultTypeIR matches pattern `DEFAULT`)), then

      1. Return ({ [] })

    2. Else Phantom#109

  19. Case (% has type invalidHeaderTypeIR)

    1. (Let invalidHeaderTypeIR be (typeIR'' as invalidHeaderTypeIR))

    2. If ((invalidHeaderTypeIR matches pattern `HEADER_INVALID`)), then

      1. Return ({ [] })

    2. Else Phantom#110

  20. Case (% has type sequenceTypeIR)

    1. (Let sequenceTypeIR be (typeIR'' as sequenceTypeIR))

    2. Case analysis on sequenceTypeIR

      1. Case (% matches pattern `SEQ <%>`)

        1. (Let (seq < typeIR''* >) be sequenceTypeIR)

        2. Return $unions_set<typeId>($free_typeIR(typeIR'')*)

      2. Case (% matches pattern `SEQ <% , ...>`)

        1. (Let (seq < typeIR''* , ... >) be sequenceTypeIR)

        2. Return $unions_set<typeId>($free_typeIR(typeIR'')*)

  21. Case (% has type recordTypeIR)

    1. (Let recordTypeIR be (typeIR'' as recordTypeIR))

    2. Case analysis on recordTypeIR

      1. Case (% matches pattern `RECORD {%}`)

        1. (Let (record { (_annotationList typeIR'' _nameIR ;)* }) be recordTypeIR)

        2. Return $unions_set<typeId>($free_typeIR(typeIR'')*)

      2. Case (% matches pattern `RECORD {% , ...}`)

        1. (Let (record { (_annotationList typeIR'' _nameIR ;)* , ... }) be recordTypeIR)

        2. Return $unions_set<typeId>($free_typeIR(typeIR'')*)

  22. Case (% has type setTypeIR)

    1. (Let (set < typeIR'' >) be (typeIR'' as setTypeIR))

    2. Return $free_typeIR(typeIR'')

  23. Case (% has type tableMetadataTypeIR)

    1. (Let tableMetadataTypeIR be (typeIR'' as tableMetadataTypeIR))

    2. Return ({ [] })

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.5.1-type-free.spectec:11:1-12:47:
dec $free_typeDefIR(typeDefIR)

1. (Let (typeParameterIR_expl*, typeParameterIR_impl*) be $typeParameterListIR_of_typeDefIR(typeDefIR))

2. (Let B_tparams be ({ typeParameterIR_expl* ++ typeParameterIR_impl* }))

3. (Let typeIR be $typeIR_of_typeDefIR(typeDefIR))

4. (Let B_base be $free_typeIR(typeIR))

5. Return $diff_set<typeId>(B_base, B_tparams)

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.5.1-type-free.spectec:14:1-15:47:
dec $free_parameterIR((_annotationList _direction typeIR _id _parameterInitializerOptIR))

1. Return $free_typeIR(typeIR)

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.5.1-type-free.spectec:16:1-17:47:
dec $free_callableTypeIR(callableTypeIR)

1. Case analysis on callableTypeIR

  1. Case (% has type actionTypeIR)

    1. (Let (_annotationList action _nameIR ( parameterIR* )) be (callableTypeIR as actionTypeIR))

    2. (Let B_params be $unions_set<typeId>($free_parameterIR(parameterIR)*))

    3. Return B_params

  2. Case (% has type definedFunctionTypeIR)

    1. (Let (function _nameIR ( parameterIR* ) : typeIR) be (callableTypeIR as definedFunctionTypeIR))

    2. (Let B_params be $unions_set<typeId>($free_parameterIR(parameterIR)*))

    3. (Let B_ret be $free_typeIR(typeIR))

    4. Return $union_set<typeId>(B_params, B_ret)

  3. Case (% has type externFunctionTypeIR)

    1. (Let (extern_function _nameIR ( parameterIR* ) : typeIR) be (callableTypeIR as externFunctionTypeIR))

    2. (Let B_params be $unions_set<typeId>($free_parameterIR(parameterIR)*))

    3. (Let B_ret be $free_typeIR(typeIR))

    4. Return $union_set<typeId>(B_params, B_ret)

  4. Case (% has type builtinMethodTypeIR)

    1. (Let (builtin_method _nameIR ( parameterIR* ) : typeIR) be (callableTypeIR as builtinMethodTypeIR))

    2. (Let B_params be $unions_set<typeId>($free_parameterIR(parameterIR)*))

    3. (Let B_ret be $free_typeIR(typeIR))

    4. Return $union_set<typeId>(B_params, B_ret)

  5. Case (% has type externMethodTypeIR)

    1. (Let externMethodTypeIR be (callableTypeIR as externMethodTypeIR))

    2. Case analysis on externMethodTypeIR

      1. Case (% matches pattern `EXTERN_METHOD % (%) : %`)

        1. (Let (extern_method _nameIR ( parameterIR* ) : typeIR) be externMethodTypeIR)

        2. (Let B_params be $unions_set<typeId>($free_parameterIR(parameterIR)*))

        3. (Let B_ret be $free_typeIR(typeIR))

        4. Return $union_set<typeId>(B_params, B_ret)

      2. Case (% matches pattern `EXTERN_METHOD ABSTRACT % (%) : %`)

        1. (Let (extern_method abstract _nameIR ( parameterIR* ) : typeIR) be externMethodTypeIR)

        2. (Let B_params be $unions_set<typeId>($free_parameterIR(parameterIR)*))

        3. (Let B_ret be $free_typeIR(typeIR))

        4. Return $union_set<typeId>(B_params, B_ret)

  6. Case (% has type parserApplyMethodTypeIR)

    1. (Let (parser_apply ( parameterIR* )) be (callableTypeIR as parserApplyMethodTypeIR))

    2. (Let B_params be $unions_set<typeId>($free_parameterIR(parameterIR)*))

    3. Return B_params

  7. Case (% has type controlApplyMethodTypeIR)

    1. (Let (control_apply ( parameterIR* )) be (callableTypeIR as controlApplyMethodTypeIR))

    2. (Let B_params be $unions_set<typeId>($free_parameterIR(parameterIR)*))

    3. Return B_params

  8. Case (% has type tableApplyMethodTypeIR)

    1. (Let (table_apply : _tableMetadataStructTypeIR) be (callableTypeIR as tableApplyMethodTypeIR))

    2. Return ({ [] })

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.5.1-type-free.spectec:18:1-19:47:
dec $free_callableTypeDefIR(callableTypeDefIR)

1. (Let (typeId_tparam_expl*, typeId_tparam_impl*) be $typeParameterListIR_of_callableTypeDefIR(callableTypeDefIR))

2. (Let B_tparams be ({ typeId_tparam_expl* ++ typeId_tparam_impl* }))

3. (Let callableTypeIR be $callableTypeIR_of_callableTypeDefIR(callableTypeDefIR))

4. (Let B_base be $free_callableTypeIR(callableTypeIR))

5. Return $diff_set<typeId>(B_base, B_tparams)

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.5.2-type-subst.spectec:5:16-5:35:
syntax theta = map<typeId, typeIR>

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.5.2-type-subst.spectec:7:1-7:25:
dec $empty_theta

1. Return $empty_map<typeId, typeIR>

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.5.2-type-subst.spectec:10:1-11:30:
dec $capture_avoiding_(theta, typeParameterIR*, B)

1. (Let ({ typeId_free* }) be $diff_set<typeId>(B, ({ typeParameterIR* })))

2. (Let typeIR? be $find_map<typeId, typeIR>(theta, typeId_free))*

3. If ((typeIR? matches pattern (_)))*, then

  1. (Let ?(typeIR_free) be typeIR?)*

  2. (Let B_capture be $unions_set<typeId>($free_typeIR(typeIR_free)*))

  3. (Let typeParameterIR_fresh* be $fresh_typeIds(|typeParameterIR*|))

  4. If (~$in_set<typeId>(typeParameterIR_fresh, B_capture))*, then

    1. (Let theta_fresh be $adds_map<typeId, typeIR>(theta, typeParameterIR*, ((` typeParameterIR_fresh) as typeIR)*))

    2. Return (theta_fresh, typeParameterIR_fresh*)

  4. Else Phantom#111

3. Else Phantom#112

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.5.2-type-subst.spectec:12:1-13:30:
dec $capture_avoiding(theta, typeParameterIR_expl*, typeParameterIR_impl*, B)

1. (Let ({ typeId_free* }) be $diff_set<typeId>(B, ({ typeParameterIR_expl* ++ typeParameterIR_impl* })))

2. (Let typeIR? be $find_map<typeId, typeIR>(theta, typeId_free))*

3. If ((typeIR? matches pattern (_)))*, then

  1. (Let ?(typeIR_free) be typeIR?)*

  2. (Let B_capture be $unions_set<typeId>($free_typeIR(typeIR_free)*))

  3. (Let typeId_fresh* be $fresh_typeIds(|typeParameterIR_expl* ++ typeParameterIR_impl*|))

  4. If (~$in_set<typeId>(typeId_fresh, B_capture))*, then

    1. (Let typeParameterIR_expl_fresh* be typeId_fresh*[0 : |typeParameterIR_expl*|])

    2. (Let typeParameterIR_impl_fresh* be typeId_fresh*[|typeParameterIR_expl*| : |typeParameterIR_impl*|])

    3. (Let theta_fresh be $adds_map<typeId, typeIR>(theta, typeParameterIR_expl* ++ typeParameterIR_impl*, ((` typeParameterIR_expl_fresh) as typeIR)* ++ ((` typeParameterIR_impl_fresh) as typeIR)*))

    4. Return (theta_fresh, typeParameterIR_expl_fresh*, typeParameterIR_impl_fresh*)

  4. Else Phantom#113

3. Else Phantom#114

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.5.2-type-subst.spectec:15:1-16:40:
dec $subst_typeIR(set<pair<typeId, typeIR>>', typeIR)

1. If ((set<pair<typeId, typeIR>>' = ({ [] }))), then

  1. Return typeIR

2. Otherwise

  1. Return $subst_typeIR'(set<pair<typeId, typeIR>>', typeIR)

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.5.2-type-subst.spectec:17:1-18:52:
dec $subst_typeIR'(theta, typeIR''')

1. Case analysis on typeIR'''

  1. Case (% has type baseTypeIR)

    1. (Let baseTypeIR be (typeIR''' as baseTypeIR))

    2. Return (baseTypeIR as typeIR)

  2. Case (% has type nameTypeIR)

    1. (Let (` typeId) be (typeIR''' as nameTypeIR))

    2. (Let typeIR''? be $find_map<typeId, typeIR>(theta, typeId))

    3. If ((typeIR''? matches pattern (_))), then

      1. (Let ?(typeIR''') be typeIR''?)

      2. Return typeIR'''

    3. Else Phantom#115

    4. If ((?() = $find_map<typeId, typeIR>(theta, typeId))), then

      1. Return ((` typeId) as typeIR)

    4. Else Phantom#116

  3. Case (% has type typedefTypeIR)

    1. (Let (typedef typeId typeIR''') be (typeIR''' as typedefTypeIR))

    2. (Let typeIR_subst be $subst_typeIR'(theta, typeIR'''))

    3. Return ((typedef typeId typeIR_subst) as typeIR)

  4. Case (% has type newTypeIR)

    1. (Let (type typeId typeIR''') be (typeIR''' as newTypeIR))

    2. (Let typeIR_subst be $subst_typeIR'(theta, typeIR'''))

    3. Return ((type typeId typeIR_subst) as typeIR)

  5. Case (% has type listTypeIR)

    1. (Let (list < typeIR''' >) be (typeIR''' as listTypeIR))

    2. (Let typeIR_subst be $subst_typeIR'(theta, typeIR'''))

    3. Return ((list < typeIR_subst >) as typeIR)

  6. Case (% has type tupleTypeIR)

    1. (Let (tuple < typeIR'''* >) be (typeIR''' as tupleTypeIR))

    2. (Let typeIR_subst be $subst_typeIR'(theta, typeIR'''))*

    3. Return ((tuple < typeIR_subst* >) as typeIR)

  7. Case (% has type headerStackTypeIR)

    1. (Let (typeIR''' [ n_size ]) be (typeIR''' as headerStackTypeIR))

    2. (Let typeIR_subst be $subst_typeIR'(theta, typeIR'''))

    3. Return ((typeIR_subst [ n_size ]) as typeIR)

  8. Case (% has type structTypeIR)

    1. (Let structTypeIR be (typeIR''' as structTypeIR))

    2. (Let (struct typeId < typeArgumentIR* > { (annotationList typeIR_field nameIR_field ;)* }) be structTypeIR)

    3. (Let typeArgumentIR_subst be $subst_typeIR'(theta, typeArgumentIR))*

    4. (Let typeIR_field_subst be $subst_typeIR'(theta, typeIR_field))*

    5. (Let structTypeIR_subst be (struct typeId < typeArgumentIR_subst* > { (annotationList typeIR_field_subst nameIR_field ;)* }))

    6. Return (structTypeIR_subst as typeIR)

  9. Case (% has type headerTypeIR)

    1. (Let headerTypeIR be (typeIR''' as headerTypeIR))

    2. (Let (header typeId < typeArgumentIR* > { (annotationList typeIR_field nameIR_field ;)* }) be headerTypeIR)

    3. (Let typeArgumentIR_subst be $subst_typeIR'(theta, typeArgumentIR))*

    4. (Let typeIR_field_subst be $subst_typeIR'(theta, typeIR_field))*

    5. (Let headerTypeIR_subst be (header typeId < typeArgumentIR_subst* > { (annotationList typeIR_field_subst nameIR_field ;)* }))

    6. Return (headerTypeIR_subst as typeIR)

  10. Case (% has type headerUnionTypeIR)

    1. (Let headerUnionTypeIR be (typeIR''' as headerUnionTypeIR))

    2. (Let (header_union typeId < typeArgumentIR* > { (annotationList typeIR_field nameIR_field ;)* }) be headerUnionTypeIR)

    3. (Let typeArgumentIR_subst be $subst_typeIR'(theta, typeArgumentIR))*

    4. (Let typeIR_field_subst be $subst_typeIR'(theta, typeIR_field))*

    5. (Let headerUnionTypeIR_subst be (header_union typeId < typeArgumentIR_subst* > { (annotationList typeIR_field_subst nameIR_field ;)* }))

    6. Return (headerUnionTypeIR_subst as typeIR)

  11. Case (% has type simpleEnumTypeIR)

    1. (Let (enum typeId { id_field* }) be (typeIR''' as simpleEnumTypeIR))

    2. Return ((enum typeId { id_field* }) as typeIR)

  12. Case (% has type serializableEnumTypeIR)

    1. (Let (enum typeId < typeIR''' > { valueFieldIR* }) be (typeIR''' as serializableEnumTypeIR))

    2. (Let typeIR_subst be $subst_typeIR'(theta, typeIR'''))

    3. Return ((enum typeId < typeIR_subst > { valueFieldIR* }) as typeIR)

  13. Case (% has type externObjectTypeIR)

    1. (Let externObjectTypeIR be (typeIR''' as externObjectTypeIR))

    2. (Let (extern typeId < typeArgumentIR* > ({ (callableId : externMethodTypeDefIR)* })) be externObjectTypeIR)

    3. (Let typeArgumentIR_subst be $subst_typeIR'(theta, typeArgumentIR))*

    4. (Let callableTypeDefIR be $subst_callableTypeDefIR(theta, (externMethodTypeDefIR as callableTypeDefIR)))*

    5. If ((callableTypeDefIR has type externMethodTypeDefIR))*, then

      1. (Let externMethodTypeDefIR_subst be (callableTypeDefIR as externMethodTypeDefIR))*

      2. (Let externObjectTypeIR_subst be (extern typeId < typeArgumentIR_subst* > ({ (callableId : externMethodTypeDefIR_subst)* })))

      3. Return (externObjectTypeIR_subst as typeIR)

    5. Else Phantom#117

  14. Case (% has type parserObjectTypeIR)

    1. (Let parserObjectTypeIR be (typeIR''' as parserObjectTypeIR))

    2. (Let (parser typeId < typeArgumentIR* > ( parameterIR* )) be parserObjectTypeIR)

    3. (Let typeArgumentIR_subst be $subst_typeIR'(theta, typeArgumentIR))*

    4. (Let parameterIR_subst be $subst_parameterIR'(theta, parameterIR))*

    5. (Let parserObjectTypeIR_subst be (parser typeId < typeArgumentIR_subst* > ( parameterIR_subst* )))

    6. Return (parserObjectTypeIR_subst as typeIR)

  15. Case (% has type controlObjectTypeIR)

    1. (Let controlObjectTypeIR be (typeIR''' as controlObjectTypeIR))

    2. (Let (control typeId < typeArgumentIR* > ( parameterIR* )) be controlObjectTypeIR)

    3. (Let typeArgumentIR_subst be $subst_typeIR'(theta, typeArgumentIR))*

    4. (Let parameterIR_subst be $subst_parameterIR'(theta, parameterIR))*

    5. (Let controlObjectTypeIR_subst be (control typeId < typeArgumentIR_subst* > ( parameterIR_subst* )))

    6. Return (controlObjectTypeIR_subst as typeIR)

  16. Case (% has type packageObjectTypeIR)

    1. (Let packageObjectTypeIR be (typeIR''' as packageObjectTypeIR))

    2. (Let (package typeId < typeArgumentIR* > { typeIR'''* }) be packageObjectTypeIR)

    3. (Let typeArgumentIR_subst be $subst_typeIR'(theta, typeArgumentIR))*

    4. (Let typeIR_subst be $subst_typeIR'(theta, typeIR'''))*

    5. (Let packageObjectTypeIR_subst be (package typeId < typeArgumentIR_subst* > { typeIR_subst* }))

    6. Return (packageObjectTypeIR_subst as typeIR)

  17. Case (% has type tableObjectTypeIR)

    1. (Let tableObjectTypeIR be (typeIR''' as tableObjectTypeIR))

    2. Return (tableObjectTypeIR as typeIR)

  18. Case (% has type defaultTypeIR)

    1. (Let defaultTypeIR be (typeIR''' as defaultTypeIR))

    2. If ((defaultTypeIR matches pattern `DEFAULT`)), then

      1. Return ((default) as typeIR)

    2. Else Phantom#118

  19. Case (% has type invalidHeaderTypeIR)

    1. (Let invalidHeaderTypeIR be (typeIR''' as invalidHeaderTypeIR))

    2. If ((invalidHeaderTypeIR matches pattern `HEADER_INVALID`)), then

      1. Return ((header_invalid) as typeIR)

    2. Else Phantom#119

  20. Case (% has type sequenceTypeIR)

    1. (Let sequenceTypeIR be (typeIR''' as sequenceTypeIR))

    2. Case analysis on sequenceTypeIR

      1. Case (% matches pattern `SEQ <%>`)

        1. (Let (seq < typeIR'''* >) be sequenceTypeIR)

        2. (Let typeIR_subst be $subst_typeIR'(theta, typeIR'''))*

        3. Return ((seq < typeIR_subst* >) as typeIR)

      2. Case (% matches pattern `SEQ <% , ...>`)

        1. (Let (seq < typeIR'''* , ... >) be sequenceTypeIR)

        2. (Let typeIR_subst be $subst_typeIR'(theta, typeIR'''))*

        3. Return ((seq < typeIR_subst* , ... >) as typeIR)

  21. Case (% has type recordTypeIR)

    1. (Let recordTypeIR be (typeIR''' as recordTypeIR))

    2. Case analysis on recordTypeIR

      1. Case (% matches pattern `RECORD {%}`)

        1. (Let (record { (annotationList typeIR_field id_field ;)* }) be recordTypeIR)

        2. (Let typeIR_field_subst be $subst_typeIR'(theta, typeIR_field))*

        3. Return ((record { (annotationList typeIR_field_subst id_field ;)* }) as typeIR)

      2. Case (% matches pattern `RECORD {% , ...}`)

        1. (Let (record { (annotationList typeIR_field id_field ;)* , ... }) be recordTypeIR)

        2. (Let typeIR_field_subst be $subst_typeIR'(theta, typeIR_field))*

        3. Return ((record { (annotationList typeIR_field_subst id_field ;)* , ... }) as typeIR)

  22. Case (% has type setTypeIR)

    1. (Let (set < typeIR''' >) be (typeIR''' as setTypeIR))

    2. (Let typeIR_subst be $subst_typeIR'(theta, typeIR'''))

    3. Return ((set < typeIR_subst >) as typeIR)

  23. Case (% has type tableMetadataTypeIR)

    1. (Let tableMetadataTypeIR be (typeIR''' as tableMetadataTypeIR))

    2. Return (tableMetadataTypeIR as typeIR)

