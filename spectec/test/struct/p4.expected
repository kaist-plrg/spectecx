;; ../../../../../spectec/examples/p4-concrete/5-typing/5.04-typing-relation.spectec:599:1-609:77:
relation Inst_ok: cursor', TC, instctxt, constructorTypeIR, typeArgumentIR*, typeId_infer*, argumentIR*, id_default*, id_optional*

1. If ((cursor' matches pattern `GLOBAL`)), then

  1. (Let (constructor ( parameterIR* ) : typeIR_object) be constructorTypeIR)

  2. (Let typeIR be $unroll_typeIR(typeIR_object))

  3. If ((typeIR has type packageObjectTypeIR)), then

    1. (Let (package _typeId < _typeArgumentIR* > { _typeIR* }) be (typeIR as packageObjectTypeIR))

    2. (Let (given parameterIR_aligned* default _parameterIR*) be $align_parameterListIR(parameterIR*, argumentIR*, id_default*, id_optional*))

    3. (Let inference be $infer(typeId_infer*, parameterIR_aligned*, argumentIR*))

    4. (Let typeIR'? be $find_map<typeId, typeIR>(inference, typeId_infer))*

    5. If ((typeIR'? matches pattern (_)))*, then

      1. (Let ?(typeIR_inferred) be typeIR'?)*

      2. (Let typeArgumentIR_inferred* be typeArgumentIR* ++ typeIR_inferred*)

      3. (Let parameterIR_aligned_inferred be $subst_parameterIR(inference, parameterIR_aligned))*

      4. (Let typeIR_object_inferred be $subst_typeIR(inference, typeIR_object))

      5. (Let constructorTypeIR_inferred be (constructor ( parameterIR_aligned_inferred* ) : typeIR_object_inferred))

      6. If (ConstructorType_wf: $bound((global), TC) |- constructorTypeIR_inferred holds), then

        1. If ($instantiable((global), TC, instctxt, typeIR_object_inferred)), then

          1. (Call_convention_ok: (block) TC (noaction) |- parameterIR_aligned_inferred* @ argumentIR* : argumentIR_cast*)

          2. Result in typeIR_object_inferred, typeArgumentIR_inferred*, argumentIR_cast*

        1. Else Phantom#1409

      6. Else Phantom#1410

    5. Else Phantom#1411

  3. Else Phantom#1412

1. Else Phantom#1413

2. (Let (constructor ( parameterIR* ) : typeIR_object) be constructorTypeIR)

3. (Let typeIR_object_unroll be $unroll_typeIR(typeIR_object))

4. If (~(typeIR_object_unroll has type packageObjectTypeIR)), then

  1. (Let (given parameterIR_aligned* default _parameterIR*) be $align_parameterListIR(parameterIR*, argumentIR*, id_default*, id_optional*))

  2. (Let inference be $infer(typeId_infer*, parameterIR_aligned*, argumentIR*))

