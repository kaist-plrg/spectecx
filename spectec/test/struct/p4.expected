    1. (Let (parser _typeId < _typeArgumentIR* > ( parameterIR_param* )) be (typeIR'' as parserObjectTypeIR))

    2. If ((typeIR_arg' has type parserObjectTypeIR)), then

      1. (Let (parser _typeId' < _typeArgumentIR'* > ( parameterIR_arg* )) be (typeIR_arg' as parserObjectTypeIR))

      2. (Let (_annotationList direction typeIR'' _id _parameterInitializerOptIR) be parameterIR_param)*

      3. (Let (_annotationList' direction' typeIR_arg' _id' _parameterInitializerOptIR') be parameterIR_arg)*

      4. If ((direction' = direction))*, then

        1. Return $gen_constraints(constraint, typeIR''*, typeIR_arg'*)

  12. Case (% has type controlObjectTypeIR)

    1. (Let (control _typeId < _typeArgumentIR* > ( parameterIR_param* )) be (typeIR'' as controlObjectTypeIR))

    2. If ((typeIR_arg' has type controlObjectTypeIR)), then

      1. (Let (control _typeId' < _typeArgumentIR'* > ( parameterIR_arg* )) be (typeIR_arg' as controlObjectTypeIR))

      2. (Let (_annotationList direction typeIR'' _id _parameterInitializerOptIR) be parameterIR_param)*

      3. (Let (_annotationList' direction' typeIR_arg' _id' _parameterInitializerOptIR') be parameterIR_arg)*

      4. If ((direction' = direction))*, then

        1. Return $gen_constraints(constraint, typeIR''*, typeIR_arg'*)

  13. Case (% has type packageObjectTypeIR)

    1. (Let (package _typeId < _typeArgumentIR* > { typeIR''* }) be (typeIR'' as packageObjectTypeIR))

    2. If ((typeIR_arg' has type packageObjectTypeIR)), then

      1. (Let (package _typeId' < _typeArgumentIR'* > { typeIR_arg'* }) be (typeIR_arg' as packageObjectTypeIR))

      2. Return $gen_constraints(constraint, typeIR''*, typeIR_arg'*)

2. If ((typeIR_arg' has type typedefTypeIR)), then

  1. (Let (typedef _typeId typeIR_arg') be (typeIR_arg' as typedefTypeIR))

  2. If (~(typeIR'' has type nameTypeIR)), then

    1. If (~(typeIR'' has type typedefTypeIR)), then

      1. Return $gen_constraint(constraint, typeIR'', typeIR_arg')

3. Otherwise

  1. Return constraint

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.15.2-typing-call-inference.spectec:27:1-27:64:
dec $gen_constraints(constraint, typeIR_param*, typeIR_arg*)

1. (Let constraint_pair be $gen_constraint(constraint, typeIR_param, typeIR_arg))*

2. Return $merge_constraints(constraint, constraint_pair*)

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.15.2-typing-call-inference.spectec:29:1-29:59:
dec $merge_constraint(constraint_pre, constraint_post)

1. (Let ({ typeId_pre* }) be $dom_map<typeId, infer>(constraint_pre))

2. (Let ({ typeId_post* }) be $dom_map<typeId, infer>(constraint_post))

3. If ($eq_set<typeId>(({ typeId_pre* }), ({ typeId_post* }))), then

  1. Return $merge_constraint'(constraint_pre, constraint_post, typeId_pre*, ({ [] }))

3. Else Phantom#1657

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.15.2-typing-call-inference.spectec:30:1-30:81:
dec $merge_constraint'(constraint_pre, constraint_post, typeId*, constraint)

1. Case analysis on typeId*

  1. Case (% matches pattern [])

    1. Return constraint

  2. Case (% matches pattern _ :: _)

    1. (Let typeId_h :: typeId_t* be typeId*)

    2. If ((?((unknown)) = $find_map<typeId, infer>(constraint_pre, typeId_h))), then

      1. If ((?((unknown)) = $find_map<typeId, infer>(constraint_post, typeId_h))), then

        1. (Let constraint_updated be $update_map<typeId, infer>(constraint, typeId_h, (unknown)))

        2. Return $merge_constraint'(constraint_pre, constraint_post, typeId_t*, constraint_updated)

      1. Else Phantom#1658

      2. (Let infer'? be $find_map<typeId, infer>(constraint_post, typeId_h))

      3. If ((infer'? matches pattern (_))), then

        1. (Let ?(infer) be infer'?)

        2. If ((infer matches pattern `KNOWN AS %`)), then

          1. (Let (known as typeIR_post) be infer)

          2. (Let constraint_updated be $update_map<typeId, infer>(constraint, typeId_h, (known as typeIR_post)))

          3. Return $merge_constraint'(constraint_pre, constraint_post, typeId_t*, constraint_updated)

        2. Else Phantom#1659

      3. Else Phantom#1660

    2. Else Phantom#1661

    3. (Let infer'? be $find_map<typeId, infer>(constraint_pre, typeId_h))

    4. If ((infer'? matches pattern (_))), then

      1. (Let ?(infer) be infer'?)

      2. If ((infer matches pattern `KNOWN AS %`)), then

        1. (Let (known as typeIR_pre) be infer)

        2. If ((?((unknown)) = $find_map<typeId, infer>(constraint_post, typeId_h))), then

          1. (Let constraint_updated be $update_map<typeId, infer>(constraint, typeId_h, (known as typeIR_pre)))

          2. Return $merge_constraint'(constraint_pre, constraint_post, typeId_t*, constraint_updated)

        2. Else Phantom#1662

        3. (Let infer'''? be $find_map<typeId, infer>(constraint_post, typeId_h))

        4. If ((infer'''? matches pattern (_))), then

          1. (Let ?(infer'') be infer'''?)

          2. If ((infer'' matches pattern `KNOWN AS %`)), then

            1. (Let (known as typeIR_post) be infer'')

            2. If (Cast_impl: typeIR_pre -> typeIR_post holds), then

              1. (Let constraint_updated be $update_map<typeId, infer>(constraint, typeId_h, (known as typeIR_post)))

              2. Return $merge_constraint'(constraint_pre, constraint_post, typeId_t*, constraint_updated)

            2. Else Phantom#1663

            3. If (Cast_impl: typeIR_pre -> typeIR_post does not hold), then

              1. If (Cast_impl: typeIR_post -> typeIR_pre holds), then

                1. (Let constraint_updated be $update_map<typeId, infer>(constraint, typeId_h, (known as typeIR_pre)))

                2. Return $merge_constraint'(constraint_pre, constraint_post, typeId_t*, constraint_updated)

              1. Else Phantom#1664

            3. Else Phantom#1665

          2. Else Phantom#1666

        4. Else Phantom#1667

      2. Else Phantom#1668

    4. Else Phantom#1669

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.15.2-typing-call-inference.spectec:31:1-31:61:
dec $merge_constraints(constraint_pre', constraint*)

1. Case analysis on constraint*

  1. Case (% matches pattern [])

    1. Return constraint_pre'

  2. Case (% matches pattern _ :: _)

    1. (Let constraint_post_h :: constraint_post_t* be constraint*)

    2. (Let constraint_pre_1 be $merge_constraint(constraint_pre', constraint_post_h))

    3. (Let constraint_pre_2 be $merge_constraints(constraint_pre_1, constraint_post_t*))

    4. Return constraint_pre_2

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.15.2-typing-call-inference.spectec:33:1-33:48:
dec $resolve_constraint(({ (typeId : infer)* }))

1. If ((infer matches pattern `KNOWN AS %`))*, then

  1. (Let (known as typeIR) be infer)*

  2. Return ({ (typeId : typeIR)* })

1. Else Phantom#1670

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.15.3-typing-constructor-call.spectec:5:1-6:82:
dec $resolve_type_alias(typeIR)

1. Case analysis on typeIR

  1. Case (% has type typedefTypeIR)

    1. (Let (typedef nameIR_alias typeIR_alias) be (typeIR as typedefTypeIR))

    2. Return $resolve_type_alias(typeIR_alias)

  2. Case (% has type externObjectTypeIR)

    1. (Let (extern nameIR_alias < typeIR_arg* > _externMethodTypeDefEnv) be (typeIR as externObjectTypeIR))

    2. Return (nameIR_alias, typeIR_arg*)

  3. Case (% has type packageObjectTypeIR)

    1. (Let (package nameIR_alias < typeIR_arg* > { _typeIR* }) be (typeIR as packageObjectTypeIR))

    2. Return (nameIR_alias, typeIR_arg*)

1. Else Phantom#1671

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.15.3-typing-constructor-call.spectec:65:1-65:65:
dec $instantiable_extern(cursor, TC, instctxt)

1. Case analysis on cursor

  1. Case (% matches pattern `GLOBAL`)

    1. Return true

  2. Case (% matches pattern `BLOCK`)

    1. Return true

  3. Case (% matches pattern `LOCAL`)

    1. Return true

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.15.3-typing-constructor-call.spectec:71:1-71:65:
dec $instantiable_parser(cursor, TC, instctxt)

1. Case analysis on cursor

  1. Case (% matches pattern `GLOBAL`)

    1. Return (instctxt = (anon))

  2. Case (% matches pattern `BLOCK`)

    1. (Let blockKind be TC.block.kind)

    2. Return ((blockKind = (parser)) \/ (blockKind = (package)))

  3. Case (% matches pattern `LOCAL`)

    1. (Let localKind be TC.local.kind)

    2. Return (localKind = ((parser_state) as localKind))

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.15.3-typing-constructor-call.spectec:82:1-82:66:
dec $instantiable_control(cursor, TC, instctxt)

1. Case analysis on cursor

  1. Case (% matches pattern `GLOBAL`)

    1. Return (instctxt = (anon))

  2. Case (% matches pattern `BLOCK`)

    1. (Let blockKind be TC.block.kind)

    2. Return ((blockKind = (control)) \/ (blockKind = (package)))

  3. Case (% matches pattern `LOCAL`)

    1. (Let localKind be TC.local.kind)

    2. Return (localKind = ((control_apply_method) as localKind))

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.15.3-typing-constructor-call.spectec:93:1-93:66:
dec $instantiable_package(cursor, TC, instctxt)

1. Case analysis on cursor

  1. Case (% matches pattern `GLOBAL`)

    1. Return true

  2. Case (% matches pattern `BLOCK`)

    1. (Let blockKind be TC.block.kind)

    2. Return (blockKind = (package))

  3. Case (% matches pattern `LOCAL`)

    1. Return false

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.15.3-typing-constructor-call.spectec:101:1-101:64:
dec $instantiable_table(cursor, TC, instctxt)

1. Case analysis on cursor

  1. Case (% matches pattern `GLOBAL`)

    1. Return false

  2. Case (% matches pattern `BLOCK`)

    1. (Let blockKind be TC.block.kind)

    2. Return (blockKind = (control))

  3. Case (% matches pattern `LOCAL`)

    1. Return false

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.15.3-typing-constructor-call.spectec:109:1-109:66:
dec $instantiable(p, TC, instctxt, typeIR)

1. (Let typeIR_unroll be $unroll_typeIR(typeIR))

2. Case analysis on typeIR_unroll

  1. Case (% has type externObjectTypeIR)

    1. Return $instantiable_extern(p, TC, instctxt)

  2. Case (% has type parserObjectTypeIR)

    1. Return $instantiable_parser(p, TC, instctxt)

  3. Case (% has type controlObjectTypeIR)

    1. Return $instantiable_control(p, TC, instctxt)

  4. Case (% has type packageObjectTypeIR)

    1. Return $instantiable_package(p, TC, instctxt)

  5. Case (% has type tableObjectTypeIR)

    1. Return $instantiable_table(p, TC, instctxt)

2. Else Phantom#1672

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.15.4-typing-callable-call.spectec:243:1-243:51:
dec $callable_action(cursor, TC)

1. Case analysis on cursor

  1. Case (% matches pattern `GLOBAL`)

    1. Return false

  2. Case (% matches pattern `BLOCK`)

    1. Return false

  3. Case (% matches pattern `LOCAL`)

    1. (Let localKind be TC.local.kind)

    2. Return ((localKind = ((action) as localKind)) \/ (localKind = ((control_apply_method) as localKind)))

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.15.4-typing-callable-call.spectec:274:1-274:60:
dec $callable_definedFunction(cursor, TC)

1. Case analysis on cursor

  1. Case (% matches pattern `GLOBAL`)

    1. Return false

  2. Case (% matches pattern `BLOCK`)

    1. (Let blockKind be TC.block.kind)

    2. Return ((blockKind = (parser)) \/ (blockKind = (control)))

  3. Case (% matches pattern `LOCAL`)

    1. (Let localKind be TC.local.kind)

    2. Return ~(localKind has type externMethodLocalKind)

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.15.4-typing-callable-call.spectec:317:1-317:67:
dec $callable_externFunction(cursor, TC, nameIR)

1. Case analysis on cursor

  1. Case (% matches pattern `GLOBAL`)

    1. Case analysis on nameIR

      1. Case (% = "verify")

        1. Return false

      2. Case (% =/= "verify")

        1. Return true

  2. Case (% matches pattern `BLOCK`)

    1. Case analysis on nameIR

      1. Case (% = "verify")

        1. (Let blockKind be TC.block.kind)

        2. Return (blockKind = (parser))

      2. Case (% =/= "verify")

        1. (Let blockKind be TC.block.kind)

        2. Return ((blockKind = (parser)) \/ (blockKind = (control)))

  3. Case (% matches pattern `LOCAL`)

    1. Case analysis on nameIR

      1. Case (% = "verify")

        1. (Let localKind be TC.local.kind)

        2. Return (localKind = ((parser_state) as localKind))

      2. Case (% =/= "verify")

        1. Return true

