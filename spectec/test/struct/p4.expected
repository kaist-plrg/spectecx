        2. Result in typeIR_object_inferred, typeArgumentIR_inferred*, argumentIR_cast*

      1. Else Phantom#1414

    6. Else Phantom#1415

  4. Else Phantom#1416

4. Else Phantom#1417

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.05.2-typing-casting.spectec:377:1-378:66:
dec $reduce_serenum(typedExpressionIR)

1. (Let typeIR be $type_of_typedExpressionIR(typedExpressionIR))

2. (Let ctk be $ctk_of_typedExpressionIR(typedExpressionIR))

3. (Let typeIR' be $unroll_typeIR(typeIR))

4. If ((typeIR' has type serializableEnumTypeIR)), then

  1. (Let (enum _typeId < typeIR_underlying > { _valueFieldIR* }) be (typeIR' as serializableEnumTypeIR))

  2. (Let typedExpressionIR_reduced be (((( typeIR_underlying ) typedExpressionIR) as expressionIR) # (( typeIR_underlying ctk ))))

  3. Return typedExpressionIR_reduced

5. Otherwise

  1. Return typedExpressionIR

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.05.2-typing-casting.spectec:391:1-395:93:
dec $reduce_serenum_unary(typedExpressionIR, $check)

1. (Let (_expressionIR # (( typeIR _ctk ))) be typedExpressionIR)

2. Case analysis on $check(typeIR)

  1. Case true

    1. Return ?(typedExpressionIR)

  2. Case false

    1. (Let typeIR' be $unroll_typeIR(typeIR))

    2. If ((typeIR' has type serializableEnumTypeIR)), then

      1. (Let (enum _typeId < typeIR_underlying > { _valueFieldIR* }) be (typeIR' as serializableEnumTypeIR))

      2. (Let typedExpressionIR_cast be (((( typeIR_underlying ) typedExpressionIR) as expressionIR) # (( typeIR_underlying _ctk ))))

      3. Return $reduce_serenum_unary(typedExpressionIR_cast, $check)

3. Otherwise

  1. Return ?()

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.05.2-typing-casting.spectec:415:1-420:102:
dec $reduce_serenum_binary(typedExpressionIR_l, typedExpressionIR_r, $check)

1. (Let (_expressionIR # (( typeIR_l _ctk ))) be typedExpressionIR_l)

2. (Let (_expressionIR' # (( typeIR_r _ctk' ))) be typedExpressionIR_r)

3. Case analysis on $check(typeIR_l, typeIR_r)

  1. Case true

    1. Return ?((typedExpressionIR_l, typedExpressionIR_r))

  2. Case false

    1. (Let typeIR be $unroll_typeIR(typeIR_l))

    2. If ((typeIR has type serializableEnumTypeIR)), then

      1. (Let (enum _typeId < typeIR_l_underlying > { _valueFieldIR* }) be (typeIR as serializableEnumTypeIR))

      2. (Let typedExpressionIR_l_cast be (((( typeIR_l_underlying ) typedExpressionIR_l) as expressionIR) # (( typeIR_l_underlying _ctk' ))))

      3. Return $reduce_serenum_binary(typedExpressionIR_l_cast, typedExpressionIR_r, $check)

    3. If (~($unroll_typeIR(typeIR_l) has type serializableEnumTypeIR)), then

      1. (Let typeIR be $unroll_typeIR(typeIR_r))

      2. If ((typeIR has type serializableEnumTypeIR)), then

        1. (Let (enum _typeId < typeIR_r_underlying > { _valueFieldIR* }) be (typeIR as serializableEnumTypeIR))

        2. (Let typedExpressionIR_r_cast be (((( typeIR_r_underlying ) typedExpressionIR_r) as expressionIR) # (( typeIR_r_underlying _ctk' ))))

        3. Return $reduce_serenum_binary(typedExpressionIR_l, typedExpressionIR_r_cast, $check)

4. Otherwise

  1. Return ?()

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.05.2-typing-casting.spectec:461:1-462:44:
dec $cast_unary(typedExpressionIR, typeIR_to)

1. (Let (_expressionIR # (( typeIR _ctk ))) be typedExpressionIR)

2. If (Type_alpha: typeIR ~~ typeIR_to holds), then

  1. Return ?(typedExpressionIR)

3. If (Type_alpha: typeIR ~~ typeIR_to does not hold), then

  1. If (Cast_impl: typeIR -> typeIR_to holds), then

    1. (Let typedExpressionIR_cast be (((( typeIR_to ) typedExpressionIR) as expressionIR) # (( typeIR_to _ctk ))))

    2. Return ?(typedExpressionIR_cast)

4. Otherwise

  1. Return ?()

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.05.2-typing-casting.spectec:480:1-482:62:
dec $cast_binary(typedExpressionIR_l, typedExpressionIR_r)

1. (Let (_expressionIR # (( typeIR_l _ctk ))) be typedExpressionIR_l)

2. (Let (_expressionIR' # (( typeIR_r _ctk' ))) be typedExpressionIR_r)

3. If (Type_alpha: typeIR_l ~~ typeIR_r holds), then

  1. Return ?((typedExpressionIR_l, typedExpressionIR_r))

4. If (Type_alpha: typeIR_l ~~ typeIR_r does not hold), then

  1. If (Cast_impl: typeIR_l -> typeIR_r holds), then

    1. (Let typedExpressionIR_l_cast be (((( typeIR_r ) typedExpressionIR_l) as expressionIR) # (( typeIR_r _ctk' ))))

    2. Return ?((typedExpressionIR_l_cast, typedExpressionIR_r))

5. If (Type_alpha: typeIR_l ~~ typeIR_r does not hold), then

  1. If (Cast_impl: typeIR_l -> typeIR_r does not hold), then

    1. If (Cast_impl: typeIR_r -> typeIR_l holds), then

      1. (Let typedExpressionIR_r_cast be (((( typeIR_l ) typedExpressionIR_r) as expressionIR) # (( typeIR_l _ctk' ))))

      2. Return ?((typedExpressionIR_l, typedExpressionIR_r_cast))

6. If (Type_alpha: typeIR_l ~~ typeIR_r does not hold), then

  1. If (Cast_impl: typeIR_l -> typeIR_r does not hold), then

    1. If (Cast_impl: typeIR_r -> typeIR_l does not hold), then

      1. (Let typedExpressionIR_l_cast be $reduce_serenum(typedExpressionIR_l))

      2. If ((typedExpressionIR_l =/= typedExpressionIR_l_cast)), then

        1. Return $cast_binary(typedExpressionIR_l_cast, typedExpressionIR_r)

7. If (Type_alpha: typeIR_l ~~ typeIR_r does not hold), then

  1. If (Cast_impl: typeIR_l -> typeIR_r does not hold), then

    1. If (Cast_impl: typeIR_r -> typeIR_l does not hold), then

      1. (Let typedExpressionIR_l_cast be $reduce_serenum(typedExpressionIR_l))

      2. If ((typedExpressionIR_l = typedExpressionIR_l_cast)), then

        1. (Let typedExpressionIR_r_cast be $reduce_serenum(typedExpressionIR_r))

        2. If ((typedExpressionIR_r =/= typedExpressionIR_r_cast)), then

          1. Return $cast_binary(typedExpressionIR_l, typedExpressionIR_r_cast)

8. Otherwise

  1. Return ?()

