  7. Case (% has type serializableEnumTypeIR)

    1. (Let (enum _typeId < typeIR'' > { _valueFieldIR* }) be (typeIR'' as serializableEnumTypeIR))

    2. Return $sizeof_maxSizeInBits'(typeIR'')

  8. Case (% has type tupleTypeIR)

    1. (Let (tuple < typeIR''* >) be (typeIR'' as tupleTypeIR))

    2. Return $sum_nat($sizeof_maxSizeInBits'(typeIR'')*)

  9. Case (% has type headerStackTypeIR)

    1. (Let (typeIR'' [ n_size ]) be (typeIR'' as headerStackTypeIR))

    2. Return ($sizeof_maxSizeInBits'(typeIR'') * n_size)

  10. Case (% has type structTypeIR)

    1. (Let (struct _typeId < _typeArgumentIR* > { (_annotationList typeIR'' _nameIR ;)* }) be (typeIR'' as structTypeIR))

    2. Return $sum_nat($sizeof_maxSizeInBits'(typeIR'')*)

  11. Case (% has type headerTypeIR)

    1. (Let (header _typeId < _typeArgumentIR* > { (_annotationList typeIR'' _nameIR ;)* }) be (typeIR'' as headerTypeIR))

    2. Return $sum_nat($sizeof_maxSizeInBits'(typeIR'')*)

  12. Case (% has type headerUnionTypeIR)

    1. (Let (header_union _typeId < _typeArgumentIR* > { (_annotationList typeIR'' _nameIR ;)* }) be (typeIR'' as headerUnionTypeIR))

    2. Return $max_nat($sizeof_maxSizeInBits'(typeIR'')*)

1. Else Phantom#479

;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:937:1-938:23:
dec $sizeof_maxSizeInBytes(typeIR)

