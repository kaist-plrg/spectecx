;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.01.1-dynamic-env.spectec:12:19-12:41:
syntax stateEnv = map<id, parserStateIR>

;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.01.1-dynamic-env.spectec:14:1-14:33:
dec $empty_stateEnv

