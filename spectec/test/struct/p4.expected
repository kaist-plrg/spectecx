        3. (Let externMethodTypeDefIR be (extern_method abstract nameIR < typeId_expl* , typeId_impl* > ( parameterIR* ) : typeIR_ret))

        4. If (CallableTypeDef_wf: $bound((block), TC_0) |- (externMethodTypeDefIR as callableTypeDefIR) holds), then

