2. Return store

;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.01.2-dynamic-store.spectec:20:1-21:50:
dec $add_store(store, objectId, object)

1. (Let store' be $add_map<objectId, object>(store, objectId, object))

2. Return store'

;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.01.2-dynamic-store.spectec:30:1-31:41:
dec $find_store(store, objectId)

1. (Let object'? be $find_map<objectId, object>(store, objectId))

2. If ((object'? matches pattern (_))), then

  1. (Let ?(object) be object'?)

  2. Return object

2. Else Phantom#1674

;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.02-inst-context.spectec:8:3-11:18:
syntax globalInstLayer = {constructor constructorDefEnv, type typeDefEnv, callable callableDefEnv, frame frame}

;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.02-inst-context.spectec:16:3-19:18:
syntax blockInstLayer = {type theta, callable callableDefEnv, state stateEnv, frame frame}

;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.02-inst-context.spectec:24:3-25:20:
syntax localInstLayer = {type theta, frames frame*}

;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.02-inst-context.spectec:32:3-35:27:
syntax instContext = {path objectId, global globalInstLayer, block blockInstLayer, local localInstLayer}

;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.02-inst-context.spectec:43:1-44:50:
dec $empty_instContext

1. (Let globalInstLayer be {constructor $empty_constructorDefEnv, type $empty_typeDefEnv, callable $empty_callableDefEnv, frame $empty_frame})

2. (Let blockInstLayer be {type $empty_theta, callable $empty_callableDefEnv, state $empty_stateEnv, frame $empty_frame})

3. (Let localInstLayer be {type $empty_theta, frames [$empty_frame]})

4. (Let IC be {path [], global globalInstLayer, block blockInstLayer, local localInstLayer})

5. Return IC

;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.02-inst-context.spectec:70:1-71:45:
dec $enter_i(IC)

1. Return IC[local.frames = $empty_frame :: IC.local.frames]

;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.02-inst-context.spectec:75:1-76:55:
dec $exit_i(IC)

1. (Let frame* be IC.local.frames)

2. If ((frame* matches pattern _ :: _)), then

  1. (Let frame_h :: frame_t* be frame*)

  2. Return IC[local.frames = frame_t*]

2. Else Phantom#1675

;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.02-inst-context.spectec:85:1-86:50:
dec $enter_path_i(IC, id)

1. Return IC[path = IC.path ++ [id]]

;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.02-inst-context.spectec:94:1-95:78:
dec $inherit_i(cursor, IC)

1. Case analysis on cursor

  1. Case (% matches pattern `GLOBAL`)

    1. (Let blockInstLayer be {type $empty_theta, callable $empty_callableDefEnv, state $empty_stateEnv, frame $empty_frame})

    2. (Let localInstLayer be {type $empty_theta, frames [$empty_frame]})

    3. Return IC[block = blockInstLayer][local = localInstLayer]

  2. Case (% matches pattern `BLOCK`)

    1. (Let localInstLayer be {type $empty_theta, frames [$empty_frame]})

    2. Return IC[local = localInstLayer]

  3. Case (% matches pattern `LOCAL`)

    1. Return IC

;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.02-inst-context.spectec:116:1-117:68:
dec $add_var_i(cursor, IC, id, value)

1. Case analysis on cursor

  1. Case (% matches pattern `GLOBAL`)

    1. If (~$in_set<id>(id, $dom_map<id, value>(IC.global.frame))), then

      1. (Let frame be $add_map<id, value>(IC.global.frame, id, value))

      2. Return IC[global.frame = frame]

    1. Else Phantom#1676

  2. Case (% matches pattern `BLOCK`)

    1. If (~$in_set<id>(id, $dom_map<id, value>(IC.block.frame))), then

      1. (Let frame be $add_map<id, value>(IC.block.frame, id, value))

      2. Return IC[block.frame = frame]

    1. Else Phantom#1677

  3. Case (% matches pattern `LOCAL`)

    1. (Let frame* be IC.local.frames)

    2. If ((frame* matches pattern _ :: _)), then

      1. (Let frame_h :: frame_t* be frame*)

      2. If (~$in_set<id>(id, $dom_map<id, value>(frame_h))), then

        1. (Let frame_h' be $add_map<id, value>(frame_h, id, value))

        2. Return IC[local.frames = frame_h' :: frame_t*]

      2. Else Phantom#1678

    2. Else Phantom#1679

;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.02-inst-context.spectec:118:1-119:85:
dec $add_vars_i(p, IC, id*, value*)

1. Case analysis on id*

  1. Case (% matches pattern [])

    1. If ((value* matches pattern [])), then

      1. Return IC

    1. Else Phantom#1680

  2. Case (% matches pattern _ :: _)

    1. (Let id_h :: id_t* be id*)

    2. If ((value* matches pattern _ :: _)), then

      1. (Let value_h :: value_t* be value*)

      2. (Let IC' be $add_var_i(p, IC, id_h, value_h))

      3. (Let IC'' be $add_vars_i(p, IC', id_t*, value_t*))

      4. Return IC''

    2. Else Phantom#1681

;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.02-inst-context.spectec:139:1-140:68:
dec $add_typeDef_i(cursor, IC, typeId, typeDefIR)

1. If ((cursor matches pattern `GLOBAL`)), then

  1. (Let typeDefEnv be $add_map<typeId, typeDefIR>(IC.global.type, typeId, typeDefIR))

  2. Return IC[global.type = typeDefEnv]

1. Else Phantom#1682

;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.02-inst-context.spectec:149:1-150:50:
dec $add_parserState_i(IC, nameIR, parserStateIR)

1. If (~$in_set<nameIR>(nameIR, $dom_map<nameIR, parserStateIR>(IC.block.state))), then

  1. (Let stateEnv be $add_map<nameIR, parserStateIR>(IC.block.state, nameIR, parserStateIR))

  2. Return IC[block.state = stateEnv]

1. Else Phantom#1683

;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.02-inst-context.spectec:162:1-162:67:
dec $add_type_i(cursor, IC, typeId, typeIR)

1. Case analysis on cursor

  1. Case (% matches pattern `BLOCK`)

    1. (Let theta be $add_map<typeId, typeIR>(IC.block.type, typeId, typeIR))

    2. Return IC[block.type = theta]

  2. Case (% matches pattern `LOCAL`)

    1. (Let theta be $add_map<typeId, typeIR>(IC.local.type, typeId, typeIR))

    2. Return IC[local.type = theta]

1. Else Phantom#1684

;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.02-inst-context.spectec:163:1-163:70:
dec $add_types_i(p, IC, typeId*, typeIR*)

1. Case analysis on typeId*

  1. Case (% matches pattern [])

    1. If ((typeIR* matches pattern [])), then

      1. Return IC

    1. Else Phantom#1685

  2. Case (% matches pattern _ :: _)

    1. (Let typeId_h :: typeId_t* be typeId*)

    2. If ((typeIR* matches pattern _ :: _)), then

      1. (Let typeIR_h :: typeIR_t* be typeIR*)

      2. (Let IC' be $add_type_i(p, IC, typeId_h, typeIR_h))

      3. Return $add_types_i(p, IC', typeId_t*, typeIR_t*)

    2. Else Phantom#1686

;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.02-inst-context.spectec:177:1-179:94:
dec $add_callableDef_overload_i(cursor, IC, callableId, callableDef)

1. Case analysis on cursor

  1. Case (% matches pattern `GLOBAL`)

    1. If (~$in_set<callableId>(callableId, $dom_map<callableId, callableDef>(IC.global.callable))), then

      1. (Let callableDefEnv be $add_map<callableId, callableDef>(IC.global.callable, callableId, callableDef))

      2. Return IC[global.callable = callableDefEnv]

    1. Else Phantom#1687

  2. Case (% matches pattern `BLOCK`)

    1. If (~$in_set<callableId>(callableId, $dom_map<callableId, callableDef>(IC.block.callable))), then

      1. (Let callableDefEnv be $add_map<callableId, callableDef>(IC.block.callable, callableId, callableDef))

      2. Return IC[block.callable = callableDefEnv]

    1. Else Phantom#1688

1. Else Phantom#1689

;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.02-inst-context.spectec:192:1-194:97:
dec $add_callableDef_non_overload_i(cursor, IC, callableId, callableDef)

1. Case analysis on cursor

  1. Case (% matches pattern `GLOBAL`)

    1. (Let (id ( _id* )) be callableId)

    2. (Let ({ (id_k ( _id'* ))* }) be $dom_map<callableId, callableDef>(IC.global.callable))

    3. If (~$in_set<id>(id, ({ id_k* }))), then

      1. (Let callableDefEnv be $add_map<callableId, callableDef>(IC.global.callable, callableId, callableDef))

      2. Return IC[global.callable = callableDefEnv]

    3. Else Phantom#1690

  2. Case (% matches pattern `BLOCK`)

    1. (Let (id ( _id* )) be callableId)

    2. (Let ({ (id_k ( _id'* ))* }) be $dom_map<callableId, callableDef>(IC.block.callable))

    3. If (~$in_set<id>(id, ({ id_k* }))), then

      1. (Let callableDefEnv be $add_map<callableId, callableDef>(IC.block.callable, callableId, callableDef))

      2. Return IC[block.callable = callableDefEnv]

    3. Else Phantom#1691

1. Else Phantom#1692

;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.02-inst-context.spectec:213:1-215:92:
dec $find_callableDef_non_overload_i(p', IC, prefixedNameIR)

1. If ((prefixedNameIR matches pattern `. %`)), then

  1. (Let (. nameIR) be prefixedNameIR)

  2. If ((?() = $find_non_overloaded<callableDef>(IC.global.callable, nameIR))), then

    1. Return ?()

  2. Else Phantom#1693

  3. (Let (callableId, callableDef)? be $find_non_overloaded<callableDef>(IC.global.callable, nameIR))

  4. If (((callableId, callableDef)? matches pattern (_))), then

    1. (Let ?((callableId, callableDef)) be (callableId, callableDef)?)

    2. Return ?(((global), callableId, callableDef))

  4. Else Phantom#1694

1. Else Phantom#1695

2. Case analysis on p'

  1. Case (% matches pattern `GLOBAL`)

    1. If ((prefixedNameIR matches pattern `` %`)), then

      1. (Let (` nameIR) be prefixedNameIR)

      2. Return $find_callableDef_non_overload_i((global), IC, (. nameIR))

    1. Else Phantom#1696

  2. Case (% matches pattern `BLOCK`)

    1. If ((prefixedNameIR matches pattern `` %`)), then

      1. (Let (` nameIR) be prefixedNameIR)

      2. (Let (callableId, callableDef)? be $find_non_overloaded<callableDef>(IC.block.callable, nameIR))

      3. If (((callableId, callableDef)? matches pattern (_))), then

        1. (Let ?((callableId, callableDef)) be (callableId, callableDef)?)

        2. Return ?(((block), callableId, callableDef))

      3. Else Phantom#1697

      4. If ((?() = $find_non_overloaded<callableDef>(IC.block.callable, nameIR))), then

        1. Return $find_callableDef_non_overload_i((global), IC, (` nameIR))

      4. Else Phantom#1698

    1. Else Phantom#1699

  3. Case (% matches pattern `LOCAL`)

    1. If ((prefixedNameIR matches pattern `` %`)), then

      1. (Let (` nameIR) be prefixedNameIR)

      2. Return $find_callableDef_non_overload_i((block), IC, (` nameIR))

    1. Else Phantom#1700

;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.02-inst-context.spectec:238:1-239:53:
dec $add_constructorDef_i(IC, callableId, constructorDef)

1. (Let constructorDefEnv be $add_map<callableId, constructorDef>(IC.global.constructor, callableId, constructorDef))

2. Return IC[global.constructor = constructorDefEnv]

;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.02-inst-context.spectec:240:1-241:70:
dec $add_constructorDefs_i(IC, callableId*, constructorDef*)

1. Case analysis on callableId*

  1. Case (% matches pattern [])

    1. If ((constructorDef* matches pattern [])), then

      1. Return IC

    1. Else Phantom#1701

  2. Case (% matches pattern _ :: _)

    1. (Let callableId_h :: callableId_t* be callableId*)

    2. If ((constructorDef* matches pattern _ :: _)), then

      1. (Let constructorDef_h :: constructorDef_t* be constructorDef*)

      2. (Let IC' be $add_constructorDef_i(IC, callableId_h, constructorDef_h))

      3. (Let IC'' be $add_constructorDefs_i(IC', callableId_t*, constructorDef_t*))

      4. Return IC''

    2. Else Phantom#1702

;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.02-inst-context.spectec:263:1-264:63:
dec $find_var_i(prefixedNameIR, p', IC)

1. Case analysis on prefixedNameIR

  1. Case (% matches pattern `. %`)

    1. (Let (. id) be prefixedNameIR)

    2. (Let value'? be $find_map<id, value>(IC.global.frame, id))

    3. If ((value'? matches pattern (_))), then

      1. (Let ?(value) be value'?)

      2. Return value

    3. Else Phantom#1703

  2. Case (% matches pattern `` %`)

    1. (Let (` id) be prefixedNameIR)

    2. Case analysis on p'

      1. Case (% matches pattern `GLOBAL`)

        1. (Let value'? be $find_map<id, value>(IC.global.frame, id))

        2. If ((value'? matches pattern (_))), then

          1. (Let ?(value) be value'?)

          2. Return value

        2. Else Phantom#1704

      2. Case (% matches pattern `BLOCK`)

        1. (Let value'? be $find_map<id, value>(IC.block.frame, id))

        2. If ((value'? matches pattern (_))), then

          1. (Let ?(value) be value'?)

          2. Return value

        2. Else Phantom#1705

        3. If ((?() = $find_map<id, value>(IC.block.frame, id))), then

          1. Return $find_var_i((` id), (global), IC)

        3. Else Phantom#1706

      3. Case (% matches pattern `LOCAL`)

        1. (Let value'? be $find_maps<id, value>(IC.local.frames, id))

        2. If ((value'? matches pattern (_))), then

          1. (Let ?(value) be value'?)

          2. Return value

        2. Else Phantom#1707

        3. If ((?() = $find_maps<id, value>(IC.local.frames, id))), then

          1. Return $find_var_i((` id), (block), IC)

        3. Else Phantom#1708

;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.02-inst-context.spectec:283:1-284:73:
dec $find_typeDef_i(_cursor, IC, prefixedNameIR)

1. Case analysis on prefixedNameIR

  1. Case (% matches pattern `` %`)

    1. (Let (` nameIR) be prefixedNameIR)

    2. Return $find_map<typeId, typeDefIR>(IC.global.type, nameIR)

  2. Case (% matches pattern `. %`)

    1. (Let (. nameIR) be prefixedNameIR)

    2. Return $find_map<typeId, typeDefIR>(IC.global.type, nameIR)

;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.02-inst-context.spectec:293:1-295:79:
dec $find_constructorDef_i(IC, prefixedNameIR, argumentIR*)

1. Case analysis on prefixedNameIR

  1. Case (% matches pattern `` %`)

    1. (Let (` nameIR) be prefixedNameIR)

    2. (Let callTargetKey be $callTargetKey(nameIR, argumentIR*))

    3. Return $find_overloaded<constructorDef>(IC.global.constructor, callTargetKey, $parameterListIR_of_constructorDef)

  2. Case (% matches pattern `. %`)

    1. (Let (. nameIR) be prefixedNameIR)

    2. (Let callTargetKey be $callTargetKey(nameIR, argumentIR*))

    3. Return $find_overloaded<constructorDef>(IC.global.constructor, callTargetKey, $parameterListIR_of_constructorDef)

;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.02-inst-context.spectec:314:1-315:86:
dec $subst_type_i(cursor, IC, typeIR)

1. Case analysis on cursor

  1. Case (% matches pattern `GLOBAL`)

    1. Return typeIR

  2. Case (% matches pattern `BLOCK`)

    1. (Let theta be IC.block.type)

    2. (Let typeIR_subst be $subst_typeIR(theta, typeIR))

    3. Return typeIR_subst

  3. Case (% matches pattern `LOCAL`)

    1. (Let theta_block be IC.block.type)

    2. (Let theta_local be IC.local.type)

    3. (Let theta be $extend_map<typeId, typeIR>(theta_block, theta_local))

    4. (Let typeIR_subst be $subst_typeIR(theta, typeIR))

    5. Return typeIR_subst

;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.03-inst-relation.spectec:5:1-10:38:
relation Expr_inst: p, IC, STO', (expressionIR # _expressionNoteIR')

1. Case analysis on expressionIR

  1. Case (% has type booleanLiteral)

    1. (Let booleanLiteral be (expressionIR as booleanLiteral))

    2. (Let boolValue be $ite<boolValue>((booleanLiteral = (true)), (true), (false)))

    3. Result in STO', (boolValue as value)

  2. Case (% has type integerLiteral)

    1. (Let integerLiteral be (expressionIR as integerLiteral))

    2. Result in STO', (integerLiteral as value)

  3. Case (% has type stringLiteral)

    1. (Let stringLiteral be (expressionIR as stringLiteral))

    2. Result in STO', (stringLiteral as value)

  4. Case (% has type prefixedNameIR)

    1. (Let prefixedNameIR be (expressionIR as prefixedNameIR))

    2. (Let value be $find_var_i(prefixedNameIR, p, IC))

    3. Result in STO', value

  5. Case (% has type defaultExpression)

    1. (Let defaultExpression be (expressionIR as defaultExpression))

    2. If ((defaultExpression matches pattern `...`)), then

      1. Result in STO', ((default) as value)

    2. Else Phantom#1709

  6. Case (% has type unaryExpressionIR)

    1. (Let (unop typedExpressionIR) be (expressionIR as unaryExpressionIR))

    2. (Expr_inst: p IC STO' |- typedExpressionIR : STO_1 value)

    3. Result in STO_1, $un_op(unop, value)

  7. Case (% has type binaryExpressionIR)

    1. (Let (typedExpressionIR_l binop typedExpressionIR_r) be (expressionIR as binaryExpressionIR))

    2. If (~binop is in [(&&), (||)]), then

      1. (Expr_inst: p IC STO' |- typedExpressionIR_l : STO_1 value_l)

      2. (Expr_inst: p IC STO_1 |- typedExpressionIR_r : STO_2 value_r)

      3. Result in STO_2, $bin_op(binop, value_l, value_r)

    2. Else Phantom#1710

    3. Case analysis on binop

      1. Case (% matches pattern `&&`)

        1. (Expr_inst: p IC STO' |- typedExpressionIR_l : STO_1 value)

        2. If ((value = ((false) as value))), then

          1. Result in STO_1, ((false) as value)

        2. Else Phantom#1711

        3. If ((value = ((true) as value))), then

          1. (Expr_inst: p IC STO_1 |- typedExpressionIR_r : STO_2 value_r)

          2. Result in STO_2, value_r

        3. Else Phantom#1712

      2. Case (% matches pattern `||`)

        1. (Expr_inst: p IC STO' |- typedExpressionIR_l : STO_1 value)

        2. If ((value = ((true) as value))), then

          1. Result in STO_1, ((true) as value)

        2. Else Phantom#1713

        3. If ((value = ((false) as value))), then

          1. (Expr_inst: p IC STO_1 |- typedExpressionIR_r : STO_2 value_r)

          2. Result in STO_2, value_r

        3. Else Phantom#1714

    3. Else Phantom#1715

  8. Case (% has type ternaryExpressionIR)

    1. (Let (typedExpressionIR_cond ? typedExpressionIR_true : typedExpressionIR_false) be (expressionIR as ternaryExpressionIR))

    2. (Expr_inst: p IC STO' |- typedExpressionIR_cond : STO_1 value)

    3. If ((value = ((true) as value))), then

      1. (Expr_inst: p IC STO_1 |- typedExpressionIR_true : STO_2 value_true)

      2. Result in STO_2, value_true

    3. Else Phantom#1716

    4. If ((value = ((false) as value))), then

      1. (Expr_inst: p IC STO_1 |- typedExpressionIR_false : STO_2 value_false)

      2. Result in STO_2, value_false

    4. Else Phantom#1717

  9. Case (% has type castExpressionIR)

    1. (Let (( typeIR ) typedExpressionIR) be (expressionIR as castExpressionIR))

    2. (Expr_inst: p IC STO' |- typedExpressionIR : STO_1 value)

    3. (Let value_cast be $cast_op(typeIR, value))

    4. Result in STO_1, value_cast

  10. Case (% has type invalidHeaderExpression)

    1. (Let invalidHeaderExpression be (expressionIR as invalidHeaderExpression))

    2. If ((invalidHeaderExpression matches pattern `{#}`)), then

      1. Result in STO', (({#}) as value)

    2. Else Phantom#1718

  11. Case (% has type sequenceExpressionIR)

    1. (Let sequenceExpressionIR be (expressionIR as sequenceExpressionIR))

    2. Case analysis on sequenceExpressionIR

      1. Case (% matches pattern `SEQ {%}`)

        1. (Let (seq { typedExpressionListIR }) be sequenceExpressionIR)

        2. (Exprs_inst: p IC STO' |- typedExpressionListIR : STO_1 value*)

        3. Result in STO_1, ((seq ( value* )) as value)

      2. Case (% matches pattern `SEQ {% , ...}`)

        1. (Let (seq { typedExpressionListIR , ... }) be sequenceExpressionIR)

        2. (Exprs_inst: p IC STO' |- typedExpressionListIR : STO_1 value*)

        3. Result in STO_1, ((seq ( value* , ... )) as value)

  12. Case (% has type recordExpressionIR)

    1. (Let recordExpressionIR be (expressionIR as recordExpressionIR))

    2. Case analysis on recordExpressionIR

      1. Case (% matches pattern `RECORD {%}`)

        1. (Let (record { (nameIR = typedExpressionIR)* }) be recordExpressionIR)

        2. (Exprs_inst: p IC STO' |- typedExpressionIR* : STO_1 value*)

        3. Result in STO_1, ((record { (value nameIR ;)* }) as value)

      2. Case (% matches pattern `RECORD {% , ...}`)

        1. (Let (record { (nameIR = typedExpressionIR)* , ... }) be recordExpressionIR)

        2. (Exprs_inst: p IC STO' |- typedExpressionIR* : STO_1 value*)

        3. Result in STO_1, ((record { (value nameIR ;)* , ... }) as value)

  13. Case (% has type errorAccessExpressionIR)

    1. (Let (error . nameIR) be (expressionIR as errorAccessExpressionIR))

    2. (Let nameIR_error be "error." ++ nameIR)

    3. (Let value_error be $find_var_i((` nameIR_error), p, IC))

    4. Result in STO', value_error

  14. Case (% has type memberAccessExpressionIR)

    1. (Let (memberAccessBaseIR . nameIR) be (expressionIR as memberAccessExpressionIR))

    2. If ((memberAccessBaseIR matches pattern `TYPE %`)), then

      1. (Let (type prefixedNameIR) be memberAccessBaseIR)

      2. (Let typeDefIR'? be $find_typeDef_i(p, IC, prefixedNameIR))

      3. If ((typeDefIR'? matches pattern (_))), then

        1. (Let ?(typeDefIR) be typeDefIR'?)

        2. Case analysis on typeDefIR

          1. Case (% has type simpleEnumTypeIR)

            1. (Let (enum typeId { _nameIR* }) be (typeDefIR as simpleEnumTypeIR))

            2. Result in STO', ((typeId . nameIR) as value)

          2. Case (% has type serializableEnumTypeIR)

            1. (Let (enum typeId < _typeIR > { (id_member = value_member ;)* }) be (typeDefIR as serializableEnumTypeIR))

            2. (Let value'? be $assoc_<nameIR, value>(nameIR, (id_member, value_member)*))

            3. If ((value'? matches pattern (_))), then

              1. (Let ?(value) be value'?)

              2. Result in STO', ((typeId . nameIR . value) as value)

            3. Else Phantom#1719

        2. Else Phantom#1720

      3. Else Phantom#1721

    2. Else Phantom#1722

    3. If ((memberAccessBaseIR has type typedExpressionIR)), then

      1. (Let typedExpressionIR_base be (memberAccessBaseIR as typedExpressionIR))

      2. (Let typeIR_base be $type_of_typedExpressionIR(typedExpressionIR_base))

      3. (Let typeIR be $unroll_typeIR(typeIR_base))

      4. If ((typeIR has type headerStackTypeIR)), then

        1. (Let (_typeIR [ n_size ]) be (typeIR as headerStackTypeIR))

        2. If ((nameIR = "size")), then

          1. Result in STO', ((d (n_size as int)) as value)

        2. Else Phantom#1723

      4. Else Phantom#1724

      5. (Expr_inst: p IC STO' |- typedExpressionIR_base : STO_1 value')

      6. Case analysis on value'

        1. Case (% has type structValue)

          1. (Let structValue be (value' as structValue))

          2. (Let (struct _typeId { (value_field id_field ;)* }) be structValue)

          3. (Let value''? be $assoc_<id, value>(nameIR, (id_field, value_field)*))

          4. If ((value''? matches pattern (_))), then

            1. (Let ?(value) be value''?)

            2. Result in STO_1, value

          4. Else Phantom#1725

        2. Case (% has type headerValue)

          1. (Let headerValue be (value' as headerValue))

          2. (Let (header _typeId { _bool ; (value_field id_field ;)* }) be headerValue)

          3. (Let value''? be $assoc_<id, value>(nameIR, (id_field, value_field)*))

          4. If ((value''? matches pattern (_))), then

            1. (Let ?(value) be value''?)

            2. Result in STO_1, value

          4. Else Phantom#1726

        3. Case (% has type headerUnionValue)

          1. (Let headerUnionValue be (value' as headerUnionValue))

          2. (Let (header_union _typeId { (value_field id_field ;)* }) be headerUnionValue)

          3. (Let value''? be $assoc_<id, value>(nameIR, (id_field, value_field)*))

          4. If ((value''? matches pattern (_))), then

            1. (Let ?(value) be value''?)

            2. Result in STO_1, value

          4. Else Phantom#1727

      6. Else Phantom#1728

    3. Else Phantom#1729

  15. Case (% has type indexAccessExpressionIR)

    1. (Let (typedExpressionIR_base [ typedExpressionIR_index ]) be (expressionIR as indexAccessExpressionIR))

    2. (Expr_inst: p IC STO' |- typedExpressionIR_base : STO_1 value_base)

    3. (Expr_inst: p IC STO_1 |- typedExpressionIR_index : STO_2 value')

    4. If ((value' has type integerValue)), then

      1. (Let integerValue_index be (value' as integerValue))

      2. (Let value'' be value_base)

      3. Case analysis on value''

        1. Case (% has type tupleValue)

          1. (Let (tuple ( value_e* )) be (value'' as tupleValue))

          2. (Let nat? be $nat_of_integerValue(integerValue_index))

          3. If ((nat? matches pattern (_))), then

            1. (Let ?(n_index) be nat?)

            2. If ((n_index < |value_e*|)), then

              1. (Let value be value_e*[n_index])

              2. Result in STO_2, value

            2. Else Phantom#1730

          3. Else Phantom#1731

        2. Case (% has type headerStackValue)

          1. (Let (header_stack [ value_e* ( _nat ; _nat' ) ]) be (value'' as headerStackValue))

          2. (Let nat? be $nat_of_integerValue(integerValue_index))

          3. If ((nat? matches pattern (_))), then

            1. (Let ?(n_index) be nat?)

            2. If ((n_index < |value_e*|)), then

              1. (Let value be value_e*[n_index])

              2. Result in STO_2, value

            2. Else Phantom#1732

          3. Else Phantom#1733

      3. Else Phantom#1734

    4. Else Phantom#1735

  16. Case (% has type sliceAccessExpressionIR)

    1. (Let sliceAccessExpressionIR be (expressionIR as sliceAccessExpressionIR))

    2. If ((sliceAccessExpressionIR matches pattern `% [% : %]`)), then

      1. (Let (typedExpressionIR_base [ typedExpressionIR_hi : typedExpressionIR_lo ]) be sliceAccessExpressionIR)

      2. (Expr_inst: p IC STO' |- typedExpressionIR_base : STO_1 value_base)

      3. (Expr_inst: p IC STO_1 |- typedExpressionIR_hi : STO_2 value_hi)

      4. (Expr_inst: p IC STO_2 |- typedExpressionIR_lo : STO_3 value_lo)

      5. Result in STO_3, $bitacc_range_op(value_base, value_hi, value_lo)

      6. (Expr_inst: p IC STO_1 |- typedExpressionIR_hi : STO_2 value_l)

      7. (Expr_inst: p IC STO_2 |- typedExpressionIR_lo : STO_3 value_w)

      8. Result in STO_3, $bitacc_offset_op(value_base, value_l, value_w)

    2. Else Phantom#1736

  17. Case (% has type callExpressionIR)

    1. (Let callExpressionIR be (expressionIR as callExpressionIR))

    2. Case analysis on callExpressionIR

      1. Case (% matches pattern `% (%)`)

        1. (Let ((prefixedNameIR < typeArgumentListIR >) ( argumentListIR )) be callExpressionIR)

        2. (Constructor_inst: p IC |- prefixedNameIR < typeArgumentListIR > ( argumentListIR ) : constructorDef < typeArgumentListIR_inst > ( # id_default* # id_optional* ))

        3. (Constructor_call: p IC STO' |- constructorDef < typeArgumentListIR_inst > ( argumentListIR # id_default* # id_optional* ) : STO_1 object)

        4. (Let STO_2 be $add_store(STO_1, IC.path, object))

        5. (Let value_ref be ((ref IC.path) as value))

        6. Result in STO_2, value_ref

      2. Case (% matches pattern `% <%> (%)`)

        1. (Let (callableTargetIR < _typeArgumentListIR > ( _argumentListIR )) be callExpressionIR)

        2. Case analysis on callableTargetIR

          1. Case (% matches pattern `% . %`)

            1. (Let (typedExpressionIR_base . nameIR) be callableTargetIR)

            2. (Let (_expressionIR # (( typeIR_base _ctk ))) be typedExpressionIR_base)

            3. If (nameIR is in ["minSizeInBits", "minSizeInBytes", "maxSizeInBits", "maxSizeInBytes"]), then

              1. Result in STO', $sizeof(typeIR_base, nameIR)

            3. Else Phantom#1737

          2. Case (% matches pattern `TYPE % . %`)

            1. (Let (type prefixedNameIR . nameIR) be callableTargetIR)

            2. (Let typeDefIR? be $find_typeDef_i(p, IC, prefixedNameIR))

            3. If ((typeDefIR? matches pattern (_))), then

              1. (Let ?(typeDefIR_base) be typeDefIR?)

              2. Case analysis on $is_monomorphic_typeDefIR(typeDefIR_base)

                1. Case true

                  1. (Let typeIR_base be $typeIR_of_typeDefIR(typeDefIR_base))

                  2. If (nameIR is in ["minSizeInBits", "minSizeInBytes", "maxSizeInBits", "maxSizeInBytes"]), then

                    1. Result in STO', $sizeof(typeIR_base, nameIR)

                  2. Else Phantom#1738

                2. Case false

                  1. If ((([], []) = $typeParameterListIR_of_typeDefIR(typeDefIR_base))), then

                    1. (Let typeIR_base be $typeIR_of_typeDefIR(typeDefIR_base))

                    2. If (nameIR is in ["minSizeInBits", "minSizeInBytes", "maxSizeInBits", "maxSizeInBytes"]), then

                      1. Result in STO', $sizeof(typeIR_base, nameIR)

                    2. Else Phantom#1739

                  1. Else Phantom#1740

            3. Else Phantom#1741

          3. Case (% matches pattern `(%)`)

            1. (Let (( callableTargetIR )) be callableTargetIR)

            2. (Expr_inst: p IC STO' |- (((callableTargetIR < _typeArgumentListIR > ( _argumentListIR )) as expressionIR) # _expressionNoteIR') : STO_1 value)

            3. Result in STO_1, value

        2. Else Phantom#1742

  18. Case (% has type parenthesizedExpressionIR)

    1. (Let (( typedExpressionIR )) be (expressionIR as parenthesizedExpressionIR))

    2. (Expr_inst: p IC STO' |- typedExpressionIR : STO_1 value)

    3. Result in STO_1, value

;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.03-inst-relation.spectec:12:1-17:38:
relation Exprs_inst: p, IC, STO', typedExpressionIR*

1. Case analysis on typedExpressionIR*

  1. Case (% matches pattern [])

    1. Result in STO', []

  2. Case (% matches pattern _ :: _)

    1. (Let typedExpressionIR_h :: typedExpressionIR_t* be typedExpressionIR*)

    2. (Expr_inst: p IC STO' |- typedExpressionIR_h : STO_1 value_h)

    3. (Exprs_inst: p IC STO_1 |- typedExpressionIR_t* : STO_2 value_t*)

    4. Result in STO_2, value_h :: value_t*

;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.03-inst-relation.spectec:23:1-28:38:
relation Argument_inst: p, IC, STO_0, argumentIR

1. If ((argumentIR has type typedExpressionIR)), then

  1. (Let typedExpressionIR be (argumentIR as typedExpressionIR))

  2. (Expr_inst: p IC STO_0 |- typedExpressionIR : STO_1 value)

  3. Result in STO_1, value

1. Else Phantom#1743

2. If ((argumentIR matches pattern `% = %`)), then

  1. (Let (nameIR = typedExpressionIR) be argumentIR)

  2. (Expr_inst: p IC STO_0 |- typedExpressionIR : STO_1 value)

  3. Result in STO_1, value

2. Else Phantom#1744

;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.03-inst-relation.spectec:34:1-40:55:
relation DirectApplicationStmt_inst: p, IC, STO_0, (constructorTargetIR . apply ( argumentListIR ) ;)

1. (Let (prefixedNameIR < typeArgumentListIR >) be constructorTargetIR)

2. (Constructor_inst: p IC |- prefixedNameIR < typeArgumentListIR > ( [] ) : constructorDef < typeArgumentListIR_inst > ( # id_default* # id_optional* ))

3. (Let typeId be $flatten_prefixedNameIR(prefixedNameIR))

4. (Let IC_callee be $enter_path_i(IC, typeId))

5. (Constructor_call: p IC_callee STO_0 |- constructorDef < typeArgumentListIR_inst > ( [] # id_default* # id_optional* ) : STO_1 object)

6. (Let typeId_fresh be $fresh_typeId)

7. (Let typeIR be ((` typeId) as typeIR))

8. (Let nameIR be $concat_text([typeId, "_", typeId_fresh]))

9. (Let objectId be IC.path ++ [typeId])

10. (Let STO_2 be $add_store(STO_1, objectId, object))

11. (Let constantDeclarationIR be (() const typeIR nameIR (= ((ref objectId) as value)) ;))

12. (Let typedExpressionIR_base be (((` nameIR) as expressionIR) # (( typeIR (ctk) ))))

13. (Let callableTargetIR be (typedExpressionIR_base . "apply"))

14. (Let callStatementIR be (callableTargetIR < typeArgumentListIR_inst > ( argumentListIR ) ;))

15. Result in STO_2, constantDeclarationIR, callStatementIR

;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.03-inst-relation.spectec:42:1-48:55:
relation Stmt_inst: p', IC', STO', statementIR''

1. Case analysis on statementIR''

  1. Case (% has type emptyStatementIR)

    1. (Let emptyStatementIR be (statementIR'' as emptyStatementIR))

    2. Result in IC', STO', (emptyStatementIR as statementIR)

  2. Case (% has type assignmentStatementIR)

    1. (Let assignmentStatementIR be (statementIR'' as assignmentStatementIR))

    2. Result in IC', STO', (assignmentStatementIR as statementIR)

  3. Case (% has type callStatementIR)

    1. (Let callStatementIR be (statementIR'' as callStatementIR))

    2. Result in IC', STO', (callStatementIR as statementIR)

  4. Case (% has type directApplicationStatementIR)

    1. (Let directApplicationStatementIR be (statementIR'' as directApplicationStatementIR))

    2. (DirectApplicationStmt_inst: p' IC' STO' |- directApplicationStatementIR : STO_1 constantDeclarationIR callStatementIR)

    3. (Let blockStatementIR be (() { [(constantDeclarationIR as blockElementStatementIR), (callStatementIR as blockElementStatementIR)] }))

    4. Result in IC', STO_1, (blockStatementIR as statementIR)

  5. Case (% has type exitStatementIR)

    1. (Let exitStatementIR be (statementIR'' as exitStatementIR))

    2. Result in IC', STO', (exitStatementIR as statementIR)

  6. Case (% has type conditionalStatementIR)

    1. (Let conditionalStatementIR be (statementIR'' as conditionalStatementIR))

    2. Case analysis on conditionalStatementIR

      1. Case (% matches pattern `IF (%) %`)

        1. (Let (if ( typedExpressionIR_cond ) statementIR_then) be conditionalStatementIR)

        2. (Stmt_inst: p' IC' STO' |- statementIR_then : IC_then STO_1 statementIR_then_inst)

        3. Result in IC', STO_1, ((if ( typedExpressionIR_cond ) statementIR_then_inst) as statementIR)

      2. Case (% matches pattern `IF (%) % ELSE %`)

        1. (Let (if ( typedExpressionIR_cond ) statementIR_then else statementIR_else) be conditionalStatementIR)

        2. (Stmt_inst: p' IC' STO' |- statementIR_then : IC_then STO_1 statementIR_then_inst)

        3. (Stmt_inst: p' IC' STO_1 |- statementIR_else : IC_else STO_2 statementIR_else_inst)

        4. Result in IC', STO_2, ((if ( typedExpressionIR_cond ) statementIR_then_inst else statementIR_else_inst) as statementIR)

  7. Case (% has type forStatementIR)

    1. (Let forStatementIR' be (statementIR'' as forStatementIR))

    2. Case analysis on forStatementIR'

      1. Case (% matches pattern `% FOR (% ; % ; %) %`)

        1. (Let (annotationList for ( forInitStatementListIR ; typedExpressionIR ; forUpdateStatementListIR ) statementIR'') be forStatementIR')

        2. (Stmt_inst: p' IC' STO' |- statementIR'' : IC_body STO_1 statementIR_body)

        3. (Let forStatementIR be (annotationList for ( forInitStatementListIR ; typedExpressionIR ; forUpdateStatementListIR ) statementIR_body))

        4. Result in IC', STO_1, (forStatementIR as statementIR)

      2. Case (% matches pattern `% FOR (% % IN %) %`)

        1. (Let (annotationList for ( typeIR nameIR in forCollectionExpressionIR ) statementIR'') be forStatementIR')

        2. (Stmt_inst: p' IC' STO' |- statementIR'' : IC_body STO_1 statementIR_body)

        3. (Let forStatementIR be (annotationList for ( typeIR nameIR in forCollectionExpressionIR ) statementIR_body))

        4. Result in IC', STO_1, (forStatementIR as statementIR)

      3. Case (% matches pattern `% FOR (% % % IN %) %`)

        1. (Let (annotationList for ( annotationList' typeIR nameIR in forCollectionExpressionIR ) statementIR'') be forStatementIR')

        2. If ((annotationList = annotationList')), then

          1. (Stmt_inst: p' IC' STO' |- statementIR'' : IC_body STO_1 statementIR_body)

          2. (Let forStatementIR be (annotationList for ( annotationList typeIR nameIR in forCollectionExpressionIR ) statementIR_body))

