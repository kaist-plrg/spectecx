;; ../../../../../spectec/examples/p4-concrete/5-typing/5.04-typing-relation.spectec:386:1-390:46:
relation TableProperty_ok: TC, TBLC_0', tableProperty

1. Case analysis on tableProperty

  1. Case (% matches pattern `KEY = {%}`)

    1. (Let (key = { tableKeyList }) be tableProperty)

    2. (Let tableKey* be $flatten_tableKeyList(tableKeyList))

    3. (TableKeys_ok: TC TBLC_0' |- tableKey* : TBLC_1 tableKeyIR*)

    4. (Let TBLC_2 be $update_mode_tbl(TBLC_1, tableKeyIR*))

    5. Result in TBLC_2, ((key = { tableKeyIR* }) as tablePropertyIR)

  2. Case (% matches pattern `ACTIONS = {%}`)

    1. (Let (actions = { tableActionList }) be tableProperty)

    2. (Let tableAction* be $flatten_tableActionList(tableActionList))

    3. (TableActions_ok: TC TBLC_0' |- tableAction* : TBLC_1 tableActionIR*)

    4. Result in TBLC_1, ((actions = { tableActionIR* }) as tablePropertyIR)

  3. Case (% matches pattern `% % ENTRIES = {%}`)

    1. (Let (annotationList constOpt entries = { tableEntryList }) be tableProperty)

    2. (Let tableEntry* be $flatten_tableEntryList(tableEntryList))

    3. If (((|TBLC_0'.keys| = 0) => (|tableEntry*| = 0))), then

      1. (Let TBLC_1 be TBLC_0'[entries.size = |tableEntry*|])

      2. (Let constOptIR be $flatten_constOpt(constOpt))

      3. (Let TBLC_2 be TBLC_1[entries.const = (constOptIR = ?((const)))])

      4. (TableEntry_ok: TC TBLC_2 |- tableEntry : TBLS tableEntryIR)*

      5. (Let tableEntryIR_pri* be $set_priorities_of_tableEntryListIR(TBLC_2, TBLS*, tableEntryIR*))

      6. Result in TBLC_2, ((annotationList constOptIR entries = { tableEntryIR_pri* }) as tablePropertyIR)

    3. Else Phantom#1239

  4. Case (% matches pattern `% % % % ;`)

    1. (Let (annotationList constOpt tableCustomName initializer ;) be tableProperty)

    2. If (("default_action" = $tableCustomName(tableCustomName))), then

      1. (TableDefaultAction_ok: TC TBLC_0' |- initializer : tableActionReferenceIR)

      2. (Let constOptIR be $flatten_constOpt(constOpt))

      3. (Let tablePropertyIR be ((annotationList constOptIR default_action = tableActionReferenceIR ;) as tablePropertyIR))

      4. Result in TBLC_0', tablePropertyIR

    2. Else Phantom#1240

    3. (Let (annotationList constOpt tableCustomName (= expression) ;) be tableProperty)

    4. If (("largest_priority_wins" = $tableCustomName(tableCustomName))), then

      1. (Expr_ok: (local) TC |- expression : typedExpressionIR)

      2. (Let typeIR be $type_of_typedExpressionIR(typedExpressionIR))

      3. If (((lctk) = $ctk_of_typedExpressionIR(typedExpressionIR))), then

        1. If ((((bool) as typeIR) = $unroll_typeIR(typeIR))), then

          1. (Expr_eval_lctk: (local) TC |- typedExpressionIR ~> value)

          2. If ((value has type boolValue)), then

            1. (Let (b_lw) be (value as boolValue))

            2. (Let TBLC_1 be TBLC_0'[priorities.largest_wins = b_lw])

            3. (Let constOptIR be $flatten_constOpt(constOpt))

            4. (Let tablePropertyIR be ((annotationList constOptIR custom_const "largest_priority_wins" (= ((b_lw) as value)) ;) as tablePropertyIR))

            5. Result in TBLC_1, tablePropertyIR

          2. Else Phantom#1241

        1. Else Phantom#1242

      3. Else Phantom#1243

    4. Else Phantom#1244

    5. If (("priority_delta" = $tableCustomName(tableCustomName))), then

      1. (Expr_ok: (local) TC |- expression : typedExpressionIR)

      2. (Let typeIR be $type_of_typedExpressionIR(typedExpressionIR))

      3. If (((lctk) = $ctk_of_typedExpressionIR(typedExpressionIR))), then

        1. (Let typeIR_unroll be $unroll_typeIR(typeIR))

        2. If (((typeIR_unroll has type integerTypeIR) /\ ~(typeIR_unroll has type varBitTypeIR))), then

          1. (Expr_eval_lctk: (local) TC |- typedExpressionIR ~> value)

          2. If ((value has type integerValue)), then

            1. (Let integerValue be (value as integerValue))

            2. (Let nat? be $nat_of_integerValue(integerValue))

            3. If ((nat? matches pattern (_))), then

              1. (Let ?(n_delta) be nat?)

              2. If ((n_delta > 0)), then

                1. (Let TBLC_1 be TBLC_0'[priorities.delta = n_delta])

                2. (Let constOptIR be $flatten_constOpt(constOpt))

                3. (Let tablePropertyIR be ((annotationList constOptIR custom_const "priority_delta" (= ((d (n_delta as int)) as value)) ;) as tablePropertyIR))

                4. Result in TBLC_1, tablePropertyIR

              2. Else Phantom#1245

            3. Else Phantom#1246

          2. Else Phantom#1247

        2. Else Phantom#1248

      3. Else Phantom#1249

    5. Else Phantom#1250

    6. If (("size" = $tableCustomName(tableCustomName))), then

      1. (Expr_ok: (local) TC |- expression : typedExpressionIR)

      2. (Let typeIR be $type_of_typedExpressionIR(typedExpressionIR))

      3. (Let typeIR_unroll be $unroll_typeIR(typeIR))

      4. If (((typeIR_unroll has type integerTypeIR) /\ ~(typeIR_unroll has type varBitTypeIR))), then

        1. (Let constOptIR be $flatten_constOpt(constOpt))

        2. (Let tablePropertyIR be ((annotationList constOptIR custom "size" (= typedExpressionIR) ;) as tablePropertyIR))

        3. Result in TBLC_0', tablePropertyIR

      4. Else Phantom#1251

    6. Else Phantom#1252

    7. (Let nameIR be $tableCustomName(tableCustomName))

    8. If (((((nameIR =/= "default_action") /\ (nameIR =/= "size")) /\ (nameIR =/= "largest_priority_wins")) /\ (nameIR =/= "priority_delta"))), then

      1. (Expr_ok: (local) TC |- expression : typedExpressionIR)

      2. (Let constOptIR be $flatten_constOpt(constOpt))

      3. (Let tablePropertyIR be ((annotationList constOptIR custom nameIR (= typedExpressionIR) ;) as tablePropertyIR))

      4. Result in TBLC_0', tablePropertyIR

    8. Else Phantom#1253

