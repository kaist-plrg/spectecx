;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:378:1-381:23:
dec $bin_eq(value, value')

1. Case analysis on value

  1. Case (% has type boolValue)

    1. (Let (b_a) be (value as boolValue))

    2. If ((value' has type boolValue)), then

      1. (Let (b_b) be (value' as boolValue))

      2. Return (b_a = b_b)

    2. Else Phantom#332

  2. Case (% has type errorValue)

    1. (Let (error . id_a) be (value as errorValue))

    2. If ((value' has type errorValue)), then

      1. (Let (error . id_b) be (value' as errorValue))

      2. Return (id_a = id_b)

    2. Else Phantom#333

  3. Case (% has type matchKindValue)

    1. (Let (match_kind . id_a) be (value as matchKindValue))

    2. If ((value' has type matchKindValue)), then

      1. (Let (match_kind . id_b) be (value' as matchKindValue))

      2. Return (id_a = id_b)

    2. Else Phantom#334

  4. Case (% has type stringValue)

    1. (Let stringValue_a be (value as stringValue))

    2. If ((value' has type stringValue)), then

      1. (Let stringValue_b be (value' as stringValue))

      2. Return (stringValue_a = stringValue_b)

    2. Else Phantom#335

  5. Case (% has type integerLiteral)

    1. (Let integerLiteral be (value as integerLiteral))

    2. Case analysis on integerLiteral

      1. Case (% matches pattern `D %`)

        1. (Let (d i_a) be integerLiteral)

        2. If ((value' has type integerLiteral)), then

          1. (Let integerLiteral' be (value' as integerLiteral))

          2. If ((integerLiteral' matches pattern `D %`)), then

            1. (Let (d i_b) be integerLiteral')

            2. Return (i_a = i_b)

          2. Else Phantom#336

        2. Else Phantom#337

      2. Case (% matches pattern `% W %`)

        1. (Let (w_a w i_a) be integerLiteral)

        2. If ((value' has type integerLiteral)), then

          1. (Let integerLiteral' be (value' as integerLiteral))

          2. If ((integerLiteral' matches pattern `% W %`)), then

            1. (Let (w_b w i_b) be integerLiteral')

            2. Return ((w_a = w_b) /\ (i_a = i_b))

          2. Else Phantom#338

        2. Else Phantom#339

      3. Case (% matches pattern `% S %`)

        1. (Let (w_a s i_a) be integerLiteral)

        2. If ((value' has type integerLiteral)), then

          1. (Let integerLiteral' be (value' as integerLiteral))

          2. If ((integerLiteral' matches pattern `% S %`)), then

            1. (Let (w_b s i_b) be integerLiteral')

            2. Return ((w_a = w_b) /\ (i_a = i_b))

          2. Else Phantom#340

        2. Else Phantom#341

  6. Case (% has type listValue)

    1. (Let (list [ value_a* ]) be (value as listValue))

    2. If ((value' has type listValue)), then

      1. (Let (list [ value_b* ]) be (value' as listValue))

      2. Return ((|value_a*| = |value_b*|) /\ $forall_($bin_eq(value_a, value_b)*))

    2. Else Phantom#342

  7. Case (% has type tupleValue)

    1. (Let (tuple ( value_a* )) be (value as tupleValue))

    2. If ((value' has type tupleValue)), then

      1. (Let (tuple ( value_b* )) be (value' as tupleValue))

      2. Return ((|value_a*| = |value_b*|) /\ $forall_($bin_eq(value_a, value_b)*))

    2. Else Phantom#343

  8. Case (% has type headerStackValue)

    1. (Let (header_stack [ value_a* ( _nat ; n_size_a ) ]) be (value as headerStackValue))

    2. If ((value' has type headerStackValue)), then

      1. (Let (header_stack [ value_b* ( _nat' ; n_size_b ) ]) be (value' as headerStackValue))

      2. Return (((|value_a*| = |value_b*|) /\ $forall_($bin_eq(value_a, value_b)*)) /\ (n_size_a = n_size_b))

    2. Else Phantom#344

  9. Case (% has type structValue)

    1. (Let (struct typeId_a { fieldValue_a* }) be (value as structValue))

    2. If ((value' has type structValue)), then

      1. (Let (struct typeId_b { fieldValue_b* }) be (value' as structValue))

      2. (Let (value_field_a nameIR_field_a ;) be fieldValue_a)*

      3. (Let (value_field_b nameIR_field_b ;) be fieldValue_b)*

      4. Return ((((typeId_a = typeId_b) /\ (|fieldValue_a*| = |fieldValue_b*|)) /\ $forall_($bin_eq(value_field_a, value_field_b)*)) /\ $forall_((nameIR_field_a = nameIR_field_b)*))

    2. Else Phantom#345

  10. Case (% has type headerValue)

    1. (Let (header typeId_a { _bool ; fieldValue_a* }) be (value as headerValue))

    2. If ((value' has type headerValue)), then

      1. (Let (header typeId_b { _bool' ; fieldValue_b* }) be (value' as headerValue))

      2. (Let (value_field_a nameIR_field_a ;) be fieldValue_a)*

      3. (Let (value_field_b nameIR_field_b ;) be fieldValue_b)*

      4. Return ((((typeId_a = typeId_b) /\ (|fieldValue_a*| = |fieldValue_b*|)) /\ $forall_($bin_eq(value_field_a, value_field_b)*)) /\ $forall_((nameIR_field_a = nameIR_field_b)*))

    2. Else Phantom#346

  11. Case (% has type headerUnionValue)

    1. (Let (header_union typeId_a { fieldValue_a* }) be (value as headerUnionValue))

    2. If ((value' has type headerUnionValue)), then

      1. (Let (header_union typeId_b { fieldValue_b* }) be (value' as headerUnionValue))

      2. (Let (value_field_a nameIR_field_a ;) be fieldValue_a)*

      3. (Let (value_field_b nameIR_field_b ;) be fieldValue_b)*

      4. Return ((((typeId_a = typeId_b) /\ (|fieldValue_a*| = |fieldValue_b*|)) /\ $forall_($bin_eq(value_field_a, value_field_b)*)) /\ $forall_((nameIR_field_a = nameIR_field_b)*))

    2. Else Phantom#347

  12. Case (% has type enumValue)

    1. (Let enumValue be (value as enumValue))

    2. Case analysis on enumValue

      1. Case (% matches pattern `% . %`)

        1. (Let (typeId_a . nameIR_field_a) be enumValue)

        2. If ((value' has type enumValue)), then

          1. (Let enumValue' be (value' as enumValue))

          2. If ((enumValue' matches pattern `% . %`)), then

            1. (Let (typeId_b . nameIR_field_b) be enumValue')

            2. Return ((typeId_a = typeId_b) /\ (nameIR_field_a = nameIR_field_b))

          2. Else Phantom#348

        2. Else Phantom#349

      2. Case (% matches pattern `% . % . %`)

        1. (Let (typeId_a . _nameIR . value_field_a) be enumValue)

        2. If ((value' has type enumValue)), then

          1. (Let enumValue' be (value' as enumValue))

          2. If ((enumValue' matches pattern `% . % . %`)), then

            1. (Let (typeId_b . _nameIR' . value_field_b) be enumValue')

            2. Return ((typeId_a = typeId_b) /\ $bin_eq(value_field_a, value_field_b))

          2. Else Phantom#350

        2. Else Phantom#351

  13. Case (% has type invalidHeaderValue)

    1. (Let invalidHeaderValue be (value as invalidHeaderValue))

    2. If ((invalidHeaderValue matches pattern `{#}`)), then

      1. If ((value' has type invalidHeaderValue)), then

        1. (Let invalidHeaderValue' be (value' as invalidHeaderValue))

        2. If ((invalidHeaderValue' matches pattern `{#}`)), then

          1. Return true

        2. Else Phantom#352

      1. Else Phantom#353

    2. Else Phantom#354

1. Else Phantom#355

2. If ((value has type integerValue)), then

  1. (Let integerValue be (value as integerValue))

  2. If ((integerValue matches pattern `% . % V %`)), then

    1. (Let (w_max_a . _nat v i_a) be integerValue)

    2. If ((value' has type integerValue)), then

      1. (Let integerValue' be (value' as integerValue))

      2. If ((integerValue' matches pattern `% . % V %`)), then

        1. (Let (w_max_b . _nat' v i_b) be integerValue')

        2. Return ((w_max_a = w_max_b) /\ (i_a = i_b))

      2. Else Phantom#356

    2. Else Phantom#357

  2. Else Phantom#358

2. Else Phantom#359

;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:448:1-451:23:
dec $bin_ne(value_l, value_r)

