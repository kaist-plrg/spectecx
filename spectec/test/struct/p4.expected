;; ../../../../../spectec/examples/p4-concrete/5-typing/5.04-typing-relation.spectec:398:1-402:40:
relation Table_ok: TC, tableProperty*

1. If ((|$filter_<tableProperty>(tableProperty*, $is_tableKeysProperty(tableProperty)*)| <= 1)), then

  1. If ((|$filter_<tableProperty>(tableProperty*, $is_tableActionsProperty(tableProperty)*)| = 1)), then

    1. Case analysis on |$filter_<tableProperty>(tableProperty*, $is_tableDefaultActionProperty(tableProperty)*)|

      1. Case (% = 0)

        1. (Let TBLC_0 be $empty_tableContext)

        2. (TableProperties_ok: TC TBLC_0 |- tableProperty* : TBLC_1 tablePropertyIR*)

        3. (Let tablePropertyIR_default_action be ((() ?() default_action = ((` "NoAction") ?() ( [] )) ;) as tablePropertyIR))

        4. (Let (TBLC_2, tablePropertyIR_updated*) be $insert_NoAction_tablePropertyIR(TBLC_1, tablePropertyIR*))

        5. Result in TBLC_2, tablePropertyIR_updated* ++ [tablePropertyIR_default_action]

      2. Case (% = 1)

        1. (Let TBLC_0 be $empty_tableContext)

        2. (TableProperties_ok: TC TBLC_0 |- tableProperty* : TBLC_1 tablePropertyIR*)

        3. Result in TBLC_1, tablePropertyIR*

    1. Else Phantom#1254

  1. Else Phantom#1255

1. Else Phantom#1256

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.04-typing-relation.spectec:404:1-408:54:
relation TableType_ok: TC_0, TBLC, name

1. (Let nameIR be $name(name))

2. (Let typeId_enum be "action_list(" ++ nameIR ++ ")")

3. (Let (prefixedNameIR_action ( _parameterIR* @ _argumentListIR ))* be TBLC.actions)

4. (Let nameIR_enum_field be $flatten_prefixedNameIR(prefixedNameIR_action))*

5. (Let tableMetadataEnumTypeIR be (table_enum typeId_enum { nameIR_enum_field* }))

6. (Let value_enum_field be ((table_enum typeId_enum . nameIR_enum_field) as value))*

7. (Let varTypeIR_enum_field be (() (tableMetadataEnumTypeIR as typeIR) (lctk) ?(value_enum_field)))*

8. (Let TC_1 be $add_vars_t((block), TC_0, typeId_enum ++ "." ++ nameIR_enum_field*, varTypeIR_enum_field*))

9. (Let typeId_struct be "apply_result(" ++ nameIR ++ ")")

10. (Let tableMetadataStructTypeIR be (table_struct typeId_struct { hit (bool) ; miss (bool) ; action_run tableMetadataEnumTypeIR ; }))

11. (Let typeIR_table be ((table nameIR { tableMetadataStructTypeIR }) as typeIR))

12. Result in TC_1, typeIR_table

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.04-typing-relation.spectec:410:1-415:40:
relation ControlLocalDecl_ok: TC_0, controlLocalDeclaration

1. Case analysis on controlLocalDeclaration

  1. Case (% has type constantDeclaration)

    1. (Let constantDeclaration be (controlLocalDeclaration as constantDeclaration))

    2. (ConstDecl_ok: (block) TC_0 |- constantDeclaration : TC_1 constantDeclarationIR)

    3. Result in TC_1, (constantDeclarationIR as controlLocalDeclarationIR)

  2. Case (% has type instantiation)

    1. (Let instantiation be (controlLocalDeclaration as instantiation))

    2. (InstDecl_ok: (block) TC_0 |- instantiation : TC_1 instantiationIR)

    3. Result in TC_1, (instantiationIR as controlLocalDeclarationIR)

  3. Case (% has type variableDeclaration)

    1. (Let variableDeclaration be (controlLocalDeclaration as variableDeclaration))

    2. (VarDecl_ok: (block) TC_0 |- variableDeclaration : TC_1 variableDeclarationIR)

    3. Result in TC_1, (variableDeclarationIR as controlLocalDeclarationIR)

  4. Case (% has type actionDeclaration)

    1. (Let actionDeclaration be (controlLocalDeclaration as actionDeclaration))

    2. (ActionDecl_ok: (block) TC_0 |- actionDeclaration : TC_1 actionDeclarationIR)

    3. Result in TC_1, (actionDeclarationIR as controlLocalDeclarationIR)

  5. Case (% has type tableDeclaration)

    1. (Let (annotationList table name { tablePropertyList }) be (controlLocalDeclaration as tableDeclaration))

    2. (Let TC_1 be TC_0[local.kind = ((table_apply_method) as localKind)])

    3. (Let tableProperty* be $flatten_tablePropertyList(tablePropertyList))

    4. (Table_ok: TC_1 |- tableProperty* : TBLC tablePropertyIR*)

    5. (Let nameIR be $name(name))

    6. (TableType_ok: TC_1 TBLC |- name : TC_2 typeIR_table)

    7. (Let varTypeIR be (() typeIR_table (dyn) ?()))

    8. (Let TC_3 be $add_var_t((block), TC_2, nameIR, varTypeIR))

    9. (Let tableDeclarationIR be (annotationList table typeIR_table nameIR { tablePropertyIR* }))

    10. Result in TC_3, (tableDeclarationIR as controlLocalDeclarationIR)

