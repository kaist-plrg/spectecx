    1. (Let (nameIR = typedExpressionIR) be argumentIR)

    2. (Let (_annotationList _direction typeIR_param _id _parameterInitializerOptIR) be parameterIR)

    3. (Let typeIR_arg be $type_of_typedExpressionIR(typedExpressionIR))

    4. Return $gen_constraint(constraint, typeIR_param, typeIR_arg)

