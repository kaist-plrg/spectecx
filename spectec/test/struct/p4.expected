;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:504:1-506:23:
dec $bin_concat(value, value')

1. Case analysis on value

  1. Case (% has type stringLiteral)

    1. (Let (" t_l ") be (value as stringLiteral))

    2. If ((value' has type stringLiteral)), then

      1. (Let (" t_r ") be (value' as stringLiteral))

      2. Return ((" t_l ++ t_r ") as value)

    2. Else Phantom#384

  2. Case (% has type integerLiteral)

    1. (Let integerLiteral be (value as integerLiteral))

    2. Case analysis on integerLiteral

      1. Case (% matches pattern `% W %`)

        1. (Let (w_l w i_l) be integerLiteral)

        2. If ((value' has type integerLiteral)), then

          1. (Let integerLiteral' be (value' as integerLiteral))

          2. Case analysis on integerLiteral'

            1. Case (% matches pattern `% W %`)

              1. (Let (w_r w i_r) be integerLiteral')

              2. (Let i_l' be $shl(i_l, (w_r as int)))

              3. (Let i_l'' be (i_l' + i_r))

              4. (Let w be (w_l + w_r))

              5. (Let i'' be $int_to_bitstr((w as int), i_l''))

              6. Return ((w w i'') as value)

            2. Case (% matches pattern `% S %`)

              1. (Let (w_r s i_r) be integerLiteral')

              2. (Let i_l' be $shl(i_l, (w_r as int)))

              3. (Let i_l'' be (i_l' + i_r))

              4. (Let w be (w_l + w_r))

              5. (Let i'' be $int_to_bitstr((w as int), i_l''))

              6. Return ((w w i'') as value)

          2. Else Phantom#385

        2. Else Phantom#386

      2. Case (% matches pattern `% S %`)

        1. (Let (w_l s i_l) be integerLiteral)

        2. If ((value' has type integerLiteral)), then

          1. (Let integerLiteral' be (value' as integerLiteral))

          2. Case analysis on integerLiteral'

            1. Case (% matches pattern `% W %`)

              1. (Let (w_r w i_r) be integerLiteral')

              2. (Let i_l' be $bitstr_to_int((w_l as int), i_l))

              3. (Let i_l'' be $shl(i_l', (w_r as int)))

              4. (Let i_l''' be (i_l'' + i_r))

              5. (Let w be (w_l + w_r))

              6. (Let i''' be $int_to_bitstr((w as int), i_l'''))

              7. Return ((w s i''') as value)

            2. Case (% matches pattern `% S %`)

              1. (Let (w_r s i_r) be integerLiteral')

              2. (Let i_l' be $bitstr_to_int((w_l as int), i_l))

              3. (Let i_l'' be $shl(i_l', (w_r as int)))

              4. (Let i_l''' be (i_l'' + i_r))

              5. (Let w be (w_l + w_r))

              6. (Let i''' be $int_to_bitstr((w as int), i_l'''))

              7. Return ((w s i''') as value)

          2. Else Phantom#387

        2. Else Phantom#388

    2. Else Phantom#389

1. Else Phantom#390

;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:538:1-540:23:
dec $cast_op(typeIR, value)

1. Case analysis on value

  1. Case (% has type boolValue)

    1. (Let boolValue be (value as boolValue))

    2. (Let typeIR_unroll be $unroll_typeIR(typeIR))

    3. Return $cast_bool(typeIR_unroll, boolValue)

  2. Case (% has type integerValue)

    1. (Let integerValue be (value as integerValue))

    2. (Let typeIR_unroll be $unroll_typeIR(typeIR))

    3. Return $cast_int(typeIR_unroll, integerValue)

  3. Case (% has type errorValue)

    1. (Let errorValue be (value as errorValue))

    2. (Let typeIR_unroll be $unroll_typeIR(typeIR))

    3. Return $cast_error(typeIR_unroll, errorValue)

  4. Case (% has type listValue)

    1. (Let listValue be (value as listValue))

    2. (Let typeIR_unroll be $unroll_typeIR(typeIR))

    3. Return $cast_list(typeIR_unroll, listValue)

  5. Case (% has type headerStackValue)

    1. (Let headerStackValue be (value as headerStackValue))

    2. (Let typeIR_unroll be $unroll_typeIR(typeIR))

    3. Return $cast_header_stack(typeIR_unroll, headerStackValue)

  6. Case (% has type structValue)

    1. (Let structValue be (value as structValue))

    2. (Let typeIR_unroll be $unroll_typeIR(typeIR))

    3. Return $cast_struct(typeIR_unroll, structValue)

  7. Case (% has type headerValue)

    1. (Let headerValue be (value as headerValue))

    2. (Let typeIR_unroll be $unroll_typeIR(typeIR))

    3. Return $cast_header(typeIR_unroll, headerValue)

  8. Case (% has type enumValue)

    1. (Let enumValue be (value as enumValue))

    2. (Let typeIR_unroll be $unroll_typeIR(typeIR))

    3. Return $cast_enum(typeIR_unroll, enumValue)

  9. Case (% has type sequenceValue)

    1. (Let sequenceValue be (value as sequenceValue))

    2. (Let typeIR_unroll be $unroll_typeIR(typeIR))

    3. Return $cast_sequence(typeIR_unroll, sequenceValue)

  10. Case (% has type recordValue)

    1. (Let recordValue be (value as recordValue))

    2. (Let typeIR_unroll be $unroll_typeIR(typeIR))

    3. Return $cast_record(typeIR_unroll, recordValue)

  11. Case (% has type defaultValue)

    1. (Let defaultValue be (value as defaultValue))

    2. If ((defaultValue matches pattern `DEFAULT`)), then

      1. (Let typeIR_unroll be $unroll_typeIR(typeIR))

