syntax typeDeclarationIR = 
   | annotationList enum nameIR { nameListIR } (from enumTypeDeclarationIR)
   | annotationList enum typeIR nameIR { namedValueListIR } (from enumTypeDeclarationIR)
   | annotationList struct nameIR < typeParameterListIR > { typeFieldListIR } (from structTypeDeclarationIR)
   | annotationList header nameIR < typeParameterListIR > { typeFieldListIR } (from headerTypeDeclarationIR)
   | annotationList header_union nameIR < typeParameterListIR > { typeFieldListIR } (from headerUnionTypeDeclarationIR)
   | annotationList typedef typedefIR nameIR ; (from typedefDeclarationIR)
   | annotationList type typeIR nameIR ; (from typedefDeclarationIR)
   | annotationList parser nameIR < typeParameterListIR , typeParameterListIR > ( parameterListIR ) ; (from parserTypeDeclarationIR)
   | annotationList control nameIR < typeParameterListIR , typeParameterListIR > ( parameterListIR ) ; (from controlTypeDeclarationIR)
   | annotationList package nameIR < typeParameterListIR , typeParameterListIR > ( parameterListIR ) ; (from packageTypeDeclarationIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:881:1-890:22:
syntax declarationIR = 
   | annotationList const typeIR nameIR constantInitializerIR ; (from constantDeclarationIR)
   | annotationList typeIR constructorTargetIR ( argumentListIR ) nameIR objectInitializerOptIR ; (from instantiationIR) hint(prose_fields "annotations" "type" "constructor target" "arguments" "name" "object initializer")
   | annotationList functionPrototypeIR blockStatementIR (from functionDeclarationIR)
   | annotationList action nameIR ( parameterListIR ) blockStatementIR (from actionDeclarationIR)
   | error { nameListIR } (from errorDeclarationIR)
   | match_kind { nameListIR } (from matchKindDeclarationIR)
   | annotationList extern functionPrototypeIR ; (from externFunctionDeclarationIR)
   | annotationList extern nameIR < typeParameterListIR , > { externConstructorPrototypeListIR externMethodPrototypeListIR } (from externObjectDeclarationIR)
   | annotationList parser nameIR < typeParameterListIR , typeParameterListIR > ( parameterListIR ) ( constructorParameterListIR ) { parserLocalDeclarationListIR parserStateListIR } (from parserDeclarationIR)
   | annotationList control nameIR < typeParameterListIR , typeParameterListIR > ( parameterListIR ) ( constructorParameterListIR ) { controlLocalDeclarationListIR apply controlBodyIR } (from controlDeclarationIR)
   | annotationList enum nameIR { nameListIR } (from enumTypeDeclarationIR)
   | annotationList enum typeIR nameIR { namedValueListIR } (from enumTypeDeclarationIR)
   | annotationList struct nameIR < typeParameterListIR > { typeFieldListIR } (from structTypeDeclarationIR)
   | annotationList header nameIR < typeParameterListIR > { typeFieldListIR } (from headerTypeDeclarationIR)
   | annotationList header_union nameIR < typeParameterListIR > { typeFieldListIR } (from headerUnionTypeDeclarationIR)
   | annotationList typedef typedefIR nameIR ; (from typedefDeclarationIR)
   | annotationList type typeIR nameIR ; (from typedefDeclarationIR)
   | annotationList parser nameIR < typeParameterListIR , typeParameterListIR > ( parameterListIR ) ; (from parserTypeDeclarationIR)
   | annotationList control nameIR < typeParameterListIR , typeParameterListIR > ( parameterListIR ) ; (from controlTypeDeclarationIR)
   | annotationList package nameIR < typeParameterListIR , typeParameterListIR > ( parameterListIR ) ; (from packageTypeDeclarationIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:896:22-896:39:
syntax p4programIR = 
   | declarationIR* ; (from p4programIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.1-ir-call-helper.spectec:8:1-9:47:
dec $partition_parameterListIR(parameterIR*, _nameIR''*, _nameIR'''*)

1. Case analysis on parameterIR*

  1. Case (% matches pattern [])

    1. Return ([], [], [])

  2. Case (% matches pattern _ :: _)

    1. (Let parameterIR_h :: parameterIR_t* be parameterIR*)

    2. (Let (parameterIR_given*, parameterIR_default*, parameterIR_optional*) be $partition_parameterListIR(parameterIR_t*, _nameIR''*, _nameIR'''*))

    3. (Let (_annotationList _direction _typeIR nameIR_h _parameterInitializerOptIR) be parameterIR_h)

    4. Case analysis on nameIR_h is in _nameIR''*

      1. Case true

        1. Return (parameterIR_given*, parameterIR_h :: parameterIR_default*, parameterIR_optional*)

      2. Case false

        1. If (~nameIR_h is in _nameIR'''*), then

          1. Return (parameterIR_h :: parameterIR_given*, parameterIR_default*, parameterIR_optional*)

        1. Else Phantom#499

    5. If (nameIR_h is in _nameIR'''*), then

      1. Return (parameterIR_given*, parameterIR_default*, parameterIR_h :: parameterIR_optional*)

    5. Else Phantom#500

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.1-ir-call-helper.spectec:55:20-55:59:
syntax callAlign = 
   | given parameterIR* default parameterIR* (from callAlign)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.1-ir-call-helper.spectec:57:1-61:43:
dec $align_parameterListIR(parameterIR*, argumentIR*, nameIR_default*, nameIR_optional*)

1. (Let (parameterIR_given*, parameterIR_default*, parameterIR_optional*) be $partition_parameterListIR(parameterIR*, nameIR_default*, nameIR_optional*))

2. (Let (_annotationList _direction _typeIR nameIR_given _parameterInitializerOptIR) be parameterIR_given)*

3. (Let parameterIR_given_aligned* be $align_parameterListIR_given(({ (nameIR_given : parameterIR_given)* }), parameterIR_given*, argumentIR*))

4. Return (given parameterIR_given_aligned* default parameterIR_default*)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.1-ir-call-helper.spectec:62:1-64:17:
dec $align_parameterListIR_given(({ (id : parameterIR)* }), parameterIR'*, argumentIR*)

1. Case analysis on parameterIR'*

  1. Case (% matches pattern [])

    1. If ((argumentIR* matches pattern [])), then

      1. Return []

    1. Else Phantom#501

  2. Case (% matches pattern _ :: _)

    1. (Let parameterIR_h :: parameterIR_t* be parameterIR'*)

    2. If ((argumentIR* matches pattern _ :: _)), then

      1. (Let argumentIR_h :: argumentIR_t* be argumentIR*)

      2. (Let argumentIR' be argumentIR_h)

      3. If ((argumentIR' has type typedExpressionIR)), then

        1. (Let typedExpressionIR be (argumentIR' as typedExpressionIR))

        2. (Let parameterIR_aligned* be $align_parameterListIR_given(({ (id : parameterIR)* }), parameterIR_t*, argumentIR_t*))

        3. Return parameterIR_h :: parameterIR_aligned*

      3. Else Phantom#502

      4. If ((argumentIR_h matches pattern `_`)), then

        1. (Let parameterIR_aligned* be $align_parameterListIR_given(({ (id : parameterIR)* }), parameterIR_t*, argumentIR_t*))

        2. Return parameterIR_h :: parameterIR_aligned*

      4. Else Phantom#503

      5. Case analysis on argumentIR'

        1. Case (% matches pattern `% = %`)

          1. (Let (nameIR = _typedExpressionIR) be argumentIR')

          2. (Let parameterIR''? be $find_map<id, parameterIR>(({ (id : parameterIR)* }), nameIR))

          3. If ((parameterIR''? matches pattern (_))), then

            1. (Let ?(parameterIR_match) be parameterIR''?)

            2. (Let parameterIR_aligned* be $align_parameterListIR_given(({ (id : parameterIR)* }), parameterIR_t*, argumentIR_t*))

            3. Return parameterIR_match :: parameterIR_aligned*

          3. Else Phantom#504

        2. Case (% matches pattern `% = _`)

          1. (Let (nameIR = _) be argumentIR')

          2. (Let parameterIR''? be $find_map<id, parameterIR>(({ (id : parameterIR)* }), nameIR))

          3. If ((parameterIR''? matches pattern (_))), then

            1. (Let ?(parameterIR_match) be parameterIR''?)

            2. (Let parameterIR_aligned* be $align_parameterListIR_given(({ (id : parameterIR)* }), parameterIR_t*, argumentIR_t*))

            3. Return parameterIR_match :: parameterIR_aligned*

          3. Else Phantom#505

      5. Else Phantom#506

    2. Else Phantom#507

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.2-ir-call-overload.spectec:5:24-5:40:
syntax callTargetKey = 
   | nameIR ( id?* ) (from callTargetKey)

