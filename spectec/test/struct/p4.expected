;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.0-domain.spectec:93:1-95:69:
dec $objectId_ends_with(objectId, nameIR)

1. (Let nameIR''* be $rev_<id>(objectId))

2. If ((nameIR''* matches pattern _ :: _)), then

  1. (Let nameIR' :: _nameIR* be nameIR''*)

  2. If ((nameIR' = nameIR)), then

    1. Return true

3. Otherwise

  1. Return false

