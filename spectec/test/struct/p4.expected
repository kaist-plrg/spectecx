;; ../../../../../spectec/examples/p4-concrete/5-typing/5.06.1-typing-expression.spectec:1059:1-1061:63:
dec $is_valid_bitslice(typeIR'', n_lo', n_hi')

1. Case analysis on typeIR''

  1. Case (% has type intTypeIR)

    1. (Let intTypeIR be (typeIR'' as intTypeIR))

    2. If ((intTypeIR matches pattern `INT`)), then

      1. Return (n_lo' <= n_hi')

  2. Case (% has type fixedIntTypeIR)

    1. (Let (int < w >) be (typeIR'' as fixedIntTypeIR))

    2. (Let w_slice be ((n_hi' - n_lo') + 1))

    3. Return (((n_lo' <= n_hi') /\ (n_hi' <= w)) /\ (w_slice <= w))

  3. Case (% has type fixedBitTypeIR)

    1. (Let (bit < w >) be (typeIR'' as fixedBitTypeIR))

    2. (Let w_slice be ((n_hi' - n_lo') + 1))

    3. Return (((n_lo' <= n_hi') /\ (n_hi' <= w)) /\ (w_slice <= w))

  4. Case (% has type typedefTypeIR)

    1. (Let (typedef _typeId typeIR'') be (typeIR'' as typedefTypeIR))

    2. Return $is_valid_bitslice(typeIR'', n_lo', n_hi')

2. Otherwise

  1. Return false

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.06.1-typing-expression.spectec:1316:1-1318:79:
dec $is_concrete_extern_object(typeIR)

1. Return $is_concrete_extern_object'($unroll_typeIR(typeIR))

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.06.1-typing-expression.spectec:1319:1-1319:47:
dec $is_concrete_extern_object'(typeIR)

1. Case analysis on (typeIR has type externObjectTypeIR)

  1. Case false

    1. Return true

  2. Case true

    1. (Let (extern _typeId < _typeArgumentIR* > ({ (_callableId : externMethodTypeDefIR)* })) be (typeIR as externObjectTypeIR))

    2. If ($is_concrete_extern_object''(externMethodTypeDefIR))*, then

      1. Return true

2. Otherwise

  1. Return false

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.06.1-typing-expression.spectec:1320:1-1320:63:
dec $is_concrete_extern_object''(externMethodTypeDefIR)

1. If ((externMethodTypeDefIR matches pattern `EXTERN_METHOD % <% , %> (%) : %`)), then

  1. (Let (extern_method _nameIR < _typeParameterIR* , _typeParameterIR'* > ( _parameterIR* ) : _typeIR) be externMethodTypeDefIR)

  2. Return true

2. Otherwise

  1. Return false

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.09-typing-parameter.spectec:82:1-85:23:
relation ParameterList_ok_inner: p, TC', parameter*

1. Case analysis on parameter*

  1. Case (% matches pattern [])

    1. Result in TC', [], []

  2. Case (% matches pattern _ :: _)

    1. (Let parameter_h :: parameter_t* be parameter*)

    2. (Parameter_ok: p TC' |- parameter_h : TC_1 parameterIR_h # typeId_fresh_h*)

    3. (ParameterList_ok_inner: p TC_1 |- parameter_t* : TC_2 parameterIR_t* # typeId_fresh_t*)

    4. (Let parameterIR* be parameterIR_h :: parameterIR_t*)

    5. (Let typeId_fresh* be typeId_fresh_h* ++ typeId_fresh_t*)

    6. Result in TC_2, parameterIR*, typeId_fresh*

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.10-typing-statement.spectec:253:1-257:21:
relation ForUpdateStmt_ok: TC, forUpdateStatement

1. Case analysis on forUpdateStatement

  1. Case (% matches pattern `% (%)`)

    1. (Let (lvalue_callable ( argumentList )) be forUpdateStatement)

    2. (Stmt_ok: (local) TC (cont) (noloop) |- ((lvalue_callable ( argumentList ) ;) as statement) : _typingContext _flow statementIR)

    3. If ((statementIR has type callStatementIR)), then

      1. (Let (callableTargetIR < typeArgumentIR* > ( argumentIR* ) ;) be (statementIR as callStatementIR))

      2. Result in (callableTargetIR < typeArgumentIR* > ( argumentIR* ))

    3. Else Phantom#1489

  2. Case (% matches pattern `% <%> (%)`)

    1. (Let (lvalue_callable < typeArgumentList > ( argumentList )) be forUpdateStatement)

    2. (Stmt_ok: (local) TC (cont) (noloop) |- ((lvalue_callable < typeArgumentList > ( argumentList ) ;) as statement) : _typingContext _flow statementIR)

    3. If ((statementIR has type callStatementIR)), then

      1. (Let (callableTargetIR < typeArgumentIR* > ( argumentIR* ) ;) be (statementIR as callStatementIR))

      2. Result in (callableTargetIR < typeArgumentIR* > ( argumentIR* ))

    3. Else Phantom#1490

  3. Case (% matches pattern `% % %`)

    1. (Let (lvalue assignop expression) be forUpdateStatement)

    2. (Stmt_ok: (local) TC (cont) (noloop) |- ((lvalue assignop expression ;) as statement) : _typingContext _flow statementIR)

    3. If ((statementIR has type assignmentStatementIR)), then

      1. (Let (typedLvalueIR assignop' typedExpressionIR ;) be (statementIR as assignmentStatementIR))

      2. If ((assignop' = assignop)), then

        1. Result in (typedLvalueIR assignop typedExpressionIR)

      2. Else Phantom#1491

    3. Else Phantom#1492

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.10-typing-statement.spectec:289:1-293:21:
relation ForUpdateStmtList_ok: TC, forUpdateStatementList

1. (Let forUpdateStatement* be $flatten_forUpdateStatementList(forUpdateStatementList))

2. (ForUpdateStmt_ok: TC |- forUpdateStatement : forUpdateStatementIR)*

3. Result in forUpdateStatementIR*

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.10-typing-statement.spectec:304:1-308:40:
relation ForInitStmt_ok: TC_0', forInitStatement

1. If ((forInitStatement matches pattern `% % % %`)), then

  1. (Let (annotationList type name initializerOpt) be forInitStatement)

  2. If ((initializerOpt matches pattern ``EMPTY`)), then

    1. (Type_ok: (local) TC_0' |- (type as typeOrVoid) : typeIR # typeId*)

    2. If ((typeId* matches pattern [])), then

      1. If (Type_wf: $bound((local), TC_0') |- typeIR holds), then

        1. If ($is_assignable_typeIR(typeIR)), then

          1. (Let nameIR be $name(name))

          2. (Let TC_1 be $add_var_t((local), TC_0', nameIR, ((inout) typeIR (dyn) ?())))

          3. Result in TC_1, (annotationList typeIR nameIR ?())

        1. Else Phantom#1493

      1. Else Phantom#1494

    2. Else Phantom#1495

  2. Else Phantom#1496

  3. If ((initializerOpt has type initializer)), then

    1. (Let (= expression_init) be (initializerOpt as initializer))

    2. (Type_ok: (local) TC_0' |- (type as typeOrVoid) : typeIR # typeId*)

    3. If ((typeId* matches pattern [])), then

      1. If (Type_wf: $bound((local), TC_0') |- typeIR holds), then

        1. If ($is_assignable_typeIR(typeIR)), then

          1. (Expr_ok: (local) TC_0' |- expression_init : typedExpressionIR_init)

          2. (Let typedExpressionIR? be $cast_unary(typedExpressionIR_init, typeIR))

          3. If ((typedExpressionIR? matches pattern (_))), then

            1. (Let ?(typedExpressionIR_init_cast) be typedExpressionIR?)

            2. (Let nameIR be $name(name))

            3. (Let TC_1 be $add_var_t((local), TC_0', nameIR, ((inout) typeIR (dyn) ?())))

            4. Result in TC_1, (annotationList typeIR nameIR ?((= typedExpressionIR_init_cast)))

          3. Else Phantom#1497

        1. Else Phantom#1498

      1. Else Phantom#1499

    3. Else Phantom#1500

  3. Else Phantom#1501

1. Else Phantom#1502

2. If ((forInitStatement has type forUpdateStatement)), then

  1. (Let forUpdateStatement be (forInitStatement as forUpdateStatement))

  2. (ForUpdateStmt_ok: TC_0' |- forUpdateStatement : forUpdateStatementIR)

  3. Result in TC_0', (forUpdateStatementIR as forInitStatementIR)

2. Else Phantom#1503

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.10-typing-statement.spectec:351:1-353:20:
relation ForInitStmts_ok: TC', forInitStatement*

1. Case analysis on forInitStatement*

  1. Case (% matches pattern [])

    1. Result in TC', []

  2. Case (% matches pattern _ :: _)

    1. (Let forInitStatement_h :: forInitStatement_t* be forInitStatement*)

    2. (ForInitStmt_ok: TC' |- forInitStatement_h : TC_1 forInitStatementIR_h)

    3. (ForInitStmts_ok: TC_1 |- forInitStatement_t* : TC_2 forInitStatementIR_t*)

    4. Result in TC_2, forInitStatementIR_h :: forInitStatementIR_t*

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.10-typing-statement.spectec:368:1-372:40:
relation ForInitStmtList_ok: TC_0, forInitStatementList

1. (Let forInitStatement* be $flatten_forInitStatementList(forInitStatementList))

2. (ForInitStmts_ok: TC_0 |- forInitStatement* : TC_1 forInitStatementIR*)

3. Result in TC_1, forInitStatementIR*

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.10-typing-statement.spectec:415:1-419:21:
relation ForCollectionExpr_ok: TC, typeIR_var, forCollectionExpression

1. If ((forCollectionExpression has type expression)), then

  1. (Let expression be (forCollectionExpression as expression))

  2. (Expr_ok: (local) TC |- expression : typedExpressionIR)

  3. (Let typeIR_expression be $type_of_typedExpressionIR(typedExpressionIR))

  4. (Let typeIR be $unroll_typeIR(typeIR_expression))

  5. Case analysis on typeIR

    1. Case (% has type listTypeIR)

      1. (Let (list < typeIR_e >) be (typeIR as listTypeIR))

      2. If (Cast_impl: typeIR_e -> typeIR_var holds), then

        1. Result in (typedExpressionIR as forCollectionExpressionIR)

      2. Else Phantom#1504

    2. Case (% has type headerStackTypeIR)

      1. (Let (typeIR_e [ _nat ]) be (typeIR as headerStackTypeIR))

      2. If (Type_alpha: typeIR_e ~~ typeIR_var holds), then

        1. Result in (typedExpressionIR as forCollectionExpressionIR)

      2. Else Phantom#1505

  5. Else Phantom#1506

1. Else Phantom#1507

2. If ((forCollectionExpression matches pattern `% .. %`)), then

  1. (Let (expression_l .. expression_r) be forCollectionExpression)

  2. (Expr_ok: (local) TC |- expression_l : typedExpressionIR_l)

  3. (Expr_ok: (local) TC |- expression_r : typedExpressionIR_r)

  4. (Let typedExpressionIR? be $cast_unary(typedExpressionIR_l, typeIR_var))

  5. If ((typedExpressionIR? matches pattern (_))), then

    1. (Let ?(typedExpressionIR_l_casted) be typedExpressionIR?)

    2. (Let typedExpressionIR'? be $cast_unary(typedExpressionIR_r, typeIR_var))

    3. If ((typedExpressionIR'? matches pattern (_))), then

      1. (Let ?(typedExpressionIR_r_casted) be typedExpressionIR'?)

      2. (Let typeIR_l be $type_of_typedExpressionIR(typedExpressionIR_l_casted))

      3. (Let typeIR_r be $type_of_typedExpressionIR(typedExpressionIR_r_casted))

      4. If ($compat_range(typeIR_l, typeIR_r)), then

        1. Result in (typedExpressionIR_l_casted .. typedExpressionIR_r_casted)

      4. Else Phantom#1508

    3. Else Phantom#1509

  5. Else Phantom#1510

2. Else Phantom#1511

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.10-typing-statement.spectec:421:1-423:65:
dec $compat_range(typeIR'', typeIR''')

1. Case analysis on typeIR''

  1. Case (% has type intTypeIR)

    1. (Let intTypeIR be (typeIR'' as intTypeIR))

    2. If ((intTypeIR matches pattern `INT`)), then

      1. If ((typeIR''' has type intTypeIR)), then

        1. (Let intTypeIR' be (typeIR''' as intTypeIR))

        2. If ((intTypeIR' matches pattern `INT`)), then

          1. Return true

        2. Else Phantom#1512

      1. Else Phantom#1513

