    4. (Let argumentIR_action_data* be argumentIR_action*[0 : |parameterIR_action_data*|])

    5. (Let argumentIR_cast_data* be argumentIR_cast*[0 : |parameterIR_action_data*|])

    6. If ((argumentIR_action_data = argumentIR_cast_data))*, then

      1. Result in (prefixedNameIR ?() ( argumentIR_cast* ))

    6. Else Phantom#1233

  4. Else Phantom#1234

2. Else Phantom#1235

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.04-typing-relation.spectec:374:1-378:21:
relation TableEntry_priority_ok: TC, tableEntryPriority

1. Case analysis on tableEntryPriority

