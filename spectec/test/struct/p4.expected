dec $replace_text_except'(n_len'', n_len''', t, t_old, t_new)

1. If ((n_len'' = n_len''')), then

  1. Return t

1. Else Phantom#5

2. If ((n_len'' < n_len''')), then

  1. (Let t_replaced be $ite<text>((t[n_len''] = t_old), t, t[[n_len''] = t_new]))

  2. Return $replace_text_except'((n_len'' + 1), n_len''', t_replaced, t_old, t_new)

2. Else Phantom#6

