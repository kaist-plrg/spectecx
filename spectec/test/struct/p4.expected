  3. Result in value

2. Else Phantom#818

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.04-typing-relation.spectec:32:1-36:51:
relation Type_ok: p, TC, typeOrVoid

1. If ((typeOrVoid matches pattern `VOID`)), then

  1. Result in ((void) as typeIR), []

1. Else Phantom#819

2. Case analysis on typeOrVoid

  1. Case (% has type baseType)

    1. (Let baseType be (typeOrVoid as baseType))

    2. Case analysis on baseType

      1. Case (% matches pattern `BOOL`)

        1. Result in ((bool) as typeIR), []

      2. Case (% matches pattern `ERROR`)

        1. Result in ((error) as typeIR), []

      3. Case (% matches pattern `MATCH_KIND`)

        1. Result in ((match_kind) as typeIR), []

      4. Case (% matches pattern `STRING`)

        1. Result in ((string) as typeIR), []

      5. Case (% matches pattern `INT`)

        1. Result in ((int) as typeIR), []

      6. Case (% matches pattern `INT <%>`)

        1. (Let (int < int >) be baseType)

        2. If ((int has type nat)), then

          1. (Let n be (int as nat))

          2. If ((n > 0)), then

            1. Result in ((int < n >) as typeIR), []

          2. Else Phantom#820

        2. Else Phantom#821

      7. Case (% matches pattern `INT <(%)>`)

        1. (Let (int < ( expression ) >) be baseType)

        2. (Expr_ok: p TC |- expression : typedExpressionIR)

        3. If (((lctk) = $ctk_of_typedExpressionIR(typedExpressionIR))), then

          1. (Expr_eval_lctk: p TC |- typedExpressionIR ~> value)

          2. If ((value has type integerValue)), then

            1. (Let integerValue be (value as integerValue))

            2. (Let nat? be $nat_of_integerValue(integerValue))

            3. If ((nat? matches pattern (_))), then

              1. (Let ?(n) be nat?)

              2. If ((n > 0)), then

                1. Result in ((int < n >) as typeIR), []

              2. Else Phantom#822

            3. Else Phantom#823

          2. Else Phantom#824

        3. Else Phantom#825

      8. Case (% matches pattern `BIT`)

        1. Result in ((bit < 1 >) as typeIR), []

      9. Case (% matches pattern `BIT <%>`)

        1. (Let (bit < int >) be baseType)

        2. If ((int has type nat)), then

          1. (Let n be (int as nat))

          2. Result in ((bit < n >) as typeIR), []

        2. Else Phantom#826

      10. Case (% matches pattern `BIT <(%)>`)

        1. (Let (bit < ( expression ) >) be baseType)

        2. (Expr_ok: p TC |- expression : typedExpressionIR)

        3. If (((lctk) = $ctk_of_typedExpressionIR(typedExpressionIR))), then

          1. (Expr_eval_lctk: p TC |- typedExpressionIR ~> value)

          2. If ((value has type integerValue)), then

            1. (Let integerValue be (value as integerValue))

            2. (Let nat? be $nat_of_integerValue(integerValue))

            3. If ((nat? matches pattern (_))), then

              1. (Let ?(n) be nat?)

              2. Result in ((bit < n >) as typeIR), []

            3. Else Phantom#827

          2. Else Phantom#828

        3. Else Phantom#829

      11. Case (% matches pattern `VARBIT <%>`)

        1. (Let (varbit < int >) be baseType)

        2. If ((int has type nat)), then

          1. (Let n be (int as nat))

          2. Result in ((varbit < n >) as typeIR), []

        2. Else Phantom#830

      12. Case (% matches pattern `VARBIT <(%)>`)

        1. (Let (varbit < ( expression ) >) be baseType)

        2. (Expr_ok: p TC |- expression : typedExpressionIR)

        3. If (((lctk) = $ctk_of_typedExpressionIR(typedExpressionIR))), then

          1. (Expr_eval_lctk: p TC |- typedExpressionIR ~> value)

          2. If ((value has type integerValue)), then

            1. (Let integerValue be (value as integerValue))

            2. (Let nat? be $nat_of_integerValue(integerValue))

            3. If ((nat? matches pattern (_))), then

              1. (Let ?(n) be nat?)

              2. Result in ((varbit < n >) as typeIR), []

            3. Else Phantom#831

          2. Else Phantom#832

        3. Else Phantom#833

  2. Case (% has type identifier)

    1. (Let (typeId) be (typeOrVoid as identifier))

    2. (Type_ok: p TC |- ((typeId) as typeOrVoid) : typeIR # typeId_fresh*)

    3. Result in typeIR, typeId_fresh*

  3. Case (% has type prefixedTypeName)

    1. (Let prefixedTypeName be (typeOrVoid as prefixedTypeName))

    2. (Let prefixedNameIR be $prefixedTypeName(prefixedTypeName))

    3. (Let typeDefIR'? be $find_typeDef_t(p, TC, prefixedNameIR))

    4. If ((typeDefIR'? matches pattern (_))), then

      1. (Let ?(typeDefIR) be typeDefIR'?)

      2. Case analysis on $is_monomorphic_typeDefIR(typeDefIR)

        1. Case true

          1. (Let typeIR be $typeIR_of_typeDefIR(typeDefIR))

          2. Result in typeIR, []

        2. Case false

          1. (Let typeIR be $specialize_typeDefIR(typeDefIR, []))

          2. Result in typeIR, []

    4. Else Phantom#834

  4. Case (% has type specializedType)

    1. (Let (prefixedTypeName < typeArgumentList >) be (typeOrVoid as specializedType))

    2. (Let prefixedNameIR be $prefixedTypeName(prefixedTypeName))

    3. (Let typeDefIR'? be $find_typeDef_t(p, TC, prefixedNameIR))

    4. If ((typeDefIR'? matches pattern (_))), then

      1. (Let ?(typeDefIR) be typeDefIR'?)

      2. If ($is_polymorphic_typeDefIR(typeDefIR)), then

        1. (TypeArgumentList_ok: p TC |- typeArgumentList : typeIR_arg* # typeId_fresh*)

        2. (Let typeIR be $specialize_typeDefIR(typeDefIR, typeIR_arg*))

        3. Result in typeIR, typeId_fresh*

      2. Else Phantom#835

    4. Else Phantom#836

  5. Case (% has type headerStackType)

    1. (Let (namedType [ expression_size ]) be (typeOrVoid as headerStackType))

    2. (Type_ok: p TC |- (namedType as typeOrVoid) : typeIR_base # typeId_fresh*)

    3. (Expr_ok: p TC |- expression_size : typedExpressionIR_size)

    4. If (((lctk) = $ctk_of_typedExpressionIR(typedExpressionIR_size))), then

      1. (Expr_eval_lctk: p TC |- typedExpressionIR_size ~> value)

      2. If ((value has type integerValue)), then

        1. (Let integerValue_size be (value as integerValue))

        2. (Let nat? be $nat_of_integerValue(integerValue_size))

        3. If ((nat? matches pattern (_))), then

          1. (Let ?(n_size) be nat?)

          2. If ((n_size > 0)), then

            1. Result in ((typeIR_base [ n_size ]) as typeIR), typeId_fresh*

          2. Else Phantom#837

        3. Else Phantom#838

      2. Else Phantom#839

    4. Else Phantom#840

  6. Case (% has type listType)

    1. (Let (list < typeArgument >) be (typeOrVoid as listType))

    2. (TypeArgument_ok: p TC |- typeArgument : typeIR_arg # typeId_fresh*)

    3. Result in ((list < typeIR_arg >) as typeIR), typeId_fresh*

  7. Case (% has type tupleType)

    1. (Let (tuple < typeArgumentList >) be (typeOrVoid as tupleType))

    2. (TypeArgumentList_ok: p TC |- typeArgumentList : typeIR_arg* # typeId_fresh*)

    3. Result in ((tuple < typeIR_arg* >) as typeIR), typeId_fresh*

2. Else Phantom#841

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.04-typing-relation.spectec:38:1-42:56:
relation TypeParameterListOpt_ok: p, TC_0, typeParameterListOpt

1. (Let typeParameter* be $flatten_typeParameterListOpt(typeParameterListOpt))

2. (Let typeId be $name(typeParameter))*

3. (Let TC_1 be $add_typeParameters_t(p, TC_0, typeId*))

4. Result in TC_1, typeId*

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.04-typing-relation.spectec:44:1-48:51:
relation TypeArgument_ok: p, TC, typeArgument

1. Case analysis on typeArgument

  1. Case (% has type type)

    1. (Let type be (typeArgument as type))

    2. (Type_ok: p TC |- (type as typeOrVoid) : typeIR # typeId_impl*)

    3. Result in typeIR, typeId_impl*

  2. Case (% has type nonTypeName)

    1. (Let nonTypeName be (typeArgument as nonTypeName))

    2. (Let typeId be $name((nonTypeName as name)))

    3. Result in ((` typeId) as typeIR), []

1. Else Phantom#842

2. If ((typeArgument has type realTypeArgument)), then

  1. (Let realTypeArgument be (typeArgument as realTypeArgument))

  2. Case analysis on realTypeArgument

    1. Case (% matches pattern `VOID`)

      1. Result in ((void) as typeIR), []

    2. Case (% matches pattern `_`)

      1. (Let typeId_impl be $fresh_typeId)

      2. Result in ((` typeId_impl) as typeIR), [typeId_impl]

  2. Else Phantom#843

2. Else Phantom#844

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.04-typing-relation.spectec:50:1-54:51:
relation TypeArguments_ok: p, TC, typeArgument*

1. Case analysis on typeArgument*

  1. Case (% matches pattern [])

    1. Result in [], []

  2. Case (% matches pattern _ :: _)

    1. (Let typeArgument_h :: typeArgument_t* be typeArgument*)

    2. (TypeArgument_ok: p TC |- typeArgument_h : typeArgumentIR_h # typeId_impl_h*)

    3. (TypeArguments_ok: p TC |- typeArgument_t* : typeArgumentIR_t* # typeId_impl_t*)

    4. (Let typeId_impl* be typeId_impl_h* ++ typeId_impl_t*)

    5. Result in typeArgumentIR_h :: typeArgumentIR_t*, typeId_impl*

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.04-typing-relation.spectec:56:1-60:51:
relation TypeArgumentList_ok: p, TC, typeArgumentList

1. (Let typeArgument* be $flatten_typeArgumentList(typeArgumentList))

2. (TypeArguments_ok: p TC |- typeArgument* : typeArgumentIR* # typeId_impl*)

3. Result in typeArgumentIR*, typeId_impl*

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.04-typing-relation.spectec:66:1-69:57:
relation Cast_expl: typeIR_a, typeIR_b

1. (Let typeIR_a_unroll be $unroll_typeIR(typeIR_a))

2. (Let typeIR_b_unroll be $unroll_typeIR(typeIR_b))

3. If (Type_alpha: typeIR_a_unroll ~~ typeIR_b_unroll holds), then

  1. The relation holds

3. Else Phantom#845

4. If (Type_alpha: typeIR_a_unroll ~~ typeIR_b_unroll does not hold), then

  1. If (Cast_expl_neq: typeIR_a_unroll -> typeIR_b_unroll holds), then

    1. The relation holds

  1. Else Phantom#846

4. Else Phantom#847

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.04-typing-relation.spectec:70:1-73:74:
relation Cast_expl_neq: typeIR''''', typeIR''''''

1. Case analysis on typeIR'''''

  1. Case (% has type boolTypeIR)

    1. (Let boolTypeIR be (typeIR''''' as boolTypeIR))

    2. If ((boolTypeIR matches pattern `BOOL`)), then

      1. If ((typeIR'''''' = ((bit < 1 >) as typeIR))), then

        1. The relation holds

      1. Else Phantom#848

    2. Else Phantom#849

  2. Case (% has type intTypeIR)

    1. (Let intTypeIR be (typeIR''''' as intTypeIR))

    2. If ((intTypeIR matches pattern `INT`)), then

      1. Case analysis on typeIR''''''

        1. Case (% has type boolTypeIR)

          1. (Let boolTypeIR be (typeIR'''''' as boolTypeIR))

          2. If ((boolTypeIR matches pattern `BOOL`)), then

            1. The relation holds

          2. Else Phantom#850

        2. Case (% has type fixedIntTypeIR)

          1. (Let (int < _nat >) be (typeIR'''''' as fixedIntTypeIR))

          2. The relation holds

        3. Case (% has type fixedBitTypeIR)

          1. (Let (bit < _nat >) be (typeIR'''''' as fixedBitTypeIR))

