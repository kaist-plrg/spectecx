   | control < typeParameterListIR > ( parameterListIR ) ( constructorParameterListIR ) { controlLocalDeclarationListIR apply controlBodyIR } (from controlObjectConstructorDef)

;; ../../../../../spectec/examples/p4-concrete/6-dynamic-runtime/6.3.1-constructor-def.spectec:25:3-26:36:
syntax packageObjectConstructorDef = 
   | package < typeParameterListIR > ( constructorParameterListIR ) (from packageObjectConstructorDef)

;; ../../../../../spectec/examples/p4-concrete/6-dynamic-runtime/6.3.1-constructor-def.spectec:29:1-32:32:
syntax constructorDef = 
   | extern nameIR < typeParameterListIR > ( constructorParameterListIR ) { externMethodPrototypeListIR } (from externObjectConstructorDef)
   | parser < typeParameterListIR > ( parameterListIR ) ( constructorParameterListIR ) { parserLocalDeclarationListIR parserStateListIR } (from parserObjectConstructorDef)
   | control < typeParameterListIR > ( parameterListIR ) ( constructorParameterListIR ) { controlLocalDeclarationListIR apply controlBodyIR } (from controlObjectConstructorDef)
   | package < typeParameterListIR > ( constructorParameterListIR ) (from packageObjectConstructorDef)

;; ../../../../../spectec/examples/p4-concrete/6-dynamic-runtime/6.3.2-constructor-def-aux.spectec:5:1-6:17:
dec $parameterListIR_of_constructorDef(constructorDef)

1. Case analysis on constructorDef

  1. Case (% has type externObjectConstructorDef)

    1. (Let (extern _nameIR < _typeParameterListIR > ( constructorParameterListIR ) { _externMethodPrototypeListIR }) be (constructorDef as externObjectConstructorDef))

    2. Return constructorParameterListIR

  2. Case (% has type parserObjectConstructorDef)

    1. (Let (parser < _typeParameterListIR > ( _parameterListIR ) ( constructorParameterListIR ) { _parserLocalDeclarationListIR _parserStateListIR }) be (constructorDef as parserObjectConstructorDef))

    2. Return constructorParameterListIR

  3. Case (% has type controlObjectConstructorDef)

    1. (Let (control < _typeParameterListIR > ( _parameterListIR ) ( constructorParameterListIR ) { _controlLocalDeclarationListIR apply _controlBodyIR }) be (constructorDef as controlObjectConstructorDef))

    2. Return constructorParameterListIR

  4. Case (% has type packageObjectConstructorDef)

    1. (Let (package < _typeParameterListIR > ( constructorParameterListIR )) be (constructorDef as packageObjectConstructorDef))

    2. Return constructorParameterListIR

