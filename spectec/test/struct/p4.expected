;; ../../../../../spectec/examples/p4-concrete/6-dynamic-runtime/6.2.2-callable-def-aux.spectec:29:1-30:17:
dec $parameterListIR_of_externFunctionDef((extern_function _nameIR < _typeParameterListIR > ( parameterListIR )))

1. Return parameterListIR

;; ../../../../../spectec/examples/p4-concrete/6-dynamic-runtime/6.2.2-callable-def-aux.spectec:45:1-46:17:
dec $parameterListIR_of_methodDef(methodDef)

1. Case analysis on methodDef

  1. Case (% has type externMethodDef)

    1. (Let externMethodDef be (methodDef as externMethodDef))

    2. Return $parameterListIR_of_externMethodDef(externMethodDef)

  2. Case (% has type parserApplyMethodDef)

    1. (Let parserApplyMethodDef be (methodDef as parserApplyMethodDef))

    2. Return $parameterListIR_of_parserApplyMethodDef(parserApplyMethodDef)

  3. Case (% has type controlApplyMethodDef)

    1. (Let controlApplyMethodDef be (methodDef as controlApplyMethodDef))

    2. Return $parameterListIR_of_controlApplyMethodDef(controlApplyMethodDef)

  4. Case (% has type tableApplyMethodDef)

    1. (Let tableApplyMethodDef be (methodDef as tableApplyMethodDef))

    2. Return $parameterListIR_of_tableApplyMethodDef(tableApplyMethodDef)

;; ../../../../../spectec/examples/p4-concrete/6-dynamic-runtime/6.2.2-callable-def-aux.spectec:48:1-49:17:
dec $parameterListIR_of_externMethodDef(externMethodDef)

1. If ((externMethodDef matches pattern `EXTERN_METHOD % <%> (%) %`)), then

  1. (Let (extern_method _nameIR < _typeParameterListIR > ( parameterListIR ) _blockStatementIR?) be externMethodDef)

  2. Return parameterListIR

1. Else Phantom#1673

;; ../../../../../spectec/examples/p4-concrete/6-dynamic-runtime/6.2.2-callable-def-aux.spectec:54:1-55:17:
dec $parameterListIR_of_parserApplyMethodDef((parser_apply ( parameterListIR ) { _parserLocalDeclarationListIR ; _stateEnv }))

1. Return parameterListIR

;; ../../../../../spectec/examples/p4-concrete/6-dynamic-runtime/6.2.2-callable-def-aux.spectec:60:1-61:17:
dec $parameterListIR_of_controlApplyMethodDef((control_apply ( parameterListIR ) { _controlLocalDeclarationListIR ; _actionDefEnv ; _controlBodyIR }))

1. Return parameterListIR

;; ../../../../../spectec/examples/p4-concrete/6-dynamic-runtime/6.2.2-callable-def-aux.spectec:66:1-67:17:
dec $parameterListIR_of_tableApplyMethodDef((table_apply { _tablePropertyListIR }))

1. Return []

;; ../../../../../spectec/examples/p4-concrete/6-dynamic-runtime/6.2.3-callable-callee.spectec:10:3-11:49:
syntax actionCallee = 
   | action cursor . nameIR ( parameterListIR # id* ) blockStatementIR (from actionCallee)

;; ../../../../../spectec/examples/p4-concrete/6-dynamic-runtime/6.2.3-callable-callee.spectec:18:3-19:49:
syntax definedFunctionCallee = 
