dec $concat_text(text*)

1. Case analysis on text*

  1. Case (% matches pattern [])

    1. Return ""

  2. Case (% matches pattern _ :: _)

    1. (Let t_h :: t_t* be text*)

    2. Return t_h ++ $concat_text(t_t*)

;; ../../../../../spectec/examples/p4-concrete/0-aux/0.0-stdlib.spectec:62:1-63:64:
dec $join_text(text''*, t_sep)

1. Case analysis on text''*

  1. Case (% matches pattern [])

    1. Return ""

  2. Case (% matches pattern [ _/1 ])

    1. (Let [t_h] be text''*)

    2. Return t_h

  3. Case (% matches pattern _ :: _)

    1. (Let t_h1 :: text''* be text''*)

    2. If ((text''* matches pattern _ :: _)), then

      1. (Let t_h2 :: t_t* be text''*)

      2. Return t_h1 ++ t_sep ++ $join_text(t_h2 :: t_t*, t_sep)

    2. Else Phantom#1

1. Else Phantom#2

;; ../../../../../spectec/examples/p4-concrete/0-aux/0.0-stdlib.spectec:69:1-70:77:
dec $replace_text(t, t_old, t_new)

1. Return $replace_text'(0, |t|, t, t_old, t_new)

;; ../../../../../spectec/examples/p4-concrete/0-aux/0.0-stdlib.spectec:71:1-71:54:
dec $replace_text'(n_len'', n_len''', t, t_old, t_new)

1. If ((n_len'' = n_len''')), then

  1. Return t

1. Else Phantom#3

2. If ((n_len'' < n_len''')), then

  1. (Let t_replaced be $ite<text>((t[n_len''] = t_old), t[[n_len''] = t_new], t))

  2. Return $replace_text'((n_len'' + 1), n_len''', t_replaced, t_old, t_new)

2. Else Phantom#4

;; ../../../../../spectec/examples/p4-concrete/0-aux/0.0-stdlib.spectec:80:1-81:81:
