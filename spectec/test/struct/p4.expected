  1. Else Phantom#1268

2. Else Phantom#1269

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.04-typing-relation.spectec:442:1-447:40:
relation InstDecl_ok: p, TC_0, instantiation

1. Case analysis on instantiation

  1. Case (% matches pattern `% % (%) % ;`)

    1. (Let (annotationList type ( argumentList ) name ;) be instantiation)

    2. Case analysis on type

      1. Case (% has type prefixedTypeName)

        1. (Let prefixedTypeName be (type as prefixedTypeName))

        2. (InstDecl_non_objectInitializer_ok: p TC_0 |- annotationList prefixedTypeName < () > ( argumentList ) name ; : TC_1 instantiationIR)

        3. Result in TC_1, instantiationIR

      2. Case (% has type specializedType)

        1. (Let (prefixedTypeName < typeArgumentList >) be (type as specializedType))

        2. (InstDecl_non_objectInitializer_ok: p TC_0 |- annotationList prefixedTypeName < typeArgumentList > ( argumentList ) name ; : TC_1 instantiationIR)

        3. Result in TC_1, instantiationIR

    2. Else Phantom#1270

  2. Case (% matches pattern `% % (%) % % ;`)

    1. (Let (annotationList type ( argumentList ) name (= { objectDeclarationList }) ;) be instantiation)

    2. Case analysis on type

      1. Case (% has type prefixedTypeName)

        1. (Let prefixedTypeName be (type as prefixedTypeName))

        2. (InstDecl_objectInitializer_ok: p TC_0 |- annotationList prefixedTypeName < () > ( argumentList ) name = { objectDeclarationList } ; : TC_1 instantiationIR)

        3. Result in TC_1, instantiationIR

      2. Case (% has type specializedType)

        1. (Let (prefixedTypeName < typeArgumentList >) be (type as specializedType))

        2. (InstDecl_objectInitializer_ok: p TC_0 |- annotationList prefixedTypeName < typeArgumentList > ( argumentList ) name = { objectDeclarationList } ; : TC_1 instantiationIR)

        3. Result in TC_1, instantiationIR

    2. Else Phantom#1271

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.04-typing-relation.spectec:449:1-454:40:
relation FuncDecl_ok: p, TC_0, (annotationList (typeOrVoid name typeParameterListOpt ( parameterList )) blockStatement)

1. (TypeParameterListOpt_ok: (local) TC_0 |- typeParameterListOpt : TC_1 typeId_expl*)

2. (Type_ok: (local) TC_1 |- typeOrVoid : typeIR_ret # typeId*)

3. If ((typeId* matches pattern [])), then

  1. (ParameterList_ok: (local) TC_1 |- parameterList : TC_2 parameterIR* # typeId_impl*)

  2. (Let TC_3 be TC_2[local.kind = ((function : typeIR_ret) as localKind)])

  3. (Block_ok: TC_3 (cont) (noloop) |- blockStatement : _typingContext f blockStatementIR)

  4. If (((f = (ret)) \/ (typeIR_ret = ((void) as typeIR)))), then

    1. (Let callableId be $callableId(name, parameterList))

    2. (Let nameIR be $name(name))

    3. (Let definedFunctionTypeDefIR be (function nameIR < typeId_expl* , typeId_impl* > ( parameterIR* ) : typeIR_ret))

    4. If (CallableTypeDef_wf: $bound(p, TC_0) |- (definedFunctionTypeDefIR as callableTypeDefIR) holds), then

      1. (Let TC_4 be $add_callableDef_overload_t(p, TC_0, callableId, (definedFunctionTypeDefIR as callableTypeDefIR)))

      2. (Let functionDeclarationIR be (annotationList (typeIR_ret nameIR < typeId_expl* , typeId_impl* > ( parameterIR* )) blockStatementIR))

      3. Result in TC_4, functionDeclarationIR

    4. Else Phantom#1272

  4. Else Phantom#1273

3. Else Phantom#1274

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.04-typing-relation.spectec:456:1-461:40:
relation ActionDecl_ok: p, TC_0, (annotationList action name ( parameterList ) blockStatement)

1. (Let TC_1 be TC_0[local.kind = ((action) as localKind)])

2. (ParameterList_ok: (local) TC_1 |- parameterList : TC_2 parameterIR* # typeId*)

3. If ((typeId* matches pattern [])), then

  1. (Block_ok: TC_2 (cont) (noloop) |- blockStatement : _typingContext _flow blockStatementIR)

  2. (Let callableId be $callableId(name, parameterList))

  3. (Let nameIR be $name(name))

  4. (Let actionTypeDefIR be (annotationList action nameIR ( parameterIR* )))

  5. If (CallableTypeDef_wf: $bound(p, TC_0) |- (actionTypeDefIR as callableTypeDefIR) holds), then

    1. (Let TC_3 be $add_callableDef_non_overload_t(p, TC_0, callableId, (actionTypeDefIR as callableTypeDefIR)))

    2. (Let actionDeclarationIR be (annotationList action nameIR ( parameterIR* ) blockStatementIR))

