   | @ name [ structuredAnnotationBody ] (from annotation) hint(print "@"#%0#"["#%1#"]")
   | @ pragma name annotationBody (from annotation) hint(print "@pragma" %0 %1)
   | annotationListNonEmpty annotation (from annotationListNonEmpty)

;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:1431:1-1432:32:
dec $flatten_annotationList(annotationList)

1. If ((annotationList matches pattern ``EMPTY`)), then

  1. Return []

1. Else Phantom#57

2. If ((annotationList has type annotation)), then

  1. (Let annotation be (annotationList as annotation))

  2. Return [annotation]

2. Else Phantom#58

3. If ((annotationList has type annotationListNonEmpty)), then

  1. (Let annotationListNonEmpty' be (annotationList as annotationListNonEmpty))

  2. If ((annotationListNonEmpty' matches pattern `% %`)), then

    1. (Let (annotationListNonEmpty annotation) be annotationListNonEmpty')

    2. Return $flatten_annotationList((annotationListNonEmpty as annotationList)) ++ [annotation]

  2. Else Phantom#59

3. Else Phantom#60

