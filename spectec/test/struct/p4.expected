      2. Else Phantom#610

      3. If ((n_prefix' = 0)), then

        1. If ((nat > 0)), then

          1. (Let w' be (nat - 1))

          2. If (((n \ 2) = 0)), then

            1. (Let value' be ((w' w ((n / 2) as int)) as value))

            2. Return $tableEntry_lpm_prefix'(value', 0)

