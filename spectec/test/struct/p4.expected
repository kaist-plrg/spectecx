dec $bitacc_range_op(value, value', value'')

1. If ((value has type integerValue)), then

  1. (Let integerValue_b be (value as integerValue))

  2. If ((value' has type integerValue)), then

    1. (Let integerValue_h be (value' as integerValue))

    2. If ((value'' has type integerValue)), then

      1. (Let integerValue_l be (value'' as integerValue))

      2. (Let i_b be $int_of_integerValue(integerValue_b))

      3. (Let i_h be $int_of_integerValue(integerValue_h))

      4. (Let i_l be $int_of_integerValue(integerValue_l))

      5. (Let int be ((i_h + (1 as int)) - i_l))

      6. If ((int has type nat)), then

        1. (Let w be (int as nat))

        2. (Let i be $bitacc(i_b, i_h, i_l))

        3. Return ((w w i) as value)

      6. Else Phantom#450

    2. Else Phantom#451

  2. Else Phantom#452

1. Else Phantom#453

;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:875:1-877:35:
dec $bitacc_offset_op(value, value', value'')

1. If ((value has type integerValue)), then

  1. (Let integerValue_b be (value as integerValue))

  2. If ((value' has type integerValue)), then

    1. (Let integerValue_l be (value' as integerValue))

    2. If ((value'' has type integerValue)), then

      1. (Let integerValue_w be (value'' as integerValue))

      2. (Let i_b be $int_of_integerValue(integerValue_b))

      3. (Let i_l be $int_of_integerValue(integerValue_l))

      4. (Let nat? be $nat_of_integerValue(integerValue_w))

      5. If ((nat? matches pattern (_))), then

        1. (Let ?(w) be nat?)

        2. (Let i_h be ((i_l + (w as int)) - (1 as int)))

        3. (Let i be $bitacc(i_b, i_h, i_l))

        4. Return ((w w i) as value)

      5. Else Phantom#454

    2. Else Phantom#455

  2. Else Phantom#456

1. Else Phantom#457

;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:890:1-892:53:
dec $bitacc_range_replace_op(value, value', value'', value''')

1. If ((value has type integerValue)), then

  1. (Let integerValue_b be (value as integerValue))

  2. If ((value' has type integerValue)), then

    1. (Let integerValue_h be (value' as integerValue))

    2. If ((value'' has type integerValue)), then

      1. (Let integerValue_l be (value'' as integerValue))

      2. If ((value''' has type integerValue)), then

        1. (Let integerValue_r be (value''' as integerValue))

        2. (Let integerValue be integerValue_b)

        3. If ((integerValue has type integerLiteral)), then

          1. (Let integerLiteral be (integerValue as integerLiteral))

          2. If ((integerLiteral matches pattern `% W %`)), then

            1. (Let (w w i_b) be integerLiteral)

            2. (Let i_h be $int_of_integerValue(integerValue_h))

            3. (Let i_l be $int_of_integerValue(integerValue_l))

            4. (Let integerValue' be integerValue_r)

            5. If ((integerValue' has type integerLiteral)), then

              1. (Let integerLiteral' be (integerValue' as integerLiteral))

              2. If ((integerLiteral' matches pattern `% W %`)), then

                1. (Let (_nat w i_r) be integerLiteral')

                2. (Let i be $bitacc_replace(i_b, i_h, i_l, i_r))

                3. Return ((w w i) as value)

              2. Else Phantom#458

            5. Else Phantom#459

          2. Else Phantom#460

        3. Else Phantom#461

      2. Else Phantom#462

    2. Else Phantom#463

  2. Else Phantom#464

1. Else Phantom#465

;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:905:1-907:54:
dec $bitacc_offset_replace_op(value, value', value'', value''')

1. If ((value has type integerValue)), then

  1. (Let integerValue_b be (value as integerValue))

  2. If ((value' has type integerValue)), then

    1. (Let integerValue_l be (value' as integerValue))

    2. If ((value'' has type integerValue)), then

      1. (Let integerValue_w be (value'' as integerValue))

      2. If ((value''' has type integerValue)), then

        1. (Let integerValue_r be (value''' as integerValue))

        2. (Let integerValue be integerValue_b)

        3. If ((integerValue has type integerLiteral)), then

          1. (Let integerLiteral be (integerValue as integerLiteral))

          2. If ((integerLiteral matches pattern `% W %`)), then

            1. (Let (w w i_b) be integerLiteral)

            2. (Let i_l be $int_of_integerValue(integerValue_l))

            3. (Let nat? be $nat_of_integerValue(integerValue_w))

            4. If ((nat? matches pattern (_))), then

              1. (Let ?(n_w) be nat?)

              2. (Let i_h be ((i_l + (n_w as int)) - (1 as int)))

              3. (Let integerValue' be integerValue_r)

              4. If ((integerValue' has type integerLiteral)), then

                1. (Let integerLiteral' be (integerValue' as integerLiteral))

                2. If ((integerLiteral' matches pattern `% W %`)), then

                  1. (Let (_nat w i_r) be integerLiteral')

                  2. (Let i be $bitacc_replace(i_b, i_h, i_l, i_r))

                  3. Return ((w w i) as value)

                2. Else Phantom#466

              4. Else Phantom#467

            4. Else Phantom#468

          2. Else Phantom#469

        3. Else Phantom#470

      2. Else Phantom#471

    2. Else Phantom#472

  2. Else Phantom#473

1. Else Phantom#474

;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:921:1-922:23:
dec $sizeof(typeIR, text)

1. Case analysis on text

  1. Case (% = "minSizeInBits")

    1. Return $sizeof_minSizeInBits(typeIR)

  2. Case (% = "minSizeInBytes")

    1. Return $sizeof_minSizeInBytes(typeIR)

  3. Case (% = "maxSizeInBits")

    1. Return $sizeof_maxSizeInBits(typeIR)

  4. Case (% = "maxSizeInBytes")

    1. Return $sizeof_maxSizeInBytes(typeIR)

1. Else Phantom#475

;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:924:1-925:23:
dec $sizeof_minSizeInBits(typeIR)

1. Return ((d ($sizeof_minSizeInBits'(typeIR) as int)) as value)

;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:926:1-927:23:
dec $sizeof_minSizeInBits'(typeIR'')

1. Case analysis on typeIR''

  1. Case (% has type boolTypeIR)

    1. (Let boolTypeIR be (typeIR'' as boolTypeIR))

    2. If ((boolTypeIR matches pattern `BOOL`)), then

      1. Return 1

    2. Else Phantom#476

  2. Case (% has type fixedIntTypeIR)

    1. (Let (int < w >) be (typeIR'' as fixedIntTypeIR))

    2. Return w

  3. Case (% has type fixedBitTypeIR)

    1. (Let (bit < w >) be (typeIR'' as fixedBitTypeIR))

    2. Return w

  4. Case (% has type varBitTypeIR)

    1. (Let (varbit < _nat >) be (typeIR'' as varBitTypeIR))

    2. Return 0

  5. Case (% has type typedefTypeIR)

    1. (Let (typedef _typeId typeIR'') be (typeIR'' as typedefTypeIR))

    2. Return $sizeof_minSizeInBits'(typeIR'')

  6. Case (% has type newTypeIR)

    1. (Let (type _typeId typeIR'') be (typeIR'' as newTypeIR))

    2. Return $sizeof_minSizeInBits'(typeIR'')

  7. Case (% has type serializableEnumTypeIR)

    1. (Let (enum _typeId < typeIR'' > { _valueFieldIR* }) be (typeIR'' as serializableEnumTypeIR))

    2. Return $sizeof_minSizeInBits'(typeIR'')

  8. Case (% has type tupleTypeIR)

    1. (Let (tuple < typeIR''* >) be (typeIR'' as tupleTypeIR))

    2. Return $sum_nat($sizeof_minSizeInBits'(typeIR'')*)

  9. Case (% has type headerStackTypeIR)

    1. (Let (typeIR'' [ n_size ]) be (typeIR'' as headerStackTypeIR))

    2. Return ($sizeof_minSizeInBits'(typeIR'') * n_size)

  10. Case (% has type structTypeIR)

    1. (Let (struct _typeId < _typeArgumentIR* > { (_annotationList typeIR'' _nameIR ;)* }) be (typeIR'' as structTypeIR))

    2. Return $sum_nat($sizeof_minSizeInBits'(typeIR'')*)

  11. Case (% has type headerTypeIR)

    1. (Let (header _typeId < _typeArgumentIR* > { (_annotationList typeIR'' _nameIR ;)* }) be (typeIR'' as headerTypeIR))

    2. Return $sum_nat($sizeof_minSizeInBits'(typeIR'')*)

  12. Case (% has type headerUnionTypeIR)

    1. (Let (header_union _typeId < _typeArgumentIR* > { (_annotationList typeIR'' _nameIR ;)* }) be (typeIR'' as headerUnionTypeIR))

    2. Return $min_nat($sizeof_minSizeInBits'(typeIR'')*)

1. Else Phantom#477

;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:929:1-930:23:
dec $sizeof_minSizeInBytes(typeIR)

1. (Let n_size be $sizeof_minSizeInBits'(typeIR))

2. Return ((d ((n_size / 8) as int)) as value)

;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:932:1-933:23:
dec $sizeof_maxSizeInBits(typeIR)

