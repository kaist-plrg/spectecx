;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.5.2-type-subst.spectec:32:1-33:52:
dec $subst_callableTypeDefIR'(theta, callableTypeDefIR)

1. Case analysis on callableTypeDefIR

  1. Case (% has type actionTypeDefIR)

    1. (Let actionTypeDefIR be (callableTypeDefIR as actionTypeDefIR))

    2. (Let callableTypeIR be $subst_callableTypeIR'(theta, (actionTypeDefIR as callableTypeIR)))

    3. If ((callableTypeIR has type actionTypeDefIR)), then

      1. (Let actionTypeDefIR_subst be (callableTypeIR as actionTypeDefIR))

      2. Return (actionTypeDefIR_subst as callableTypeDefIR)

    3. Else Phantom#120

  2. Case (% has type definedFunctionTypeDefIR)

    1. (Let (function nameIR < typeParameterIR_expl* , typeParameterIR_impl* > ( parameterIR* ) : typeIR) be (callableTypeDefIR as definedFunctionTypeDefIR))

    2. (Let B be $free_callableTypeIR(((function nameIR ( parameterIR* ) : typeIR) as callableTypeIR)))

    3. (Let (theta_fresh, typeParameterIR_expl_fresh*, typeParameterIR_impl_fresh*) be $capture_avoiding(theta, typeParameterIR_expl*, typeParameterIR_impl*, B))

    4. (Let parameterIR_subst be $subst_parameterIR(theta_fresh, parameterIR))*

    5. (Let typeIR_subst be $subst_typeIR(theta_fresh, typeIR))

    6. Return ((function nameIR < typeParameterIR_expl_fresh* , typeParameterIR_impl_fresh* > ( parameterIR_subst* ) : typeIR_subst) as callableTypeDefIR)

  3. Case (% has type externFunctionTypeDefIR)

    1. (Let (extern_function nameIR < typeParameterIR_expl* , typeParameterIR_impl* > ( parameterIR* ) : typeIR) be (callableTypeDefIR as externFunctionTypeDefIR))

    2. (Let B be $free_callableTypeIR(((extern_function nameIR ( parameterIR* ) : typeIR) as callableTypeIR)))

    3. (Let (theta_fresh, typeParameterIR_expl_fresh*, typeParameterIR_impl_fresh*) be $capture_avoiding(theta, typeParameterIR_expl*, typeParameterIR_impl*, B))

    4. (Let parameterIR_subst be $subst_parameterIR(theta_fresh, parameterIR))*

    5. (Let typeIR_subst be $subst_typeIR(theta_fresh, typeIR))

    6. Return ((extern_function nameIR < typeParameterIR_expl_fresh* , typeParameterIR_impl_fresh* > ( parameterIR_subst* ) : typeIR_subst) as callableTypeDefIR)

  4. Case (% has type externMethodTypeDefIR)

    1. (Let externMethodTypeDefIR be (callableTypeDefIR as externMethodTypeDefIR))

    2. Case analysis on externMethodTypeDefIR

      1. Case (% matches pattern `EXTERN_METHOD % <% , %> (%) : %`)

        1. (Let (extern_method nameIR < typeParameterIR_expl* , typeParameterIR_impl* > ( parameterIR* ) : typeIR) be externMethodTypeDefIR)

        2. (Let B be $free_callableTypeIR(((extern_method nameIR ( parameterIR* ) : typeIR) as callableTypeIR)))

        3. (Let (theta_fresh, typeParameterIR_expl_fresh*, typeParameterIR_impl_fresh*) be $capture_avoiding(theta, typeParameterIR_expl*, typeParameterIR_impl*, B))

        4. (Let parameterIR_subst be $subst_parameterIR(theta_fresh, parameterIR))*

        5. (Let typeIR_subst be $subst_typeIR(theta_fresh, typeIR))

        6. Return ((extern_method nameIR < typeParameterIR_expl_fresh* , typeParameterIR_impl_fresh* > ( parameterIR_subst* ) : typeIR_subst) as callableTypeDefIR)

      2. Case (% matches pattern `EXTERN_METHOD ABSTRACT % <% , %> (%) : %`)

        1. (Let (extern_method abstract nameIR < typeParameterIR_expl* , typeParameterIR_impl* > ( parameterIR* ) : typeIR) be externMethodTypeDefIR)

        2. (Let B be $free_callableTypeIR(((extern_method abstract nameIR ( parameterIR* ) : typeIR) as callableTypeIR)))

        3. (Let (theta_fresh, typeParameterIR_expl_fresh*, typeParameterIR_impl_fresh*) be $capture_avoiding(theta, typeParameterIR_expl*, typeParameterIR_impl*, B))

        4. (Let parameterIR_subst be $subst_parameterIR(theta_fresh, parameterIR))*

        5. (Let typeIR_subst be $subst_typeIR(theta_fresh, typeIR))

        6. Return ((extern_method abstract nameIR < typeParameterIR_expl_fresh* , typeParameterIR_impl_fresh* > ( parameterIR_subst* ) : typeIR_subst) as callableTypeDefIR)

  5. Case (% has type parserApplyMethodTypeDefIR)

    1. (Let parserApplyMethodTypeDefIR be (callableTypeDefIR as parserApplyMethodTypeDefIR))

    2. (Let callableTypeIR be $subst_callableTypeIR'(theta, (parserApplyMethodTypeDefIR as callableTypeIR)))

    3. If ((callableTypeIR has type parserApplyMethodTypeDefIR)), then

      1. (Let parserApplyMethodTypeDefIR_subst be (callableTypeIR as parserApplyMethodTypeDefIR))

      2. Return (parserApplyMethodTypeDefIR_subst as callableTypeDefIR)

    3. Else Phantom#121

  6. Case (% has type controlApplyMethodTypeDefIR)

    1. (Let controlApplyMethodTypeDefIR be (callableTypeDefIR as controlApplyMethodTypeDefIR))

    2. (Let callableTypeIR be $subst_callableTypeIR'(theta, (controlApplyMethodTypeDefIR as callableTypeIR)))

    3. If ((callableTypeIR has type controlApplyMethodTypeDefIR)), then

      1. (Let controlApplyMethodTypeDefIR_subst be (callableTypeIR as controlApplyMethodTypeDefIR))

      2. Return (controlApplyMethodTypeDefIR_subst as callableTypeDefIR)

    3. Else Phantom#122

1. Else Phantom#123

