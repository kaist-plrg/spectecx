;; ../../../../../spectec/examples/p4-concrete/5-typing/5.14.1-typing-control-table.spectec:7:1-7:52:
dec $compat_table_exact_optional_key(typeIR'')

1. Case analysis on typeIR''

  1. Case (% has type boolTypeIR)

    1. (Let boolTypeIR be (typeIR'' as boolTypeIR))

    2. If ((boolTypeIR matches pattern `BOOL`)), then

      1. Return true

    2. Else Phantom#1599

  2. Case (% has type errorTypeIR)

    1. (Let errorTypeIR be (typeIR'' as errorTypeIR))

    2. If ((errorTypeIR matches pattern `ERROR`)), then

      1. Return true

    2. Else Phantom#1600

  3. Case (% has type integerTypeIR)

    1. (Let integerTypeIR be (typeIR'' as integerTypeIR))

    2. Return true

  4. Case (% has type typedefTypeIR)

    1. (Let (typedef _typeId typeIR'') be (typeIR'' as typedefTypeIR))

    2. Return $compat_table_exact_optional_key(typeIR'')

  5. Case (% has type newTypeIR)

    1. (Let (type _typeId typeIR'') be (typeIR'' as newTypeIR))

    2. Return $compat_table_exact_optional_key(typeIR'')

  6. Case (% has type simpleEnumTypeIR)

    1. (Let (enum _typeId { _nameIR* }) be (typeIR'' as simpleEnumTypeIR))

    2. Return true

  7. Case (% has type serializableEnumTypeIR)

    1. (Let (enum _typeId < typeIR'' > { _valueFieldIR* }) be (typeIR'' as serializableEnumTypeIR))

    2. Return $compat_table_exact_optional_key(typeIR'')

1. Else Phantom#1601

2. Return false

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.14.1-typing-control-table.spectec:17:1-17:55:
dec $compat_table_lpm_ternary_range_key(typeIR'')

1. Case analysis on typeIR''

  1. Case (% has type intTypeIR)

    1. (Let intTypeIR be (typeIR'' as intTypeIR))

    2. If ((intTypeIR matches pattern `INT`)), then

      1. Return true

    2. Else Phantom#1602

  2. Case (% has type fixedIntTypeIR)

    1. (Let (int < _nat >) be (typeIR'' as fixedIntTypeIR))

    2. Return true

  3. Case (% has type fixedBitTypeIR)

    1. (Let (bit < _nat >) be (typeIR'' as fixedBitTypeIR))

    2. Return true

  4. Case (% has type typedefTypeIR)

    1. (Let (typedef _typeId typeIR'') be (typeIR'' as typedefTypeIR))

    2. Return $compat_table_lpm_ternary_range_key(typeIR'')

  5. Case (% has type newTypeIR)

    1. (Let (type _typeId typeIR'') be (typeIR'' as newTypeIR))

    2. Return $compat_table_lpm_ternary_range_key(typeIR'')

  6. Case (% has type serializableEnumTypeIR)

    1. (Let (enum _typeId < typeIR'' > { _valueFieldIR* }) be (typeIR'' as serializableEnumTypeIR))

    2. Return $compat_table_lpm_ternary_range_key(typeIR'')

1. Else Phantom#1603

2. Return false

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.14.1-typing-control-table.spectec:26:1-28:59:
dec $compat_table_key(nameIR, typeIR)

1. Case analysis on nameIR

  1. Case (% = "exact")

    1. If ($compat_table_exact_optional_key(typeIR)), then

      1. Return true

  2. Case (% = "optional")

    1. If ($compat_table_exact_optional_key(typeIR)), then

      1. Return true

  3. Case (% = "selector")

    1. If ($compat_table_exact_optional_key(typeIR)), then

      1. Return true

  4. Case (% = "lpm")

    1. If ($compat_table_lpm_ternary_range_key(typeIR)), then

      1. Return true

  5. Case (% = "ternary")

    1. If ($compat_table_lpm_ternary_range_key(typeIR)), then

      1. Return true

  6. Case (% = "range")

    1. If ($compat_table_lpm_ternary_range_key(typeIR)), then

      1. Return true

2. Otherwise

  1. Return false

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.14.1-typing-control-table.spectec:46:1-46:42:
dec $name_expression(expression'')

1. Case analysis on expression''

  1. Case (% has type booleanLiteral)

    1. (Let booleanLiteral be (expression'' as booleanLiteral))

    2. Case analysis on booleanLiteral

      1. Case (% matches pattern `TRUE`)

        1. Return "true"

      2. Case (% matches pattern `FALSE`)

        1. Return "false"

  2. Case (% has type integerLiteral)

    1. (Let integerLiteral be (expression'' as integerLiteral))

    2. Case analysis on integerLiteral

      1. Case (% matches pattern `D %`)

        1. (Let (d i) be integerLiteral)

        2. Return $int_to_text(i)

      2. Case (% matches pattern `% W %`)

        1. (Let (n w i) be integerLiteral)

        2. Return $int_to_text((n as int)) ++ "w" ++ $int_to_text(i)

      3. Case (% matches pattern `% S %`)

        1. (Let (n s i) be integerLiteral)

        2. Return $int_to_text((n as int)) ++ "s" ++ $int_to_text(i)

  3. Case (% has type stringLiteral)

    1. (Let (" text ") be (expression'' as stringLiteral))

    2. Return "\"" ++ text ++ "\""

  4. Case (% has type referenceExpression)

    1. (Let referenceExpression be (expression'' as referenceExpression))

    2. If ((referenceExpression matches pattern `THIS`)), then

      1. Return "this"

  5. Case (% has type errorAccessExpression)

    1. (Let (error . member) be (expression'' as errorAccessExpression))

    2. Return "error." ++ $name(member)

  6. Case (% has type memberAccessExpression)

    1. (Let (memberAccessBase . member) be (expression'' as memberAccessExpression))

    2. Case analysis on memberAccessBase

      1. Case (% has type prefixedTypeName)

        1. (Let prefixedTypeName be (memberAccessBase as prefixedTypeName))

        2. Return $flatten_prefixedNameIR($prefixedTypeName(prefixedTypeName)) ++ "." ++ $name(member)

      2. Case (% has type expression)

        1. (Let expression'' be (memberAccessBase as expression))

        2. Return $name_expression(expression'') ++ "." ++ $name(member)

  7. Case (% has type indexAccessExpression)

    1. (Let (expression_base [ expression_index ]) be (expression'' as indexAccessExpression))

    2. Return $name_expression(expression_base) ++ "[" ++ $name_expression(expression_index) ++ "]"

  8. Case (% has type sliceAccessExpression)

    1. (Let sliceAccessExpression be (expression'' as sliceAccessExpression))

    2. Case analysis on sliceAccessExpression

      1. Case (% matches pattern `% [% : %]`)

        1. (Let (expression_base [ expression_hi : expression_lo ]) be sliceAccessExpression)

        2. Return $name_expression(expression_base) ++ "[" ++ $name_expression(expression_hi) ++ ":" ++ $name_expression(expression_lo) ++ "]"

      2. Case (% matches pattern `% [% + : %]`)

        1. (Let (expression_base [ expression_l + : expression_w ]) be sliceAccessExpression)

        2. Return $name_expression(expression_base) ++ "[" ++ $name_expression(expression_l) ++ "+:" ++ $name_expression(expression_w) ++ "]"

  9. Case (% has type parenthesizedExpression)

    1. (Let (( expression'' )) be (expression'' as parenthesizedExpression))

    2. Return "(" ++ $name_expression(expression'') ++ ")"

2. If ((expression'' has type nonTypeName)), then

  1. (Let nonTypeName be (expression'' as nonTypeName))

  2. Return $name((nonTypeName as name))

3. If ((expression'' has type prefixedNonTypeName)), then

  1. (Let prefixedNonTypeName be (expression'' as prefixedNonTypeName))

  2. If ((prefixedNonTypeName matches pattern ``ID . %`)), then

    1. (Let (. nonTypeName) be prefixedNonTypeName)

    2. Return "." ++ $name((nonTypeName as name))

4. Otherwise

  1. Return ""

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.14.1-typing-control-table.spectec:139:1-141:73:
dec $split_dataplane_parameters(parameterIR*)

1. Case analysis on parameterIR*

  1. Case (% matches pattern [])

    1. Return ([], [])

  2. Case (% matches pattern _ :: _)

    1. (Let parameterIR_h :: parameterIR_t* be parameterIR*)

    2. (Let (_annotationList direction _typeIR _id _parameterInitializerOptIR) be parameterIR_h)

    3. Case analysis on (direction matches pattern ``EMPTY`)

      1. Case true

        1. (Let (parameterIR_data*, parameterIR_control*) be $split_dataplane_parameters(parameterIR_t*))

        2. Return (parameterIR_data*, parameterIR_h :: parameterIR_control*)

      2. Case false

        1. (Let (parameterIR_data*, parameterIR_control*) be $split_dataplane_parameters(parameterIR_t*))

        2. Return (parameterIR_h :: parameterIR_data*, parameterIR_control*)

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.14.1-typing-control-table.spectec:158:1-160:63:
dec $is_table_application(typedExpressionIR)

1. (Let typeIR be $type_of_typedExpressionIR(typedExpressionIR))

2. (Let typeIR_unroll be $unroll_typeIR(typeIR))

3. Return (typeIR_unroll has type tableMetadataStructTypeIR)

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.14.1-typing-control-table.spectec:325:1-328:26:
relation TableEntry_keyset_simple_ok: TC, TBLC, (typeIR_key : text'), simpleKeysetExpression

1. Case analysis on text'

  1. Case (% = "lpm")

    1. If ((simpleKeysetExpression has type expression)), then

      1. (Let expression be (simpleKeysetExpression as expression))

      2. (Let matchMode be TBLC.mode)

      3. If ((matchMode matches pattern `LPM %`)), then

        1. (Let (lpm n) be matchMode)

