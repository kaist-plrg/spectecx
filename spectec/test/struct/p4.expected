builtin dec $bitacc_replace(int, int', int'', int''')

;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:33:1-35:23:
dec $un_op(unop, value)

1. Case analysis on unop

  1. Case (% matches pattern `~`)

    1. Return $un_bnot(value)

  2. Case (% matches pattern `!`)

    1. Return $un_lnot(value)

  3. Case (% matches pattern `+`)

    1. Return $un_plus(value)

  4. Case (% matches pattern `-`)

    1. Return $un_minus(value)

;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:39:1-41:23:
dec $un_bnot(value)

1. If ((value has type integerLiteral)), then

  1. (Let integerLiteral be (value as integerLiteral))

  2. If ((integerLiteral matches pattern `% W %`)), then

    1. (Let (w w i) be integerLiteral)

    2. (Let i' be $bneg(i))

    3. (Let i'' be $ite<int>((i' >= (0 as int)), i', ($pow2(w) + i')))

    4. Return ((w w i'') as value)

  2. Else Phantom#221

1. Else Phantom#222

;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:51:1-53:23:
dec $un_lnot(value)

1. If ((value has type boolValue)), then

  1. (Let (b) be (value as boolValue))

  2. Return ((~b) as value)

1. Else Phantom#223

;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:61:1-63:23:
dec $un_plus(value)

1. If ((value has type integerLiteral)), then

  1. (Let integerLiteral be (value as integerLiteral))

  2. Case analysis on integerLiteral

    1. Case (% matches pattern `D %`)

      1. (Let (d i) be integerLiteral)

      2. Return ((d i) as value)

    2. Case (% matches pattern `% W %`)

      1. (Let (w w i) be integerLiteral)

      2. Return ((w w i) as value)

    3. Case (% matches pattern `% S %`)

      1. (Let (w s i) be integerLiteral)

      2. Return ((w s i) as value)

1. Else Phantom#224

;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:73:1-75:23:
dec $un_minus(value)

1. If ((value has type integerLiteral)), then

  1. (Let integerLiteral be (value as integerLiteral))

  2. Case analysis on integerLiteral

    1. Case (% matches pattern `D %`)

      1. (Let (d i) be integerLiteral)

      2. Return ((d -i) as value)

    2. Case (% matches pattern `% W %`)

      1. (Let (w w i) be integerLiteral)

      2. (Let i' be ($pow2(w) - i))

      3. Return ((w w i') as value)

    3. Case (% matches pattern `% S %`)

      1. (Let (w s i) be integerLiteral)

      2. (Let i' be $int_to_bitstr((w as int), $bitstr_to_int((w as int), -i)))

      3. Return ((w s i') as value)

1. Else Phantom#225

;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:89:1-91:23:
dec $bin_op(binop, value_l, value_r)

1. Case analysis on binop

  1. Case (% matches pattern `+`)

    1. Return $bin_plus(value_l, value_r)

  2. Case (% matches pattern `|+|`)

    1. Return $bin_satplus(value_l, value_r)

  3. Case (% matches pattern `-`)

    1. Return $bin_minus(value_l, value_r)

  4. Case (% matches pattern `|-|`)

    1. Return $bin_satminus(value_l, value_r)

  5. Case (% matches pattern `*`)

    1. Return $bin_mul(value_l, value_r)

  6. Case (% matches pattern `/`)

    1. Return $bin_div(value_l, value_r)

  7. Case (% matches pattern `%`)

    1. Return $bin_mod(value_l, value_r)

  8. Case (% matches pattern `<<`)

    1. Return $bin_shl(value_l, value_r)

