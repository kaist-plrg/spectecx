1. Case analysis on expression''

  1. Case (% has type referenceExpression)

    1. (Let referenceExpression be (expression'' as referenceExpression))

    2. Return ?((referenceExpression as lvalue))

  2. Case (% has type memberAccessExpression)

    1. (Let (memberAccessBase . member) be (expression'' as memberAccessExpression))

    2. If ((memberAccessBase has type expression)), then

      1. (Let expression'' be (memberAccessBase as expression))

      2. (Let lvalue'? be $expression_as_lvalue(expression''))

      3. If ((lvalue'? matches pattern (_))), then

        1. (Let ?(lvalue) be lvalue'?)

        2. Return ?((lvalue . member))

      3. Else Phantom#38

    2. Else Phantom#39

  3. Case (% has type indexAccessExpression)

    1. (Let (expression_base [ expression_index ]) be (expression'' as indexAccessExpression))

    2. (Let lvalue? be $expression_as_lvalue(expression_base))

    3. If ((lvalue? matches pattern (_))), then

      1. (Let ?(lvalue_base) be lvalue?)

      2. Return ?((lvalue_base [ expression_index ]))

    3. Else Phantom#40

  4. Case (% has type sliceAccessExpression)

    1. (Let sliceAccessExpression be (expression'' as sliceAccessExpression))

    2. Case analysis on sliceAccessExpression

      1. Case (% matches pattern `% [% : %]`)

        1. (Let (expression_base [ expression_hi : expression_lo ]) be sliceAccessExpression)

        2. (Let lvalue? be $expression_as_lvalue(expression_base))

        3. If ((lvalue? matches pattern (_))), then

          1. (Let ?(lvalue_base) be lvalue?)

          2. Return ?((lvalue_base [ expression_hi : expression_lo ]))

        3. Else Phantom#41

      2. Case (% matches pattern `% [% + : %]`)

        1. (Let (expression_base [ expression_hi + : expression_lo ]) be sliceAccessExpression)

        2. (Let lvalue? be $expression_as_lvalue(expression_base))

        3. If ((lvalue? matches pattern (_))), then

          1. (Let ?(lvalue_base) be lvalue?)

          2. Return ?((lvalue_base [ expression_hi + : expression_lo ]))

        3. Else Phantom#42

  5. Case (% has type parenthesizedExpression)

    1. (Let (( expression'' )) be (expression'' as parenthesizedExpression))

    2. (Let lvalue'? be $expression_as_lvalue(expression''))

    3. If ((lvalue'? matches pattern (_))), then

      1. (Let ?(lvalue) be lvalue'?)

      2. Return ?((( lvalue )))

    3. Else Phantom#43

1. Else Phantom#44

;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:684:25-684:27:
syntax emptyStatement = 
   | ; (from emptyStatement)

;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:691:1-693:34:
syntax assignop = 
   | = (from assignop)
   | += (from assignop)
   | -= (from assignop)
   | |+|= (from assignop)
   | |-|= (from assignop)
   | *= (from assignop)
   | /= (from assignop)
   | %= (from assignop)
   | <<= (from assignop)
   | >>= (from assignop)
   | &= (from assignop)
   | ^= (from assignop)
   | |= (from assignop)

;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:695:30-695:59:
syntax assignmentStatement = 
   | lvalue assignop expression ; (from assignmentStatement)

;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:697:1-698:59:
dec $assignop_as_binop(assignop)

1. Case analysis on assignop

  1. Case (% matches pattern `+=`)

    1. Return ?((+))

  2. Case (% matches pattern `-=`)

    1. Return ?((-))

  3. Case (% matches pattern `|+|=`)

    1. Return ?((|+|))

  4. Case (% matches pattern `|-|=`)

    1. Return ?((|-|))

  5. Case (% matches pattern `*=`)

    1. Return ?((*))

  6. Case (% matches pattern `/=`)

    1. Return ?((/))

  7. Case (% matches pattern `%=`)

    1. Return ?((%))

  8. Case (% matches pattern `<<=`)

    1. Return ?((<<))

  9. Case (% matches pattern `>>=`)

    1. Return ?((>>))

  10. Case (% matches pattern `&=`)

    1. Return ?((&))

  11. Case (% matches pattern `^=`)

    1. Return ?((^))

  12. Case (% matches pattern `|=`)

    1. Return ?((|))

2. Otherwise

  1. Return ?()

