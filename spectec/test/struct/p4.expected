;; ../../../../../spectec/examples/p4-concrete/5-typing/5.06.1-typing-expression.spectec:445:1-445:44:
dec $result_concat(typeIR'', typeIR''')

1. Case analysis on typeIR''

  1. Case (% has type stringTypeIR)

    1. (Let stringTypeIR be (typeIR'' as stringTypeIR))

    2. If ((stringTypeIR matches pattern `STRING`)), then

      1. If ((typeIR''' has type stringTypeIR)), then

        1. (Let stringTypeIR' be (typeIR''' as stringTypeIR))

        2. If ((stringTypeIR' matches pattern `STRING`)), then

          1. Return ((string) as typeIR)

        2. Else Phantom#1466

      1. Else Phantom#1467

    2. Else Phantom#1468

  2. Case (% has type fixedIntTypeIR)

    1. (Let (int < w_a >) be (typeIR'' as fixedIntTypeIR))

    2. Case analysis on typeIR'''

      1. Case (% has type fixedIntTypeIR)

        1. (Let (int < w_b >) be (typeIR''' as fixedIntTypeIR))

        2. Return ((int < (w_a + w_b) >) as typeIR)

      2. Case (% has type fixedBitTypeIR)

        1. (Let (bit < w_b >) be (typeIR''' as fixedBitTypeIR))

        2. Return ((int < (w_a + w_b) >) as typeIR)

    2. Else Phantom#1469

  3. Case (% has type fixedBitTypeIR)

    1. (Let (bit < w_a >) be (typeIR'' as fixedBitTypeIR))

    2. Case analysis on typeIR'''

      1. Case (% has type fixedIntTypeIR)

        1. (Let (int < w_b >) be (typeIR''' as fixedIntTypeIR))

        2. Return ((bit < (w_a + w_b) >) as typeIR)

      2. Case (% has type fixedBitTypeIR)

        1. (Let (bit < w_b >) be (typeIR''' as fixedBitTypeIR))

        2. Return ((bit < (w_a + w_b) >) as typeIR)

    2. Else Phantom#1470

  4. Case (% has type typedefTypeIR)

    1. (Let (typedef _typeId typeIR_l) be (typeIR'' as typedefTypeIR))

    2. Return $result_concat(typeIR_l, typeIR''')

1. Else Phantom#1471

2. If ((typeIR''' has type typedefTypeIR)), then

  1. (Let (typedef _typeId typeIR''') be (typeIR''' as typedefTypeIR))

  2. If (~(typeIR'' has type typedefTypeIR)), then

    1. Return $result_concat(typeIR'', typeIR''')

  2. Else Phantom#1472

2. Else Phantom#1473

