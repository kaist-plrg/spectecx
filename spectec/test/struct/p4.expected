;; ../../../../../spectec/examples/p4-concrete/6-dynamic-runtime/6.2.3-callable-callee.spectec:54:1-58:27:
syntax methodCallee = 
   | builtin_method storageReference . nameIR < typeArgumentListIR > ( parameterListIR ) (from builtinMethodCallee)
   | extern_method objectId . nameIR < typeParameterListIR > ( parameterListIR # id* # id* ) { theta ; frame ; blockStatementIR? } (from externMethodCallee)
   | parser objectId . apply ( parameterListIR # id* ) { theta ; frame ; parserLocalDeclarationListIR ; stateEnv } (from parserApplyMethodCallee)
   | control objectId . apply ( parameterListIR # id* ) { theta ; frame ; controlLocalDeclarationListIR ; actionDefEnv ; controlBodyIR } (from controlApplyMethodCallee)
   | table objectId . apply { frame ; tableObjectProperty } (from tableApplyMethodCallee)

;; ../../../../../spectec/examples/p4-concrete/6-dynamic-runtime/6.2.3-callable-callee.spectec:60:17-60:61:
syntax callee = 
   | action cursor . nameIR ( parameterListIR # id* ) blockStatementIR (from actionCallee)
   | function nameIR < typeParameterListIR > ( parameterListIR # id* ) blockStatementIR (from definedFunctionCallee)
   | extern_function nameIR < typeParameterListIR > ( parameterListIR # id* # id* ) (from externFunctionCallee)
   | builtin_method storageReference . nameIR < typeArgumentListIR > ( parameterListIR ) (from builtinMethodCallee)
   | extern_method objectId . nameIR < typeParameterListIR > ( parameterListIR # id* # id* ) { theta ; frame ; blockStatementIR? } (from externMethodCallee)
   | parser objectId . apply ( parameterListIR # id* ) { theta ; frame ; parserLocalDeclarationListIR ; stateEnv } (from parserApplyMethodCallee)
   | control objectId . apply ( parameterListIR # id* ) { theta ; frame ; controlLocalDeclarationListIR ; actionDefEnv ; controlBodyIR } (from controlApplyMethodCallee)
   | table objectId . apply { frame ; tableObjectProperty } (from tableApplyMethodCallee)

