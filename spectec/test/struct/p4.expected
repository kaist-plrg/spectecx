;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.1.2-value-aux.spectec:32:1-33:53:
dec $int_of_integerValue(integerValue)

1. If ((integerValue has type integerLiteral)), then

  1. (Let integerLiteral be (integerValue as integerLiteral))

  2. Case analysis on integerLiteral

    1. Case (% matches pattern `D %`)

      1. (Let (d i) be integerLiteral)

      2. Return i

    2. Case (% matches pattern `% S %`)

      1. (Let (w s i) be integerLiteral)

      2. Return $bitstr_to_int((w as int), i)

    3. Case (% matches pattern `% W %`)

      1. (Let (w w i) be integerLiteral)

      2. Return i

1. Else Phantom#71

2. If ((integerValue matches pattern `% . % V %`)), then

  1. (Let (_nat . _nat' v i) be integerValue)

  2. Return i

2. Else Phantom#72

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.1.2-value-aux.spectec:40:1-41:60:
dec $nat_of_integerValue(integerValue)

1. (Let int be $int_of_integerValue(integerValue))

2. If ((int has type nat)), then

  1. (Let n be (int as nat))

  2. Return ?(n)

3. Otherwise

  1. Return ?()

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.1.2-value-aux.spectec:52:1-52:65:
dec $update_fieldValue(fieldValue*, nameIR, value)

1. Case analysis on fieldValue*

  1. Case (% matches pattern [])

    1. Return []

  2. Case (% matches pattern _ :: _)

    1. (Let (value_field_h nameIR_field_h ;) :: fieldValue_t* be fieldValue*)

    2. Case analysis on nameIR_field_h

      1. Case (% = nameIR)

        1. Return (value nameIR ;) :: fieldValue_t*

      2. Case (% =/= nameIR)

        1. Return (value_field_h nameIR_field_h ;) :: $update_fieldValue(fieldValue_t*, nameIR, value)

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.1.2-value-aux.spectec:73:1-73:59:
dec $update_headerUnion(fieldValue''*, nameIR)

1. Case analysis on fieldValue''*

  1. Case (% matches pattern [])

    1. Return []

  2. Case (% matches pattern _ :: _)

    1. (Let (value_field_h nameIR_field_h ;) :: fieldValue_t* be fieldValue''*)

    2. Case analysis on nameIR_field_h

      1. Case (% = nameIR)

        1. Return (value_field_h nameIR_field_h ;) :: $update_headerUnion(fieldValue_t*, nameIR)

      2. Case (% =/= nameIR)

        1. (Let value be value_field_h)

        2. If ((value has type headerValue)), then

          1. (Let (header typeId { _bool ; fieldValue''* }) be (value as headerValue))

          2. (Let value_field_h_update be ((header typeId { false ; fieldValue''* }) as value))

          3. Return (value_field_h_update nameIR_field_h ;) :: $update_headerUnion(fieldValue_t*, nameIR)

        2. Else Phantom#73

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.1.2-value-aux.spectec:97:1-97:34:
dec $isValid_header(value)

1. If ((value has type headerValue)), then

  1. (Let headerValue be (value as headerValue))

  2. (Let (header _typeId { b_valid ; _fieldValue* }) be headerValue)

  3. Return b_valid

1. Else Phantom#74

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.1.2-value-aux.spectec:105:1-105:37:
dec $invalidate_value(value)

1. Case analysis on value

  1. Case (% has type headerValue)

    1. (Let headerValue be (value as headerValue))

    2. Return ($invalidate_header(headerValue) as value)

  2. Case (% has type headerUnionValue)

    1. (Let headerUnionValue be (value as headerUnionValue))

    2. Return ($invalidate_headerUnion(headerUnionValue) as value)

1. Else Phantom#75

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.1.2-value-aux.spectec:106:1-106:50:
dec $invalidate_header((header typeId { _bool ; fieldValue* }))

1. Return (header typeId { false ; fieldValue* })

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.1.2-value-aux.spectec:107:1-107:65:
dec $invalidate_headerUnion((header_union typeId { (value_field nameIR_field ;)* }))

1. (Let value_field_invalidated be $invalidate_value(value_field))*

2. Return (header_union typeId { (value_field_invalidated nameIR_field ;)* })

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.1.2-value-aux.spectec:124:1-124:54:
dec $write_value_from_bits(value, n_var, b*)

1. (Let (value_updated, bool*) be $write_value_from_bits'(value, n_var, b*))

2. If ((bool* matches pattern [])), then

  1. Return value_updated

2. Else Phantom#76

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.1.2-value-aux.spectec:125:1-125:64:
dec $write_value_from_bits'(value'', n_var', bool'*)

1. Case analysis on value''

  1. Case (% has type boolValue)

    1. (Let (_bool) be (value'' as boolValue))

    2. If ((bool'* matches pattern _ :: _)), then

      1. (Let b_h :: b_t* be bool'*)

      2. Return (((b_h) as value), b_t*)

    2. Else Phantom#77

  2. Case (% has type integerLiteral)

    1. (Let integerLiteral be (value'' as integerLiteral))

    2. Case analysis on integerLiteral

      1. Case (% matches pattern `% W %`)

        1. (Let (w w _int) be integerLiteral)

        2. If ((|bool'*| >= w)), then

          1. (Let b_h* be bool'*[0 : w])

          2. (Let n_t be (|bool'*| - w))

          3. (Let b_t* be bool'*[w : n_t])

          4. (Let i be $int_to_bitstr((w as int), $bits_to_int_unsigned(b_h*)))

          5. Return (((w w i) as value), b_t*)

        2. Else Phantom#78

      2. Case (% matches pattern `% S %`)

        1. (Let (w s _int) be integerLiteral)

        2. If ((|bool'*| >= w)), then

          1. (Let b_h* be bool'*[0 : w])

          2. (Let n_t be (|bool'*| - w))

          3. (Let b_t* be bool'*[w : n_t])

          4. (Let i be $int_to_bitstr((w as int), $bits_to_int_signed(b_h*)))

          5. Return (((w s i) as value), b_t*)

        2. Else Phantom#79

    2. Else Phantom#80

  3. Case (% has type structValue)

    1. (Let (struct typeId { fieldValue* }) be (value'' as structValue))

    2. (Let (fieldValue_updated*, b_rest*) be $write_value_fields_from_bits'(fieldValue*, n_var', bool'*))

    3. Return (((struct typeId { fieldValue_updated* }) as value), b_rest*)

  4. Case (% has type headerValue)

    1. (Let (header typeId { _bool ; fieldValue* }) be (value'' as headerValue))

    2. (Let (fieldValue_updated*, b_rest*) be $write_value_fields_from_bits'(fieldValue*, n_var', bool'*))

    3. Return (((header typeId { true ; fieldValue_updated* }) as value), b_rest*)

  5. Case (% has type enumValue)

    1. (Let enumValue be (value'' as enumValue))

    2. If ((enumValue matches pattern `% . % . %`)), then

      1. (Let (typeId . nameIR . value'') be enumValue)

      2. (Let (value_updated, b_rest*) be $write_value_from_bits'(value'', n_var', bool'*))

      3. Return (((typeId . "__UNSPECIFIED" . value_updated) as value), b_rest*)

    2. Else Phantom#81

  6. Case (% has type headerStackValue)

    1. (Let (header_stack [ value''* ( n_idx ; n_size ) ]) be (value'' as headerStackValue))

    2. (Let (value_updated*, b_rest*) be $write_values_from_bits'(value''*, n_var', bool'*))

    3. Return (((header_stack [ value_updated* ( n_idx ; n_size ) ]) as value), b_rest*)

1. Else Phantom#82

2. If ((value'' has type integerValue)), then

  1. (Let integerValue be (value'' as integerValue))

  2. If ((integerValue matches pattern `% . % V %`)), then

    1. (Let (n_max . _nat v i) be integerValue)

    2. If ((n_var' = 0)), then

      1. Return (((n_max . 0 v i) as value), bool'*)

    2. Else Phantom#83

    3. If ((|bool'*| >= n_var')), then

      1. (Let b_h* be bool'*[0 : n_var'])

      2. (Let n_t be (|bool'*| - n_var'))

      3. (Let b_t* be bool'*[n_var' : n_t])

      4. (Let i be $int_to_bitstr((n_var' as int), $bits_to_int_signed(b_h*)))

      5. Return (((n_max . n_var' v i) as value), b_t*)

    3. Else Phantom#84

  2. Else Phantom#85

2. Else Phantom#86

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.1.2-value-aux.spectec:126:1-126:67:
dec $write_values_from_bits'(value*, n_var, b*)

1. Case analysis on value*

  1. Case (% matches pattern [])

    1. Return ([], b*)

  2. Case (% matches pattern _ :: _)

    1. (Let value_h :: value_t* be value*)

    2. (Let (value_h_updated, b_t*) be $write_value_from_bits'(value_h, n_var, b*))

    3. (Let (value_t_updated*, b_rest*) be $write_values_from_bits'(value_t*, n_var, b_t*))

    4. Return (value_h_updated :: value_t_updated*, b_rest*)

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.1.2-value-aux.spectec:127:1-127:83:
dec $write_value_fields_from_bits'(fieldValue*, n_var, b*)

1. Case analysis on fieldValue*

  1. Case (% matches pattern [])

    1. Return ([], b*)

  2. Case (% matches pattern _ :: _)

    1. (Let fieldValue_h :: fieldValue_t* be fieldValue*)

    2. (Let (fieldValue_h_updated, b_t*) be $write_value_field_from_bits'(fieldValue_h, n_var, b*))

    3. (Let (fieldValue_t_updated*, b_rest*) be $write_value_fields_from_bits'(fieldValue_t*, n_var, b_t*))

    4. Return (fieldValue_h_updated :: fieldValue_t_updated*, b_rest*)

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.1.2-value-aux.spectec:128:1-128:80:
dec $write_value_field_from_bits'((value id ;), n_var, b*)

1. (Let (value_updated, b_rest*) be $write_value_from_bits'(value, n_var, b*))

2. Return ((value_updated id ;), b_rest*)

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.1.2-value-aux.spectec:204:1-204:42:
dec $write_bits_from_value(value'')

1. Case analysis on value''

  1. Case (% has type boolValue)

    1. (Let (b) be (value'' as boolValue))

    2. Return [b]

  2. Case (% has type integerLiteral)

    1. (Let integerLiteral be (value'' as integerLiteral))

    2. Case analysis on integerLiteral

      1. Case (% matches pattern `% S %`)

        1. (Let (w s i) be integerLiteral)

        2. Return $int_to_bits_signed(w, i)

      2. Case (% matches pattern `% W %`)

        1. (Let (w w i) be integerLiteral)

        2. Return $int_to_bits_unsigned(w, i)

    2. Else Phantom#87

  3. Case (% has type headerStackValue)

    1. (Let (header_stack [ value_element* ( _nat ; _nat' ) ]) be (value'' as headerStackValue))

    2. Return $concat_<bool>($write_bits_from_value(value_element)*)

  4. Case (% has type structValue)

    1. (Let (struct _typeId { (value_field id_field ;)* }) be (value'' as structValue))

    2. Return $concat_<bool>($write_bits_from_value(value_field)*)

  5. Case (% has type headerValue)

    1. (Let (header _typeId { bool ; (value_field id_field ;)* }) be (value'' as headerValue))

    2. If ((bool = true)), then

      1. Return $concat_<bool>($write_bits_from_value(value_field)*)

    2. Else Phantom#88

    3. (Let (header _typeId { bool ; _fieldValue* }) be (value'' as headerValue))

    4. If ((bool = false)), then

      1. Return []

    4. Else Phantom#89

  6. Case (% has type headerUnionValue)

    1. (Let (header_union _typeId { (value'' id ;)* }) be (value'' as headerUnionValue))

    2. Return $concat_<bool>($write_bits_from_value(value'')*)

  7. Case (% has type enumValue)

    1. (Let enumValue be (value'' as enumValue))

    2. If ((enumValue matches pattern `% . % . %`)), then

      1. (Let (typeId . id . value'') be enumValue)

      2. Return $write_bits_from_value(value'')

    2. Else Phantom#90

1. Else Phantom#91

2. If ((value'' has type integerValue)), then

  1. (Let integerValue be (value'' as integerValue))

  2. If ((integerValue matches pattern `% . % V %`)), then

    1. (Let (_nat . w v i) be integerValue)

    2. Return $int_to_bits_unsigned(w, i)

  2. Else Phantom#92

2. Else Phantom#93

