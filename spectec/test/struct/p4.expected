;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.5.3-type-specialization.spectec:11:1-12:40:
dec $specialize_typeDefIR(typeDefIR_base, typeArgumentIR*)

1. (Let (typeParameterIR_expl*, typeParameterIR_impl*) be $typeParameterListIR_of_typeDefIR(typeDefIR_base))

2. (Let typeParameterIR* be typeParameterIR_expl* ++ typeParameterIR_impl*)

3. If ((|typeParameterIR*| = |typeArgumentIR*|)), then

  1. (Let theta be ({ (typeParameterIR : typeArgumentIR)* }))

  2. (Let typeIR_base be $typeIR_of_typeDefIR(typeDefIR_base))

  3. (Let typeIR_spec be $subst_typeIR(theta, typeIR_base))

  4. Return typeIR_spec

3. Else Phantom#124

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.5.3-type-specialization.spectec:32:1-34:40:
dec $specialize_callableTypeDefIR(callableTypeDefIR_base, typeArgumentIR*)

