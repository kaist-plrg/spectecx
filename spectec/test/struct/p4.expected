syntax object = 
   | extern typeId < theta > { objectState frame externMethodDefEnv } (from externObject)
   | parser < theta > ( parameterListIR ) { frame parserLocalDeclarationListIR stateEnv } (from parserObject)
   | control < theta > ( parameterListIR ) { frame controlLocalDeclarationListIR actionDefEnv controlBodyIR } (from controlObject)
   | package < theta > { frame } (from packageObject)
   | table typeId { frame tableObjectProperty } (from tableObject)
