;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.5.2-type-subst.spectec:27:1-28:52:
dec $subst_callableTypeIR'(theta, callableTypeIR)

1. Case analysis on callableTypeIR

  1. Case (% has type actionTypeIR)

    1. (Let (annotationList action nameIR ( parameterIR* )) be (callableTypeIR as actionTypeIR))

    2. (Let parameterIR_subst be $subst_parameterIR'(theta, parameterIR))*

    3. Return ((annotationList action nameIR ( parameterIR_subst* )) as callableTypeIR)

  2. Case (% has type definedFunctionTypeIR)

    1. (Let (function nameIR ( parameterIR* ) : typeIR) be (callableTypeIR as definedFunctionTypeIR))

    2. (Let parameterIR_subst be $subst_parameterIR'(theta, parameterIR))*

    3. (Let typeIR_subst be $subst_typeIR'(theta, typeIR))

    4. Return ((function nameIR ( parameterIR_subst* ) : typeIR_subst) as callableTypeIR)

  3. Case (% has type externFunctionTypeIR)

    1. (Let (extern_function nameIR ( parameterIR* ) : typeIR) be (callableTypeIR as externFunctionTypeIR))

    2. (Let parameterIR_subst be $subst_parameterIR'(theta, parameterIR))*

    3. (Let typeIR_subst be $subst_typeIR'(theta, typeIR))

    4. Return ((extern_function nameIR ( parameterIR_subst* ) : typeIR_subst) as callableTypeIR)

  4. Case (% has type builtinMethodTypeIR)

    1. (Let (builtin_method nameIR ( parameterIR* ) : typeIR) be (callableTypeIR as builtinMethodTypeIR))

    2. (Let parameterIR_subst be $subst_parameterIR'(theta, parameterIR))*

    3. (Let typeIR_subst be $subst_typeIR'(theta, typeIR))

    4. Return ((builtin_method nameIR ( parameterIR_subst* ) : typeIR_subst) as callableTypeIR)

  5. Case (% has type externMethodTypeIR)

    1. (Let externMethodTypeIR be (callableTypeIR as externMethodTypeIR))

    2. Case analysis on externMethodTypeIR

      1. Case (% matches pattern `EXTERN_METHOD % (%) : %`)

        1. (Let (extern_method nameIR ( parameterIR* ) : typeIR) be externMethodTypeIR)

        2. (Let parameterIR_subst be $subst_parameterIR'(theta, parameterIR))*

        3. (Let typeIR_subst be $subst_typeIR'(theta, typeIR))

        4. Return ((extern_method nameIR ( parameterIR_subst* ) : typeIR_subst) as callableTypeIR)

      2. Case (% matches pattern `EXTERN_METHOD ABSTRACT % (%) : %`)

        1. (Let (extern_method abstract nameIR ( parameterIR* ) : typeIR) be externMethodTypeIR)

        2. (Let parameterIR_subst be $subst_parameterIR'(theta, parameterIR))*

        3. (Let typeIR_subst be $subst_typeIR'(theta, typeIR))

        4. Return ((extern_method abstract nameIR ( parameterIR_subst* ) : typeIR_subst) as callableTypeIR)

  6. Case (% has type parserApplyMethodTypeIR)

    1. (Let (parser_apply ( parameterIR* )) be (callableTypeIR as parserApplyMethodTypeIR))

    2. (Let parameterIR_subst be $subst_parameterIR'(theta, parameterIR))*

    3. Return ((parser_apply ( parameterIR_subst* )) as callableTypeIR)

  7. Case (% has type controlApplyMethodTypeIR)

    1. (Let (control_apply ( parameterIR* )) be (callableTypeIR as controlApplyMethodTypeIR))

    2. (Let parameterIR_subst be $subst_parameterIR'(theta, parameterIR))*

    3. Return ((control_apply ( parameterIR_subst* )) as callableTypeIR)

  8. Case (% has type tableApplyMethodTypeIR)

    1. (Let tableApplyMethodTypeIR be (callableTypeIR as tableApplyMethodTypeIR))

    2. Return (tableApplyMethodTypeIR as callableTypeIR)

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.5.2-type-subst.spectec:30:1-31:40:
dec $subst_callableTypeDefIR(set<pair<typeId, typeIR>>', callableTypeDefIR)

1. If ((set<pair<typeId, typeIR>>' = ({ [] }))), then

