;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.3.3-type-callable-def.spectec:45:36-45:58:
syntax tableApplyMethodTypeDefIR = tableApplyMethodTypeIR

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.3.3-type-callable-def.spectec:48:1-51:30:
syntax methodTypeDefIR = 
   | extern_method nameIR < typeParameterIR* , typeParameterIR* > ( parameterIR* ) : typeIR (from externMethodTypeDefIR)
   | extern_method abstract nameIR < typeParameterIR* , typeParameterIR* > ( parameterIR* ) : typeIR (from externMethodTypeDefIR)
   | parser_apply ( parameterIR* ) (from parserApplyMethodTypeIR)
   | control_apply ( parameterIR* ) (from controlApplyMethodTypeIR)
   | table_apply : tableMetadataStructTypeIR (from tableApplyMethodTypeIR)

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.3.3-type-callable-def.spectec:58:1-60:20:
syntax callableTypeDefIR = 
   | annotationList action nameIR ( parameterIR* ) (from actionTypeIR)
   | function nameIR < typeParameterIR* , typeParameterIR* > ( parameterIR* ) : typeIR (from definedFunctionTypeDefIR)
   | extern_function nameIR < typeParameterIR* , typeParameterIR* > ( parameterIR* ) : typeIR (from externFunctionTypeDefIR)
   | extern_method nameIR < typeParameterIR* , typeParameterIR* > ( parameterIR* ) : typeIR (from externMethodTypeDefIR)
   | extern_method abstract nameIR < typeParameterIR* , typeParameterIR* > ( parameterIR* ) : typeIR (from externMethodTypeDefIR)
   | parser_apply ( parameterIR* ) (from parserApplyMethodTypeIR)
   | control_apply ( parameterIR* ) (from controlApplyMethodTypeIR)
   | table_apply : tableMetadataStructTypeIR (from tableApplyMethodTypeIR)

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.3.4-type-callable-def-aux.spectec:5:1-7:45:
dec $callableTypeIR_of_callableTypeDefIR(callableTypeDefIR)

1. Case analysis on callableTypeDefIR

  1. Case (% has type actionTypeDefIR)

    1. (Let actionTypeDefIR be (callableTypeDefIR as actionTypeDefIR))

    2. Return (actionTypeDefIR as callableTypeIR)

  2. Case (% has type definedFunctionTypeDefIR)

    1. (Let (function nameIR < _typeParameterIR* , _typeParameterIR'* > ( parameterIR* ) : typeIR) be (callableTypeDefIR as definedFunctionTypeDefIR))

    2. Return ((function nameIR ( parameterIR* ) : typeIR) as callableTypeIR)

  3. Case (% has type externFunctionTypeDefIR)

    1. (Let (extern_function nameIR < _typeParameterIR* , _typeParameterIR'* > ( parameterIR* ) : typeIR) be (callableTypeDefIR as externFunctionTypeDefIR))

    2. Return ((extern_function nameIR ( parameterIR* ) : typeIR) as callableTypeIR)

  4. Case (% has type externMethodTypeDefIR)

    1. (Let externMethodTypeDefIR be (callableTypeDefIR as externMethodTypeDefIR))

    2. Case analysis on externMethodTypeDefIR

      1. Case (% matches pattern `EXTERN_METHOD % <% , %> (%) : %`)

        1. (Let (extern_method nameIR < _typeParameterIR* , _typeParameterIR'* > ( parameterIR* ) : typeIR) be externMethodTypeDefIR)

        2. Return ((extern_method nameIR ( parameterIR* ) : typeIR) as callableTypeIR)

      2. Case (% matches pattern `EXTERN_METHOD ABSTRACT % <% , %> (%) : %`)

        1. (Let (extern_method abstract nameIR < _typeParameterIR* , _typeParameterIR'* > ( parameterIR* ) : typeIR) be externMethodTypeDefIR)

        2. Return ((extern_method abstract nameIR ( parameterIR* ) : typeIR) as callableTypeIR)

  5. Case (% has type parserApplyMethodTypeDefIR)

    1. (Let parserApplyMethodTypeDefIR be (callableTypeDefIR as parserApplyMethodTypeDefIR))

    2. Return (parserApplyMethodTypeDefIR as callableTypeIR)

  6. Case (% has type controlApplyMethodTypeDefIR)

    1. (Let controlApplyMethodTypeDefIR be (callableTypeDefIR as controlApplyMethodTypeDefIR))

    2. Return (controlApplyMethodTypeDefIR as callableTypeIR)

1. Else Phantom#107

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.3.4-type-callable-def-aux.spectec:46:1-48:45:
dec $typeParameterListIR_of_callableTypeDefIR(callableTypeDefIR)

1. Case analysis on callableTypeDefIR

  1. Case (% has type actionTypeDefIR)

    1. (Let actionTypeDefIR be (callableTypeDefIR as actionTypeDefIR))

    2. Return ([], [])

  2. Case (% has type definedFunctionTypeDefIR)

    1. (Let (function _nameIR < typeParameterIR_expl* , typeParameterIR_impl* > ( _parameterIR* ) : _typeIR) be (callableTypeDefIR as definedFunctionTypeDefIR))

    2. Return (typeParameterIR_expl*, typeParameterIR_impl*)

  3. Case (% has type externFunctionTypeDefIR)

    1. (Let (extern_function _nameIR < typeParameterIR_expl* , typeParameterIR_impl* > ( _parameterIR* ) : _typeIR) be (callableTypeDefIR as externFunctionTypeDefIR))

    2. Return (typeParameterIR_expl*, typeParameterIR_impl*)

  4. Case (% has type externMethodTypeDefIR)

    1. (Let externMethodTypeDefIR be (callableTypeDefIR as externMethodTypeDefIR))

    2. Case analysis on externMethodTypeDefIR

      1. Case (% matches pattern `EXTERN_METHOD % <% , %> (%) : %`)

        1. (Let (extern_method _nameIR < typeParameterIR_expl* , typeParameterIR_impl* > ( _parameterIR* ) : _typeIR) be externMethodTypeDefIR)

        2. Return (typeParameterIR_expl*, typeParameterIR_impl*)

      2. Case (% matches pattern `EXTERN_METHOD ABSTRACT % <% , %> (%) : %`)

        1. (Let (extern_method abstract _nameIR < typeParameterIR_expl* , typeParameterIR_impl* > ( _parameterIR* ) : _typeIR) be externMethodTypeDefIR)

        2. Return (typeParameterIR_expl*, typeParameterIR_impl*)

  5. Case (% has type parserApplyMethodTypeDefIR)

    1. (Let parserApplyMethodTypeDefIR be (callableTypeDefIR as parserApplyMethodTypeDefIR))

    2. Return ([], [])

  6. Case (% has type controlApplyMethodTypeDefIR)

    1. (Let controlApplyMethodTypeDefIR be (callableTypeDefIR as controlApplyMethodTypeDefIR))

    2. Return ([], [])

1. Else Phantom#108

