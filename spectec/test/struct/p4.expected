;; ../../../../../spectec/examples/p4-concrete/0-aux/0.0-stdlib.spectec:98:1-99:48:
dec $starts_with(t, t_prefix)

1. If ((|t_prefix| <= |t|)), then

  1. If ((t[0 : |t_prefix|] = t_prefix)), then

    1. Return true

2. Otherwise

  1. Return false

;; ../../../../../spectec/examples/p4-concrete/0-aux/0.0-stdlib.spectec:106:1-107:46:
dec $ends_with(t, t_suffix)

1. If ((|t_suffix| <= |t|)), then

  1. (Let n_start be (|t| - |t_suffix|))

  2. If ((t[n_start : |t_suffix|] = t_suffix)), then

    1. Return true

2. Otherwise

  1. Return false

;; ../../../../../spectec/examples/p4-concrete/0-aux/0.0-stdlib.spectec:115:1-116:85:
dec $strip_prefix_rec(t, t_prefix)

1. Case analysis on $starts_with(t, t_prefix)

  1. Case true

    1. (Let t_stripped be $strip_prefix(t, t_prefix))

    2. Return $strip_prefix_rec(t_stripped, t_prefix)

  2. Case false

    1. Return t

;; ../../../../../spectec/examples/p4-concrete/0-aux/0.0-stdlib.spectec:124:1-125:85:
dec $strip_suffix_rec(t, t_suffix)

1. Case analysis on $ends_with(t, t_suffix)

  1. Case true

    1. (Let t_stripped be $strip_suffix(t, t_suffix))

    2. Return $strip_suffix_rec(t_stripped, t_suffix)

  2. Case false

    1. Return t

;; ../../../../../spectec/examples/p4-concrete/0-aux/0.0-stdlib.spectec:133:1-134:45:
