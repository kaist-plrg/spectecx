syntax constructorId = callTargetId

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.0-domain.spectec:69:1-70:58:
dec $callableId(name, parameterList)

1. Return ($name(name) ( $callableId'(parameterList) ))

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.0-domain.spectec:71:1-71:38:
dec $callableId'(parameterList)

1. If ((parameterList matches pattern ``EMPTY`)), then

  1. Return []

1. Else Phantom#67

2. If ((parameterList has type parameter)), then

  1. (Let (_annotationList _direction _type name _initializerOpt) be (parameterList as parameter))

  2. Return [$name(name)]

2. Else Phantom#68

3. If ((parameterList has type nonEmptyParameterList)), then

  1. (Let nonEmptyParameterList' be (parameterList as nonEmptyParameterList))

  2. If ((nonEmptyParameterList' matches pattern `% , %`)), then

    1. (Let (nonEmptyParameterList , (_annotationList _direction _type name _initializerOpt)) be nonEmptyParameterList')

    2. Return $callableId'((nonEmptyParameterList as parameterList)) ++ [$name(name)]

  2. Else Phantom#69

3. Else Phantom#70

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.0-domain.spectec:73:1-74:56:
dec $constructorId(name, constructorParameterListOpt)

1. Case analysis on constructorParameterListOpt

  1. Case (% matches pattern ``EMPTY`)

    1. Return ($name(name) ( [] ))

  2. Case (% matches pattern `(%)`)

    1. (Let (( parameterList )) be constructorParameterListOpt)

    2. Return $callableId(name, parameterList)

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.0-domain.spectec:91:19-91:26:
