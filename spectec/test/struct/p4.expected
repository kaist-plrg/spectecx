;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.6-type-alpha.spectec:11:1-15:56:
relation ParameterType_alpha: (_annotationList direction typeIR_a _id _parameterInitializerOptIR), (_annotationList' direction' typeIR_b _id' _parameterInitializerOptIR')

1. If ((direction = direction')), then

  1. If (Type_alpha: typeIR_a ~~ typeIR_b holds), then

    1. The relation holds

  1. Else Phantom#201

1. Else Phantom#202

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.6-type-alpha.spectec:17:1-21:56:
relation ExternMethodType_alpha: externMethodTypeIR, externMethodTypeIR'

1. Case analysis on externMethodTypeIR

  1. Case (% matches pattern `EXTERN_METHOD % (%) : %`)

    1. (Let (extern_method nameIR ( parameterIR_a* ) : typeIR_a) be externMethodTypeIR)

    2. If ((externMethodTypeIR' matches pattern `EXTERN_METHOD % (%) : %`)), then

      1. (Let (extern_method nameIR' ( parameterIR_b* ) : typeIR_b) be externMethodTypeIR')

      2. If ((nameIR = nameIR')), then

        1. If (ParameterType_alpha: parameterIR_a ~~ parameterIR_b holds)*, then

          1. If (Type_alpha: typeIR_a ~~ typeIR_b holds), then

            1. The relation holds

          1. Else Phantom#203

        1. Else Phantom#204

      2. Else Phantom#205

    2. Else Phantom#206

  2. Case (% matches pattern `EXTERN_METHOD ABSTRACT % (%) : %`)

    1. (Let (extern_method abstract nameIR ( parameterIR_a* ) : typeIR_a) be externMethodTypeIR)

    2. If ((externMethodTypeIR' matches pattern `EXTERN_METHOD ABSTRACT % (%) : %`)), then

      1. (Let (extern_method abstract nameIR' ( parameterIR_b* ) : typeIR_b) be externMethodTypeIR')

      2. If ((nameIR = nameIR')), then

        1. If (ParameterType_alpha: parameterIR_a ~~ parameterIR_b holds)*, then

          1. If (Type_alpha: typeIR_a ~~ typeIR_b holds), then

            1. The relation holds

          1. Else Phantom#207

        1. Else Phantom#208

      2. Else Phantom#209

    2. Else Phantom#210

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.6-type-alpha.spectec:23:1-27:56:
relation ExternMethodTypeDef_alpha: externMethodTypeDefIR_a, externMethodTypeDefIR_b

1. (Let (typeParameterIR_expl_a*, typeParameterIR_impl_a*) be $typeParameterListIR_of_callableTypeDefIR((externMethodTypeDefIR_a as callableTypeDefIR)))

2. (Let (typeParameterIR_expl_b*, typeParameterIR_impl_b*) be $typeParameterListIR_of_callableTypeDefIR((externMethodTypeDefIR_b as callableTypeDefIR)))

3. If ((|typeParameterIR_expl_a*| = |typeParameterIR_expl_b*|)), then

  1. If ((|typeParameterIR_impl_a*| = |typeParameterIR_impl_b*|)), then

    1. (Let typeParameterIR_fresh* be $fresh_typeIds(|typeParameterIR_expl_a* ++ typeParameterIR_impl_a*|))

    2. (Let typeParameterIR_a* be typeParameterIR_expl_a* ++ typeParameterIR_impl_a*)

    3. (Let theta_a be ({ (typeParameterIR_a : ((` typeParameterIR_fresh) as typeIR))* }))

    4. (Let callableTypeIR be $callableTypeIR_of_callableTypeDefIR((externMethodTypeDefIR_a as callableTypeDefIR)))

    5. If ((callableTypeIR has type externMethodTypeIR)), then

      1. (Let externMethodTypeIR_a be (callableTypeIR as externMethodTypeIR))

      2. (Let callableTypeIR' be $subst_callableTypeIR(theta_a, (externMethodTypeIR_a as callableTypeIR)))

      3. If ((callableTypeIR' has type externMethodTypeIR)), then

        1. (Let externMethodTypeIR_a_subst be (callableTypeIR' as externMethodTypeIR))

        2. (Let typeParameterIR_b* be typeParameterIR_expl_b* ++ typeParameterIR_impl_b*)

        3. (Let theta_b be ({ (typeParameterIR_b : ((` typeParameterIR_fresh) as typeIR))* }))

        4. (Let callableTypeIR'' be $callableTypeIR_of_callableTypeDefIR((externMethodTypeDefIR_b as callableTypeDefIR)))

        5. If ((callableTypeIR'' has type externMethodTypeIR)), then

          1. (Let externMethodTypeIR_b be (callableTypeIR'' as externMethodTypeIR))

          2. (Let callableTypeIR''' be $subst_callableTypeIR(theta_b, (externMethodTypeIR_b as callableTypeIR)))

          3. If ((callableTypeIR''' has type externMethodTypeIR)), then

            1. (Let externMethodTypeIR_b_subst be (callableTypeIR''' as externMethodTypeIR))

            2. If (ExternMethodType_alpha: externMethodTypeIR_a_subst ~~ externMethodTypeIR_b_subst holds), then

              1. The relation holds

            2. Else Phantom#211

          3. Else Phantom#212

        5. Else Phantom#213

      3. Else Phantom#214

    5. Else Phantom#215

  1. Else Phantom#216

3. Else Phantom#217

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.7-compile-time-known.spectec:5:14-5:30:
syntax ctk = 
   | lctk (from ctk)
   | ctk (from ctk)
   | dyn (from ctk)

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.7-compile-time-known.spectec:7:1-8:43:
dec $join_ctk(ctk'', ctk''')

1. Case analysis on ctk''

  1. Case (% matches pattern `LCTK`)

    1. Case analysis on ctk'''

      1. Case (% matches pattern `LCTK`)

        1. Return (lctk)

      2. Case (% matches pattern `CTK`)

        1. Return (ctk)

  2. Case (% matches pattern `CTK`)

    1. Case analysis on ctk'''

      1. Case (% matches pattern `LCTK`)

        1. Return (ctk)

      2. Case (% matches pattern `CTK`)

        1. Return (ctk)

2. Otherwise

  1. Return (dyn)

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.7-compile-time-known.spectec:17:1-18:34:
dec $joins_ctk(ctk''*)

1. Case analysis on ctk''*

  1. Case (% matches pattern [])

    1. Return (lctk)

  2. Case (% matches pattern [ _/1 ])

    1. (Let [ctk''] be ctk''*)

    2. Return ctk''

  3. Case (% matches pattern _ :: _)

    1. (Let ctk_a :: ctk''* be ctk''*)

    2. Case analysis on ctk''*

      1. Case (% matches pattern [ _/1 ])

        1. (Let [ctk_b] be ctk''*)

        2. Return $join_ctk(ctk_a, ctk_b)

      2. Case (% matches pattern _ :: _)

        1. (Let ctk_b :: ctk_c* be ctk''*)

        2. If ((ctk_c* =/= [])), then

          1. (Let ctk_d be $join_ctk(ctk_a, ctk_b))

          2. Return $joins_ctk(ctk_d :: ctk_c*)

        2. Else Phantom#218

    2. Else Phantom#219

1. Else Phantom#220

;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:5:1-6:40:
