syntax annotationListNonEmpty = 
   | @ name (from annotation) hint(print "@"#%0)
   | @ name ( annotationBody ) (from annotation) hint(print "@"#%0#"("#%1#")")
   | @ name [ structuredAnnotationBody ] (from annotation) hint(print "@"#%0#"["#%1#"]")
