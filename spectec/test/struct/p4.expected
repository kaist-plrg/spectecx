   | bit < int > (from baseType)
   | bit < ( expression ) > (from baseType)
   | varbit < int > (from baseType)
   | varbit < ( expression ) > (from baseType)
   | text (from typeIdentifier)
   | . typeName (from prefixedTypeName)
   | prefixedTypeName < typeArgumentList > (from specializedType)
