;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.3-annotation.spectec:9:1-9:47:
dec $name_annotation(annotationList)

1. (Let annotation* be $flatten_annotationList(annotationList))

2. (Let nameIR_opt? be $name_annotation_opt(annotation))*

3. (Let nameIR_found** be $opt_as_seq_<nameIR>(nameIR_opt?)*)

4. Return $concat_<nameIR>(nameIR_found**)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.3-annotation.spectec:10:1-10:47:
dec $name_annotation_opt(annotation)

1. If ((annotation matches pattern `@ % (%)`)), then

  1. (Let (@ name ( annotationBody )) be annotation)

  2. If (("name" = $name(name))), then

    1. (Let annotationBody'' be annotationBody)

    2. If ((annotationBody'' matches pattern `% %`)), then

      1. (Let (annotationBody' annotationToken) be annotationBody'')

      2. If ((annotationBody' matches pattern ``EMPTY`)), then

        1. (Let nameIR be $name_annotationToken(annotationToken))

        2. Return ?($strip_prefix($strip_suffix(nameIR, "\""), "\""))

2. Otherwise

  1. Return ?()

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.3-annotation.spectec:11:1-11:62:
dec $name_annotation_default(annotationList, nameIR)

1. (Let nameIR'* be $name_annotation(annotationList))

2. If ((nameIR'* matches pattern [ _/1 ])), then

  1. (Let [nameIR_found] be nameIR'*)

  2. Return nameIR_found

2. Else Phantom#529

3. If (([] = $name_annotation(annotationList))), then

  1. Return nameIR

3. Else Phantom#530

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.3-annotation.spectec:127:1-127:60:
dec $find_name_annotation_opt(annotationList')

1. If ((annotationList' matches pattern ``EMPTY`)), then

  1. Return ?()

2. If ((annotationList' has type annotation)), then

  1. (Let annotation be (annotationList' as annotation))

  2. (Let annotation' be annotation)

  3. If ((annotation' matches pattern `@ % (%)`)), then

    1. (Let (@ name ( annotationBody )) be annotation')

    2. Case analysis on "name"

      1. Case (% = $name(name))

        1. Return ?(annotation)

      2. Case (% =/= $name(name))

        1. Return ?()

3. If ((annotationList' has type annotationListNonEmpty)), then

  1. (Let annotationListNonEmpty' be (annotationList' as annotationListNonEmpty))

  2. If ((annotationListNonEmpty' matches pattern `% %`)), then

    1. (Let (annotationListNonEmpty annotation) be annotationListNonEmpty')

    2. If ((?() = $find_name_annotation_opt((annotation as annotationList)))), then

      1. Return $find_name_annotation_opt((annotationListNonEmpty as annotationList))

    3. (Let annotation'? be $find_name_annotation_opt((annotation as annotationList)))

    4. If ((annotation'? matches pattern (_))), then

      1. (Let ?(annotation_found) be annotation'?)

      2. Return ?(annotation_found)

4. Otherwise

  1. Return ?()

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.3-annotation.spectec:146:1-146:70:
dec $add_annotationList(annotationList, annotation''?)

1. If ((annotation''? matches pattern ())), then

  1. Return annotationList

1. Else Phantom#531

2. If ((annotationList matches pattern ``EMPTY`)), then

  1. If ((annotation''? matches pattern (_))), then

    1. (Let ?(annotation'') be annotation''?)

    2. Return (annotation'' as annotationList)

  1. Else Phantom#532

2. Else Phantom#533

3. If ((annotationList has type annotationListNonEmpty)), then

  1. (Let annotationListNonEmpty be (annotationList as annotationListNonEmpty))

  2. If ((annotation''? matches pattern (_))), then

    1. (Let ?(annotation'') be annotation''?)

    2. Return ((annotationListNonEmpty annotation'') as annotationList)

  2. Else Phantom#534

3. Else Phantom#535

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.4-ir-subexpression.spectec:5:1-7:45:
dec $subexpressions_of_typedExpressionIR(typedExpressionIR)

1. (Let (expressionIR # _expressionNoteIR) be typedExpressionIR)

2. Return typedExpressionIR :: $subexpressions_of_expressionIR(expressionIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.4-ir-subexpression.spectec:9:1-11:45:
dec $subexpressions_of_typedExpressionListIR(typedExpressionIR*)

1. Return $concat_<typedExpressionIR>($subexpressions_of_typedExpressionIR(typedExpressionIR)*)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.4-ir-subexpression.spectec:13:1-15:45:
dec $subexpressions_of_expressionIR(expressionIR')

1. Case analysis on expressionIR'

  1. Case (% has type unaryExpressionIR)

    1. (Let (unop typedExpressionIR) be (expressionIR' as unaryExpressionIR))

    2. Return $subexpressions_of_typedExpressionIR(typedExpressionIR)

  2. Case (% has type binaryExpressionIR)

    1. (Let (typedExpressionIR_l binop typedExpressionIR_r) be (expressionIR' as binaryExpressionIR))

    2. Return $subexpressions_of_typedExpressionIR(typedExpressionIR_l) ++ $subexpressions_of_typedExpressionIR(typedExpressionIR_r)

  3. Case (% has type ternaryExpressionIR)

    1. (Let (typedExpressionIR_cond ? typedExpressionIR_then : typedExpressionIR_else) be (expressionIR' as ternaryExpressionIR))

    2. Return $subexpressions_of_typedExpressionIR(typedExpressionIR_cond) ++ $subexpressions_of_typedExpressionIR(typedExpressionIR_then) ++ $subexpressions_of_typedExpressionIR(typedExpressionIR_else)

  4. Case (% has type castExpressionIR)

    1. (Let (( typeIR ) typedExpressionIR) be (expressionIR' as castExpressionIR))

    2. Return $subexpressions_of_typedExpressionIR(typedExpressionIR)

  5. Case (% has type sequenceExpressionIR)

    1. (Let sequenceExpressionIR be (expressionIR' as sequenceExpressionIR))

    2. Case analysis on sequenceExpressionIR

      1. Case (% matches pattern `SEQ {%}`)

        1. (Let (seq { typedExpressionListIR }) be sequenceExpressionIR)

        2. Return $subexpressions_of_typedExpressionListIR(typedExpressionListIR)

      2. Case (% matches pattern `SEQ {% , ...}`)

        1. (Let (seq { typedExpressionListIR , ... }) be sequenceExpressionIR)

        2. Return $subexpressions_of_typedExpressionListIR(typedExpressionListIR)

  6. Case (% has type recordExpressionIR)

    1. (Let recordExpressionIR be (expressionIR' as recordExpressionIR))

    2. Case analysis on recordExpressionIR

      1. Case (% matches pattern `RECORD {%}`)

        1. (Let (record { (nameIR = typedExpressionIR)* }) be recordExpressionIR)

        2. Return $subexpressions_of_typedExpressionListIR(typedExpressionIR*)

      2. Case (% matches pattern `RECORD {% , ...}`)

        1. (Let (record { (nameIR = typedExpressionIR)* , ... }) be recordExpressionIR)

        2. Return $subexpressions_of_typedExpressionListIR(typedExpressionIR*)

  7. Case (% has type memberAccessExpressionIR)

    1. (Let (memberAccessBaseIR . nameIR) be (expressionIR' as memberAccessExpressionIR))

    2. If ((memberAccessBaseIR has type typedExpressionIR)), then

      1. (Let typedExpressionIR be (memberAccessBaseIR as typedExpressionIR))

      2. Return $subexpressions_of_typedExpressionIR(typedExpressionIR)

  8. Case (% has type indexAccessExpressionIR)

    1. (Let (typedExpressionIR_base [ typedExpressionIR_index ]) be (expressionIR' as indexAccessExpressionIR))

    2. Return $subexpressions_of_typedExpressionIR(typedExpressionIR_base) ++ $subexpressions_of_typedExpressionIR(typedExpressionIR_index)

  9. Case (% has type sliceAccessExpressionIR)

    1. (Let sliceAccessExpressionIR be (expressionIR' as sliceAccessExpressionIR))

    2. If ((sliceAccessExpressionIR matches pattern `% [% : %]`)), then

      1. (Let (typedExpressionIR_base [ typedExpressionIR_hi : typedExpressionIR_lo ]) be sliceAccessExpressionIR)

      2. Return $subexpressions_of_typedExpressionIR(typedExpressionIR_base) ++ $subexpressions_of_typedExpressionIR(typedExpressionIR_hi) ++ $subexpressions_of_typedExpressionIR(typedExpressionIR_lo)

  10. Case (% has type callExpressionIR)

    1. (Let callExpressionIR be (expressionIR' as callExpressionIR))

    2. Case analysis on callExpressionIR

      1. Case (% matches pattern `% (%)`)

        1. (Let (constructorTargetIR ( argumentIR* )) be callExpressionIR)

        2. Return $subexpressions_of_argumentListIR(argumentIR*)

      2. Case (% matches pattern `% <%> (%)`)

        1. (Let (callableTargetIR < typeArgumentIR* > ( argumentIR* )) be callExpressionIR)

        2. Return $subexpressions_of_argumentListIR(argumentIR*)

  11. Case (% has type parenthesizedExpressionIR)

    1. (Let (( typedExpressionIR )) be (expressionIR' as parenthesizedExpressionIR))

    2. Return $subexpressions_of_typedExpressionIR(typedExpressionIR)

2. Otherwise

  1. Return []

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.4-ir-subexpression.spectec:17:1-19:45:
dec $subexpressions_of_argumentIR(argumentIR')

1. If ((argumentIR' has type typedExpressionIR)), then

  1. (Let typedExpressionIR be (argumentIR' as typedExpressionIR))

  2. Return $subexpressions_of_typedExpressionIR(typedExpressionIR)

2. If ((argumentIR' matches pattern `% = %`)), then

  1. (Let (nameIR = typedExpressionIR) be argumentIR')

  2. Return $subexpressions_of_typedExpressionIR(typedExpressionIR)

3. Otherwise

  1. Return []

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.4-ir-subexpression.spectec:21:1-23:45:
dec $subexpressions_of_argumentListIR(argumentIR*)

1. Return $concat_<typedExpressionIR>($subexpressions_of_argumentIR(argumentIR)*)

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.00-flow.spectec:5:15-5:25:
syntax flow = 
   | cont (from flow)
   | ret (from flow)

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.00-flow.spectec:9:1-10:58:
dec $join_flow(flow'', flow''')

1. If ((flow'' matches pattern `RET`)), then

  1. If ((flow''' matches pattern `RET`)), then

    1. Return (ret)

2. Otherwise

  1. Return (cont)

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.01-static-env.spectec:7:20-8:82:
syntax varTypeIR = 
   | direction typeIR ctk value? (from varTypeIR) hint(prose_fields "direction" "type" "compile-time known-ness" "default value")

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.01-static-env.spectec:10:20-10:38:
syntax typeFrame = map<id, varTypeIR>

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.01-static-env.spectec:12:1-12:33:
dec $empty_typeFrame

1. Return $empty_map<id, varTypeIR>

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.01-static-env.spectec:17:21-17:43:
syntax typeDefEnv = map<typeId, typeDefIR>

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.01-static-env.spectec:19:1-19:35:
dec $empty_typeDefEnv

1. Return $empty_map<typeId, typeDefIR>

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.01-static-env.spectec:24:29-24:63:
syntax callableTypeDefEnv = map<callableId, callableTypeDefIR>

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.01-static-env.spectec:26:1-26:51:
dec $empty_callableTypeDefEnv

1. Return $empty_map<callableId, callableTypeDefIR>

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.01-static-env.spectec:31:32-31:72:
syntax constructorTypeDefEnv = map<constructorId, constructorTypeDefIR>

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.01-static-env.spectec:33:1-33:57:
dec $empty_constructorTypeDefEnv

1. Return $empty_map<constructorId, constructorTypeDefIR>

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.02.1-typing-context.spectec:8:3-11:22:
syntax globalTypingLayer = {constructor constructorTypeDefEnv, type typeDefEnv, callable callableTypeDefEnv, frame typeFrame}

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.02.1-typing-context.spectec:16:1-20:12:
syntax blockKind = 
   |  (from blockKind)
   | extern (from blockKind)
   | parser (from blockKind)
   | control (from blockKind)
   | package (from blockKind)

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.02.1-typing-context.spectec:23:3-26:22:
syntax blockTypingLayer = {kind blockKind, type typeDefEnv, callable callableTypeDefEnv, frame typeFrame}

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.02.1-typing-context.spectec:30:26-30:32:
syntax actionLocalKind = 
   | action (from actionLocalKind)

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.02.1-typing-context.spectec:33:3-33:21:
syntax definedFunctionLocalKind = 
   | function : typeIR (from definedFunctionLocalKind)

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.02.1-typing-context.spectec:36:3-36:28:
syntax externFunctionLocalKind = 
   | extern_function : typeIR (from externFunctionLocalKind)

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.02.1-typing-context.spectec:39:1-40:28:
syntax functionLocalKind = 
   | function : typeIR (from definedFunctionLocalKind)
   | extern_function : typeIR (from externFunctionLocalKind)

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.02.1-typing-context.spectec:43:1-44:37:
syntax externMethodLocalKind = 
   | extern_method : typeIR (from externMethodLocalKind)
   | extern_method abstract : typeIR (from externMethodLocalKind)

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.02.1-typing-context.spectec:47:1-50:23:
syntax methodLocalKind = 
   | extern_method : typeIR (from externMethodLocalKind)
   | extern_method abstract : typeIR (from externMethodLocalKind)
   | parser_state (from methodLocalKind)
   | control_apply_method (from methodLocalKind)
   | table_apply_method (from methodLocalKind)

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.02.1-typing-context.spectec:53:1-56:20:
syntax localKind = 
   |  (from localKind)
   | action (from actionLocalKind)
   | function : typeIR (from definedFunctionLocalKind)
   | extern_function : typeIR (from externFunctionLocalKind)
   | extern_method : typeIR (from externMethodLocalKind)
   | extern_method abstract : typeIR (from externMethodLocalKind)
   | parser_state (from methodLocalKind)
   | control_apply_method (from methodLocalKind)
   | table_apply_method (from methodLocalKind)

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.02.1-typing-context.spectec:59:3-61:24:
syntax localTypingLayer = {kind localKind, type typeDefEnv, frames typeFrame*}

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.02.1-typing-context.spectec:68:3-70:29:
syntax typingContext = {global globalTypingLayer, block blockTypingLayer, local localTypingLayer}

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.02.1-typing-context.spectec:78:1-79:43:
dec $empty_typingContext

1. (Let globalTypingLayer be {constructor $empty_constructorTypeDefEnv, type $empty_typeDefEnv, callable $empty_callableTypeDefEnv, frame $empty_typeFrame})

2. (Let blockTypingLayer be {kind (), type $empty_typeDefEnv, callable $empty_callableTypeDefEnv, frame $empty_typeFrame})

3. (Let localTypingLayer be {kind (), type $empty_typeDefEnv, frames [$empty_typeFrame]})

4. (Let TC be {global globalTypingLayer, block blockTypingLayer, local localTypingLayer})

5. Return TC

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.02.1-typing-context.spectec:105:1-106:66:
dec $bound(cursor, TC)

1. Case analysis on cursor

  1. Case (% matches pattern `GLOBAL`)

    1. Return ({ [] })

  2. Case (% matches pattern `BLOCK`)

    1. Return $dom_map<typeId, typeDefIR>(TC.block.type)

  3. Case (% matches pattern `LOCAL`)

    1. (Let B_block be $bound((block), TC))

    2. (Let B_local be $dom_map<typeId, typeDefIR>(TC.local.type))

    3. Return $union_set<typeId>(B_block, B_local)

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.02.1-typing-context.spectec:118:1-119:45:
dec $enter_t(TC)

1. Return TC[local.frames = $empty_typeFrame :: TC.local.frames]

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.02.1-typing-context.spectec:124:1-125:55:
dec $exit_t(TC)

1. (Let typeFrame* be TC.local.frames)

2. If ((typeFrame* matches pattern _ :: _)), then

  1. (Let typeFrame_h :: typeFrame_t* be typeFrame*)

  2. Return TC[local.frames = typeFrame_t*]

2. Else Phantom#536

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.02.1-typing-context.spectec:136:1-137:68:
dec $add_var_t(cursor, TC, id, varTypeIR)

1. Case analysis on cursor

  1. Case (% matches pattern `GLOBAL`)

    1. (Let typeFrame be TC.global.frame)

    2. If (~$in_set<id>(id, $dom_map<id, varTypeIR>(typeFrame))), then

      1. (Let (_direction typeIR _ctk _value?) be varTypeIR)

      2. (Let typeIR_unroll be $unroll_typeIR(typeIR))

      3. If (((id = "main") => (typeIR_unroll has type packageObjectTypeIR))), then

        1. (Let typeFrame_update be $add_map<nameIR, varTypeIR>(typeFrame, id, varTypeIR))

        2. (Let TC' be TC[global.frame = typeFrame_update])

        3. Return TC'

      3. Else Phantom#537

    2. Else Phantom#538

  2. Case (% matches pattern `BLOCK`)

    1. (Let typeFrame be TC.block.frame)

    2. If (~$in_set<id>(id, $dom_map<id, varTypeIR>(typeFrame))), then

      1. If ((id =/= "main")), then

        1. (Let typeFrame_update be $add_map<nameIR, varTypeIR>(TC.block.frame, id, varTypeIR))

        2. (Let TC' be TC[block.frame = typeFrame_update])

        3. Return TC'

      1. Else Phantom#539

    2. Else Phantom#540

  3. Case (% matches pattern `LOCAL`)

    1. (Let typeFrame'* be TC.local.frames)

    2. If ((typeFrame'* matches pattern _ :: _)), then

      1. (Let typeFrame_h :: typeFrame_t* be typeFrame'*)

      2. If (~$in_set<id>(id, $dom_map<id, varTypeIR>(typeFrame_h))), then

        1. If ((id =/= "main")), then

          1. (Let typeFrame_h_update be $add_map<id, varTypeIR>(typeFrame_h, id, varTypeIR))

          2. (Let typeFrame* be typeFrame_h_update :: typeFrame_t*)

          3. (Let TC' be TC[local.frames = typeFrame*])

          4. Return TC'

        1. Else Phantom#541

      2. Else Phantom#542

    2. Else Phantom#543

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.02.1-typing-context.spectec:138:1-139:85:
dec $add_vars_t(p, TC, id*, varTypeIR*)

1. Case analysis on id*

  1. Case (% matches pattern [])

    1. If ((varTypeIR* matches pattern [])), then

      1. Return TC

    1. Else Phantom#544

  2. Case (% matches pattern _ :: _)

    1. (Let id_h :: id_t* be id*)

    2. If ((varTypeIR* matches pattern _ :: _)), then

      1. (Let varTypeIR_h :: varTypeIR_t* be varTypeIR*)

      2. (Let TC' be $add_var_t(p, TC, id_h, varTypeIR_h))

      3. (Let TC'' be $add_vars_t(p, TC', id_t*, varTypeIR_t*))

      4. Return TC''

    2. Else Phantom#545

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.02.1-typing-context.spectec:173:1-174:52:
dec $add_parameter_t(cursor, TC, (_annotationList direction typeIR id _parameterInitializerOptIR))

1. Case analysis on (direction matches pattern ``EMPTY`)

  1. Case true

    1. (Let varTypeIR be (() typeIR (ctk) ?()))

    2. (Let TC' be $add_var_t(cursor, TC, id, varTypeIR))

    3. Return TC'

  2. Case false

    1. (Let varTypeIR be (direction typeIR (dyn) ?()))

    2. (Let TC' be $add_var_t(cursor, TC, id, varTypeIR))

    3. Return TC'

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.02.1-typing-context.spectec:186:1-186:76:
dec $add_constructorParameter_t(TC, (_annotationList direction typeIR id _parameterInitializerOptIR))

1. (Let varTypeIR be (direction typeIR (ctk) ?()))

2. (Let TC' be $add_var_t((block), TC, id, varTypeIR))

3. Return TC'

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.02.1-typing-context.spectec:187:1-188:34:
dec $add_constructorParameters_t(TC, parameterIR*)

1. Case analysis on parameterIR*

  1. Case (% matches pattern [])

    1. Return TC

  2. Case (% matches pattern _ :: _)

    1. (Let parameterIR_h :: parameterIR_t* be parameterIR*)

    2. (Let TC' be $add_constructorParameter_t(TC, parameterIR_h))

    3. (Let TC'' be $add_constructorParameters_t(TC', parameterIR_t*))

    4. Return TC''

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.02.1-typing-context.spectec:201:1-202:68:
dec $add_typeDef_t(cursor, TC, typeId, typeDefIR)

1. Case analysis on cursor

  1. Case (% matches pattern `GLOBAL`)

    1. (Let typeDefEnv be TC.global.type)

    2. If (~$in_set<typeId>(typeId, $dom_map<typeId, typeDefIR>(typeDefEnv))), then

      1. (Let typeDefEnv_update be $add_map<typeId, typeDefIR>(typeDefEnv, typeId, typeDefIR))

      2. (Let TC' be TC[global.type = typeDefEnv_update])

      3. Return TC'

    2. Else Phantom#546

  2. Case (% matches pattern `BLOCK`)

    1. (Let typeDefEnv be TC.block.type)

    2. If (~$in_set<typeId>(typeId, $dom_map<typeId, typeDefIR>(typeDefEnv))), then

      1. (Let typeDefEnv_update be $add_map<typeId, typeDefIR>(typeDefEnv, typeId, typeDefIR))

      2. (Let TC' be TC[block.type = typeDefEnv_update])

      3. Return TC'

    2. Else Phantom#547

  3. Case (% matches pattern `LOCAL`)

    1. (Let typeDefEnv be TC.local.type)

    2. If (~$in_set<typeId>(typeId, $dom_map<typeId, typeDefIR>(typeDefEnv))), then

      1. (Let typeDefEnv_update be $add_map<typeId, typeDefIR>(typeDefEnv, typeId, typeDefIR))

      2. (Let TC' be TC[local.type = typeDefEnv_update])

      3. Return TC'

    2. Else Phantom#548

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.02.1-typing-context.spectec:203:1-204:85:
dec $add_typeDefs_t(p, TC, typeId*, typeDefIR*)

1. Case analysis on typeId*

  1. Case (% matches pattern [])

    1. If ((typeDefIR* matches pattern [])), then

      1. Return TC

    1. Else Phantom#549

  2. Case (% matches pattern _ :: _)

    1. (Let typeId_h :: typeId_t* be typeId*)

    2. If ((typeDefIR* matches pattern _ :: _)), then

      1. (Let typeDefIR_h :: typeDefIR_t* be typeDefIR*)

      2. (Let TC' be $add_typeDef_t(p, TC, typeId_h, typeDefIR_h))

      3. (Let TC'' be $add_typeDefs_t(p, TC', typeId_t*, typeDefIR_t*))

      4. Return TC''

    2. Else Phantom#550

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.02.1-typing-context.spectec:232:1-233:70:
dec $add_typeParameters_t(p, TC, typeId*)

1. Return $add_typeDefs_t(p, TC, typeId*, ((` typeId) as typeDefIR)*)

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.02.1-typing-context.spectec:240:1-242:94:
dec $add_callableDef_overload_t(cursor, TC, callableId, callableTypeDefIR)

1. Case analysis on cursor

  1. Case (% matches pattern `GLOBAL`)

    1. (Let callableTypeDefEnv be TC.global.callable)

    2. If (~$in_set<callableId>(callableId, $dom_map<callableId, callableTypeDefIR>(callableTypeDefEnv))), then

      1. (Let callableTypeDefEnv_update be $add_map<callableId, callableTypeDefIR>(callableTypeDefEnv, callableId, callableTypeDefIR))

      2. (Let TC' be TC[global.callable = callableTypeDefEnv_update])

      3. Return TC'

    2. Else Phantom#551

  2. Case (% matches pattern `BLOCK`)

    1. (Let callableTypeDefEnv be TC.block.callable)

    2. If (~$in_set<callableId>(callableId, $dom_map<callableId, callableTypeDefIR>(callableTypeDefEnv))), then

      1. (Let callableTypeDefEnv_update be $add_map<callableId, callableTypeDefIR>(callableTypeDefEnv, callableId, callableTypeDefIR))

      2. (Let TC' be TC[block.callable = callableTypeDefEnv_update])

      3. Return TC'

    2. Else Phantom#552

1. Else Phantom#553

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.02.1-typing-context.spectec:261:1-263:97:
dec $add_callableDef_non_overload_t(cursor, TC, callableId, callableTypeDefIR)

1. Case analysis on cursor

  1. Case (% matches pattern `GLOBAL`)

    1. (Let callableTypeDefEnv be TC.global.callable)

    2. (Let (nameIR ( _id* )) be callableId)

    3. (Let ({ (nameIR_k ( _id'* ))* }) be $dom_map<callableId, callableTypeDefIR>(callableTypeDefEnv))

    4. If (~$in_set<nameIR>(nameIR, ({ nameIR_k* }))), then

      1. (Let callableTypeDefEnv_update be $add_map<callableId, callableTypeDefIR>(callableTypeDefEnv, callableId, callableTypeDefIR))

      2. (Let TC' be TC[global.callable = callableTypeDefEnv_update])

      3. Return TC'

    4. Else Phantom#554

  2. Case (% matches pattern `BLOCK`)

    1. (Let callableTypeDefEnv be TC.block.callable)

    2. (Let (nameIR ( _id* )) be callableId)

    3. (Let ({ (nameIR_k ( _id'* ))* }) be $dom_map<callableId, callableTypeDefIR>(callableTypeDefEnv))

    4. If (~$in_set<nameIR>(nameIR, ({ nameIR_k* }))), then

      1. (Let callableTypeDefEnv_update be $add_map<callableId, callableTypeDefIR>(callableTypeDefEnv, callableId, callableTypeDefIR))

      2. (Let TC' be TC[block.callable = callableTypeDefEnv_update])

      3. Return TC'

    4. Else Phantom#555

1. Else Phantom#556

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.02.1-typing-context.spectec:288:1-290:53:
dec $add_constructorDef_t(TC, callableId, constructorTypeDefIR)

1. (Let constructorTypeDefEnv be TC.global.constructor)

2. If (~$in_set<callableId>(callableId, $dom_map<callableId, constructorTypeDefIR>(constructorTypeDefEnv))), then

  1. (Let constructorTypeDefEnv_update be $add_map<callableId, constructorTypeDefIR>(constructorTypeDefEnv, callableId, constructorTypeDefIR))

  2. (Let TC' be TC[global.constructor = constructorTypeDefEnv_update])

  3. Return TC'

2. Else Phantom#557

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.02.1-typing-context.spectec:291:1-293:53:
dec $add_constructorDef_non_overload_t(TC, callableId, constructorTypeDefIR)

1. (Let constructorTypeDefEnv be TC.global.constructor)

2. (Let (nameIR ( _id* )) be callableId)

3. (Let ({ (nameIR_k ( _id'* ))* }) be $dom_map<callableId, constructorTypeDefIR>(constructorTypeDefEnv))

4. If (~$in_set<nameIR>(nameIR, ({ nameIR_k* }))), then

  1. (Let constructorTypeDefEnv_update be $add_map<callableId, constructorTypeDefIR>(constructorTypeDefEnv, callableId, constructorTypeDefIR))

  2. (Let TC' be TC[global.constructor = constructorTypeDefEnv_update])

  3. Return TC'

4. Else Phantom#558

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.02.1-typing-context.spectec:294:1-296:70:
dec $add_constructorDefs_t(TC, callableId*, constructorTypeDefIR*)

1. Case analysis on callableId*

  1. Case (% matches pattern [])

    1. If ((constructorTypeDefIR* matches pattern [])), then

      1. Return TC

    1. Else Phantom#559

  2. Case (% matches pattern _ :: _)

    1. (Let callableId_h :: callableId_t* be callableId*)

    2. If ((constructorTypeDefIR* matches pattern _ :: _)), then

      1. (Let constructorTypeDefIR_h :: constructorTypeDefIR_t* be constructorTypeDefIR*)

      2. (Let TC' be $add_constructorDef_t(TC, callableId_h, constructorTypeDefIR_h))

      3. (Let TC'' be $add_constructorDefs_t(TC', callableId_t*, constructorTypeDefIR_t*))

      4. Return TC''

    2. Else Phantom#560

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.02.1-typing-context.spectec:332:1-333:71:
dec $find_var_t(prefixedNameIR, p', TC)

1. Case analysis on prefixedNameIR

  1. Case (% matches pattern `. %`)

    1. (Let (. id) be prefixedNameIR)

    2. (Let typeFrame be TC.global.frame)

    3. Return $find_map<id, varTypeIR>(typeFrame, id)

  2. Case (% matches pattern `` %`)

    1. (Let (` id) be prefixedNameIR)

    2. Case analysis on p'

      1. Case (% matches pattern `GLOBAL`)

        1. (Let typeFrame be TC.global.frame)

        2. Return $find_map<id, varTypeIR>(typeFrame, id)

      2. Case (% matches pattern `BLOCK`)

        1. (Let typeFrame be TC.block.frame)

        2. (Let varTypeIR'? be $find_map<id, varTypeIR>(typeFrame, id))

        3. If ((varTypeIR'? matches pattern (_))), then

          1. (Let ?(varTypeIR) be varTypeIR'?)

          2. Return ?(varTypeIR)

        3. Else Phantom#561

        4. If ((?() = $find_map<id, varTypeIR>(typeFrame, id))), then

          1. Return $find_var_t((` id), (global), TC)

        4. Else Phantom#562

      3. Case (% matches pattern `LOCAL`)

        1. (Let typeFrame* be TC.local.frames)

        2. (Let varTypeIR'? be $find_maps<id, varTypeIR>(typeFrame*, id))

        3. If ((varTypeIR'? matches pattern (_))), then

          1. (Let ?(varTypeIR) be varTypeIR'?)

          2. Return ?(varTypeIR)

        3. Else Phantom#563

        4. If ((?() = $find_maps<id, varTypeIR>(typeFrame*, id))), then

          1. Return $find_var_t((` id), (block), TC)

        4. Else Phantom#564

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.02.1-typing-context.spectec:356:1-357:72:
dec $find_var_value_t(prefixedNameIR, p, TC)

1. (Let varTypeIR? be $find_var_t(prefixedNameIR, p, TC))

2. If ((varTypeIR? matches pattern (_))), then

  1. (Let ?((_direction _typeIR _ctk value'?)) be varTypeIR?)

  2. If ((value'? matches pattern (_))), then

    1. (Let ?(value) be value'?)

    2. Return value

  2. Else Phantom#565

2. Else Phantom#566

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.02.1-typing-context.spectec:364:1-365:73:
dec $find_typeDef_t(p', TC, prefixedNameIR)

1. If ((prefixedNameIR matches pattern `. %`)), then

  1. (Let (. typeId) be prefixedNameIR)

  2. (Let typeDefEnv be TC.global.type)

  3. Return $find_map<typeId, typeDefIR>(typeDefEnv, typeId)

1. Else Phantom#567

2. Case analysis on p'

  1. Case (% matches pattern `GLOBAL`)

    1. If ((prefixedNameIR matches pattern `` %`)), then

      1. (Let (` typeId) be prefixedNameIR)

      2. (Let typeDefEnv be TC.global.type)

      3. Return $find_map<typeId, typeDefIR>(typeDefEnv, typeId)

    1. Else Phantom#568

  2. Case (% matches pattern `BLOCK`)

    1. If ((prefixedNameIR matches pattern `` %`)), then

      1. (Let (` typeId) be prefixedNameIR)

      2. (Let typeDefEnv be TC.block.type)

      3. (Let typeDefIR'? be $find_map<typeId, typeDefIR>(typeDefEnv, typeId))

      4. If ((typeDefIR'? matches pattern (_))), then

        1. (Let ?(typeDefIR) be typeDefIR'?)

        2. Return ?(typeDefIR)

      4. Else Phantom#569

      5. If ((?() = $find_map<typeId, typeDefIR>(typeDefEnv, typeId))), then

        1. Return $find_typeDef_t((global), TC, (` typeId))

      5. Else Phantom#570

    1. Else Phantom#571

  3. Case (% matches pattern `LOCAL`)

    1. If ((prefixedNameIR matches pattern `` %`)), then

      1. (Let (` typeId) be prefixedNameIR)

      2. (Let typeDefEnv* be [TC.local.type])

      3. (Let typeDefIR'? be $find_maps<typeId, typeDefIR>(typeDefEnv*, typeId))

      4. If ((typeDefIR'? matches pattern (_))), then

        1. (Let ?(typeDefIR) be typeDefIR'?)

        2. Return ?(typeDefIR)

      4. Else Phantom#572

      5. If ((?() = $find_maps<typeId, typeDefIR>(typeDefEnv*, typeId))), then

        1. Return $find_typeDef_t((block), TC, (` typeId))

      5. Else Phantom#573

    1. Else Phantom#574

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.02.1-typing-context.spectec:392:1-394:97:
dec $find_callableDef_overloaded_t(cursor, TC, prefixedNameIR, argumentIR*)

1. Case analysis on cursor

  1. Case (% matches pattern `GLOBAL`)

    1. Case analysis on prefixedNameIR

      1. Case (% matches pattern `. %`)

        1. (Let (. nameIR) be prefixedNameIR)

        2. (Let callableTypeDefEnv be TC.global.callable)

        3. (Let callTargetKey be $callTargetKey(nameIR, argumentIR*))

        4. Return $find_overloaded<callableTypeDefIR>(callableTypeDefEnv, callTargetKey, $parameterListIR_of_callableTypeDefIR)

      2. Case (% matches pattern `` %`)

        1. (Let (` nameIR) be prefixedNameIR)

        2. (Let callableTypeDefEnv be TC.global.callable)

        3. (Let callTargetKey be $callTargetKey(nameIR, argumentIR*))

        4. Return $find_overloaded<callableTypeDefIR>(callableTypeDefEnv, callTargetKey, $parameterListIR_of_callableTypeDefIR)

  2. Case (% matches pattern `BLOCK`)

    1. If ((prefixedNameIR matches pattern `` %`)), then

      1. (Let (` nameIR) be prefixedNameIR)

      2. (Let callableTypeDefEnv be TC.block.callable)

      3. (Let callTargetKey be $callTargetKey(nameIR, argumentIR*))

      4. (Let callResolution<callableTypeDefIR>? be $find_overloaded<callableTypeDefIR>(callableTypeDefEnv, callTargetKey, $parameterListIR_of_callableTypeDefIR))

      5. If ((callResolution<callableTypeDefIR>? matches pattern (_))), then

        1. (Let ?((callableId : callableTypeDefIR # id_default* # id_optional*)) be callResolution<callableTypeDefIR>?)

        2. Return ?((callableId : callableTypeDefIR # id_default* # id_optional*))

      5. Else Phantom#575

      6. If ((?() = $find_overloaded<callableTypeDefIR>(callableTypeDefEnv, callTargetKey, $parameterListIR_of_callableTypeDefIR))), then

        1. Return $find_callableDef_overloaded_t((global), TC, (` nameIR), argumentIR*)

      6. Else Phantom#576

    1. Else Phantom#577

  3. Case (% matches pattern `LOCAL`)

    1. If ((prefixedNameIR matches pattern `` %`)), then

      1. (Let (` nameIR) be prefixedNameIR)

