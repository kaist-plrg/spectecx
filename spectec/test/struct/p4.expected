;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.03-inst-relation.spectec:184:1-191:42:
relation ControlLocalDecl_inst: IC_0', STO', controlLocalDeclarationIR

1. Case analysis on controlLocalDeclarationIR

  1. Case (% has type constantDeclarationIR)

    1. (Let constantDeclarationIR be (controlLocalDeclarationIR as constantDeclarationIR))

    2. (ConstDecl_inst: (block) IC_0' |- constantDeclarationIR : IC_1)

    3. Result in IC_1, STO', ?((constantDeclarationIR as controlLocalDeclarationIR))

  2. Case (% has type instantiationIR)

    1. (Let instantiationIR be (controlLocalDeclarationIR as instantiationIR))

    2. (InstDecl_inst: (block) IC_0' STO' |- instantiationIR : IC_1 STO_1 constantDeclarationIR)

    3. Result in IC_1, STO_1, ?((constantDeclarationIR as controlLocalDeclarationIR))

  3. Case (% has type variableDeclarationIR)

    1. (Let variableDeclarationIR be (controlLocalDeclarationIR as variableDeclarationIR))

    2. Result in IC_0', STO', ?((variableDeclarationIR as controlLocalDeclarationIR))

  4. Case (% has type actionDeclarationIR)

    1. (Let actionDeclarationIR be (controlLocalDeclarationIR as actionDeclarationIR))

    2. (ActionDecl_inst: (block) IC_0' |- actionDeclarationIR : IC_1)

    3. Result in IC_1, STO', ?()

  5. Case (% has type tableDeclarationIR)

    1. (Let (annotationList table typeIR nameIR { tablePropertyListIR }) be (controlLocalDeclarationIR as tableDeclarationIR))

    2. (Let IC_callee_0 be $inherit_i((block), IC_0'))

    3. (Let IC_frame be $enter_i(IC_callee_0))

    4. (TableProperties_inst: IC_frame STO' |- tablePropertyListIR : STO_1 tablePropertyListIR_inst)

    5. (Let TBL be $init_table(tablePropertyListIR_inst))

    6. (Let frame'* be IC_frame.local.frames)

    7. If ((frame'* matches pattern _ :: _)), then

      1. (Let frame :: _frame* be frame'*)

      2. (Let object_table be ((table nameIR { frame TBL }) as object))

      3. (Let nameIR_object be $name_annotation_default(annotationList, nameIR))

      4. (Let objectId be IC_0'.path ++ [nameIR_object])

      5. (Let STO_2 be $add_store(STO_1, objectId, object_table))

      6. If (([] = $name_annotation(annotationList))), then

        1. (Let IC_1 be $add_var_i((block), IC_0', nameIR, ((ref objectId) as value)))

        2. (Let constantDeclarationIR be (() const typeIR nameIR (= ((ref objectId) as value)) ;))

        3. Result in IC_1, STO_2, ?((constantDeclarationIR as controlLocalDeclarationIR))

      6. Else Phantom#1758

      7. (Let nameIR'* be $name_annotation(annotationList))

      8. If ((nameIR'* matches pattern [ _/1 ])), then

        1. (Let [nameIR_annotation] be nameIR'*)

        2. (Let objectId_annotation be IC_0'.path ++ [nameIR_annotation])

        3. (Let STO_3 be $add_store(STO_2, objectId_annotation, object_table))

        4. (Let IC_1 be $add_var_i((block), IC_0', nameIR, ((ref objectId) as value)))

        5. (Let constantDeclarationIR be (() const typeIR nameIR (= ((ref objectId) as value)) ;))

        6. Result in IC_1, STO_3, ?((constantDeclarationIR as controlLocalDeclarationIR))

      8. Else Phantom#1759

    7. Else Phantom#1760

