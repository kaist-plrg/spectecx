dec $flatten_nameList(nameList'')

1. If ((nameList'' has type name)), then

  1. (Let name be (nameList'' as name))

  2. Return [name]

1. Else Phantom#14

2. If ((nameList'' matches pattern `% , %`)), then

  1. (Let (nameList'' , name) be nameList'')

  2. Return $flatten_nameList(nameList'') ++ [name]

2. Else Phantom#15

