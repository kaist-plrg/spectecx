          2. If ((w = w')), then

            1. (Let i_l' be $bitstr_to_int((w as int), i_l))

            2. (Let i_r' be $bitstr_to_int((w as int), i_r))

            3. (Let i' be $int_to_bitstr((w as int), $band(i_l', i_r')))

            4. Return ((w s i') as value)

