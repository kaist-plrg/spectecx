   | " text " (from stringLiteral) hint(print "#%#")
   | d int (from integerLiteral) hint(print %)
   | nat w int (from integerLiteral) hint(print %#W#%)
   | nat s int (from integerLiteral) hint(print %#S#%)
   | nat . nat v int (from integerValue)
   | list [ value* ] (from listValue)
   | tuple ( value* ) (from tupleValue)
   | header_stack [ value* ( nat ; nat ) ] (from headerStackValue)
   | struct typeId { fieldValue* } (from structValue)
   | header typeId { bool ; fieldValue* } (from headerValue)
   | header_union typeId { fieldValue* } (from headerUnionValue)
   | typeId . nameIR (from enumValue)
   | typeId . nameIR . value (from enumValue)
   | ref objectId (from objectReferenceValue)
   | default (from defaultValue)
   | {#} (from invalidHeaderValue)
