;; ../../../../../spectec/examples/p4-concrete/5-typing/5.04-typing-relation.spectec:469:1-473:40:
relation Decls_ok: TC', declaration*

1. Case analysis on declaration*

  1. Case (% matches pattern [])

    1. Result in TC', []

  2. Case (% matches pattern _ :: _)

    1. (Let declaration_h :: declaration_t* be declaration*)

    2. (Decl_ok: TC' |- declaration_h : TC_1 declarationIR_h)

    3. (Decls_ok: TC_1 |- declaration_t* : TC_2 declarationIR_t*)

    4. Result in TC_2, declarationIR_h :: declarationIR_t*

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.04-typing-relation.spectec:475:1-479:40:
relation Program_ok: p4program

1. (Let declaration* be $flatten_p4program(p4program))

2. (Let TC_0 be $empty_typingContext)

3. (Decls_ok: TC_0 |- declaration* : TC_1 declarationIR*)

4. Result in (declarationIR* ;)

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.04-typing-relation.spectec:489:18-489:35:
syntax actctxt = 
   | action (from actctxt)
   | noaction (from actctxt)

;; ../../../../../spectec/examples/p4-concrete/5-typing/5.04-typing-relation.spectec:491:1-496:68:
relation Call_convention_expr_ok: p, TC, actctxt, (_annotationList direction typeIR_param _id _parameterInitializerOptIR), typedExpressionIR_arg

1. Case analysis on direction

  1. Case (% matches pattern `IN`)

    1. (Let typedExpressionIR? be $cast_unary(typedExpressionIR_arg, typeIR_param))

    2. If ((typedExpressionIR? matches pattern (_))), then

      1. (Let ?(typedExpressionIR_arg_cast) be typedExpressionIR?)

      2. Result in typedExpressionIR_arg_cast

    2. Else Phantom#1318

  2. Case (% matches pattern `OUT`)

    1. (Let typeIR_arg be $type_of_typedExpressionIR(typedExpressionIR_arg))

    2. If (Type_alpha: typeIR_param ~~ typeIR_arg holds), then

      1. If (Expr_lvalue_ok: p TC |- typedExpressionIR_arg holds), then

        1. Result in typedExpressionIR_arg

      1. Else Phantom#1319

    2. Else Phantom#1320

  3. Case (% matches pattern `INOUT`)

    1. (Let typeIR_arg be $type_of_typedExpressionIR(typedExpressionIR_arg))

    2. If (Type_alpha: typeIR_param ~~ typeIR_arg holds), then

      1. If (Expr_lvalue_ok: p TC |- typedExpressionIR_arg holds), then

        1. Result in typedExpressionIR_arg

      1. Else Phantom#1321

    2. Else Phantom#1322

1. Else Phantom#1323

2. Case analysis on actctxt

  1. Case (% matches pattern `ACTION`)

    1. If ((direction matches pattern ``EMPTY`)), then

      1. (Let typedExpressionIR? be $cast_unary(typedExpressionIR_arg, typeIR_param))

      2. If ((typedExpressionIR? matches pattern (_))), then

