   | annotationList { parserStatementListIR } (from parserBlockStatementIR)
   | if ( typedExpressionIR ) parserStatementIR (from parserConditionalStatementIR)
   | if ( typedExpressionIR ) parserStatementIR else parserStatementIR (from parserConditionalStatementIR)

