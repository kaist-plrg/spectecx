    3. Case analysis on controlLocalDeclarationIR'?

      1. Case (% matches pattern ())

        1. (ControlLocalDecls_inst: IC_1 STO_1 |- controlLocalDeclarationIR_t* : IC_2 STO_2 controlLocalDeclarationIR_t_inst*)

        2. Result in IC_2, STO_2, controlLocalDeclarationIR_t_inst*

      2. Case (% matches pattern (_))

        1. (Let ?(controlLocalDeclarationIR_h_inst) be controlLocalDeclarationIR'?)

        2. (ControlLocalDecls_inst: IC_1 STO_1 |- controlLocalDeclarationIR_t* : IC_2 STO_2 controlLocalDeclarationIR_t_inst*)

        3. Result in IC_2, STO_2, controlLocalDeclarationIR_h_inst :: controlLocalDeclarationIR_t_inst*

;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.03-inst-relation.spectec:206:1-211:31:
relation ConstDecl_inst: p, IC_0, (annotationList const typeIR nameIR (= value) ;)

1. (Let IC_1 be $add_var_i(p, IC_0, nameIR, value))

2. Result in IC_1

;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.03-inst-relation.spectec:213:1-219:47:
relation InstDecl_inst: p, IC_0, STO_0, (annotationList typeIR constructorTargetIR ( argumentListIR ) nameIR objectInitializerOptIR ;)

1. (Let (prefixedNameIR < typeArgumentListIR >) be constructorTargetIR)

2. (Constructor_inst: p IC_0 |- prefixedNameIR < typeArgumentListIR > ( argumentListIR ) : constructorDef < typeArgumentListIR_inst > ( # id_default* # id_optional* ))

3. (Let IC_inner be $enter_path_i(IC_0, nameIR))

4. (Constructor_call: p IC_inner STO_0 |- constructorDef < typeArgumentListIR_inst > ( argumentListIR # id_default* # id_optional* ) : STO_1 object)

5. If ((object has type externObject)), then

  1. (Let (extern typeId < theta > { objectState frame externMethodDefEnv }) be (object as externObject))

  2. (Let IC_decl be $inherit_i((global), IC_0))

  3. (Let objectDeclarationListIR be $flatten_objectInitializerOptIR(objectInitializerOptIR))

  4. (ObjectDecls_inst: IC_decl STO_1 |- objectDeclarationListIR : IC_decl_post STO_2)

  5. (Let frame_merged be $merge_frames(frame, IC_decl_post.block.frame))

  6. (Let externMethodDefEnv_merged be $merge_externMethodDefEnvs(externMethodDefEnv, IC_decl_post.block.callable))

  7. (Let object_merged be ((extern typeId < theta > { objectState frame_merged externMethodDefEnv_merged }) as object))

  8. (Let objectId be IC_0.path ++ [nameIR])

  9. (Let STO_3 be $add_store(STO_2, objectId, object_merged))

  10. (Let IC_1 be $add_var_i(p, IC_0, nameIR, ((ref objectId) as value)))

  11. (Let constantDeclarationIR be (() const typeIR nameIR (= ((ref objectId) as value)) ;))

  12. Result in IC_1, STO_3, constantDeclarationIR

5. Else Phantom#1761

6. (Let nameIR' be $name_annotation_default(annotationList, nameIR))

7. (Let IC_inner be $enter_path_i(IC_0, nameIR'))

8. If (~(object has type externObject)), then

  1. (Let objectId be IC_0.path ++ [nameIR])

  2. (Let STO_2 be $add_store(STO_1, objectId, object))

  3. (Let IC_1 be $add_var_i(p, IC_0, nameIR, ((ref objectId) as value)))

  4. (Let constantDeclarationIR be (() const typeIR nameIR (= ((ref objectId) as value)) ;))

  5. Result in IC_1, STO_2, constantDeclarationIR

8. Else Phantom#1762

;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.03-inst-relation.spectec:221:1-226:31:
relation FuncDecl_inst: p, IC_0, (annotationList (typeIR nameIR < typeParameterListIR_expl , typeParameterListIR_impl > ( parameterListIR )) blockStatementIR)

1. (Let callableId be $callableId_IR(nameIR, parameterListIR))

2. (Let typeParameterListIR be typeParameterListIR_expl ++ typeParameterListIR_impl)

3. (Let definedFunctionDef be (function nameIR < typeParameterListIR > ( parameterListIR ) blockStatementIR))

4. (Let IC_1 be $add_callableDef_overload_i(p, IC_0, callableId, (definedFunctionDef as callableDef)))

5. Result in IC_1

;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.03-inst-relation.spectec:228:1-233:31:
relation ActionDecl_inst: p, IC_0, (annotationList action nameIR ( parameterListIR ) blockStatementIR)

1. (Let callableId be $callableId_IR(nameIR, parameterListIR))

2. (Let actionDef be (annotationList action nameIR ( parameterListIR ) blockStatementIR))

3. (Let IC_1 be $add_callableDef_non_overload_i(p, IC_0, callableId, (actionDef as callableDef)))

4. Result in IC_1

;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.03-inst-relation.spectec:235:1-241:46:
relation Decl_inst: IC_0, STO', declarationIR

1. Case analysis on declarationIR

  1. Case (% has type constantDeclarationIR)

    1. (Let constantDeclarationIR be (declarationIR as constantDeclarationIR))

    2. (ConstDecl_inst: (global) IC_0 |- constantDeclarationIR : IC_1)

    3. Result in IC_1, STO'

  2. Case (% has type instantiationIR)

    1. (Let instantiationIR be (declarationIR as instantiationIR))

    2. (InstDecl_inst: (global) IC_0 STO' |- instantiationIR : IC_1 STO_1 _constantDeclarationIR)

    3. Result in IC_1, STO_1

  3. Case (% has type functionDeclarationIR)

    1. (Let functionDeclarationIR be (declarationIR as functionDeclarationIR))

    2. (FuncDecl_inst: (global) IC_0 |- functionDeclarationIR : IC_1)

    3. Result in IC_1, STO'

  4. Case (% has type actionDeclarationIR)

    1. (Let actionDeclarationIR be (declarationIR as actionDeclarationIR))

    2. (ActionDecl_inst: (global) IC_0 |- actionDeclarationIR : IC_1)

    3. Result in IC_1, STO'

  5. Case (% has type errorDeclarationIR)

    1. (Let (error { nameIR* }) be (declarationIR as errorDeclarationIR))

    2. (Let nameIR_error be $concat_text(["error.", nameIR]))*

    3. (Let value_error be ((error . nameIR) as value))*

    4. (Let IC_1 be $add_vars_i((global), IC_0, nameIR_error*, value_error*))

    5. Result in IC_1, STO'

  6. Case (% has type matchKindDeclarationIR)

    1. (Let (match_kind { nameIR* }) be (declarationIR as matchKindDeclarationIR))

    2. (Let value_match_kind be ((match_kind . nameIR) as value))*

    3. (Let IC_1 be $add_vars_i((global), IC_0, nameIR*, value_match_kind*))

    4. Result in IC_1, STO'

  7. Case (% has type externFunctionDeclarationIR)

    1. (Let (annotationList extern (typeIR nameIR < typeParameterListIR_expl , typeParameterListIR_impl > ( parameterListIR )) ;) be (declarationIR as externFunctionDeclarationIR))

    2. (Let callableId be $callableId_IR(nameIR, parameterListIR))

    3. (Let typeParameterListIR be typeParameterListIR_expl ++ typeParameterListIR_impl)

    4. (Let externFunctionDef be (extern_function nameIR < typeParameterListIR > ( parameterListIR )))

    5. (Let IC_1 be $add_callableDef_overload_i((global), IC_0, callableId, (externFunctionDef as callableDef)))

    6. Result in IC_1, STO'

  8. Case (% has type externObjectDeclarationIR)

    1. (Let (annotationList extern nameIR < typeParameterListIR , > { externConstructorPrototypeIR* externMethodPrototypeIR* }) be (declarationIR as externObjectDeclarationIR))

    2. If ((externConstructorPrototypeIR* matches pattern [])), then

      1. (Let callableId_method be $callableId_of_externMethodPrototypeIR(externMethodPrototypeIR))*

      2. (Let externMethodTypeDefIR be $type_of_externMethodPrototypeIR(externMethodPrototypeIR))*

      3. (Let externMethodTypeDefEnv be ({ (callableId_method : externMethodTypeDefIR)* }))

      4. (Let externObjectTypeDefIR be (extern nameIR < typeParameterListIR , [] > externMethodTypeDefEnv))

      5. (Let IC_1 be $add_typeDef_i((global), IC_0, nameIR, (externObjectTypeDefIR as typeDefIR)))

      6. (Let callableId_constructor be $callableId_IR(nameIR, []))

      7. (Let constructorDef be ((extern nameIR < typeParameterListIR > ( [] ) { externMethodPrototypeIR* }) as constructorDef))

      8. (Let IC_2 be $add_constructorDef_i(IC_1, callableId_constructor, constructorDef))

      9. Result in IC_2, STO'

    2. Else Phantom#1763

    3. If ((externConstructorPrototypeIR* =/= [])), then

      1. (Let callableId_method be $callableId_of_externMethodPrototypeIR(externMethodPrototypeIR))*

      2. (Let externMethodTypeDefIR be $type_of_externMethodPrototypeIR(externMethodPrototypeIR))*

      3. (Let externMethodTypeDefEnv be ({ (callableId_method : externMethodTypeDefIR)* }))

      4. (Let externObjectTypeDefIR be (extern nameIR < typeParameterListIR , [] > externMethodTypeDefEnv))

      5. (Let IC_1 be $add_typeDef_i((global), IC_0, nameIR, (externObjectTypeDefIR as typeDefIR)))

      6. (Let callableId_constructor be $callableId_of_externConstructorPrototypeIR(externConstructorPrototypeIR))*

      7. (Let constructorDef be $constructor_of_externConstructorPrototypeIR(typeParameterListIR, externMethodPrototypeIR*, externConstructorPrototypeIR))*

      8. (Let IC_2 be $add_constructorDefs_i(IC_1, callableId_constructor*, constructorDef*))

      9. Result in IC_2, STO'

    3. Else Phantom#1764

  9. Case (% has type parserDeclarationIR)

    1. (Let (annotationList parser nameIR < typeParameterListIR_expl , typeParameterListIR_impl > ( parameterListIR ) ( constructorParameterListIR ) { parserLocalDeclarationListIR parserStateListIR }) be (declarationIR as parserDeclarationIR))

    2. (Let callableId be $callableId_IR(nameIR, constructorParameterListIR))

    3. (Let typeParameterListIR be typeParameterListIR_expl ++ typeParameterListIR_impl)

    4. (Let constructorDef be ((parser < typeParameterListIR > ( parameterListIR ) ( constructorParameterListIR ) { parserLocalDeclarationListIR parserStateListIR }) as constructorDef))

    5. (Let IC_1 be $add_constructorDef_i(IC_0, callableId, constructorDef))

    6. Result in IC_1, STO'

  10. Case (% has type controlDeclarationIR)

    1. (Let (annotationList control nameIR < typeParameterListIR_expl , typeParameterListIR_impl > ( parameterListIR ) ( constructorParameterListIR ) { controlLocalDeclarationListIR apply controlBodyIR }) be (declarationIR as controlDeclarationIR))

    2. (Let callableId be $callableId_IR(nameIR, constructorParameterListIR))

    3. (Let typeParameterListIR be typeParameterListIR_expl ++ typeParameterListIR_impl)

    4. (Let constructorDef be ((control < typeParameterListIR > ( parameterListIR ) ( constructorParameterListIR ) { controlLocalDeclarationListIR apply controlBodyIR }) as constructorDef))

    5. (Let IC_1 be $add_constructorDef_i(IC_0, callableId, constructorDef))

    6. Result in IC_1, STO'

  11. Case (% has type enumTypeDeclarationIR)

    1. (Let enumTypeDeclarationIR be (declarationIR as enumTypeDeclarationIR))

    2. Case analysis on enumTypeDeclarationIR

      1. Case (% matches pattern `% ENUM % {%}`)

        1. (Let (annotationList enum nameIR { nameIR_field* }) be enumTypeDeclarationIR)

        2. (Let nameIR_enum_field be nameIR ++ "." ++ nameIR_field)*

        3. (Let value_enum_field be ((nameIR . nameIR_field) as value))*

        4. (Let IC_1 be $add_vars_i((global), IC_0, nameIR_enum_field*, value_enum_field*))

        5. (Let enumTypeDefIR be ((enum nameIR { nameIR_field* }) as enumTypeIR))

        6. (Let IC_2 be $add_typeDef_i((global), IC_1, nameIR, (enumTypeDefIR as typeDefIR)))

        7. Result in IC_2, STO'

      2. Case (% matches pattern `% ENUM % % {%}`)

        1. (Let (annotationList enum typeIR nameIR { (nameIR_field = value_field)* }) be enumTypeDeclarationIR)

        2. (Let nameIR_serenum_field be nameIR ++ "." ++ nameIR_field)*

        3. (Let value_serenum_field be ((nameIR . nameIR_field . value_field) as value))*

        4. (Let IC_1 be $add_vars_i((global), IC_0, nameIR_serenum_field*, value_serenum_field*))

        5. (Let enumTypeDefIR be ((enum nameIR < typeIR > { (nameIR_field = value_field ;)* }) as enumTypeIR))

        6. (Let IC_2 be $add_typeDef_i((global), IC_1, nameIR, (enumTypeDefIR as typeDefIR)))

        7. Result in IC_2, STO'

  12. Case (% has type structTypeDeclarationIR)

    1. (Let (annotationList struct nameIR < typeParameterListIR > { typeFieldIR* }) be (declarationIR as structTypeDeclarationIR))

    2. (Let (annotationList_field typeIR_field nameIR_field ;) be typeFieldIR)*

    3. (Let structTypeDefIR be (struct nameIR < typeParameterListIR > { (annotationList_field typeIR_field nameIR_field ;)* }))

    4. (Let IC_1 be $add_typeDef_i((global), IC_0, nameIR, (structTypeDefIR as typeDefIR)))

    5. Result in IC_1, STO'

  13. Case (% has type headerTypeDeclarationIR)

    1. (Let (annotationList header nameIR < typeParameterListIR > { typeFieldIR* }) be (declarationIR as headerTypeDeclarationIR))

    2. (Let (annotationList_field typeIR_field nameIR_field ;) be typeFieldIR)*

    3. (Let headerTypeDefIR be (header nameIR < typeParameterListIR > { (annotationList_field typeIR_field nameIR_field ;)* }))

    4. (Let IC_1 be $add_typeDef_i((global), IC_0, nameIR, (headerTypeDefIR as typeDefIR)))

    5. Result in IC_1, STO'

  14. Case (% has type headerUnionTypeDeclarationIR)

    1. (Let (annotationList header_union nameIR < typeParameterListIR > { typeFieldIR* }) be (declarationIR as headerUnionTypeDeclarationIR))

    2. (Let (annotationList_field typeIR_field nameIR_field ;) be typeFieldIR)*

    3. (Let headerUnionTypeDefIR be (header_union nameIR < typeParameterListIR > { (annotationList_field typeIR_field nameIR_field ;)* }))

    4. (Let IC_1 be $add_typeDef_i((global), IC_0, nameIR, (headerUnionTypeDefIR as typeDefIR)))

    5. Result in IC_1, STO'

  15. Case (% has type typedefDeclarationIR)

    1. (Let typedefDeclarationIR be (declarationIR as typedefDeclarationIR))

    2. Case analysis on typedefDeclarationIR

      1. Case (% matches pattern `% TYPEDEF % % ;`)

        1. (Let (annotationList typedef typedefIR nameIR ;) be typedefDeclarationIR)

        2. Case analysis on typedefIR

          1. Case (% has type typeIR)

            1. (Let typeIR be (typedefIR as typeIR))

            2. (Let aliasTypeDefIR be ((typedef nameIR typeIR) as aliasTypeIR))

            3. (Let IC_1 be $add_typeDef_i((global), IC_0, nameIR, (aliasTypeDefIR as typeDefIR)))

            4. Result in IC_1, STO'

          2. Case (% has type derivedTypeDeclarationIR)

            1. (Let derivedTypeDeclarationIR be (typedefIR as derivedTypeDeclarationIR))

            2. (Decl_inst: IC_0 $empty_store |- (derivedTypeDeclarationIR as declarationIR) : IC_local _store)

            3. (Let ({ typeId* }) be $diff_set<typeId>($dom_map<typeId, typeDefIR>(IC_local.global.type), $dom_map<typeId, typeDefIR>(IC_0.global.type)))

            4. If ((typeId* matches pattern [ _/1 ])), then

              1. (Let [typeId_newtype] be typeId*)

              2. (Let typeDefIR'? be $find_typeDef_i((global), IC_local, (. typeId_newtype)))

              3. If ((typeDefIR'? matches pattern (_))), then

                1. (Let ?(typeDefIR) be typeDefIR'?)

                2. Case analysis on $is_monomorphic_typeDefIR(typeDefIR)

                  1. Case true

                    1. (Let typeIR be $typeIR_of_typeDefIR(typeDefIR))

                    2. (Let aliasTypeDefIR be ((typedef nameIR typeIR) as aliasTypeIR))

                    3. (Let IC_1 be $add_typeDef_i((global), IC_0, nameIR, (aliasTypeDefIR as typeDefIR)))

                    4. Result in IC_1, STO'

                  2. Case false

                    1. If ((([], []) = $typeParameterListIR_of_typeDefIR(typeDefIR))), then

                      1. (Let typeIR be $specialize_typeDefIR(typeDefIR, []))

                      2. (Let typedefTypeIR be (typedef nameIR typeIR))

                      3. (Let IC_1 be $add_typeDef_i((global), IC_0, nameIR, (typedefTypeIR as typeDefIR)))

                      4. Result in IC_1, STO'

                    1. Else Phantom#1765

              3. Else Phantom#1766

            4. Else Phantom#1767

      2. Case (% matches pattern `% TYPE % % ;`)

        1. (Let (annotationList type typeIR nameIR ;) be typedefDeclarationIR)

        2. (Let aliasTypeDefIR be ((type nameIR typeIR) as aliasTypeIR))

        3. (Let IC_1 be $add_typeDef_i((global), IC_0, nameIR, (aliasTypeDefIR as typeDefIR)))

        4. Result in IC_1, STO'

  16. Case (% has type parserTypeDeclarationIR)

    1. (Let (annotationList parser nameIR < typeParameterListIR , typeParameterListIR_inferred > ( parameterIR* ) ;) be (declarationIR as parserTypeDeclarationIR))

    2. (Let parserObjectTypeDefIR be (parser nameIR < typeParameterListIR , typeParameterListIR_inferred > ( parameterIR* )))

    3. (Let IC_1 be $add_typeDef_i((global), IC_0, nameIR, (parserObjectTypeDefIR as typeDefIR)))

    4. Result in IC_1, STO'

  17. Case (% has type controlTypeDeclarationIR)

    1. (Let (annotationList control nameIR < typeParameterListIR , typeParameterListIR_inferred > ( parameterIR* ) ;) be (declarationIR as controlTypeDeclarationIR))

    2. (Let controlObjectTypeDefIR be (control nameIR < typeParameterListIR , typeParameterListIR_inferred > ( parameterIR* )))

    3. (Let IC_1 be $add_typeDef_i((global), IC_0, nameIR, (controlObjectTypeDefIR as typeDefIR)))

    4. Result in IC_1, STO'

  18. Case (% has type packageTypeDeclarationIR)

    1. (Let (annotationList package nameIR < typeParameterListIR , typeParameterListIR_inferred > ( parameterIR* ) ;) be (declarationIR as packageTypeDeclarationIR))

    2. (Let (_annotationList _direction typeIR _id _parameterInitializerOptIR) be parameterIR)*

    3. (Let packageObjectTypeDefIR be (package nameIR < typeParameterListIR , typeParameterListIR_inferred > { typeIR* }))

    4. (Let IC_1 be $add_typeDef_i((global), IC_0, nameIR, (packageObjectTypeDefIR as typeDefIR)))

    5. (Let callableId be $callableId_IR(nameIR, parameterIR*))

    6. (Let constructorDef be ((package < typeParameterListIR ++ typeParameterListIR_inferred > ( parameterIR* )) as constructorDef))

    7. (Let IC_2 be $add_constructorDef_i(IC_1, callableId, constructorDef))

    8. Result in IC_2, STO'

;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.03-inst-relation.spectec:243:1-249:46:
relation Decls_inst: IC', STO', declarationIR*

1. Case analysis on declarationIR*

  1. Case (% matches pattern [])

    1. Result in IC', STO'

  2. Case (% matches pattern _ :: _)

    1. (Let declarationIR_h :: declarationIR_t* be declarationIR*)

    2. (Decl_inst: IC' STO' |- declarationIR_h : IC_1 STO_1)

    3. (Decls_inst: IC_1 STO_1 |- declarationIR_t* : IC_2 STO_2)

    4. Result in IC_2, STO_2

;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.03-inst-relation.spectec:251:1-256:33:
relation Program_inst: p4program

1. (Program_ok: |- p4program : (declarationIR* ;))

2. (Let IC_0 be $empty_instContext)

3. (Let STO_0 be $empty_store)

4. (Decls_inst: IC_0 STO_0 |- declarationIR* : IC_1 STO_1)

5. Result in IC_1.global, STO_1

;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.03-inst-relation.spectec:263:1-267:35:
relation Copy_in_argument_inst: STO_0, p_caller, IC_caller, argumentIR, p_callee, IC_callee_0, id

1. (Let IC_caller_inner be $enter_path_i(IC_caller, id))

2. (Argument_inst: p_caller IC_caller_inner STO_0 |- argumentIR : STO_1 value)

3. (Let IC_callee_1 be $add_var_i(p_callee, IC_callee_0, id, value))

4. Result in STO_1, IC_callee_1

;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.03-inst-relation.spectec:269:1-276:46:
relation Copy_in_inst: STO', p_caller, IC_caller, argumentIR*, p_callee, IC_callee', id*

1. Case analysis on argumentIR*

  1. Case (% matches pattern [])

    1. If ((id* matches pattern [])), then

      1. Result in STO', IC_callee'

    1. Else Phantom#1768

  2. Case (% matches pattern _ :: _)

    1. (Let argumentIR_h :: argumentIR_t* be argumentIR*)

    2. If ((id* matches pattern _ :: _)), then

      1. (Let id_h :: id_t* be id*)

      2. (Copy_in_argument_inst: STO' p_caller IC_caller argumentIR_h @ p_callee IC_callee' id_h ~> STO_1 IC_callee_1)

      3. (Copy_in_inst: STO_1 p_caller IC_caller argumentIR_t* @ p_callee IC_callee_1 id_t* ~> STO_2 IC_callee_2)

      4. Result in STO_2, IC_callee_2

    2. Else Phantom#1769

;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.03-inst-relation.spectec:278:1-282:32:
relation Copy_in_argument_inst_default: STO_0', p_caller, IC_caller, p_callee, IC_callee_0, parameterIR

1. (Let (_annotationList _direction _typeIR id parameterInitializerOptIR) be parameterIR)

2. If ((parameterInitializerOptIR matches pattern (_))), then

  1. (Let ?(parameterInitializerIR) be parameterInitializerOptIR)

  2. Case analysis on parameterInitializerIR

    1. Case (% has type initializerIR)

      1. (Let (= typedExpressionIR) be (parameterInitializerIR as initializerIR))

      2. (Let IC_caller_inner be $enter_path_i(IC_caller, id))

      3. (Expr_inst: p_caller IC_caller_inner STO_0' |- typedExpressionIR : STO_1 value)

      4. (Let IC_callee_1 be $add_var_i(p_callee, IC_callee_0, id, value))

      5. Result in STO_1, IC_callee_1

    2. Case (% has type constantInitializerIR)

      1. (Let (= value) be (parameterInitializerIR as constantInitializerIR))

      2. (Let IC_callee_1 be $add_var_i(p_callee, IC_callee_0, id, value))

      3. Result in STO_0', IC_callee_1

2. Else Phantom#1770

;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.03-inst-relation.spectec:284:1-291:46:
relation Copy_in_inst_default: STO', p_caller, IC_caller, p_callee, IC_callee', parameterIR*

1. Case analysis on parameterIR*

  1. Case (% matches pattern [])

    1. Result in STO', IC_callee'

  2. Case (% matches pattern _ :: _)

    1. (Let parameterIR_h :: parameterIR_t* be parameterIR*)

    2. (Copy_in_argument_inst_default: STO' p_caller IC_caller @ p_callee IC_callee' parameterIR_h ~> STO_1 IC_callee_1)

    3. (Copy_in_inst_default: STO_1 p_caller IC_caller @ p_callee IC_callee_1 parameterIR_t* ~> STO_2 IC_callee_2)

    4. Result in STO_2, IC_callee_2

;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.03-inst-relation.spectec:298:1-307:56:
relation Constructor_inst: p, IC, prefixedNameIR, typeArgumentIR''*, argumentIR*

1. If ((?() = $find_typeDef_i(p, IC, prefixedNameIR))), then

  1. (Let callResolution<constructorDef>? be $find_constructorDef_i(IC, prefixedNameIR, argumentIR*))

  2. If ((callResolution<constructorDef>? matches pattern (_))), then

    1. (Let ?((_callableId : constructorDef # id_default* # id_optional*)) be callResolution<constructorDef>?)

    2. Result in constructorDef, typeArgumentIR''*, id_default*, id_optional*

  2. Else Phantom#1771

1. Else Phantom#1772

2. (Let typeDefIR'? be $find_typeDef_i(p, IC, prefixedNameIR))

3. If ((typeDefIR'? matches pattern (_))), then

  1. (Let ?(typeDefIR) be typeDefIR'?)

  2. If (~(typeDefIR has type typedefTypeIR)), then

    1. (Let callResolution<constructorDef>? be $find_constructorDef_i(IC, prefixedNameIR, argumentIR*))

    2. If ((callResolution<constructorDef>? matches pattern (_))), then

      1. (Let ?((_callableId : constructorDef # id_default* # id_optional*)) be callResolution<constructorDef>?)

      2. Result in constructorDef, typeArgumentIR''*, id_default*, id_optional*

    2. Else Phantom#1773

  2. Else Phantom#1774

3. Else Phantom#1775

4. If ((typeArgumentIR''* matches pattern [])), then

  1. If ((typeDefIR'? matches pattern (_))), then

    1. (Let ?(typeDefIR) be typeDefIR'?)

    2. If ((typeDefIR has type typedefTypeIR)), then

      1. (Let (typedef nameIR_alias typeIR_alias) be (typeDefIR as typedefTypeIR))

      2. (Let (nameIR, typeArgumentIR''*) be $resolve_type_alias(typeIR_alias))

      3. (Let callResolution<constructorDef>? be $find_constructorDef_i(IC, (` nameIR), argumentIR*))

      4. If ((callResolution<constructorDef>? matches pattern (_))), then

        1. (Let ?((_callableId : constructorDef # id_default* # id_optional*)) be callResolution<constructorDef>?)

        2. Result in constructorDef, typeArgumentIR''*, id_default*, id_optional*

      4. Else Phantom#1776

    2. Else Phantom#1777

  1. Else Phantom#1778

4. Else Phantom#1779

;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.03-inst-relation.spectec:309:1-318:51:
relation Constructor_call: p, IC, STO_0, constructorDef, typeArgumentIR*, argumentIR*, id_default*, id_optional*

1. Case analysis on constructorDef

  1. Case (% has type externObjectConstructorDef)

    1. (Let externObjectConstructorDef be (constructorDef as externObjectConstructorDef))

    2. (Let (extern nameIR < typeParameterIR* > ( constructorParameterIR* ) { externMethodPrototypeIR* }) be externObjectConstructorDef)

    3. (Let p_callee be (block))

    4. (Let IC_callee_0 be $inherit_i((global), IC))

    5. (Let theta be ({ (typeParameterIR : typeArgumentIR)* }))

    6. (Let IC_callee_1 be IC_callee_0[block.type = theta])

    7. (Let (given constructorParameterIR_aligned* default constructorParameterIR_default*) be $align_parameterListIR(constructorParameterIR*, argumentIR*, id_default*, id_optional*))

    8. (Let (_annotationList _direction _typeIR id_aligned _parameterInitializerOptIR) be constructorParameterIR_aligned)*

    9. (Copy_in_inst: STO_0 p IC argumentIR* @ p_callee IC_callee_1 id_aligned* ~> STO_1 IC_callee_2)

    10. (Copy_in_inst_default: STO_0 p IC @ p_callee IC_callee_2 constructorParameterIR_default* ~> STO_2 IC_callee_3)

    11. (ExternMethods_inst: IC_callee_3 |- externMethodPrototypeIR* : IC_callee_4)

    12. (Let ({ (callableId : callableDef)* }) be IC_callee_4.block.callable)

    13. If ((callableDef has type externMethodDef))*, then

      1. (Let externMethodDef be (callableDef as externMethodDef))*

      2. (Let (_annotationList' _direction' _typeIR' id_cparam _parameterInitializerOptIR') be constructorParameterIR)*

      3. (Let value? be $find_map<id, value>(IC_callee_4.block.frame, id_cparam))*

      4. If ((value? matches pattern (_)))*, then

        1. (Let ?(value_cparam) be value?)*

        2. (Let objectState be $init_objectState(nameIR, typeArgumentIR*, value_cparam*))

        3. (Let theta_extern be IC_callee_4.block.type)

        4. (Let frame_extern be IC_callee_4.block.frame)

        5. (Let externMethodDefEnv_extern be ({ (callableId : externMethodDef)* }))

        6. (Let object_extern be ((extern nameIR < theta_extern > { objectState frame_extern externMethodDefEnv_extern }) as object))

        7. Result in STO_2, object_extern

      4. Else Phantom#1780

    13. Else Phantom#1781

  2. Case (% has type parserObjectConstructorDef)

    1. (Let parserObjectConstructorDef be (constructorDef as parserObjectConstructorDef))

    2. (Let (parser < typeParameterIR* > ( parameterIR* ) ( constructorParameterIR* ) { parserLocalDeclarationIR* parserStateIR* }) be parserObjectConstructorDef)

    3. (Let p_callee be (block))

    4. (Let IC_callee_0 be $inherit_i((global), IC))

    5. (Let theta_parser be ({ (typeParameterIR : typeArgumentIR)* }))

    6. (Let IC_callee_1 be IC_callee_0[block.type = theta_parser])

    7. (Let (given constructorParameterIR_aligned* default constructorParameterIR_default*) be $align_parameterListIR(constructorParameterIR*, argumentIR*, id_default*, id_optional*))

    8. (Let (_annotationList _direction _typeIR id_aligned _parameterInitializerOptIR) be constructorParameterIR_aligned)*

    9. (Copy_in_inst: STO_0 p IC argumentIR* @ p_callee IC_callee_1 id_aligned* ~> STO_1 IC_callee_2)

    10. (Copy_in_inst_default: STO_0 p IC @ p_callee IC_callee_2 constructorParameterIR_default* ~> STO_2 IC_callee_3)

    11. (ParserLocalDecls_inst: IC_callee_3 STO_2 |- parserLocalDeclarationIR* : IC_local STO_3 parserLocalDeclarationIR_inst*)

    12. (ParserStates_inst: IC_local STO_3 |- parserStateIR* : IC_state STO_4)

    13. (Let frame_parser be IC_callee_3.block.frame)

    14. (Let stateEnv_parser be IC_state.block.state)

    15. (Let object_parser be ((parser < theta_parser > ( parameterIR* ) { frame_parser parserLocalDeclarationIR_inst* stateEnv_parser }) as object))

    16. Result in STO_4, object_parser

  3. Case (% has type controlObjectConstructorDef)

    1. (Let controlObjectConstructorDef be (constructorDef as controlObjectConstructorDef))

    2. (Let (control < typeParameterIR* > ( parameterIR* ) ( constructorParameterIR* ) { controlLocalDeclarationIR* apply controlBodyIR }) be controlObjectConstructorDef)

    3. (Let p_callee be (block))

    4. (Let IC_callee_0 be $inherit_i((global), IC))

    5. (Let theta_control be ({ (typeParameterIR : typeArgumentIR)* }))

    6. (Let IC_callee_1 be IC_callee_0[block.type = theta_control])

    7. (Let (given constructorParameterIR_aligned* default constructorParameterIR_default*) be $align_parameterListIR(constructorParameterIR*, argumentIR*, id_default*, id_optional*))

    8. (Let (_annotationList _direction _typeIR id_aligned _parameterInitializerOptIR) be constructorParameterIR_aligned)*

    9. (Copy_in_inst: STO_0 p IC argumentIR* @ p_callee IC_callee_1 id_aligned* ~> STO_1 IC_callee_2)

    10. (Copy_in_inst_default: STO_0 p IC @ p_callee IC_callee_2 constructorParameterIR_default* ~> STO_2 IC_callee_3)

    11. (ControlLocalDecls_inst: IC_callee_3 STO_2 |- controlLocalDeclarationIR* : IC_local_0 STO_3 controlLocalDeclarationIR_inst*)

    12. (Block_inst: IC_local_0 STO_3 |- controlBodyIR : IC_local_1 STO_4 controlBodyIR_inst)

    13. (Let frame_control be IC_callee_3.block.frame)

    14. (Let ({ (callableId : callableDef)* }) be IC_local_1.block.callable)

    15. If ((callableDef has type actionDef))*, then

      1. (Let actionDef be (callableDef as actionDef))*

      2. (Let actionDefEnv_control be ({ (callableId : actionDef)* }))

      3. (Let object_control be ((control < theta_control > ( parameterIR* ) { frame_control controlLocalDeclarationIR_inst* ({ (callableId : actionDef)* }) controlBodyIR_inst }) as object))

      4. Result in STO_4, object_control

    15. Else Phantom#1782

  4. Case (% has type packageObjectConstructorDef)

    1. (Let packageObjectConstructorDef be (constructorDef as packageObjectConstructorDef))

    2. (Let (package < typeParameterIR* > ( constructorParameterIR* )) be packageObjectConstructorDef)

    3. (Let p_callee be (block))

    4. (Let IC_callee_0 be $inherit_i((global), IC))

    5. (Let IC_callee_1 be IC_callee_0[block.type = ({ (typeParameterIR : typeArgumentIR)* })])

    6. (Let (given constructorParameterIR_aligned* default constructorParameterIR_default*) be $align_parameterListIR(constructorParameterIR*, argumentIR*, id_default*, id_optional*))

    7. (Let (_annotationList _direction _typeIR id_aligned _parameterInitializerOptIR) be constructorParameterIR_aligned)*

    8. (Copy_in_inst: STO_0 p IC argumentIR* @ p_callee IC_callee_1 id_aligned* ~> STO_1 IC_callee_2)

    9. (Copy_in_inst_default: STO_1 p IC @ p_callee IC_callee_2 constructorParameterIR_default* ~> STO_2 IC_callee_3)

    10. (Let theta_package be IC_callee_3.block.type)

    11. (Let frame_package be IC_callee_3.block.frame)

    12. (Let object_package be ((package < theta_package > { frame_package }) as object))

    13. Result in STO_2, object_package

;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.06-inst-statement.spectec:179:1-185:38:
relation SwitchCase_inst: p, IC, STO_0', switchCaseIR

1. Case analysis on switchCaseIR

  1. Case (% matches pattern `% : %`)

    1. (Let (switchLabelIR : blockStatementIR) be switchCaseIR)

    2. (Stmt_inst: p IC STO_0' |- (blockStatementIR as statementIR) : IC_switch STO_1 statementIR)

    3. If ((statementIR has type blockStatementIR)), then

      1. (Let blockStatementIR_inst be (statementIR as blockStatementIR))

      2. Result in STO_1, (switchLabelIR : blockStatementIR_inst)

    3. Else Phantom#1783

  2. Case (% matches pattern `% :`)

    1. (Let (switchLabelIR :) be switchCaseIR)

    2. Result in STO_0', (switchLabelIR :)

;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.06-inst-statement.spectec:204:1-210:38:
relation SwitchCases_inst: p, IC, STO', switchCaseIR*

1. Case analysis on switchCaseIR*

  1. Case (% matches pattern [])

    1. Result in STO', []

  2. Case (% matches pattern _ :: _)

    1. (Let switchCaseIR_h :: switchCaseIR_t* be switchCaseIR*)

    2. (SwitchCase_inst: p IC STO' |- switchCaseIR_h : STO_1 switchCaseIR_h')

    3. (SwitchCases_inst: p IC STO_1 |- switchCaseIR_t* : STO_2 switchCaseIR_t'*)

    4. Result in STO_2, switchCaseIR_h' :: switchCaseIR_t'*

;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.07-inst-declaration.spectec:29:1-30:51:
dec $merge_frames(frame, ({ (id : value)* }))

1. Return $adds_map<id, value>(frame, id*, value*)

;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.07-inst-declaration.spectec:37:1-40:29:
dec $merge_externMethodDefEnvs(externMethodDefEnv, set<pair<callableId, callableDef>>')

1. If ((set<pair<callableId, callableDef>>' = ({ [] }))), then

  1. Return externMethodDefEnv

1. Else Phantom#1784

2. (Let ({ pair<callableId, callableDef>* }) be set<pair<callableId, callableDef>>')

3. If ((pair<callableId, callableDef>* matches pattern _ :: _)), then

  1. (Let (callableId_h : callableDef_h) :: (callableId_t : callableDef_t)* be pair<callableId, callableDef>*)

  2. (Let callableDef be callableDef_h)

  3. If ((callableDef has type definedFunctionDef)), then

    1. (Let (function nameIR < typeParameterListIR > ( parameterListIR ) blockStatementIR) be (callableDef as definedFunctionDef))

    2. (Let externMethodDef_h be (extern_method nameIR < typeParameterListIR > ( parameterListIR ) ?(blockStatementIR)))

    3. (Let externMethodDefEnv_post be $update_map<callableId, externMethodDef>(externMethodDefEnv, callableId_h, externMethodDef_h))

    4. Return $merge_externMethodDefEnvs(externMethodDefEnv_post, ({ (callableId_t : callableDef_t)* }))

  3. Else Phantom#1785

3. Else Phantom#1786

;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.07-inst-declaration.spectec:60:1-64:72:
relation ObjectDecl_inst: IC_0, STO', objectDeclarationIR

1. Case analysis on objectDeclarationIR

  1. Case (% has type functionDeclarationIR)

    1. (Let functionDeclarationIR be (objectDeclarationIR as functionDeclarationIR))

    2. (FuncDecl_inst: (block) IC_0 |- functionDeclarationIR : IC_1)

    3. Result in IC_1, STO'

  2. Case (% has type instantiationIR)

    1. (Let instantiationIR be (objectDeclarationIR as instantiationIR))

    2. (InstDecl_inst: (global) IC_0 STO' |- instantiationIR : IC_1 STO_1 _constantDeclarationIR)

    3. Result in IC_1, STO_1

;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.07-inst-declaration.spectec:80:1-84:72:
relation ObjectDecls_inst: IC', STO', objectDeclarationIR*

1. Case analysis on objectDeclarationIR*

  1. Case (% matches pattern [])

    1. Result in IC', STO'

  2. Case (% matches pattern _ :: _)

    1. (Let objectDeclarationIR_h :: objectDeclarationIR_t* be objectDeclarationIR*)

    2. (ObjectDecl_inst: IC' STO' |- objectDeclarationIR_h : IC_1 STO_1)

    3. (ObjectDecls_inst: IC_1 STO_1 |- objectDeclarationIR_t* : IC_2 STO_2)

    4. Result in IC_2, STO_2

;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.07-inst-declaration.spectec:257:1-260:42:
dec $callableId_of_externMethodPrototypeIR(externMethodPrototypeIR)

1. Case analysis on externMethodPrototypeIR

  1. Case (% matches pattern `% % ;`)

    1. (Let (_annotationList (_typeIR nameIR < _typeParameterListIR , _typeParameterListIR' > ( parameterListIR )) ;) be externMethodPrototypeIR)

    2. Return $callableId_IR(nameIR, parameterListIR)

  2. Case (% matches pattern `% ABSTRACT % ;`)

    1. (Let (_annotationList abstract (_typeIR nameIR < _typeParameterListIR , _typeParameterListIR' > ( parameterListIR )) ;) be externMethodPrototypeIR)

    2. Return $callableId_IR(nameIR, parameterListIR)

;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.07-inst-declaration.spectec:269:1-272:45:
dec $callableId_of_externConstructorPrototypeIR((_annotationList nameIR < , _typeParameterListIR > ( parameterIR* ) ;))

1. Return $callableId_IR(nameIR, parameterIR*)

;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.07-inst-declaration.spectec:278:1-284:63:
dec $constructor_of_externConstructorPrototypeIR(typeParameterListIR_expl, externMethodPrototypeListIR, (_annotationList nameIR < , typeParameterListIR_impl > ( parameterIR* ) ;))

1. (Let typeParameterListIR be typeParameterListIR_expl ++ typeParameterListIR_impl)

2. (Let constructorDef be ((extern nameIR < typeParameterListIR > ( parameterIR* ) { externMethodPrototypeListIR }) as constructorDef))

3. Return constructorDef

;; ../../../../../spectec/examples/p4-concrete/7-instantiation/7.10.1-inst-control-table.spectec:166:1-166:59:
dec $init_table(tablePropertyIR*)

1. (Let tableKeysPropertyIR be $init_tableKeys(tablePropertyIR*))

2. (Let tablePropertyIR'* be $filter_<tablePropertyIR>(tablePropertyIR*, (tablePropertyIR has type tableActionsPropertyIR)*))

3. If ((tablePropertyIR'* has type tableActionsPropertyIR*)), then

  1. (Let tableActionsPropertyIR'* be (tablePropertyIR'* as tableActionsPropertyIR*))

  2. If ((tableActionsPropertyIR'* matches pattern [ _/1 ])), then

    1. (Let [tableActionsPropertyIR] be tableActionsPropertyIR'*)

    2. (Let tablePropertyIR''* be $filter_<tablePropertyIR>(tablePropertyIR*, (tablePropertyIR has type tableDefaultActionPropertyIR)*))

    3. If ((tablePropertyIR''* has type tableDefaultActionPropertyIR*)), then

      1. (Let tableDefaultActionPropertyIR'* be (tablePropertyIR''* as tableDefaultActionPropertyIR*))

      2. If ((tableDefaultActionPropertyIR'* matches pattern [ _/1 ])), then

        1. (Let [tableDefaultActionPropertyIR] be tableDefaultActionPropertyIR'*)

        2. (Let tableEntriesPropertyIR be $init_tableEntries(tablePropertyIR*))

        3. (Let tablePropertyIR'''* be $filter_<tablePropertyIR>(tablePropertyIR*, (tablePropertyIR has type tableCustomPropertyIR)*))

        4. If ((tablePropertyIR'''* has type tableCustomPropertyIR*)), then

          1. (Let tableCustomPropertyIR* be (tablePropertyIR'''* as tableCustomPropertyIR*))

          2. (Let TBL be {keys tableKeysPropertyIR, actions tableActionsPropertyIR, default_action tableDefaultActionPropertyIR, entries tableEntriesPropertyIR, customs tableCustomPropertyIR*})

          3. Return TBL

        4. Else Phantom#1787

      2. Else Phantom#1788

    3. Else Phantom#1789

  2. Else Phantom#1790

3. Else Phantom#1791

