;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.2-ir-call-overload.spectec:9:30-9:52:
syntax callTargetParameter = 
   | nameIR # bool # bool (from callTargetParameter)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.2-ir-call-overload.spectec:10:26-10:46:
syntax callTargetValue = callTargetParameter*

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.2-ir-call-overload.spectec:13:1-14:12:
syntax callTargetMatch = 
   | match id* id* (from callTargetMatch) hint(prose MATCH "with defaults" %0 and "optionals" %1)
   | nomatch (from callTargetMatch)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.2-ir-call-overload.spectec:17:3-18:75:
syntax callResolution<V> = 
   | callableId : V # nameIR* # nameIR* (from callResolution<V>) hint(prose_fields "call target id" "call target" "defaults" "optionals")

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.2-ir-call-overload.spectec:20:1-21:54:
dec $callTargetKey(nameIR_f, argumentIR*)

1. (Let id_arg? be $callTargetKey'(argumentIR))*

2. Return (nameIR_f ( id_arg?* ))

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.2-ir-call-overload.spectec:22:1-22:38:
dec $callTargetKey'(argumentIR)

1. If ((argumentIR has type typedExpressionIR)), then

  1. (Let typedExpressionIR be (argumentIR as typedExpressionIR))

  2. Return ?()

1. Else Phantom#508

2. Case analysis on argumentIR

  1. Case (% matches pattern `% = %`)

    1. (Let (id_arg = _typedExpressionIR) be argumentIR)

    2. Return ?(id_arg)

  2. Case (% matches pattern `% = _`)

    1. (Let (id_arg = _) be argumentIR)

    2. Return ?(id_arg)

  3. Case (% matches pattern `_`)

    1. Return ?()

2. Else Phantom#509

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.2-ir-call-overload.spectec:37:1-42:82:
dec $match_overloaded_named<V>((callTargetId : V), (nameIR_f ( id_arg* )), $get_parameterListIR)

1. (Let (nameIR ( id_param* )) be callTargetId)

2. If ((nameIR = nameIR_f)), then

  1. (Let parameterIR* be $get_parameterListIR(V))

  2. If ((id_param = $id_of_parameterIR(parameterIR)))*, then

    1. If ((|id_param*| = |id_arg*|)), then

      1. Return $ite<callTargetMatch>($eq_set<id>(({ id_param* }), ({ id_arg* })), (match [] []), (nomatch))

    2. (Let b_default be $is_default_parameterIR(parameterIR))*

    3. (Let b_optional be $is_optional_parameterIR(parameterIR))*

    4. If ((|id_param*| > |id_arg*|)), then

      1. (Let ({ id_param_omitted* }) be $diff_set<id>(({ id_param* }), ({ id_arg* })))

      2. (Let id_default_param* be $filter_<id>(id_param*, $is_default_parameterIR(parameterIR)*))

      3. (Let id_default* be $filter_<id>(id_param_omitted*, id_param_omitted is in id_default_param**))

      4. (Let id_optional_param* be $filter_<id>(id_param*, $is_optional_parameterIR(parameterIR)*))

      5. (Let id_optional* be $filter_<id>(id_param_omitted*, id_param_omitted is in id_optional_param**))

      6. If ($eq_set<id>(({ id_default* ++ id_optional* }), ({ id_param_omitted* }))), then

        1. Return (match id_default* id_optional*)

3. Otherwise

  1. Return (nomatch)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.2-ir-call-overload.spectec:106:1-111:84:
dec $match_overloaded_unnamed<V>((callTargetId : V), (nameIR_f ( n_arg )), $get_parameterListIR)

1. (Let (nameIR ( id_param* )) be callTargetId)

2. If ((nameIR = nameIR_f)), then

  1. (Let parameterIR* be $get_parameterListIR(V))

  2. (Let b_default be $is_default_parameterIR(parameterIR))*

  3. (Let b_optional be $is_optional_parameterIR(parameterIR))*

  4. If (~($exists_(b_default*) /\ $exists_(b_optional*))), then

    1. If ((|id_param*| = n_arg)), then

      1. Return (match [] [])

    2. If ((|id_param*| > n_arg)), then

      1. (Let (parameterIR_given*, parameterIR_omitted*) be $partition_<parameterIR>(parameterIR*, n_arg))

      2. If (~$is_optional_parameterIR(parameterIR_omitted))*, then

        1. If ($is_default_parameterIR(parameterIR_omitted))*, then

          1. (Let id_default be $id_of_parameterIR(parameterIR_omitted))*

          2. Return (match id_default* [])

      3. If (~$is_default_parameterIR(parameterIR_given))*, then

        1. If ($is_optional_parameterIR(parameterIR_omitted))*, then

          1. (Let id_optional be $id_of_parameterIR(parameterIR_omitted))*

          2. Return (match [] id_optional*)

3. Otherwise

  1. Return (nomatch)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.2-ir-call-overload.spectec:194:1-199:95:
dec $find_overloadeds_named<V>(set<pair<callableId, V>>', (nameIR_f ( id_arg* )), $get_parameterListIR)

1. If ((set<pair<callableId, V>>' = ({ [] }))), then

  1. Return []

1. Else Phantom#510

2. (Let ({ pair<callableId, V>* }) be set<pair<callableId, V>>')

3. If ((pair<callableId, V>* matches pattern _ :: _)), then

  1. (Let (callTargetId_h : V_h) :: (callTargetId_t : V_t)* be pair<callableId, V>*)

  2. If (((nomatch) = $match_overloaded_named<V>((callTargetId_h : V_h), (nameIR_f ( id_arg* )), $get_parameterListIR))), then

    1. Return $find_overloadeds_named<V>(({ (callTargetId_t : V_t)* }), (nameIR_f ( id_arg* )), $get_parameterListIR)

  2. Else Phantom#511

  3. (Let callTargetMatch be $match_overloaded_named<V>((callTargetId_h : V_h), (nameIR_f ( id_arg* )), $get_parameterListIR))

  4. If ((callTargetMatch matches pattern `MATCH % %`)), then

    1. (Let (match id_default* id_optional*) be callTargetMatch)

    2. Return (callTargetId_h : V_h # id_default* # id_optional*) :: $find_overloadeds_named<V>(({ (callTargetId_t : V_t)* }), (nameIR_f ( id_arg* )), $get_parameterListIR)

  4. Else Phantom#512

3. Else Phantom#513

