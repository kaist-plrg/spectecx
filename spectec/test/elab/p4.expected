;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.2.1-type.spectec:67:22-67:53:
syntax fieldTypeIR = 
   | annotationList typeIR nameIR ; (from fieldTypeIR)

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.2.1-type.spectec:70:3-71:28:
syntax structTypeIR = 
   | struct typeId < typeArgumentIR* > { fieldTypeIR* } (from structTypeIR) hint(print %0#"<"#%1#">")

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.2.1-type.spectec:73:3-74:28:
syntax headerTypeIR = 
   | header typeId < typeArgumentIR* > { fieldTypeIR* } (from headerTypeIR) hint(print %0#"<"#%1#">")

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.2.1-type.spectec:76:3-77:28:
syntax headerUnionTypeIR = 
