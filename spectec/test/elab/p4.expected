def $opt_as_seq_<X>(X?) : X* =

   ;; ../../../../../spectec/examples/p4-concrete/0-aux/0.0-stdlib.spectec:155:1-155:31:
   clause 0(X?{X <- X?}) = []
      -- if X?{X <- X?} matches ()

   ;; ../../../../../spectec/examples/p4-concrete/0-aux/0.0-stdlib.spectec:156:1-156:31:
   clause 1(X'?{X' <- X'?}) = [X]
      -- if X'?{X' <- X'?} matches (_)
      -- let ?(X) = X'?{X' <- X'?}

