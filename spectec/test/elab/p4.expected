;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.2.1-type.spectec:171:1-176:24:
syntax synthesizedTypeIR = 
   | default (from defaultTypeIR)
   | header_invalid (from invalidHeaderTypeIR)
   | seq < typeIR* > (from sequenceTypeIR)
   | seq < typeIR* , ... > (from sequenceTypeIR)
   | record { fieldTypeIR* } (from recordTypeIR)
   | record { fieldTypeIR* , ... } (from recordTypeIR)
   | set < typeIR > (from setTypeIR)
   | table_enum typeId { nameIR* } (from tableMetadataEnumTypeIR) hint(print %0)
   | table_struct typeId { hit boolTypeIR ; miss boolTypeIR ; action_run tableMetadataEnumTypeIR ; } (from tableMetadataStructTypeIR) hint(print %0)

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.2.1-type.spectec:183:1-188:22:
syntax typeIR = 
   | void (from voidTypeIR)
   | bool (from boolTypeIR)
   | error (from errorTypeIR)
   | match_kind (from matchKindTypeIR)
   | string (from stringTypeIR)
   | int (from intTypeIR)
   | int < nat > (from fixedIntTypeIR)
   | bit < nat > (from fixedBitTypeIR)
   | varbit < nat > (from varBitTypeIR)
   | ` typeId (from nameTypeIR) hint(print %0)
   | typedef typeId typeIR (from typedefTypeIR) hint(print %0)
   | type typeId typeIR (from newTypeIR) hint(print %0)
   | list < typeIR > (from listTypeIR)
   | tuple < typeIR* > (from tupleTypeIR)
   | typeIR [ nat ] (from headerStackTypeIR)
   | struct typeId < typeArgumentIR* > { fieldTypeIR* } (from structTypeIR) hint(print %0#"<"#%1#">")
   | header typeId < typeArgumentIR* > { fieldTypeIR* } (from headerTypeIR) hint(print %0#"<"#%1#">")
   | header_union typeId < typeArgumentIR* > { fieldTypeIR* } (from headerUnionTypeIR) hint(print %0#"<"#%1#">")
   | enum typeId { nameIR* } (from simpleEnumTypeIR) hint(print %0)
   | enum typeId < typeIR > { valueFieldIR* } (from serializableEnumTypeIR) hint(print %0)
   | extern typeId < typeArgumentIR* > externMethodTypeDefEnv (from externObjectTypeIR) hint(print %0#"<"#%1#">")
   | parser typeId < typeArgumentIR* > ( parameterIR* ) (from parserObjectTypeIR) hint(print %0#"<"#%1#">")
   | control typeId < typeArgumentIR* > ( parameterIR* ) (from controlObjectTypeIR) hint(print %0#"<"#%1#">")
   | package typeId < typeArgumentIR* > { typeIR* } (from packageObjectTypeIR) hint(print %0#"<"#%1#">")
   | table typeId { tableMetadataStructTypeIR } (from tableObjectTypeIR) hint(print %0)
   | default (from defaultTypeIR)
   | header_invalid (from invalidHeaderTypeIR)
   | seq < typeIR* > (from sequenceTypeIR)
   | seq < typeIR* , ... > (from sequenceTypeIR)
   | record { fieldTypeIR* } (from recordTypeIR)
   | record { fieldTypeIR* , ... } (from recordTypeIR)
   | set < typeIR > (from setTypeIR)
   | table_enum typeId { nameIR* } (from tableMetadataEnumTypeIR) hint(print %0)
   | table_struct typeId { hit boolTypeIR ; miss boolTypeIR ; action_run tableMetadataEnumTypeIR ; } (from tableMetadataStructTypeIR) hint(print %0)

