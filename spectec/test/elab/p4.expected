;; ../../../../../spectec/examples/p4-concrete/6-dynamic-runtime/6.0-domain.spectec:5:1-6:58:
def $callableId_IR(nameIR, parameterListIR) : callableId =

   ;; ../../../../../spectec/examples/p4-concrete/6-dynamic-runtime/6.0-domain.spectec:8:1-10:36:
   clause 0(nameIR, parameterIR*{parameterIR <- parameterIR*}) = nameIR ( id*{id <- id*} )
      -- (let _annotationList _direction _typeIR id _parameterInitializerOptIR = parameterIR)*{_annotationList <- _annotationList*, _direction <- _direction*, _parameterInitializerOptIR <- _parameterInitializerOptIR*, _typeIR <- _typeIR*, id <- id*, parameterIR <- parameterIR*}

;; ../../../../../spectec/examples/p4-concrete/6-dynamic-runtime/6.1-storage-reference.spectec:6:1-10:42:
syntax storageReference = 
   | ` nameIR (from prefixedNameIR) hint(print %0)
   | . nameIR (from prefixedNameIR)
   | storageReference . nameIR (from storageReference)
   | storageReference [ value ] (from storageReference)
   | storageReference [ value : value ] (from storageReference)
   | storageReference [ value + : value ] (from storageReference)

;; ../../../../../spectec/examples/p4-concrete/6-dynamic-runtime/6.2.1-callable-def.spectec:12:3-12:69:
syntax actionDef = 
   | annotationList action nameIR ( parameterListIR ) blockStatementIR (from actionDef)

;; ../../../../../spectec/examples/p4-concrete/6-dynamic-runtime/6.2.1-callable-def.spectec:19:3-20:42:
syntax definedFunctionDef = 
   | function nameIR < typeParameterListIR > ( parameterListIR ) blockStatementIR (from definedFunctionDef)

;; ../../../../../spectec/examples/p4-concrete/6-dynamic-runtime/6.2.1-callable-def.spectec:23:3-24:50:
syntax externFunctionDef = 
   | extern_function nameIR < typeParameterListIR > ( parameterListIR ) (from externFunctionDef)

;; ../../../../../spectec/examples/p4-concrete/6-dynamic-runtime/6.2.1-callable-def.spectec:27:1-28:22:
syntax functionDef = 
   | function nameIR < typeParameterListIR > ( parameterListIR ) blockStatementIR (from definedFunctionDef)
   | extern_function nameIR < typeParameterListIR > ( parameterListIR ) (from externFunctionDef)

;; ../../../../../spectec/examples/p4-concrete/6-dynamic-runtime/6.2.1-callable-def.spectec:35:1-38:52:
syntax externMethodDef = 
   | extern_method nameIR < typeParameterListIR > ( parameterListIR ) blockStatementIR? (from externMethodDef)
   | extern_method abstract nameIR < typeParameterListIR > ( parameterListIR ) (from externMethodDef)

;; ../../../../../spectec/examples/p4-concrete/6-dynamic-runtime/6.2.1-callable-def.spectec:41:3-42:50:
syntax parserApplyMethodDef = 
   | parser_apply ( parameterListIR ) { parserLocalDeclarationListIR ; stateEnv } (from parserApplyMethodDef)

;; ../../../../../spectec/examples/p4-concrete/6-dynamic-runtime/6.2.1-callable-def.spectec:45:3-46:72:
syntax controlApplyMethodDef = 
   | control_apply ( parameterListIR ) { controlLocalDeclarationListIR ; actionDefEnv ; controlBodyIR } (from controlApplyMethodDef)

;; ../../../../../spectec/examples/p4-concrete/6-dynamic-runtime/6.2.1-callable-def.spectec:49:3-49:39:
syntax tableApplyMethodDef = 
   | table_apply { tablePropertyListIR } (from tableApplyMethodDef)

;; ../../../../../spectec/examples/p4-concrete/6-dynamic-runtime/6.2.1-callable-def.spectec:52:1-55:24:
syntax methodDef = 
   | extern_method nameIR < typeParameterListIR > ( parameterListIR ) blockStatementIR? (from externMethodDef)
   | extern_method abstract nameIR < typeParameterListIR > ( parameterListIR ) (from externMethodDef)
   | parser_apply ( parameterListIR ) { parserLocalDeclarationListIR ; stateEnv } (from parserApplyMethodDef)
   | control_apply ( parameterListIR ) { controlLocalDeclarationListIR ; actionDefEnv ; controlBodyIR } (from controlApplyMethodDef)
   | table_apply { tablePropertyListIR } (from tableApplyMethodDef)

;; ../../../../../spectec/examples/p4-concrete/6-dynamic-runtime/6.2.1-callable-def.spectec:57:22-57:57:
syntax callableDef = 
   | annotationList action nameIR ( parameterListIR ) blockStatementIR (from actionDef)
   | function nameIR < typeParameterListIR > ( parameterListIR ) blockStatementIR (from definedFunctionDef)
   | extern_function nameIR < typeParameterListIR > ( parameterListIR ) (from externFunctionDef)
   | extern_method nameIR < typeParameterListIR > ( parameterListIR ) blockStatementIR? (from externMethodDef)
   | extern_method abstract nameIR < typeParameterListIR > ( parameterListIR ) (from externMethodDef)
   | parser_apply ( parameterListIR ) { parserLocalDeclarationListIR ; stateEnv } (from parserApplyMethodDef)
   | control_apply ( parameterListIR ) { controlLocalDeclarationListIR ; actionDefEnv ; controlBodyIR } (from controlApplyMethodDef)
   | table_apply { tablePropertyListIR } (from tableApplyMethodDef)

;; ../../../../../spectec/examples/p4-concrete/6-dynamic-runtime/6.2.2-callable-def-aux.spectec:5:1-6:17:
