;; ../../../../../spectec/examples/p4-concrete/6-dynamic-runtime/6.2.3-callable-callee.spectec:10:3-11:49:
syntax actionCallee = 
   | action cursor . nameIR ( parameterListIR # id* ) blockStatementIR (from actionCallee)

;; ../../../../../spectec/examples/p4-concrete/6-dynamic-runtime/6.2.3-callable-callee.spectec:18:3-19:49:
syntax definedFunctionCallee = 
   | function nameIR < typeParameterListIR > ( parameterListIR # id* ) blockStatementIR (from definedFunctionCallee)

;; ../../../../../spectec/examples/p4-concrete/6-dynamic-runtime/6.2.3-callable-callee.spectec:22:3-23:64:
syntax externFunctionCallee = 
   | extern_function nameIR < typeParameterListIR > ( parameterListIR # id* # id* ) (from externFunctionCallee)

;; ../../../../../spectec/examples/p4-concrete/6-dynamic-runtime/6.2.3-callable-callee.spectec:26:1-27:25:
syntax functionCallee = 
   | function nameIR < typeParameterListIR > ( parameterListIR # id* ) blockStatementIR (from definedFunctionCallee)
   | extern_function nameIR < typeParameterListIR > ( parameterListIR # id* # id* ) (from externFunctionCallee)

;; ../../../../../spectec/examples/p4-concrete/6-dynamic-runtime/6.2.3-callable-callee.spectec:34:3-35:49:
syntax builtinMethodCallee = 
   | builtin_method storageReference . nameIR < typeArgumentListIR > ( parameterListIR ) (from builtinMethodCallee)

;; ../../../../../spectec/examples/p4-concrete/6-dynamic-runtime/6.2.3-callable-callee.spectec:38:3-40:45:
syntax externMethodCallee = 
   | extern_method objectId . nameIR < typeParameterListIR > ( parameterListIR # id* # id* ) { theta ; frame ; blockStatementIR? } (from externMethodCallee)

;; ../../../../../spectec/examples/p4-concrete/6-dynamic-runtime/6.2.3-callable-callee.spectec:43:3-44:68:
syntax parserApplyMethodCallee = 
   | parser objectId . apply ( parameterListIR # id* ) { theta ; frame ; parserLocalDeclarationListIR ; stateEnv } (from parserApplyMethodCallee)

;; ../../../../../spectec/examples/p4-concrete/6-dynamic-runtime/6.2.3-callable-callee.spectec:47:3-48:90:
syntax controlApplyMethodCallee = 
   | control objectId . apply ( parameterListIR # id* ) { theta ; frame ; controlLocalDeclarationListIR ; actionDefEnv ; controlBodyIR } (from controlApplyMethodCallee)

;; ../../../../../spectec/examples/p4-concrete/6-dynamic-runtime/6.2.3-callable-callee.spectec:51:3-51:60:
syntax tableApplyMethodCallee = 
   | table objectId . apply { frame ; tableObjectProperty } (from tableApplyMethodCallee)

;; ../../../../../spectec/examples/p4-concrete/6-dynamic-runtime/6.2.3-callable-callee.spectec:54:1-58:27:
syntax methodCallee = 
   | builtin_method storageReference . nameIR < typeArgumentListIR > ( parameterListIR ) (from builtinMethodCallee)
   | extern_method objectId . nameIR < typeParameterListIR > ( parameterListIR # id* # id* ) { theta ; frame ; blockStatementIR? } (from externMethodCallee)
   | parser objectId . apply ( parameterListIR # id* ) { theta ; frame ; parserLocalDeclarationListIR ; stateEnv } (from parserApplyMethodCallee)
   | control objectId . apply ( parameterListIR # id* ) { theta ; frame ; controlLocalDeclarationListIR ; actionDefEnv ; controlBodyIR } (from controlApplyMethodCallee)
   | table objectId . apply { frame ; tableObjectProperty } (from tableApplyMethodCallee)

;; ../../../../../spectec/examples/p4-concrete/6-dynamic-runtime/6.2.3-callable-callee.spectec:60:17-60:61:
syntax callee = 
   | action cursor . nameIR ( parameterListIR # id* ) blockStatementIR (from actionCallee)
   | function nameIR < typeParameterListIR > ( parameterListIR # id* ) blockStatementIR (from definedFunctionCallee)
   | extern_function nameIR < typeParameterListIR > ( parameterListIR # id* # id* ) (from externFunctionCallee)
   | builtin_method storageReference . nameIR < typeArgumentListIR > ( parameterListIR ) (from builtinMethodCallee)
   | extern_method objectId . nameIR < typeParameterListIR > ( parameterListIR # id* # id* ) { theta ; frame ; blockStatementIR? } (from externMethodCallee)
   | parser objectId . apply ( parameterListIR # id* ) { theta ; frame ; parserLocalDeclarationListIR ; stateEnv } (from parserApplyMethodCallee)
   | control objectId . apply ( parameterListIR # id* ) { theta ; frame ; controlLocalDeclarationListIR ; actionDefEnv ; controlBodyIR } (from controlApplyMethodCallee)
   | table objectId . apply { frame ; tableObjectProperty } (from tableApplyMethodCallee)

;; ../../../../../spectec/examples/p4-concrete/6-dynamic-runtime/6.3.1-constructor-def.spectec:6:3-8:37:
syntax externObjectConstructorDef = 
   | extern nameIR < typeParameterListIR > ( constructorParameterListIR ) { externMethodPrototypeListIR } (from externObjectConstructorDef)

;; ../../../../../spectec/examples/p4-concrete/6-dynamic-runtime/6.3.1-constructor-def.spectec:11:3-15:27:
syntax parserObjectConstructorDef = 
   | parser < typeParameterListIR > ( parameterListIR ) ( constructorParameterListIR ) { parserLocalDeclarationListIR parserStateListIR } (from parserObjectConstructorDef)

;; ../../../../../spectec/examples/p4-concrete/6-dynamic-runtime/6.3.1-constructor-def.spectec:18:3-22:29:
syntax controlObjectConstructorDef = 
   | control < typeParameterListIR > ( parameterListIR ) ( constructorParameterListIR ) { controlLocalDeclarationListIR apply controlBodyIR } (from controlObjectConstructorDef)

;; ../../../../../spectec/examples/p4-concrete/6-dynamic-runtime/6.3.1-constructor-def.spectec:25:3-26:36:
syntax packageObjectConstructorDef = 
   | package < typeParameterListIR > ( constructorParameterListIR ) (from packageObjectConstructorDef)

;; ../../../../../spectec/examples/p4-concrete/6-dynamic-runtime/6.3.1-constructor-def.spectec:29:1-32:32:
syntax constructorDef = 
   | extern nameIR < typeParameterListIR > ( constructorParameterListIR ) { externMethodPrototypeListIR } (from externObjectConstructorDef)
   | parser < typeParameterListIR > ( parameterListIR ) ( constructorParameterListIR ) { parserLocalDeclarationListIR parserStateListIR } (from parserObjectConstructorDef)
   | control < typeParameterListIR > ( parameterListIR ) ( constructorParameterListIR ) { controlLocalDeclarationListIR apply controlBodyIR } (from controlObjectConstructorDef)
   | package < typeParameterListIR > ( constructorParameterListIR ) (from packageObjectConstructorDef)

;; ../../../../../spectec/examples/p4-concrete/6-dynamic-runtime/6.3.2-constructor-def-aux.spectec:5:1-6:17:
def $parameterListIR_of_constructorDef(constructorDef) : parameterIR* =

   ;; ../../../../../spectec/examples/p4-concrete/6-dynamic-runtime/6.3.2-constructor-def-aux.spectec:8:1-10:31:
   clause 0(constructorDef) = constructorParameterListIR
      -- if constructorDef <: externObjectConstructorDef
      -- let extern _nameIR < _typeParameterListIR > ( constructorParameterListIR ) { _externMethodPrototypeListIR } = constructorDef as externObjectConstructorDef

   ;; ../../../../../spectec/examples/p4-concrete/6-dynamic-runtime/6.3.2-constructor-def-aux.spectec:12:1-14:31:
   clause 1(constructorDef) = constructorParameterListIR
      -- if constructorDef <: parserObjectConstructorDef
      -- let parser < _typeParameterListIR > ( _parameterListIR ) ( constructorParameterListIR ) { _parserLocalDeclarationListIR _parserStateListIR } = constructorDef as parserObjectConstructorDef

   ;; ../../../../../spectec/examples/p4-concrete/6-dynamic-runtime/6.3.2-constructor-def-aux.spectec:16:1-18:31:
   clause 2(constructorDef) = constructorParameterListIR
      -- if constructorDef <: controlObjectConstructorDef
      -- let control < _typeParameterListIR > ( _parameterListIR ) ( constructorParameterListIR ) { _controlLocalDeclarationListIR apply _controlBodyIR } = constructorDef as controlObjectConstructorDef

   ;; ../../../../../spectec/examples/p4-concrete/6-dynamic-runtime/6.3.2-constructor-def-aux.spectec:20:1-22:31:
   clause 3(constructorDef) = constructorParameterListIR
      -- if constructorDef <: packageObjectConstructorDef
      -- let package < _typeParameterListIR > ( constructorParameterListIR ) = constructorDef as packageObjectConstructorDef

;; ../../../../../spectec/examples/p4-concrete/6-dynamic-runtime/6.4.1-object.spectec:13:29-13:61:
syntax externMethodDefEnv = map<callableId, externMethodDef>

;; ../../../../../spectec/examples/p4-concrete/6-dynamic-runtime/6.4.1-object.spectec:15:1-16:68:
def $init_objectState(nameIR, typeIR*, value*) : objectState =

;; ../../../../../spectec/examples/p4-concrete/6-dynamic-runtime/6.4.1-object.spectec:19:3-19:69:
syntax externObject = 
   | extern typeId < theta > { objectState frame externMethodDefEnv } (from externObject)

;; ../../../../../spectec/examples/p4-concrete/6-dynamic-runtime/6.4.1-object.spectec:29:3-32:18:
syntax parserObject = 
