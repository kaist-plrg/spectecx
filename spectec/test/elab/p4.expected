;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:1016:1-1017:27:
syntax typedef = 
   | bool (from baseType)
   | error (from baseType)
   | match_kind (from baseType)
   | string (from baseType)
   | int (from baseType)
   | int < int > (from baseType)
   | int < ( expression ) > (from baseType)
   | bit (from baseType)
   | bit < int > (from baseType)
   | bit < ( expression ) > (from baseType)
   | varbit < int > (from baseType)
   | varbit < ( expression ) > (from baseType)
   | text (from typeIdentifier)
   | . typeName (from prefixedTypeName)
   | prefixedTypeName < typeArgumentList > (from specializedType)
   | namedType [ expression ] (from headerStackType)
   | list < typeArgument > (from listType)
   | tuple < typeArgumentList > (from tupleType)
   | annotationList enum name { nameList trailingCommaOpt } (from enumTypeDeclaration)
   | annotationList enum type name { namedExpressionList trailingCommaOpt } (from enumTypeDeclaration)
   | annotationList struct name typeParameterListOpt { typeFieldList } (from structTypeDeclaration)
   | annotationList header name typeParameterListOpt { typeFieldList } (from headerTypeDeclaration)
   | annotationList header_union name typeParameterListOpt { typeFieldList } (from headerUnionTypeDeclaration)

