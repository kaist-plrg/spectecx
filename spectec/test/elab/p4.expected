;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.2.1-type.spectec:82:3-82:42:
syntax simpleEnumTypeIR = 
   | enum typeId { nameIR* } (from simpleEnumTypeIR) hint(print %0)

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.2.1-type.spectec:85:3-85:60:
syntax serializableEnumTypeIR = 
   | enum typeId < typeIR > { valueFieldIR* } (from serializableEnumTypeIR) hint(print %0)

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.2.1-type.spectec:88:1-89:27:
syntax enumTypeIR = 
   | enum typeId { nameIR* } (from simpleEnumTypeIR) hint(print %0)
   | enum typeId < typeIR > { valueFieldIR* } (from serializableEnumTypeIR) hint(print %0)

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.2.1-type.spectec:92:1-98:15:
syntax dataTypeIR = 
   | list < typeIR > (from listTypeIR)
   | tuple < typeIR* > (from tupleTypeIR)
   | typeIR [ nat ] (from headerStackTypeIR)
   | struct typeId < typeArgumentIR* > { fieldTypeIR* } (from structTypeIR) hint(print %0#"<"#%1#">")
   | header typeId < typeArgumentIR* > { fieldTypeIR* } (from headerTypeIR) hint(print %0#"<"#%1#">")
   | header_union typeId < typeArgumentIR* > { fieldTypeIR* } (from headerUnionTypeIR) hint(print %0#"<"#%1#">")
   | enum typeId { nameIR* } (from simpleEnumTypeIR) hint(print %0)
   | enum typeId < typeIR > { valueFieldIR* } (from serializableEnumTypeIR) hint(print %0)

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.2.1-type.spectec:109:3-109:41:
