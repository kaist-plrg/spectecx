def $is_some_<X>(X?) : bool =

   ;; ../../../../../spectec/examples/p4-concrete/0-aux/0.0-stdlib.spectec:151:1-151:30:
   clause 0(X?{X <- X?}) = false
      -- if X?{X <- X?} matches ()

   ;; ../../../../../spectec/examples/p4-concrete/0-aux/0.0-stdlib.spectec:152:1-152:27:
   clause 1(X'?{X' <- X'?}) = true
      -- if X'?{X' <- X'?} matches (_)
      -- let ?(X) = X'?{X' <- X'?}

