;; ../../../../../spectec/examples/p4-concrete/0-aux/0.0-stdlib.spectec:82:1-82:61:
def $replace_text_except'(nat, nat, text, text, text) : text =

   ;; ../../../../../spectec/examples/p4-concrete/0-aux/0.0-stdlib.spectec:85:1-85:61:
   clause 0(n_len, n_len', t, t_old, t_new) = t
