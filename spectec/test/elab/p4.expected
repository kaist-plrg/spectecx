;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.5.1-type-free.spectec:9:1-10:47:
def $free_typeIR(typeIR) : bound =

   ;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.5.1-type-free.spectec:27:1-27:40:
   clause 0(typeIR) = { [] }
      -- if typeIR <: baseTypeIR
      -- let baseTypeIR = typeIR as baseTypeIR

   ;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.5.1-type-free.spectec:31:1-31:42:
   clause 1(typeIR) = { [typeId] }
      -- if typeIR <: nameTypeIR
      -- let ` typeId = typeIR as nameTypeIR

   ;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.5.1-type-free.spectec:35:1-35:58:
   clause 2(typeIR') = $free_typeIR(typeIR)
      -- if typeIR' <: typedefTypeIR
      -- let typedef _typeId typeIR = typeIR' as typedefTypeIR

   ;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.5.1-type-free.spectec:37:1-37:55:
   clause 3(typeIR') = $free_typeIR(typeIR)
      -- if typeIR' <: newTypeIR
      -- let type _typeId typeIR = typeIR' as newTypeIR

   ;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.5.1-type-free.spectec:41:1-41:58:
   clause 4(typeIR') = $free_typeIR(typeIR)
      -- if typeIR' <: listTypeIR
      -- let list < typeIR > = typeIR' as listTypeIR

   ;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.5.1-type-free.spectec:43:1-44:47:
   clause 5(typeIR') = $unions_set<typeId>($free_typeIR(typeIR)*{typeIR <- typeIR*})
      -- if typeIR' <: tupleTypeIR
      -- let tuple < typeIR*{typeIR <- typeIR*} > = typeIR' as tupleTypeIR

   ;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.5.1-type-free.spectec:46:1-46:55:
   clause 6(typeIR') = $free_typeIR(typeIR)
      -- if typeIR' <: headerStackTypeIR
      -- let typeIR [ _nat ] = typeIR' as headerStackTypeIR

   ;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.5.1-type-free.spectec:48:1-51:56:
   clause 7(typeIR) = $union_set<typeId>($unions_set<typeId>($free_typeIR(typeArgumentIR)*{typeArgumentIR <- typeArgumentIR*}), $unions_set<typeId>($free_typeIR(typeIR_field)*{typeIR_field <- typeIR_field*}))
      -- if typeIR <: structTypeIR
      -- let struct _typeId < typeArgumentIR*{typeArgumentIR <- typeArgumentIR*} > { _annotationList typeIR_field _nameIR ;*{_annotationList <- _annotationList*, _nameIR <- _nameIR*, typeIR_field <- typeIR_field*} } = typeIR as structTypeIR

   ;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.5.1-type-free.spectec:53:1-56:56:
   clause 8(typeIR) = $union_set<typeId>($unions_set<typeId>($free_typeIR(typeArgumentIR)*{typeArgumentIR <- typeArgumentIR*}), $unions_set<typeId>($free_typeIR(typeIR_field)*{typeIR_field <- typeIR_field*}))
      -- if typeIR <: headerTypeIR
      -- let header _typeId < typeArgumentIR*{typeArgumentIR <- typeArgumentIR*} > { _annotationList typeIR_field _nameIR ;*{_annotationList <- _annotationList*, _nameIR <- _nameIR*, typeIR_field <- typeIR_field*} } = typeIR as headerTypeIR

   ;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.5.1-type-free.spectec:58:1-61:56:
   clause 9(typeIR) = $union_set<typeId>($unions_set<typeId>($free_typeIR(typeArgumentIR)*{typeArgumentIR <- typeArgumentIR*}), $unions_set<typeId>($free_typeIR(typeIR_field)*{typeIR_field <- typeIR_field*}))
      -- if typeIR <: headerUnionTypeIR
      -- let header_union _typeId < typeArgumentIR*{typeArgumentIR <- typeArgumentIR*} > { _annotationList typeIR_field _nameIR ;*{_annotationList <- _annotationList*, _nameIR <- _nameIR*, typeIR_field <- typeIR_field*} } = typeIR as headerUnionTypeIR

   ;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.5.1-type-free.spectec:63:1-63:43:
   clause 10(typeIR) = { [] }
      -- if typeIR <: simpleEnumTypeIR
      -- let enum _typeId { _nameIR*{_nameIR <- _nameIR*} } = typeIR as simpleEnumTypeIR

   ;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.5.1-type-free.spectec:65:1-65:67:
   clause 11(typeIR') = $free_typeIR(typeIR)
      -- if typeIR' <: serializableEnumTypeIR
      -- let enum _typeId < typeIR > { _valueFieldIR*{_valueFieldIR <- _valueFieldIR*} } = typeIR' as serializableEnumTypeIR

   ;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.5.1-type-free.spectec:69:1-72:76:
   clause 12(typeIR) = $union_set<typeId>($unions_set<typeId>($free_typeIR(typeArgumentIR)*{typeArgumentIR <- typeArgumentIR*}), $unions_set<typeId>($free_callableTypeDefIR(externMethodTypeDefIR as callableTypeDefIR)*{externMethodTypeDefIR <- externMethodTypeDefIR*}))
      -- if typeIR <: externObjectTypeIR
      -- let extern _typeId < typeArgumentIR*{typeArgumentIR <- typeArgumentIR*} > { _callableId : externMethodTypeDefIR*{_callableId <- _callableId*, externMethodTypeDefIR <- externMethodTypeDefIR*} } = typeIR as externObjectTypeIR

   ;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.5.1-type-free.spectec:74:1-77:60:
   clause 13(typeIR) = $union_set<typeId>($unions_set<typeId>($free_typeIR(typeArgumentIR)*{typeArgumentIR <- typeArgumentIR*}), $unions_set<typeId>($free_parameterIR(parameterIR)*{parameterIR <- parameterIR*}))
      -- if typeIR <: parserObjectTypeIR
