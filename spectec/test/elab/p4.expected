;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.7-compile-time-known.spectec:5:14-5:30:
syntax ctk = 
   | lctk (from ctk)
   | ctk (from ctk)
   | dyn (from ctk)

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.7-compile-time-known.spectec:7:1-8:43:
def $join_ctk(ctk, ctk) : ctk =

   ;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.7-compile-time-known.spectec:10:1-10:33:
   clause 0(ctk, ctk') = lctk
      -- if ctk matches `LCTK`
      -- if ctk' matches `LCTK`

   ;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.7-compile-time-known.spectec:11:1-11:31:
   clause 1(ctk, ctk') = ctk
      -- if ctk matches `LCTK`
      -- if ctk' matches `CTK`

   ;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.7-compile-time-known.spectec:12:1-12:31:
   clause 2(ctk, ctk') = ctk
      -- if ctk matches `CTK`
      -- if ctk' matches `LCTK`

   ;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.7-compile-time-known.spectec:13:1-13:30:
   clause 3(ctk, ctk') = ctk
      -- if ctk matches `CTK`
      -- if ctk' matches `CTK`

   ;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.7-compile-time-known.spectec:14:1-15:15:
   clause 4(ctk_a, ctk_b) = dyn
      -- otherwise

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.7-compile-time-known.spectec:17:1-18:34:
def $joins_ctk(ctk*) : ctk =

   ;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.7-compile-time-known.spectec:20:1-20:27:
   clause 0(ctk*{ctk <- ctk*}) = lctk
      -- if ctk*{ctk <- ctk*} matches []

   ;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.7-compile-time-known.spectec:21:1-21:26:
   clause 1(ctk'*{ctk' <- ctk'*}) = ctk
      -- if ctk'*{ctk' <- ctk'*} matches [ _/1 ]
      -- let [ctk] = ctk'*{ctk' <- ctk'*}

   ;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.7-compile-time-known.spectec:22:1-22:57:
   clause 2(ctk'*{ctk' <- ctk'*}) = $join_ctk(ctk_a, ctk_b)
      -- if ctk'*{ctk' <- ctk'*} matches _ :: _
      -- let ctk_a :: ctk*{ctk <- ctk*} = ctk'*{ctk' <- ctk'*}
      -- if ctk*{ctk <- ctk*} matches [ _/1 ]
      -- let [ctk_b] = ctk*{ctk <- ctk*}

   ;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.7-compile-time-known.spectec:23:1-25:40:
   clause 3(ctk'*{ctk' <- ctk'*}) = $joins_ctk(ctk_d :: ctk_c*{ctk_c <- ctk_c*})
      -- if ctk'*{ctk' <- ctk'*} matches _ :: _
      -- let ctk_a :: ctk*{ctk <- ctk*} = ctk'*{ctk' <- ctk'*}
      -- if ctk*{ctk <- ctk*} matches _ :: _
      -- let ctk_b :: ctk_c*{ctk_c <- ctk_c*} = ctk*{ctk <- ctk*}
      -- if (ctk_c*{ctk_c <- ctk_c*} =/= [])
      -- let ctk_d = $join_ctk(ctk_a, ctk_b)

