syntax intTypeIR = 
   | int (from intTypeIR)

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.2.1-type.spectec:19:25-19:37:
syntax fixedIntTypeIR = 
   | int < nat > (from fixedIntTypeIR)

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.2.1-type.spectec:20:25-20:37:
syntax fixedBitTypeIR = 
   | bit < nat > (from fixedBitTypeIR)

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.2.1-type.spectec:21:23-21:38:
syntax varBitTypeIR = 
   | varbit < nat > (from varBitTypeIR)

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.2.1-type.spectec:24:1-27:17:
syntax integerTypeIR = 
   | int (from intTypeIR)
   | int < nat > (from fixedIntTypeIR)
   | bit < nat > (from fixedBitTypeIR)
   | varbit < nat > (from varBitTypeIR)

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.2.1-type.spectec:30:1-35:18:
syntax baseTypeIR = 
   | void (from voidTypeIR)
   | bool (from boolTypeIR)
   | error (from errorTypeIR)
   | match_kind (from matchKindTypeIR)
   | string (from stringTypeIR)
   | int (from intTypeIR)
   | int < nat > (from fixedIntTypeIR)
   | bit < nat > (from fixedBitTypeIR)
   | varbit < nat > (from varBitTypeIR)

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.2.1-type.spectec:41:21-41:45:
syntax nameTypeIR = 
   | ` typeId (from nameTypeIR) hint(print %0)

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.2.1-type.spectec:48:3-49:17:
syntax typedefTypeIR = 
   | typedef typeId typeIR (from typedefTypeIR) hint(print %0)

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.2.1-type.spectec:52:3-53:17:
