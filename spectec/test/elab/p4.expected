;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:538:1-542:7:
syntax simpleKeysetExpression = 
   | true (from booleanLiteral)
   | false (from booleanLiteral)
   | d int (from integerLiteral) hint(print %)
   | nat w int (from integerLiteral) hint(print %#W#%)
   | nat s int (from integerLiteral) hint(print %#S#%)
   | " text " (from stringLiteral) hint(print "#%#")
   | text (from identifier)
   | apply (from nonTypeName)
   | key (from nonTypeName)
   | actions (from nonTypeName)
   | state (from nonTypeName)
   | entries (from nonTypeName)
   | type (from nonTypeName)
   | priority (from nonTypeName)
   | . nonTypeName (from prefixedNonTypeName)
   | this (from referenceExpression)
   | ... (from defaultExpression)
   | unop expression (from unaryExpression)
   | expression binop expression (from binaryExpression)
   | expression ? expression : expression (from ternaryExpression)
   | ( type ) expression (from castExpression)
   | {#} (from invalidHeaderExpression)
   | { sequenceOrRecordElementExpression trailingCommaOpt } (from sequenceOrRecordExpression)
   | error . member (from errorAccessExpression)
   | memberAccessBase . member (from memberAccessExpression)
   | expression [ expression ] (from indexAccessExpression)
   | expression [ expression : expression ] (from sliceAccessExpression)
   | expression [ expression + : expression ] (from sliceAccessExpression)
   | callTarget ( argumentList ) (from callExpression)
   | callableTarget < realTypeArgumentList > ( argumentList ) (from callExpression)
   | ( expression ) (from parenthesizedExpression)
   | expression &&& expression (from simpleKeysetExpression)
   | expression .. expression (from simpleKeysetExpression)
   | default (from simpleKeysetExpression)
   | _ (from simpleKeysetExpression)

;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:545:1-546:57:
syntax simpleKeysetExpressionList = 
   | true (from booleanLiteral)
   | false (from booleanLiteral)
   | d int (from integerLiteral) hint(print %)
   | nat w int (from integerLiteral) hint(print %#W#%)
   | nat s int (from integerLiteral) hint(print %#S#%)
   | " text " (from stringLiteral) hint(print "#%#")
   | text (from identifier)
   | apply (from nonTypeName)
   | key (from nonTypeName)
   | actions (from nonTypeName)
   | state (from nonTypeName)
   | entries (from nonTypeName)
   | type (from nonTypeName)
   | priority (from nonTypeName)
   | . nonTypeName (from prefixedNonTypeName)
   | this (from referenceExpression)
   | ... (from defaultExpression)
   | unop expression (from unaryExpression)
   | expression binop expression (from binaryExpression)
   | expression ? expression : expression (from ternaryExpression)
   | ( type ) expression (from castExpression)
   | {#} (from invalidHeaderExpression)
   | { sequenceOrRecordElementExpression trailingCommaOpt } (from sequenceOrRecordExpression)
   | error . member (from errorAccessExpression)
   | memberAccessBase . member (from memberAccessExpression)
   | expression [ expression ] (from indexAccessExpression)
   | expression [ expression : expression ] (from sliceAccessExpression)
   | expression [ expression + : expression ] (from sliceAccessExpression)
   | callTarget ( argumentList ) (from callExpression)
   | callableTarget < realTypeArgumentList > ( argumentList ) (from callExpression)
   | ( expression ) (from parenthesizedExpression)
   | expression &&& expression (from simpleKeysetExpression)
   | expression .. expression (from simpleKeysetExpression)
   | default (from simpleKeysetExpression)
   | _ (from simpleKeysetExpression)
   | simpleKeysetExpressionList , simpleKeysetExpression (from simpleKeysetExpressionList)

;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:548:1-550:32:
def $flatten_simpleKeysetExpressionList(simpleKeysetExpressionList) : simpleKeysetExpression* =

   ;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:551:1-552:27:
   clause 0(simpleKeysetExpressionList) = [simpleKeysetExpression]
      -- if simpleKeysetExpressionList <: simpleKeysetExpression
      -- let simpleKeysetExpression = simpleKeysetExpressionList as simpleKeysetExpression

   ;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:553:1-556:34:
   clause 1(simpleKeysetExpressionList') = $flatten_simpleKeysetExpressionList(simpleKeysetExpressionList) ++ [simpleKeysetExpression]
      -- if simpleKeysetExpressionList' matches `% , %`
      -- let simpleKeysetExpressionList , simpleKeysetExpression = simpleKeysetExpressionList'

;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:559:1-563:62:
syntax tupleKeysetExpression = 
   | ( expression &&& expression ) (from tupleKeysetExpression)
   | ( expression .. expression ) (from tupleKeysetExpression)
   | ( default ) (from tupleKeysetExpression)
   | ( _ ) (from tupleKeysetExpression)
   | ( simpleKeysetExpression , simpleKeysetExpressionList ) (from tupleKeysetExpression)

;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:566:1-567:26:
syntax keysetExpression = 
   | true (from booleanLiteral)
   | false (from booleanLiteral)
   | d int (from integerLiteral) hint(print %)
   | nat w int (from integerLiteral) hint(print %#W#%)
   | nat s int (from integerLiteral) hint(print %#S#%)
   | " text " (from stringLiteral) hint(print "#%#")
   | text (from identifier)
   | apply (from nonTypeName)
   | key (from nonTypeName)
   | actions (from nonTypeName)
   | state (from nonTypeName)
   | entries (from nonTypeName)
   | type (from nonTypeName)
   | priority (from nonTypeName)
   | . nonTypeName (from prefixedNonTypeName)
   | this (from referenceExpression)
   | ... (from defaultExpression)
   | unop expression (from unaryExpression)
   | expression binop expression (from binaryExpression)
   | expression ? expression : expression (from ternaryExpression)
   | ( type ) expression (from castExpression)
   | {#} (from invalidHeaderExpression)
   | { sequenceOrRecordElementExpression trailingCommaOpt } (from sequenceOrRecordExpression)
   | error . member (from errorAccessExpression)
   | memberAccessBase . member (from memberAccessExpression)
   | expression [ expression ] (from indexAccessExpression)
   | expression [ expression : expression ] (from sliceAccessExpression)
   | expression [ expression + : expression ] (from sliceAccessExpression)
   | callTarget ( argumentList ) (from callExpression)
   | callableTarget < realTypeArgumentList > ( argumentList ) (from callExpression)
   | ( expression ) (from parenthesizedExpression)
   | expression &&& expression (from simpleKeysetExpression)
   | expression .. expression (from simpleKeysetExpression)
   | default (from simpleKeysetExpression)
   | _ (from simpleKeysetExpression)
   | ( expression &&& expression ) (from tupleKeysetExpression)
   | ( expression .. expression ) (from tupleKeysetExpression)
   | ( default ) (from tupleKeysetExpression)
   | ( _ ) (from tupleKeysetExpression)
   | ( simpleKeysetExpression , simpleKeysetExpressionList ) (from tupleKeysetExpression)

;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:574:1-576:7:
syntax realTypeArgument = 
   | bool (from baseType)
   | error (from baseType)
   | match_kind (from baseType)
   | string (from baseType)
   | int (from baseType)
   | int < int > (from baseType)
   | int < ( expression ) > (from baseType)
   | bit (from baseType)
   | bit < int > (from baseType)
   | bit < ( expression ) > (from baseType)
   | varbit < int > (from baseType)
   | varbit < ( expression ) > (from baseType)
   | text (from typeIdentifier)
   | . typeName (from prefixedTypeName)
   | prefixedTypeName < typeArgumentList > (from specializedType)
   | namedType [ expression ] (from headerStackType)
   | list < typeArgument > (from listType)
   | tuple < typeArgumentList > (from tupleType)
   | void (from realTypeArgument)
   | _ (from realTypeArgument)

;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:579:1-580:45:
syntax realTypeArgumentList = 
   | bool (from baseType)
   | error (from baseType)
   | match_kind (from baseType)
   | string (from baseType)
   | int (from baseType)
   | int < int > (from baseType)
   | int < ( expression ) > (from baseType)
   | bit (from baseType)
   | bit < int > (from baseType)
   | bit < ( expression ) > (from baseType)
   | varbit < int > (from baseType)
   | varbit < ( expression ) > (from baseType)
   | text (from typeIdentifier)
   | . typeName (from prefixedTypeName)
   | prefixedTypeName < typeArgumentList > (from specializedType)
   | namedType [ expression ] (from headerStackType)
   | list < typeArgument > (from listType)
   | tuple < typeArgumentList > (from tupleType)
   | void (from realTypeArgument)
   | _ (from realTypeArgument)
   | realTypeArgumentList , realTypeArgument (from realTypeArgumentList)

;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:582:1-583:32:
def $flatten_realTypeArgumentList(realTypeArgumentList) : realTypeArgument* =

   ;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:584:1-584:71:
   clause 0(realTypeArgumentList) = [realTypeArgument]
      -- if realTypeArgumentList <: realTypeArgument
      -- let realTypeArgument = realTypeArgumentList as realTypeArgument

   ;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:585:1-586:80:
   clause 1(realTypeArgumentList') = $flatten_realTypeArgumentList(realTypeArgumentList) ++ [realTypeArgument]
      -- if realTypeArgumentList' matches `% , %`
      -- let realTypeArgumentList , realTypeArgument = realTypeArgumentList'

;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:589:1-590:16:
syntax typeArgument = 
   | bool (from baseType)
   | error (from baseType)
   | match_kind (from baseType)
   | string (from baseType)
   | int (from baseType)
   | int < int > (from baseType)
   | int < ( expression ) > (from baseType)
   | bit (from baseType)
   | bit < int > (from baseType)
   | bit < ( expression ) > (from baseType)
   | varbit < int > (from baseType)
   | varbit < ( expression ) > (from baseType)
   | text (from typeIdentifier)
   | . typeName (from prefixedTypeName)
   | prefixedTypeName < typeArgumentList > (from specializedType)
   | namedType [ expression ] (from headerStackType)
   | list < typeArgument > (from listType)
   | tuple < typeArgumentList > (from tupleType)
   | void (from realTypeArgument)
   | _ (from realTypeArgument)
   | text (from identifier)
   | apply (from nonTypeName)
   | key (from nonTypeName)
   | actions (from nonTypeName)
   | state (from nonTypeName)
   | entries (from nonTypeName)
   | type (from nonTypeName)
   | priority (from nonTypeName)

;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:593:1-595:37:
syntax typeArgumentList = 
   |  (from typeArgumentList)
   | bool (from baseType)
   | error (from baseType)
   | match_kind (from baseType)
   | string (from baseType)
   | int (from baseType)
   | int < int > (from baseType)
   | int < ( expression ) > (from baseType)
   | bit (from baseType)
   | bit < int > (from baseType)
   | bit < ( expression ) > (from baseType)
   | varbit < int > (from baseType)
   | varbit < ( expression ) > (from baseType)
   | text (from typeIdentifier)
   | . typeName (from prefixedTypeName)
   | prefixedTypeName < typeArgumentList > (from specializedType)
   | namedType [ expression ] (from headerStackType)
   | list < typeArgument > (from listType)
   | tuple < typeArgumentList > (from tupleType)
   | void (from realTypeArgument)
   | _ (from realTypeArgument)
   | text (from identifier)
   | apply (from nonTypeName)
   | key (from nonTypeName)
   | actions (from nonTypeName)
   | state (from nonTypeName)
   | entries (from nonTypeName)
   | type (from nonTypeName)
   | priority (from nonTypeName)
   | typeArgumentList , typeArgument (from typeArgumentList)

;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:597:1-598:32:
def $flatten_typeArgumentList(typeArgumentList) : typeArgument* =

   ;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:599:1-599:44:
   clause 0(typeArgumentList) = []
      -- if typeArgumentList matches ``EMPTY`

   ;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:600:1-600:59:
   clause 1(typeArgumentList) = [typeArgument]
      -- if typeArgumentList <: typeArgument
      -- let typeArgument = typeArgumentList as typeArgument

   ;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:601:1-602:68:
   clause 2(typeArgumentList') = $flatten_typeArgumentList(typeArgumentList) ++ [typeArgument]
      -- if typeArgumentList' matches `% , %`
      -- let typeArgumentList , typeArgument = typeArgumentList'

;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:609:1-612:7:
syntax argument = 
   | true (from booleanLiteral)
   | false (from booleanLiteral)
   | d int (from integerLiteral) hint(print %)
   | nat w int (from integerLiteral) hint(print %#W#%)
   | nat s int (from integerLiteral) hint(print %#S#%)
   | " text " (from stringLiteral) hint(print "#%#")
   | text (from identifier)
   | apply (from nonTypeName)
   | key (from nonTypeName)
   | actions (from nonTypeName)
   | state (from nonTypeName)
   | entries (from nonTypeName)
   | type (from nonTypeName)
   | priority (from nonTypeName)
   | . nonTypeName (from prefixedNonTypeName)
   | this (from referenceExpression)
   | ... (from defaultExpression)
   | unop expression (from unaryExpression)
   | expression binop expression (from binaryExpression)
   | expression ? expression : expression (from ternaryExpression)
   | ( type ) expression (from castExpression)
   | {#} (from invalidHeaderExpression)
   | { sequenceOrRecordElementExpression trailingCommaOpt } (from sequenceOrRecordExpression)
   | error . member (from errorAccessExpression)
   | memberAccessBase . member (from memberAccessExpression)
   | expression [ expression ] (from indexAccessExpression)
   | expression [ expression : expression ] (from sliceAccessExpression)
   | expression [ expression + : expression ] (from sliceAccessExpression)
   | callTarget ( argumentList ) (from callExpression)
   | callableTarget < realTypeArgumentList > ( argumentList ) (from callExpression)
   | ( expression ) (from parenthesizedExpression)
   | name = expression (from argument)
   | name = _ (from argument)
   | _ (from argument)

;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:615:1-616:37:
syntax argumentListNonEmpty = 
   | true (from booleanLiteral)
   | false (from booleanLiteral)
   | d int (from integerLiteral) hint(print %)
   | nat w int (from integerLiteral) hint(print %#W#%)
   | nat s int (from integerLiteral) hint(print %#S#%)
   | " text " (from stringLiteral) hint(print "#%#")
   | text (from identifier)
   | apply (from nonTypeName)
   | key (from nonTypeName)
   | actions (from nonTypeName)
   | state (from nonTypeName)
   | entries (from nonTypeName)
   | type (from nonTypeName)
   | priority (from nonTypeName)
   | . nonTypeName (from prefixedNonTypeName)
   | this (from referenceExpression)
   | ... (from defaultExpression)
   | unop expression (from unaryExpression)
   | expression binop expression (from binaryExpression)
   | expression ? expression : expression (from ternaryExpression)
   | ( type ) expression (from castExpression)
   | {#} (from invalidHeaderExpression)
   | { sequenceOrRecordElementExpression trailingCommaOpt } (from sequenceOrRecordExpression)
   | error . member (from errorAccessExpression)
   | memberAccessBase . member (from memberAccessExpression)
   | expression [ expression ] (from indexAccessExpression)
   | expression [ expression : expression ] (from sliceAccessExpression)
   | expression [ expression + : expression ] (from sliceAccessExpression)
   | callTarget ( argumentList ) (from callExpression)
   | callableTarget < realTypeArgumentList > ( argumentList ) (from callExpression)
   | ( expression ) (from parenthesizedExpression)
   | name = expression (from argument)
   | name = _ (from argument)
   | _ (from argument)
   | argumentListNonEmpty , argument (from argumentListNonEmpty)

;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:619:1-620:25:
syntax argumentList = 
   |  (from argumentList)
   | true (from booleanLiteral)
   | false (from booleanLiteral)
   | d int (from integerLiteral) hint(print %)
   | nat w int (from integerLiteral) hint(print %#W#%)
   | nat s int (from integerLiteral) hint(print %#S#%)
   | " text " (from stringLiteral) hint(print "#%#")
   | text (from identifier)
   | apply (from nonTypeName)
   | key (from nonTypeName)
   | actions (from nonTypeName)
   | state (from nonTypeName)
   | entries (from nonTypeName)
   | type (from nonTypeName)
   | priority (from nonTypeName)
   | . nonTypeName (from prefixedNonTypeName)
   | this (from referenceExpression)
   | ... (from defaultExpression)
   | unop expression (from unaryExpression)
   | expression binop expression (from binaryExpression)
   | expression ? expression : expression (from ternaryExpression)
   | ( type ) expression (from castExpression)
   | {#} (from invalidHeaderExpression)
   | { sequenceOrRecordElementExpression trailingCommaOpt } (from sequenceOrRecordExpression)
   | error . member (from errorAccessExpression)
   | memberAccessBase . member (from memberAccessExpression)
   | expression [ expression ] (from indexAccessExpression)
   | expression [ expression : expression ] (from sliceAccessExpression)
   | expression [ expression + : expression ] (from sliceAccessExpression)
   | callTarget ( argumentList ) (from callExpression)
   | callableTarget < realTypeArgumentList > ( argumentList ) (from callExpression)
   | ( expression ) (from parenthesizedExpression)
   | name = expression (from argument)
   | name = _ (from argument)
   | _ (from argument)
   | argumentListNonEmpty , argument (from argumentListNonEmpty)

;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:622:1-623:32:
def $flatten_argumentList(argumentList) : argument* =

   ;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:624:1-624:40:
   clause 0(argumentList) = []
      -- if argumentList matches ``EMPTY`

   ;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:625:1-625:47:
   clause 1(argumentList) = [argument]
      -- if argumentList <: argument
      -- let argument = argumentList as argument

   ;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:626:1-627:64:
   clause 2(argumentList) = $flatten_argumentList(argumentListNonEmpty as argumentList) ++ [argument]
      -- if argumentList <: argumentListNonEmpty
      -- let argumentListNonEmpty' = argumentList as argumentListNonEmpty
      -- if argumentListNonEmpty' matches `% , %`
      -- let argumentListNonEmpty , argument = argumentListNonEmpty'

;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:634:1-639:16:
syntax lvalue = 
   | text (from identifier)
   | apply (from nonTypeName)
   | key (from nonTypeName)
   | actions (from nonTypeName)
   | state (from nonTypeName)
   | entries (from nonTypeName)
   | type (from nonTypeName)
   | priority (from nonTypeName)
   | . nonTypeName (from prefixedNonTypeName)
   | this (from referenceExpression)
   | lvalue . member (from lvalue)
   | lvalue [ expression ] (from lvalue)
   | lvalue [ expression : expression ] (from lvalue)
   | lvalue [ expression + : expression ] (from lvalue)
   | ( lvalue ) (from lvalue)

;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:641:1-642:54:
def $lvalue_as_expression(lvalue) : expression =

   ;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:643:1-643:69:
   clause 0(lvalue) = referenceExpression as expression
      -- if lvalue <: referenceExpression
      -- let referenceExpression = lvalue as referenceExpression

   ;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:644:1-646:61:
   clause 1(lvalue) = expression_base as memberAccessBase . member as expression
      -- if lvalue matches `% . %`
      -- let lvalue_base . member = lvalue
      -- let expression_base = $lvalue_as_expression(lvalue_base)

   ;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:647:1-649:61:
   clause 2(lvalue) = expression_base [ expression_index ] as expression
      -- if lvalue matches `% [%]`
      -- let lvalue_base [ expression_index ] = lvalue
      -- let expression_base = $lvalue_as_expression(lvalue_base)

   ;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:650:1-652:61:
   clause 3(lvalue) = expression_base [ expression_hi : expression_lo ] as expression
      -- if lvalue matches `% [% : %]`
      -- let lvalue_base [ expression_hi : expression_lo ] = lvalue
      -- let expression_base = $lvalue_as_expression(lvalue_base)

   ;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:653:1-655:61:
   clause 4(lvalue) = expression_base [ expression_hi + : expression_lo ] as expression
      -- if lvalue matches `% [% + : %]`
      -- let lvalue_base [ expression_hi + : expression_lo ] = lvalue
      -- let expression_base = $lvalue_as_expression(lvalue_base)

   ;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:656:1-657:51:
   clause 5(lvalue') = ( expression ) as expression
      -- if lvalue' matches `(%)`
      -- let ( lvalue ) = lvalue'
      -- let expression = $lvalue_as_expression(lvalue)

;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:659:1-660:51:
def $expression_as_lvalue(expression) : lvalue? =

   ;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:661:1-661:69:
   clause 0(expression) = ?(referenceExpression as lvalue)
      -- if expression <: referenceExpression
      -- let referenceExpression = expression as referenceExpression

   ;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:662:1-663:51:
   clause 1(expression') = ?(lvalue . member)
      -- if expression' <: memberAccessExpression
      -- let memberAccessBase . member = expression' as memberAccessExpression
      -- if memberAccessBase <: expression
      -- let expression = memberAccessBase as expression
      -- let lvalue'?{lvalue' <- lvalue'?} = $expression_as_lvalue(expression)
      -- if lvalue'?{lvalue' <- lvalue'?} matches (_)
      -- let ?(lvalue) = lvalue'?{lvalue' <- lvalue'?}

   ;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:664:1-666:61:
   clause 2(expression) = ?(lvalue_base [ expression_index ])
      -- if expression <: indexAccessExpression
      -- let expression_base [ expression_index ] = expression as indexAccessExpression
      -- let lvalue?{lvalue <- lvalue?} = $expression_as_lvalue(expression_base)
      -- if lvalue?{lvalue <- lvalue?} matches (_)
      -- let ?(lvalue_base) = lvalue?{lvalue <- lvalue?}

   ;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:667:1-669:61:
   clause 3(expression) = ?(lvalue_base [ expression_hi : expression_lo ])
      -- if expression <: sliceAccessExpression
      -- let sliceAccessExpression = expression as sliceAccessExpression
      -- if sliceAccessExpression matches `% [% : %]`
      -- let expression_base [ expression_hi : expression_lo ] = sliceAccessExpression
      -- let lvalue?{lvalue <- lvalue?} = $expression_as_lvalue(expression_base)
      -- if lvalue?{lvalue <- lvalue?} matches (_)
      -- let ?(lvalue_base) = lvalue?{lvalue <- lvalue?}

   ;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:670:1-672:61:
   clause 4(expression) = ?(lvalue_base [ expression_hi + : expression_lo ])
      -- if expression <: sliceAccessExpression
      -- let sliceAccessExpression = expression as sliceAccessExpression
      -- if sliceAccessExpression matches `% [% + : %]`
      -- let expression_base [ expression_hi + : expression_lo ] = sliceAccessExpression
      -- let lvalue?{lvalue <- lvalue?} = $expression_as_lvalue(expression_base)
      -- if lvalue?{lvalue <- lvalue?} matches (_)
      -- let ?(lvalue_base) = lvalue?{lvalue <- lvalue?}

   ;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:673:1-674:51:
   clause 5(expression') = ?(( lvalue ))
      -- if expression' <: parenthesizedExpression
      -- let ( expression ) = expression' as parenthesizedExpression
      -- let lvalue'?{lvalue' <- lvalue'?} = $expression_as_lvalue(expression)
      -- if lvalue'?{lvalue' <- lvalue'?} matches (_)
      -- let ?(lvalue) = lvalue'?{lvalue' <- lvalue'?}

;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:684:25-684:27:
syntax emptyStatement = 
   | ; (from emptyStatement)

;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:691:1-693:34:
syntax assignop = 
   | = (from assignop)
   | += (from assignop)
   | -= (from assignop)
   | |+|= (from assignop)
   | |-|= (from assignop)
   | *= (from assignop)
   | /= (from assignop)
   | %= (from assignop)
   | <<= (from assignop)
   | >>= (from assignop)
   | &= (from assignop)
   | ^= (from assignop)
   | |= (from assignop)

;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:695:30-695:59:
syntax assignmentStatement = 
   | lvalue assignop expression ; (from assignmentStatement)

;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:697:1-698:59:
def $assignop_as_binop(assignop) : binop? =

   ;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:699:1-699:33:
   clause 0(assignop) = ?(+)
      -- if assignop matches `+=`

   ;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:700:1-700:33:
   clause 1(assignop) = ?(-)
      -- if assignop matches `-=`

   ;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:701:1-701:37:
   clause 2(assignop) = ?(|+|)
      -- if assignop matches `|+|=`

   ;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:702:1-702:37:
   clause 3(assignop) = ?(|-|)
      -- if assignop matches `|-|=`

   ;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:703:1-703:33:
   clause 4(assignop) = ?(*)
      -- if assignop matches `*=`

   ;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:704:1-704:33:
   clause 5(assignop) = ?(/)
      -- if assignop matches `/=`

   ;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:705:1-705:33:
   clause 6(assignop) = ?(%)
      -- if assignop matches `%=`

   ;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:706:1-706:35:
   clause 7(assignop) = ?(<<)
      -- if assignop matches `<<=`

   ;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:707:1-707:35:
   clause 8(assignop) = ?(>>)
      -- if assignop matches `>>=`

   ;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:708:1-708:33:
   clause 9(assignop) = ?(&)
      -- if assignop matches `&=`

   ;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:709:1-709:33:
   clause 10(assignop) = ?(^)
      -- if assignop matches `^=`

   ;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:710:1-710:33:
   clause 11(assignop) = ?(|)
      -- if assignop matches `|=`

   ;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:711:1-712:15:
   clause 12(assignop) = ?()
      -- otherwise

;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:719:1-720:54:
syntax callStatement = 
   | lvalue ( argumentList ) ; (from callStatement)
   | lvalue < typeArgumentList > ( argumentList ) ; (from callStatement)

;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:726:37-726:76:
syntax directApplicationStatement = 
   | namedType . apply ( argumentList ) ; (from directApplicationStatement)

;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:733:1-734:25:
syntax returnStatement = 
   | return ; (from returnStatement)
   | return expression ; (from returnStatement)

;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:740:24-740:31:
syntax exitStatement = 
   | exit ; (from exitStatement)

;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:748:25-748:70:
syntax blockStatement = 
   | annotationList { blockElementStatementList } (from blockStatement)

;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:757:1-758:48:
syntax conditionalStatement = 
   | if ( expression ) statement (from conditionalStatement)
   | if ( expression ) statement else statement (from conditionalStatement)

;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:767:1-769:31:
syntax forUpdateStatement = 
   | lvalue ( argumentList ) (from forUpdateStatement)
   | lvalue < typeArgumentList > ( argumentList ) (from forUpdateStatement)
   | lvalue assignop expression (from forUpdateStatement)

;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:772:1-773:57:
syntax forUpdateStatementListNonEmpty = 
   | lvalue ( argumentList ) (from forUpdateStatement)
   | lvalue < typeArgumentList > ( argumentList ) (from forUpdateStatement)
   | lvalue assignop expression (from forUpdateStatement)
   | forUpdateStatementListNonEmpty , forUpdateStatement (from forUpdateStatementListNonEmpty)

;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:776:1-777:35:
syntax forUpdateStatementList = 
   |  (from forUpdateStatementList)
   | lvalue ( argumentList ) (from forUpdateStatement)
   | lvalue < typeArgumentList > ( argumentList ) (from forUpdateStatement)
   | lvalue assignop expression (from forUpdateStatement)
   | forUpdateStatementListNonEmpty , forUpdateStatement (from forUpdateStatementListNonEmpty)

;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:779:1-780:24:
def $flatten_forUpdateStatementList(forUpdateStatementList) : forUpdateStatement* =

   ;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:781:1-781:50:
   clause 0(forUpdateStatementList) = []
      -- if forUpdateStatementList matches ``EMPTY`

   ;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:782:1-783:23:
   clause 1(forUpdateStatementList) = [forUpdateStatement]
      -- if forUpdateStatementList <: forUpdateStatement
      -- let forUpdateStatement = forUpdateStatementList as forUpdateStatement

   ;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:784:1-787:30:
   clause 2(forUpdateStatementList) = $flatten_forUpdateStatementList(forUpdateStatementListNonEmpty as forUpdateStatementList) ++ [forUpdateStatement]
      -- if forUpdateStatementList <: forUpdateStatementListNonEmpty
      -- let forUpdateStatementListNonEmpty' = forUpdateStatementList as forUpdateStatementListNonEmpty
      -- if forUpdateStatementListNonEmpty' matches `% , %`
      -- let forUpdateStatementListNonEmpty , forUpdateStatement = forUpdateStatementListNonEmpty'

;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:790:1-791:23:
syntax forInitStatement = 
   | annotationList type name initializerOpt (from forInitStatement)
   | lvalue ( argumentList ) (from forUpdateStatement)
   | lvalue < typeArgumentList > ( argumentList ) (from forUpdateStatement)
   | lvalue assignop expression (from forUpdateStatement)

;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:794:1-795:53:
syntax forInitStatementListNonEmpty = 
   | annotationList type name initializerOpt (from forInitStatement)
   | lvalue ( argumentList ) (from forUpdateStatement)
   | lvalue < typeArgumentList > ( argumentList ) (from forUpdateStatement)
   | lvalue assignop expression (from forUpdateStatement)
   | forInitStatementListNonEmpty , forInitStatement (from forInitStatementListNonEmpty)

;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:798:1-799:33:
syntax forInitStatementList = 
   |  (from forInitStatementList)
   | annotationList type name initializerOpt (from forInitStatement)
   | lvalue ( argumentList ) (from forUpdateStatement)
   | lvalue < typeArgumentList > ( argumentList ) (from forUpdateStatement)
   | lvalue assignop expression (from forUpdateStatement)
   | forInitStatementListNonEmpty , forInitStatement (from forInitStatementListNonEmpty)

;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:801:1-801:76:
def $flatten_forInitStatementList(forInitStatementList) : forInitStatement* =

   ;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:802:1-802:48:
   clause 0(forInitStatementList) = []
      -- if forInitStatementList matches ``EMPTY`

   ;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:803:1-803:71:
   clause 1(forInitStatementList) = [forInitStatement]
      -- if forInitStatementList <: forInitStatement
      -- let forInitStatement = forInitStatementList as forInitStatement

   ;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:804:1-807:28:
   clause 2(forInitStatementList) = $flatten_forInitStatementList(forInitStatementListNonEmpty as forInitStatementList) ++ [forInitStatement]
      -- if forInitStatementList <: forInitStatementListNonEmpty
      -- let forInitStatementListNonEmpty' = forInitStatementList as forInitStatementListNonEmpty
      -- if forInitStatementListNonEmpty' matches `% , %`
      -- let forInitStatementListNonEmpty , forInitStatement = forInitStatementListNonEmpty'

;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:810:1-811:30:
syntax forCollectionExpression = 
   | true (from booleanLiteral)
   | false (from booleanLiteral)
   | d int (from integerLiteral) hint(print %)
   | nat w int (from integerLiteral) hint(print %#W#%)
   | nat s int (from integerLiteral) hint(print %#S#%)
   | " text " (from stringLiteral) hint(print "#%#")
   | text (from identifier)
   | apply (from nonTypeName)
   | key (from nonTypeName)
   | actions (from nonTypeName)
   | state (from nonTypeName)
   | entries (from nonTypeName)
   | type (from nonTypeName)
   | priority (from nonTypeName)
   | . nonTypeName (from prefixedNonTypeName)
   | this (from referenceExpression)
   | ... (from defaultExpression)
   | unop expression (from unaryExpression)
   | expression binop expression (from binaryExpression)
   | expression ? expression : expression (from ternaryExpression)
   | ( type ) expression (from castExpression)
   | {#} (from invalidHeaderExpression)
   | { sequenceOrRecordElementExpression trailingCommaOpt } (from sequenceOrRecordExpression)
   | error . member (from errorAccessExpression)
   | memberAccessBase . member (from memberAccessExpression)
   | expression [ expression ] (from indexAccessExpression)
   | expression [ expression : expression ] (from sliceAccessExpression)
   | expression [ expression + : expression ] (from sliceAccessExpression)
   | callTarget ( argumentList ) (from callExpression)
   | callableTarget < realTypeArgumentList > ( argumentList ) (from callExpression)
   | ( expression ) (from parenthesizedExpression)
   | expression .. expression (from forCollectionExpression)

;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:814:1-819:81:
syntax forStatement = 
   | annotationList for ( forInitStatementList ; expression ; forUpdateStatementList ) statement (from forStatement)
   | annotationList for ( type name in forCollectionExpression ) statement (from forStatement)
   | annotationList for ( annotationListNonEmpty type name in forCollectionExpression ) statement (from forStatement)

;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:826:1-827:23:
syntax switchLabel = 
   | default (from switchLabel)
   | true (from booleanLiteral)
   | false (from booleanLiteral)
   | d int (from integerLiteral) hint(print %)
   | nat w int (from integerLiteral) hint(print %#W#%)
   | nat s int (from integerLiteral) hint(print %#S#%)
   | " text " (from stringLiteral) hint(print "#%#")
   | text (from identifier)
   | apply (from nonTypeName)
   | key (from nonTypeName)
   | actions (from nonTypeName)
   | state (from nonTypeName)
   | entries (from nonTypeName)
   | type (from nonTypeName)
   | priority (from nonTypeName)
   | . nonTypeName (from prefixedNonTypeName)
   | this (from referenceExpression)
   | unop expression (from unaryExpression)
   | expressionNonBrace binop expression (from binaryExpressionNonBrace)
   | expressionNonBrace ? expression : expression (from ternaryExpressionNonBrace)
   | ( type ) expression (from castExpression)
   | error . member (from errorAccessExpression)
   | memberAccessBaseNonBrace . member (from memberAccessExpressionNonBrace)
   | expressionNonBrace [ expression ] (from indexAccessExpressionNonBrace)
   | expressionNonBrace [ expression : expression ] (from sliceAccessExpressionNonBrace)
   | expressionNonBrace [ expression + : expression ] (from sliceAccessExpressionNonBrace)
   | callTargetNonBrace ( argumentList ) (from callExpressionNonBrace)
   | callableTargetNonBrace < realTypeArgumentList > ( argumentList ) (from callExpressionNonBrace)
   | ( expression ) (from parenthesizedExpression)

;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:830:1-831:19:
syntax switchCase = 
   | switchLabel : blockStatement (from switchCase)
   | switchLabel : (from switchCase)

;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:834:1-835:30:
syntax switchCaseList = 
   |  (from switchCaseList)
   | switchCaseList switchCase (from switchCaseList)

;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:837:1-838:32:
def $flatten_switchCaseList(switchCaseList) : switchCase* =

   ;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:839:1-839:42:
   clause 0(switchCaseList) = []
      -- if switchCaseList matches ``EMPTY`

   ;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:840:1-841:62:
   clause 1(switchCaseList') = $flatten_switchCaseList(switchCaseList) ++ [switchCase]
      -- if switchCaseList' matches `% %`
      -- let switchCaseList switchCase = switchCaseList'

;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:843:26-843:68:
syntax switchStatement = 
   | switch ( expression ) { switchCaseList } (from switchStatement)

;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:849:25-849:33:
syntax breakStatement = 
   | break ; (from breakStatement)

;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:851:28-851:39:
syntax continueStatement = 
   | continue ; (from continueStatement)

;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:858:1-869:20:
syntax statement = 
   | ; (from emptyStatement)
   | lvalue assignop expression ; (from assignmentStatement)
   | lvalue ( argumentList ) ; (from callStatement)
   | lvalue < typeArgumentList > ( argumentList ) ; (from callStatement)
   | namedType . apply ( argumentList ) ; (from directApplicationStatement)
   | return ; (from returnStatement)
   | return expression ; (from returnStatement)
   | exit ; (from exitStatement)
   | annotationList { blockElementStatementList } (from blockStatement)
   | if ( expression ) statement (from conditionalStatement)
   | if ( expression ) statement else statement (from conditionalStatement)
   | annotationList for ( forInitStatementList ; expression ; forUpdateStatementList ) statement (from forStatement)
   | annotationList for ( type name in forCollectionExpression ) statement (from forStatement)
   | annotationList for ( annotationListNonEmpty type name in forCollectionExpression ) statement (from forStatement)
   | break ; (from breakStatement)
   | continue ; (from continueStatement)
   | switch ( expression ) { switchCaseList } (from switchStatement)

;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:879:22-879:35:
syntax initializer = 
   | = expression (from initializer)

;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:882:3-882:48:
syntax constantDeclaration = 
   | annotationList const type name initializer ; (from constantDeclaration)

;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:885:1-886:16:
syntax initializerOpt = 
   |  (from initializerOpt)
   | = expression (from initializer)

;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:889:3-889:45:
syntax variableDeclaration = 
   | annotationList type name initializerOpt ; (from variableDeclaration)

;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:892:1-894:14:
syntax blockElementStatement = 
   | annotationList const type name initializer ; (from constantDeclaration)
   | annotationList type name initializerOpt ; (from variableDeclaration)
   | ; (from emptyStatement)
   | lvalue assignop expression ; (from assignmentStatement)
   | lvalue ( argumentList ) ; (from callStatement)
   | lvalue < typeArgumentList > ( argumentList ) ; (from callStatement)
   | namedType . apply ( argumentList ) ; (from directApplicationStatement)
   | return ; (from returnStatement)
   | return expression ; (from returnStatement)
   | exit ; (from exitStatement)
   | annotationList { blockElementStatementList } (from blockStatement)
   | if ( expression ) statement (from conditionalStatement)
   | if ( expression ) statement else statement (from conditionalStatement)
   | annotationList for ( forInitStatementList ; expression ; forUpdateStatementList ) statement (from forStatement)
   | annotationList for ( type name in forCollectionExpression ) statement (from forStatement)
   | annotationList for ( annotationListNonEmpty type name in forCollectionExpression ) statement (from forStatement)
   | break ; (from breakStatement)
   | continue ; (from continueStatement)
   | switch ( expression ) { switchCaseList } (from switchStatement)

;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:897:1-898:52:
syntax blockElementStatementList = 
