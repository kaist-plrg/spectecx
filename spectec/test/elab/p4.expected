def $exists_(bool*) : bool =

   ;; ../../../../../spectec/examples/p4-concrete/0-aux/0.0-stdlib.spectec:165:1-165:26:
   clause 0(bool*{bool <- bool*}) = false
      -- if bool*{bool <- bool*} matches []

   ;; ../../../../../spectec/examples/p4-concrete/0-aux/0.0-stdlib.spectec:166:1-166:50:
   clause 1(bool*{bool <- bool*}) = (b_h \/ $exists_(b_t*{b_t <- b_t*}))
