      -- if typedExpressionIR?{typedExpressionIR <- typedExpressionIR?} matches (_)
      -- let ?(typedExpressionIR_base) = typedExpressionIR?{typedExpressionIR <- typedExpressionIR?}

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:312:1-314:42:
def $typedExpressionIR_as_typedLvalueIR(typedExpressionIR) : typedLvalueIR? =

   ;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:315:1-317:41:
   clause 0(expressionIR # ( typeIR _ctk )) = ?(referenceExpressionIR as lvalueIR # ( typeIR ))
      -- if expressionIR <: referenceExpressionIR
      -- let referenceExpressionIR = expressionIR as referenceExpressionIR

   ;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:318:1-322:63:
