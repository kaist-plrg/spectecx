def $repeat_<X>(X, nat) : X* =

   ;; ../../../../../spectec/examples/p4-concrete/0-aux/0.0-stdlib.spectec:183:1-183:28:
   clause 0(X, nat) = []
      -- if (nat = 0)

   ;; ../../../../../spectec/examples/p4-concrete/0-aux/0.0-stdlib.spectec:184:1-186:22:
   clause 1(X, n) = [X] ++ $repeat_<X>(X, n')
