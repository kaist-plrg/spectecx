relation Type_wf: bound |- typeIR

   ;; ../../../../../spectec/examples/p4-concrete/5-typing/5.03-typing-wellformed.spectec:65:1-66:18:
   rule baseTypeIR: B |- typeIR
      -- if typeIR <: baseTypeIR
      -- let baseTypeIR = typeIR as baseTypeIR

   ;; ../../../../../spectec/examples/p4-concrete/5-typing/5.03-typing-wellformed.spectec:70:1-72:35:
   rule nameTypeIR: B |- typeIR
      -- if typeIR <: nameTypeIR
      -- let ` typeId = typeIR as nameTypeIR
      -- if $in_set<typeId>(typeId, B)

   ;; ../../../../../spectec/examples/p4-concrete/5-typing/5.03-typing-wellformed.spectec:94:1-97:26:
   rule typedefTypeIR: B |- typeIR'
      -- if typeIR' <: typedefTypeIR
      -- let typedef _typeId typeIR = typeIR' as typedefTypeIR
