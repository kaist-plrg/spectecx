      -- if lvalueIR <: referenceExpressionIR
      -- let referenceExpressionIR = lvalueIR as referenceExpressionIR

   ;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:291:1-295:59:
   clause 1(lvalueIR # ( typeIR )) = ?(typedExpressionIR as memberAccessBaseIR . nameIR as expressionIR # ( typeIR dyn ))
      -- if lvalueIR matches `% . %`
      -- let typedLvalueIR . nameIR = lvalueIR
      -- let typedExpressionIR'?{typedExpressionIR' <- typedExpressionIR'?} = $typedLvalueIR_as_typedExpressionIR(typedLvalueIR)
      -- if typedExpressionIR'?{typedExpressionIR' <- typedExpressionIR'?} matches (_)
      -- let ?(typedExpressionIR) = typedExpressionIR'?{typedExpressionIR' <- typedExpressionIR'?}

   ;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:296:1-300:64:
   clause 2(lvalueIR # ( typeIR )) = ?(typedExpressionIR_base [ typedExpressionIR_index ] as expressionIR # ( typeIR dyn ))
      -- if lvalueIR matches `% [%]`
      -- let typedLvalueIR_base [ typedExpressionIR_index ] = lvalueIR
      -- let typedExpressionIR?{typedExpressionIR <- typedExpressionIR?} = $typedLvalueIR_as_typedExpressionIR(typedLvalueIR_base)
      -- if typedExpressionIR?{typedExpressionIR <- typedExpressionIR?} matches (_)
      -- let ?(typedExpressionIR_base) = typedExpressionIR?{typedExpressionIR <- typedExpressionIR?}

   ;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:301:1-305:64:
   clause 3(lvalueIR # ( typeIR )) = ?(typedExpressionIR_base [ typedExpressionIR_hi : typedExpressionIR_lo ] as expressionIR # ( typeIR dyn ))
      -- if lvalueIR matches `% [% : %]`
      -- let typedLvalueIR_base [ typedExpressionIR_hi : typedExpressionIR_lo ] = lvalueIR
      -- let typedExpressionIR?{typedExpressionIR <- typedExpressionIR?} = $typedLvalueIR_as_typedExpressionIR(typedLvalueIR_base)
      -- if typedExpressionIR?{typedExpressionIR <- typedExpressionIR?} matches (_)
      -- let ?(typedExpressionIR_base) = typedExpressionIR?{typedExpressionIR <- typedExpressionIR?}

   ;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:306:1-310:64:
   clause 4(lvalueIR # ( typeIR )) = ?(typedExpressionIR_base [ typedExpressionIR_l + : typedExpressionIR_w ] as expressionIR # ( typeIR dyn ))
      -- if lvalueIR matches `% [% + : %]`
