   ;; ../../../../../spectec/examples/p4-concrete/0-aux/0.0-stdlib.spectec:198:1-200:12:
   clause 1(X*{X <- X*}, bool*{bool <- bool*}) = X_h :: $filter_<X>(X_t*{X_t <- X_t*}, b_t*{b_t <- b_t*})
