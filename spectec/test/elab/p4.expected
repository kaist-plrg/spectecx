;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:352:27-352:41:
syntax emptyStatementIR = emptyStatement

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:359:3-359:46:
syntax assignmentStatementIR = 
   | typedLvalueIR assignop typedExpressionIR ; (from assignmentStatementIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:366:3-366:66:
syntax callStatementIR = 
   | callableTargetIR < typeArgumentListIR > ( argumentListIR ) ; (from callStatementIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:373:3-373:54:
syntax directApplicationStatementIR = 
   | constructorTargetIR . apply ( argumentListIR ) ; (from directApplicationStatementIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:380:1-381:32:
syntax returnStatementIR = 
   | return ; (from returnStatementIR)
   | return typedExpressionIR ; (from returnStatementIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:387:26-387:39:
syntax exitStatementIR = exitStatement

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:396:3-396:50:
syntax blockStatementIR = 
   | annotationList { blockElementStatementListIR } (from blockStatementIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:405:1-406:59:
syntax conditionalStatementIR = 
   | if ( typedExpressionIR ) statementIR (from conditionalStatementIR)
   | if ( typedExpressionIR ) statementIR else statementIR (from conditionalStatementIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:415:1-416:45:
syntax forUpdateStatementIR = 
   | callableTargetIR < typeArgumentListIR > ( argumentListIR ) (from forUpdateStatementIR)
   | typedLvalueIR assignop typedExpressionIR (from forUpdateStatementIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:418:35-418:56:
syntax forUpdateStatementListIR = forUpdateStatementIR*

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:421:1-422:25:
syntax forInitStatementIR = 
   | annotationList typeIR nameIR initializerOptIR (from forInitStatementIR)
   | callableTargetIR < typeArgumentListIR > ( argumentListIR ) (from forUpdateStatementIR)
   | typedLvalueIR assignop typedExpressionIR (from forUpdateStatementIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:424:33-424:52:
syntax forInitStatementListIR = forInitStatementIR*

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:427:1-428:44:
syntax forCollectionExpressionIR = 
   | expressionIR # expressionNoteIR (from typedExpressionIR) hint(print %0) hint(prose %0 "annotated with" %1) hint(prose_fields "expression" "note")
   | typedExpressionIR .. typedExpressionIR (from forCollectionExpressionIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:431:1-439:18:
syntax forStatementIR = 
   | annotationList for ( forInitStatementListIR ; typedExpressionIR ; forUpdateStatementListIR ) statementIR (from forStatementIR)
   | annotationList for ( typeIR nameIR in forCollectionExpressionIR ) statementIR (from forStatementIR)
   | annotationList for ( annotationList typeIR nameIR in forCollectionExpressionIR ) statementIR (from forStatementIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:446:1-447:22:
syntax switchLabelIR = 
   | default (from switchLabelIR)
   | expressionIR # expressionNoteIR (from typedExpressionIR) hint(print %0) hint(prose %0 "annotated with" %1) hint(prose_fields "expression" "note")

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:450:1-451:21:
syntax switchCaseIR = 
   | switchLabelIR : blockStatementIR (from switchCaseIR)
   | switchLabelIR : (from switchCaseIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:453:27-453:40:
syntax switchCaseListIR = switchCaseIR*

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:456:3-456:54:
syntax switchStatementIR = 
   | switch ( typedExpressionIR ) { switchCaseListIR } (from switchStatementIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:462:27-462:41:
syntax breakStatementIR = breakStatement

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:464:30-464:47:
syntax continueStatementIR = continueStatement

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:471:1-482:22:
syntax statementIR = 
   | ; (from emptyStatement)
   | typedLvalueIR assignop typedExpressionIR ; (from assignmentStatementIR)
   | callableTargetIR < typeArgumentListIR > ( argumentListIR ) ; (from callStatementIR)
   | constructorTargetIR . apply ( argumentListIR ) ; (from directApplicationStatementIR)
   | return ; (from returnStatementIR)
   | return typedExpressionIR ; (from returnStatementIR)
   | exit ; (from exitStatement)
   | annotationList { blockElementStatementListIR } (from blockStatementIR)
   | if ( typedExpressionIR ) statementIR (from conditionalStatementIR)
   | if ( typedExpressionIR ) statementIR else statementIR (from conditionalStatementIR)
   | annotationList for ( forInitStatementListIR ; typedExpressionIR ; forUpdateStatementListIR ) statementIR (from forStatementIR)
   | annotationList for ( typeIR nameIR in forCollectionExpressionIR ) statementIR (from forStatementIR)
   | annotationList for ( annotationList typeIR nameIR in forCollectionExpressionIR ) statementIR (from forStatementIR)
   | break ; (from breakStatement)
   | continue ; (from continueStatement)
   | switch ( typedExpressionIR ) { switchCaseListIR } (from switchStatementIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:493:3-493:62:
syntax constantDeclarationIR = 
   | annotationList const typeIR nameIR constantInitializerIR ; (from constantDeclarationIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:495:27-495:41:
syntax initializerOptIR = initializerIR?

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:498:3-498:51:
syntax variableDeclarationIR = 
   | annotationList typeIR nameIR initializerOptIR ; (from variableDeclarationIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:501:1-503:16:
syntax blockElementStatementIR = 
   | annotationList const typeIR nameIR constantInitializerIR ; (from constantDeclarationIR)
   | annotationList typeIR nameIR initializerOptIR ; (from variableDeclarationIR)
   | ; (from emptyStatement)
   | typedLvalueIR assignop typedExpressionIR ; (from assignmentStatementIR)
   | callableTargetIR < typeArgumentListIR > ( argumentListIR ) ; (from callStatementIR)
   | constructorTargetIR . apply ( argumentListIR ) ; (from directApplicationStatementIR)
   | return ; (from returnStatementIR)
   | return typedExpressionIR ; (from returnStatementIR)
   | exit ; (from exitStatement)
   | annotationList { blockElementStatementListIR } (from blockStatementIR)
   | if ( typedExpressionIR ) statementIR (from conditionalStatementIR)
   | if ( typedExpressionIR ) statementIR else statementIR (from conditionalStatementIR)
   | annotationList for ( forInitStatementListIR ; typedExpressionIR ; forUpdateStatementListIR ) statementIR (from forStatementIR)
   | annotationList for ( typeIR nameIR in forCollectionExpressionIR ) statementIR (from forStatementIR)
   | annotationList for ( annotationList typeIR nameIR in forCollectionExpressionIR ) statementIR (from forStatementIR)
   | break ; (from breakStatement)
   | continue ; (from continueStatement)
   | switch ( typedExpressionIR ) { switchCaseListIR } (from switchStatementIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:505:38-505:62:
syntax blockElementStatementListIR = blockElementStatementIR*

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:512:3-513:73:
syntax functionPrototypeIR = 
   | typeIR nameIR < typeParameterListIR , typeParameterListIR > ( parameterListIR ) (from functionPrototypeIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:516:3-516:54:
syntax functionDeclarationIR = 
   | annotationList functionPrototypeIR blockStatementIR (from functionDeclarationIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:523:3-523:69:
syntax actionDeclarationIR = 
   | annotationList action nameIR ( parameterListIR ) blockStatementIR (from actionDeclarationIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:531:30-531:61:
syntax objectInitializerIR = 
   | = { objectDeclarationListIR } (from objectInitializerIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:533:33-533:53:
syntax objectInitializerOptIR = objectInitializerIR?

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:536:3-540:61:
syntax instantiationIR = 
   | annotationList typeIR constructorTargetIR ( argumentListIR ) nameIR objectInitializerOptIR ; (from instantiationIR) hint(prose_fields "annotations" "type" "constructor target" "arguments" "name" "object initializer")

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:543:1-544:20:
syntax objectDeclarationIR = 
   | annotationList functionPrototypeIR blockStatementIR (from functionDeclarationIR)
   | annotationList typeIR constructorTargetIR ( argumentListIR ) nameIR objectInitializerOptIR ; (from instantiationIR) hint(prose_fields "annotations" "type" "constructor target" "arguments" "name" "object initializer")

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:546:34-546:54:
syntax objectDeclarationListIR = objectDeclarationIR*

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:548:1-550:57:
def $flatten_objectInitializerOptIR(objectInitializerOptIR) : objectDeclarationListIR =

   ;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:552:1-552:47:
   clause 0(objectInitializerIR?{objectInitializerIR <- objectInitializerIR?}) = []
      -- if objectInitializerIR?{objectInitializerIR <- objectInitializerIR?} matches ()

   ;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:553:1-554:28:
   clause 1(objectInitializerOptIR) = objectDeclarationListIR
      -- if objectInitializerOptIR matches (_)
      -- let ?(= { objectDeclarationListIR }) = objectInitializerOptIR

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:560:29-560:50:
syntax errorDeclarationIR = 
   | error { nameListIR } (from errorDeclarationIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:566:33-566:59:
syntax matchKindDeclarationIR = 
   | match_kind { nameListIR } (from matchKindDeclarationIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:577:1-578:60:
syntax enumTypeDeclarationIR = 
   | annotationList enum nameIR { nameListIR } (from enumTypeDeclarationIR)
   | annotationList enum typeIR nameIR { namedValueListIR } (from enumTypeDeclarationIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:584:22-584:53:
syntax typeFieldIR = 
   | annotationList typeIR nameIR ; (from typeFieldIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:586:26-586:38:
syntax typeFieldListIR = typeFieldIR*

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:589:3-590:50:
syntax structTypeDeclarationIR = 
   | annotationList struct nameIR < typeParameterListIR > { typeFieldListIR } (from structTypeDeclarationIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:593:3-594:50:
syntax headerTypeDeclarationIR = 
   | annotationList header nameIR < typeParameterListIR > { typeFieldListIR } (from headerTypeDeclarationIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:597:3-598:50:
syntax headerUnionTypeDeclarationIR = 
   | annotationList header_union nameIR < typeParameterListIR > { typeFieldListIR } (from headerUnionTypeDeclarationIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:601:1-604:33:
syntax derivedTypeDeclarationIR = 
   | annotationList enum nameIR { nameListIR } (from enumTypeDeclarationIR)
   | annotationList enum typeIR nameIR { namedValueListIR } (from enumTypeDeclarationIR)
   | annotationList struct nameIR < typeParameterListIR > { typeFieldListIR } (from structTypeDeclarationIR)
   | annotationList header nameIR < typeParameterListIR > { typeFieldListIR } (from headerTypeDeclarationIR)
   | annotationList header_union nameIR < typeParameterListIR > { typeFieldListIR } (from headerUnionTypeDeclarationIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:611:1-612:29:
syntax typedefIR = 
   | void (from voidTypeIR)
   | bool (from boolTypeIR)
   | error (from errorTypeIR)
   | match_kind (from matchKindTypeIR)
   | string (from stringTypeIR)
   | int (from intTypeIR)
   | int < nat > (from fixedIntTypeIR)
   | bit < nat > (from fixedBitTypeIR)
   | varbit < nat > (from varBitTypeIR)
   | ` typeId (from nameTypeIR) hint(print %0)
   | typedef typeId typeIR (from typedefTypeIR) hint(print %0)
   | type typeId typeIR (from newTypeIR) hint(print %0)
   | list < typeIR > (from listTypeIR)
   | tuple < typeIR* > (from tupleTypeIR)
   | typeIR [ nat ] (from headerStackTypeIR)
   | struct typeId < typeArgumentIR* > { fieldTypeIR* } (from structTypeIR) hint(print %0#"<"#%1#">")
   | header typeId < typeArgumentIR* > { fieldTypeIR* } (from headerTypeIR) hint(print %0#"<"#%1#">")
   | header_union typeId < typeArgumentIR* > { fieldTypeIR* } (from headerUnionTypeIR) hint(print %0#"<"#%1#">")
   | enum typeId { nameIR* } (from simpleEnumTypeIR) hint(print %0)
   | enum typeId < typeIR > { valueFieldIR* } (from serializableEnumTypeIR) hint(print %0)
   | extern typeId < typeArgumentIR* > externMethodTypeDefEnv (from externObjectTypeIR) hint(print %0#"<"#%1#">")
   | parser typeId < typeArgumentIR* > ( parameterIR* ) (from parserObjectTypeIR) hint(print %0#"<"#%1#">")
   | control typeId < typeArgumentIR* > ( parameterIR* ) (from controlObjectTypeIR) hint(print %0#"<"#%1#">")
   | package typeId < typeArgumentIR* > { typeIR* } (from packageObjectTypeIR) hint(print %0#"<"#%1#">")
   | table typeId { tableMetadataStructTypeIR } (from tableObjectTypeIR) hint(print %0)
   | default (from defaultTypeIR)
   | header_invalid (from invalidHeaderTypeIR)
   | seq < typeIR* > (from sequenceTypeIR)
   | seq < typeIR* , ... > (from sequenceTypeIR)
   | record { fieldTypeIR* } (from recordTypeIR)
   | record { fieldTypeIR* , ... } (from recordTypeIR)
   | set < typeIR > (from setTypeIR)
   | table_enum typeId { nameIR* } (from tableMetadataEnumTypeIR) hint(print %0)
   | table_struct typeId { hit boolTypeIR ; miss boolTypeIR ; action_run tableMetadataEnumTypeIR ; } (from tableMetadataStructTypeIR) hint(print %0)
   | annotationList enum nameIR { nameListIR } (from enumTypeDeclarationIR)
   | annotationList enum typeIR nameIR { namedValueListIR } (from enumTypeDeclarationIR)
   | annotationList struct nameIR < typeParameterListIR > { typeFieldListIR } (from structTypeDeclarationIR)
   | annotationList header nameIR < typeParameterListIR > { typeFieldListIR } (from headerTypeDeclarationIR)
   | annotationList header_union nameIR < typeParameterListIR > { typeFieldListIR } (from headerUnionTypeDeclarationIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:615:1-616:41:
syntax typedefDeclarationIR = 
   | annotationList typedef typedefIR nameIR ; (from typedefDeclarationIR)
   | annotationList type typeIR nameIR ; (from typedefDeclarationIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:623:3-623:47:
syntax externFunctionDeclarationIR = 
   | annotationList extern functionPrototypeIR ; (from externFunctionDeclarationIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:626:3-626:76:
syntax externConstructorPrototypeIR = 
   | annotationList nameIR < , typeParameterListIR > ( parameterListIR ) ; (from externConstructorPrototypeIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:628:43-628:72:
syntax externConstructorPrototypeListIR = externConstructorPrototypeIR*

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:631:1-632:51:
syntax externMethodPrototypeIR = 
   | annotationList functionPrototypeIR ; (from externMethodPrototypeIR)
   | annotationList abstract functionPrototypeIR ; (from externMethodPrototypeIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:634:38-634:62:
syntax externMethodPrototypeListIR = externMethodPrototypeIR*

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:637:3-639:37:
syntax externObjectDeclarationIR = 
   | annotationList extern nameIR < typeParameterListIR , > { externConstructorPrototypeListIR externMethodPrototypeListIR } (from externObjectDeclarationIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:642:1-643:30:
syntax externDeclarationIR = 
   | annotationList extern functionPrototypeIR ; (from externFunctionDeclarationIR)
   | annotationList extern nameIR < typeParameterListIR , > { externConstructorPrototypeListIR externMethodPrototypeListIR } (from externObjectDeclarationIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:653:23-653:54:
syntax selectCaseIR = 
   | keysetExpressionIR : nameIR ; (from selectCaseIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:655:27-655:40:
syntax selectCaseListIR = selectCaseIR*

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:658:3-658:58:
syntax selectExpressionIR = 
   | select ( typedExpressionListIR ) { selectCaseListIR } (from selectExpressionIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:665:1-666:23:
syntax stateExpressionIR = 
   | nameIR ; (from stateExpressionIR)
   | select ( typedExpressionListIR ) { selectCaseListIR } (from selectExpressionIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:668:32-668:60:
syntax transitionStatementIR = 
   | transition stateExpressionIR (from transitionStatementIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:675:3-675:72:
syntax valueSetDeclarationIR = 
   | annotationList value_set < typeIR > ( typedExpressionIR ) nameIR ; (from valueSetDeclarationIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:682:3-683:76:
syntax parserTypeDeclarationIR = 
   | annotationList parser nameIR < typeParameterListIR , typeParameterListIR > ( parameterListIR ) ; (from parserTypeDeclarationIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:692:3-692:44:
syntax parserBlockStatementIR = 
   | annotationList { parserStatementListIR } (from parserBlockStatementIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:695:1-696:71:
syntax parserConditionalStatementIR = 
   | if ( typedExpressionIR ) parserStatementIR (from parserConditionalStatementIR)
   | if ( typedExpressionIR ) parserStatementIR else parserStatementIR (from parserConditionalStatementIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:699:1-706:33:
syntax parserStatementIR = 
   | annotationList const typeIR nameIR constantInitializerIR ; (from constantDeclarationIR)
   | annotationList typeIR nameIR initializerOptIR ; (from variableDeclarationIR)
   | ; (from emptyStatement)
   | typedLvalueIR assignop typedExpressionIR ; (from assignmentStatementIR)
   | callableTargetIR < typeArgumentListIR > ( argumentListIR ) ; (from callStatementIR)
   | constructorTargetIR . apply ( argumentListIR ) ; (from directApplicationStatementIR)
   | annotationList { parserStatementListIR } (from parserBlockStatementIR)
   | if ( typedExpressionIR ) parserStatementIR (from parserConditionalStatementIR)
   | if ( typedExpressionIR ) parserStatementIR else parserStatementIR (from parserConditionalStatementIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:708:32-708:50:
syntax parserStatementListIR = parserStatementIR*

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:711:3-712:53:
syntax parserStateIR = 
   | annotationList state nameIR { parserStatementListIR transitionStatementIR } (from parserStateIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:714:28-714:42:
syntax parserStateListIR = parserStateIR*

