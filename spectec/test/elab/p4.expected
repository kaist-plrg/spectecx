      -- if Type_alpha: typeIR_a ~~ typeIR_b holds

   ;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.6-type-alpha.spectec:177:1-182:38:
   rule abstract: externMethodTypeIR ~~ externMethodTypeIR'
      -- if externMethodTypeIR matches `EXTERN_METHOD ABSTRACT % (%) : %`
      -- let extern_method abstract nameIR ( parameterIR_a*{parameterIR_a <- parameterIR_a*} ) : typeIR_a = externMethodTypeIR
      -- if externMethodTypeIR' matches `EXTERN_METHOD ABSTRACT % (%) : %`
      -- let extern_method abstract nameIR' ( parameterIR_b*{parameterIR_b <- parameterIR_b*} ) : typeIR_b = externMethodTypeIR'
      -- if (nameIR = nameIR')
      -- (if ParameterType_alpha: parameterIR_a ~~ parameterIR_b holds)*{parameterIR_a <- parameterIR_a*, parameterIR_b <- parameterIR_b*}
      -- if Type_alpha: typeIR_a ~~ typeIR_b holds

