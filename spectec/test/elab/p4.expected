   ;; ../../../../../spectec/examples/p4-concrete/0-aux/0.0-stdlib.spectec:86:1-89:67:
   clause 1(n, n_len, t, t_old, t_new) = $replace_text_except'((n + 1), n_len, t_replaced, t_old, t_new)
