;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.2.1-type.spectec:161:3-164:17:
syntax tableMetadataStructTypeIR = 
   | table_struct typeId { hit boolTypeIR ; miss boolTypeIR ; action_run tableMetadataEnumTypeIR ; } (from tableMetadataStructTypeIR) hint(print %0)

;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.2.1-type.spectec:167:1-168:30:
syntax tableMetadataTypeIR = 
   | table_enum typeId { nameIR* } (from tableMetadataEnumTypeIR) hint(print %0)
