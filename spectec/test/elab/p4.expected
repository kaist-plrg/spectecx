def $filter_<X>(X*, bool*) : X* =

   ;; ../../../../../spectec/examples/p4-concrete/0-aux/0.0-stdlib.spectec:197:1-197:32:
   clause 0(X*{X <- X*}, bool*{bool <- bool*}) = []
