;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.2.1-type.spectec:132:1-136:22:
syntax objectTypeIR = 
   | extern typeId < typeArgumentIR* > externMethodTypeDefEnv (from externObjectTypeIR) hint(print %0#"<"#%1#">")
   | parser typeId < typeArgumentIR* > ( parameterIR* ) (from parserObjectTypeIR) hint(print %0#"<"#%1#">")
   | control typeId < typeArgumentIR* > ( parameterIR* ) (from controlObjectTypeIR) hint(print %0#"<"#%1#">")
   | package typeId < typeArgumentIR* > { typeIR* } (from packageObjectTypeIR) hint(print %0#"<"#%1#">")
   | table typeId { tableMetadataStructTypeIR } (from tableObjectTypeIR) hint(print %0)

