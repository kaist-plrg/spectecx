;; ../../../../../spectec/examples/p4-concrete/0-aux/0.0-stdlib.spectec:168:1-170:44:
def $forall_(bool*) : bool =

   ;; ../../../../../spectec/examples/p4-concrete/0-aux/0.0-stdlib.spectec:171:1-171:25:
   clause 0(bool*{bool <- bool*}) = true
      -- if bool*{bool <- bool*} matches []

