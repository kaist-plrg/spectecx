def $replace_text(text, text, text) : text =

   ;; ../../../../../spectec/examples/p4-concrete/0-aux/0.0-stdlib.spectec:72:1-73:44:
   clause 0(t, t_old, t_new) = $replace_text'(0, |t|, t, t_old, t_new)

;; ../../../../../spectec/examples/p4-concrete/0-aux/0.0-stdlib.spectec:71:1-71:54:
def $replace_text'(nat, nat, text, text, text) : text =

   ;; ../../../../../spectec/examples/p4-concrete/0-aux/0.0-stdlib.spectec:74:1-74:54:
   clause 0(n_len, n_len', t, t_old, t_new) = t
      -- if (n_len = n_len')

   ;; ../../../../../spectec/examples/p4-concrete/0-aux/0.0-stdlib.spectec:75:1-78:67:
   clause 1(n, n_len, t, t_old, t_new) = $replace_text'((n + 1), n_len, t_replaced, t_old, t_new)
      -- if (n < n_len)
      -- let t_replaced = $ite<text>((t[n] = t_old), t[[n] = t_new], t)

;; ../../../../../spectec/examples/p4-concrete/0-aux/0.0-stdlib.spectec:80:1-81:81:
