;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.6-type-alpha.spectec:17:1-21:56:
relation ExternMethodType_alpha: externMethodTypeIR ~~ externMethodTypeIR

   ;; ../../../../../spectec/examples/p4-concrete/2-static-runtime/2.6-type-alpha.spectec:170:1-175:38:
   rule non-abstract: externMethodTypeIR ~~ externMethodTypeIR'
      -- if externMethodTypeIR matches `EXTERN_METHOD % (%) : %`
      -- let extern_method nameIR ( parameterIR_a*{parameterIR_a <- parameterIR_a*} ) : typeIR_a = externMethodTypeIR
      -- if externMethodTypeIR' matches `EXTERN_METHOD % (%) : %`
      -- let extern_method nameIR' ( parameterIR_b*{parameterIR_b <- parameterIR_b*} ) : typeIR_b = externMethodTypeIR'
