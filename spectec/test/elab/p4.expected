;; ../../../../../spectec/examples/p4-concrete/0-aux/0.0-stdlib.spectec:98:1-99:48:
def $starts_with(text, text) : bool =

   ;; ../../../../../spectec/examples/p4-concrete/0-aux/0.0-stdlib.spectec:100:1-102:37:
   clause 0(t, t_prefix) = true
      -- if (|t_prefix| <= |t|)
      -- if (t[0 : |t_prefix|] = t_prefix)

   ;; ../../../../../spectec/examples/p4-concrete/0-aux/0.0-stdlib.spectec:103:1-104:15:
   clause 1(t, t_prefix) = false
      -- otherwise

;; ../../../../../spectec/examples/p4-concrete/0-aux/0.0-stdlib.spectec:106:1-107:46:
def $ends_with(text, text) : bool =

   ;; ../../../../../spectec/examples/p4-concrete/0-aux/0.0-stdlib.spectec:108:1-111:43:
   clause 0(t, t_suffix) = true
      -- if (|t_suffix| <= |t|)
      -- let n_start = (|t| - |t_suffix|)
      -- if (t[n_start : |t_suffix|] = t_suffix)

   ;; ../../../../../spectec/examples/p4-concrete/0-aux/0.0-stdlib.spectec:112:1-113:15:
   clause 1(t, t_suffix) = false
      -- otherwise

;; ../../../../../spectec/examples/p4-concrete/0-aux/0.0-stdlib.spectec:115:1-116:85:
def $strip_prefix_rec(text, text) : text =

   ;; ../../../../../spectec/examples/p4-concrete/0-aux/0.0-stdlib.spectec:117:1-120:48:
   clause 0(t, t_prefix) = $strip_prefix_rec(t_stripped, t_prefix)
      -- if $starts_with(t, t_prefix)
      -- let t_stripped = $strip_prefix(t, t_prefix)

   ;; ../../../../../spectec/examples/p4-concrete/0-aux/0.0-stdlib.spectec:121:1-122:35:
   clause 1(t, t_prefix) = t
      -- if ~$starts_with(t, t_prefix)

;; ../../../../../spectec/examples/p4-concrete/0-aux/0.0-stdlib.spectec:124:1-125:85:
def $strip_suffix_rec(text, text) : text =

   ;; ../../../../../spectec/examples/p4-concrete/0-aux/0.0-stdlib.spectec:126:1-129:48:
   clause 0(t, t_suffix) = $strip_suffix_rec(t_stripped, t_suffix)
      -- if $ends_with(t, t_suffix)
      -- let t_stripped = $strip_suffix(t, t_suffix)

   ;; ../../../../../spectec/examples/p4-concrete/0-aux/0.0-stdlib.spectec:130:1-131:33:
   clause 1(t, t_suffix) = t
      -- if ~$ends_with(t, t_suffix)

