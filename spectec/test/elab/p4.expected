;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:33:1-35:23:
def $un_op(unop, value) : value =

   ;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:47:1-47:40:
   clause 0(unop, value) = $un_bnot(value)
      -- if unop matches `~`

   ;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:57:1-57:40:
   clause 1(unop, value) = $un_lnot(value)
      -- if unop matches `!`

   ;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:69:1-69:40:
   clause 2(unop, value) = $un_plus(value)
      -- if unop matches `+`

   ;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:83:1-83:41:
   clause 3(unop, value) = $un_minus(value)
      -- if unop matches `-`

;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:39:1-41:23:
def $un_bnot(value) : value =

   ;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:43:1-45:58:
   clause 0(value) = w w i'' as value
      -- if value <: integerLiteral
      -- let integerLiteral = value as integerLiteral
      -- if integerLiteral matches `% W %`
      -- let w w i = integerLiteral
      -- let i' = $bneg(i)
      -- let i'' = $ite<int>((i' >= 0 as int), i', ($pow2(w) + i'))

;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:51:1-53:23:
def $un_lnot(value) : value =

   ;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:55:1-55:29:
   clause 0(value) = ~b as value
      -- if value <: boolValue
      -- let b = value as boolValue

;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:61:1-63:23:
def $un_plus(value) : value =

   ;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:65:1-65:24:
   clause 0(value) = d i as value
      -- if value <: integerLiteral
      -- let integerLiteral = value as integerLiteral
      -- if integerLiteral matches `D %`
      -- let d i = integerLiteral

   ;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:66:1-66:28:
   clause 1(value) = w w i as value
      -- if value <: integerLiteral
      -- let integerLiteral = value as integerLiteral
      -- if integerLiteral matches `% W %`
      -- let w w i = integerLiteral

   ;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:67:1-67:28:
   clause 2(value) = w s i as value
      -- if value <: integerLiteral
      -- let integerLiteral = value as integerLiteral
      -- if integerLiteral matches `% S %`
      -- let w s i = integerLiteral

;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:73:1-75:23:
def $un_minus(value) : value =

   ;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:77:1-77:29:
   clause 0(value) = d -i as value
      -- if value <: integerLiteral
      -- let integerLiteral = value as integerLiteral
      -- if integerLiteral matches `D %`
      -- let d i = integerLiteral

   ;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:78:1-79:29:
   clause 1(value) = w w i' as value
      -- if value <: integerLiteral
      -- let integerLiteral = value as integerLiteral
      -- if integerLiteral matches `% W %`
      -- let w w i = integerLiteral
      -- let i' = ($pow2(w) - i)

   ;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:80:1-81:57:
   clause 2(value) = w s i' as value
      -- if value <: integerLiteral
      -- let integerLiteral = value as integerLiteral
      -- if integerLiteral matches `% S %`
      -- let w s i = integerLiteral
      -- let i' = $int_to_bitstr(w as int, $bitstr_to_int(w as int, -i))

;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:89:1-91:23:
def $bin_op(binop, value, value) : value =

   ;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:109:1-109:64:
   clause 0(binop, value_l, value_r) = $bin_plus(value_l, value_r)
      -- if binop matches `+`

   ;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:140:1-140:69:
   clause 1(binop, value_l, value_r) = $bin_satplus(value_l, value_r)
      -- if binop matches `|+|`

   ;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:158:1-158:65:
   clause 2(binop, value_l, value_r) = $bin_minus(value_l, value_r)
      -- if binop matches `-`

   ;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:188:1-188:70:
   clause 3(binop, value_l, value_r) = $bin_satminus(value_l, value_r)
      -- if binop matches `|-|`

   ;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:206:1-206:63:
   clause 4(binop, value_l, value_r) = $bin_mul(value_l, value_r)
      -- if binop matches `*`

   ;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:216:1-216:63:
   clause 5(binop, value_l, value_r) = $bin_div(value_l, value_r)
      -- if binop matches `/`

   ;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:226:1-226:63:
   clause 6(binop, value_l, value_r) = $bin_mod(value_l, value_r)
      -- if binop matches `%`

   ;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:257:1-257:64:
   clause 7(binop, value_l, value_r) = $bin_shl(value_l, value_r)
      -- if binop matches `<<`

   ;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:314:1-314:64:
   clause 8(binop, value_l, value_r) = $bin_shr(value_l, value_r)
      -- if binop matches `>>`

   ;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:329:1-329:66:
   clause 9(binop, value_l, value_r) = $bin_le(value_l, value_r) as value
      -- if binop matches `<=`

   ;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:344:1-344:66:
   clause 10(binop, value_l, value_r) = $bin_ge(value_l, value_r) as value
      -- if binop matches `>=`

   ;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:359:1-359:66:
   clause 11(binop, value_l, value_r) = $bin_lt(value_l, value_r) as value
      -- if binop matches `<`

   ;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:374:1-374:66:
   clause 12(binop, value_l, value_r) = $bin_gt(value_l, value_r) as value
      -- if binop matches `>`

   ;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:444:1-444:66:
   clause 13(binop, value_l, value_r) = $bin_eq(value_l, value_r) as value
      -- if binop matches `==`

   ;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:455:1-455:66:
   clause 14(binop, value_l, value_r) = $bin_ne(value_l, value_r) as value
      -- if binop matches `!=`

   ;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:470:1-470:64:
   clause 15(binop, value_l, value_r) = $bin_band(value_l, value_r)
      -- if binop matches `&`

   ;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:485:1-485:64:
   clause 16(binop, value_l, value_r) = $bin_bxor(value_l, value_r)
      -- if binop matches `^`

   ;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:500:1-500:63:
   clause 17(binop, value_l, value_r) = $bin_bor(value_l, value_r)
      -- if binop matches `|`

   ;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:532:1-532:67:
   clause 18(binop, value_l, value_r) = $bin_concat(value_l, value_r)
      -- if binop matches `++`

