;; ../../../../../spectec/examples/p4-concrete/6-dynamic-runtime/6.4.1-object.spectec:42:23-42:49:
syntax actionDefEnv = map<callableId, actionDef>

;; ../../../../../spectec/examples/p4-concrete/6-dynamic-runtime/6.4.1-object.spectec:45:3-49:23:
syntax controlObject = 
   | control < theta > ( parameterListIR ) { frame controlLocalDeclarationListIR actionDefEnv controlBodyIR } (from controlObject)

;; ../../../../../spectec/examples/p4-concrete/6-dynamic-runtime/6.4.1-object.spectec:57:24-57:53:
syntax packageObject = 
   | package < theta > { frame } (from packageObject)

;; ../../../../../spectec/examples/p4-concrete/6-dynamic-runtime/6.4.1-object.spectec:65:3-69:37:
syntax tableObjectProperty = {keys tableKeysPropertyIR, actions tableActionsPropertyIR, default_action tableDefaultActionPropertyIR, entries tableEntriesPropertyIR, customs tableCustomPropertyIR*}

;; ../../../../../spectec/examples/p4-concrete/6-dynamic-runtime/6.4.1-object.spectec:75:3-75:46:
syntax tableObject = 
