   ;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:980:1-980:43:
   clause 2(typeIR) = w
      -- if typeIR <: fixedBitTypeIR
      -- let bit < w > = typeIR as fixedBitTypeIR

   ;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:981:1-981:46:
   clause 3(typeIR) = w
      -- if typeIR <: varBitTypeIR
      -- let varbit < w > = typeIR as varBitTypeIR

   ;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:982:1-983:35:
   clause 4(typeIR') = $sizeof_maxSizeInBits'(typeIR)
      -- if typeIR' <: typedefTypeIR
      -- let typedef _typeId typeIR = typeIR' as typedefTypeIR

   ;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:984:1-985:35:
   clause 5(typeIR') = $sizeof_maxSizeInBits'(typeIR)
      -- if typeIR' <: newTypeIR
      -- let type _typeId typeIR = typeIR' as newTypeIR

   ;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:986:1-987:35:
   clause 6(typeIR') = $sizeof_maxSizeInBits'(typeIR)
      -- if typeIR' <: serializableEnumTypeIR
      -- let enum _typeId < typeIR > { _valueFieldIR*{_valueFieldIR <- _valueFieldIR*} } = typeIR' as serializableEnumTypeIR

   ;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:988:1-989:46:
   clause 7(typeIR') = $sum_nat($sizeof_maxSizeInBits'(typeIR)*{typeIR <- typeIR*})
      -- if typeIR' <: tupleTypeIR
      -- let tuple < typeIR*{typeIR <- typeIR*} > = typeIR' as tupleTypeIR

   ;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:990:1-991:47:
   clause 8(typeIR') = ($sizeof_maxSizeInBits'(typeIR) * n_size)
      -- if typeIR' <: headerStackTypeIR
      -- let typeIR [ n_size ] = typeIR' as headerStackTypeIR

   ;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:992:1-993:46:
   clause 9(typeIR') = $sum_nat($sizeof_maxSizeInBits'(typeIR)*{typeIR <- typeIR*})
      -- if typeIR' <: structTypeIR
      -- let struct _typeId < _typeArgumentIR*{_typeArgumentIR <- _typeArgumentIR*} > { _annotationList typeIR _nameIR ;*{_annotationList <- _annotationList*, _nameIR <- _nameIR*, typeIR <- typeIR*} } = typeIR' as structTypeIR

   ;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:994:1-995:46:
   clause 10(typeIR') = $sum_nat($sizeof_maxSizeInBits'(typeIR)*{typeIR <- typeIR*})
      -- if typeIR' <: headerTypeIR
      -- let header _typeId < _typeArgumentIR*{_typeArgumentIR <- _typeArgumentIR*} > { _annotationList typeIR _nameIR ;*{_annotationList <- _annotationList*, _nameIR <- _nameIR*, typeIR <- typeIR*} } = typeIR' as headerTypeIR

   ;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:996:1-997:46:
   clause 11(typeIR') = $max_nat($sizeof_maxSizeInBits'(typeIR)*{typeIR <- typeIR*})
      -- if typeIR' <: headerUnionTypeIR
      -- let header_union _typeId < _typeArgumentIR*{_typeArgumentIR <- _typeArgumentIR*} > { _annotationList typeIR _nameIR ;*{_annotationList <- _annotationList*, _nameIR <- _nameIR*, typeIR <- typeIR*} } = typeIR' as headerUnionTypeIR

;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:937:1-938:23:
def $sizeof_maxSizeInBytes(typeIR) : value =

   ;; ../../../../../spectec/examples/p4-concrete/3-operations/3-operations.spectec:1003:1-1004:48:
   clause 0(typeIR) = d (n_size / 8) as int as value
      -- let n_size = $sizeof_maxSizeInBits'(typeIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:6:1-7:14:
syntax prefixedNameIR = 
   | ` nameIR (from prefixedNameIR) hint(print %0)
   | . nameIR (from prefixedNameIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:9:1-10:44:
def $prefixedNonTypeName(prefixedNonTypeName) : prefixedNameIR =

   ;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:11:1-11:62:
   clause 0(prefixedNonTypeName) = ` $name(nonTypeName as name)
      -- if prefixedNonTypeName <: nonTypeName
      -- let nonTypeName = prefixedNonTypeName as nonTypeName

   ;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:12:1-12:69:
   clause 1(prefixedNonTypeName) = . $name(nonTypeName as name)
      -- if prefixedNonTypeName matches ``ID . %`
      -- let . nonTypeName = prefixedNonTypeName

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:14:1-15:44:
def $prefixedTypeName(prefixedTypeName) : prefixedNameIR =

   ;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:16:1-16:53:
   clause 0(prefixedTypeName) = ` $name(typeName as name)
      -- if prefixedTypeName <: typeName
      -- let typeName = prefixedTypeName as typeName

   ;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:17:1-17:61:
   clause 1(prefixedTypeName) = . $name(typeName as name)
      -- if prefixedTypeName matches ``TID . %`
      -- let . typeName = prefixedTypeName

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:19:1-20:42:
def $flatten_prefixedNameIR(prefixedNameIR) : nameIR =

   ;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:21:1-21:48:
   clause 0(prefixedNameIR) = nameIR
      -- if prefixedNameIR matches `` %`
      -- let ` nameIR = prefixedNameIR

   ;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:22:1-22:55:
   clause 1(prefixedNameIR) = "." ++ nameIR
      -- if prefixedNameIR matches `. %`
      -- let . nameIR = prefixedNameIR

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:24:21-24:28:
syntax nameListIR = nameIR*

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:30:30-30:46:
syntax typeParameterListIR = typeParameterIR*

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:36:26-36:38:
syntax parameterListIR = parameterIR*

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:42:37-42:49:
syntax constructorParameterListIR = parameterIR*

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:48:23-48:38:
syntax namedValueIR = 
   | nameIR = value (from namedValueIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:50:27-50:40:
syntax namedValueListIR = namedValueIR*

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:56:28-56:55:
syntax namedExpressionIR = 
   | nameIR = typedExpressionIR (from namedExpressionIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:58:32-58:50:
syntax namedExpressionListIR = namedExpressionIR*

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:68:30-68:47:
syntax literalExpressionIR = literalExpression

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:74:32-74:46:
syntax referenceExpressionIR = prefixedNameIR

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:80:30-80:47:
syntax defaultExpressionIR = defaultExpression

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:86:28-86:50:
syntax unaryExpressionIR = 
   | unop typedExpressionIR (from unaryExpressionIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:89:3-89:44:
syntax binaryExpressionIR = 
   | typedExpressionIR binop typedExpressionIR (from binaryExpressionIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:92:3-92:62:
syntax ternaryExpressionIR = 
   | typedExpressionIR ? typedExpressionIR : typedExpressionIR (from ternaryExpressionIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:98:27-98:56:
syntax castExpressionIR = 
   | ( typeIR ) typedExpressionIR (from castExpressionIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:106:36-106:59:
syntax invalidHeaderExpressionIR = invalidHeaderExpression

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:109:1-110:43:
syntax sequenceExpressionIR = 
   | seq { typedExpressionListIR } (from sequenceExpressionIR)
   | seq { typedExpressionListIR , ... } (from sequenceExpressionIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:113:1-114:46:
syntax recordExpressionIR = 
   | record { namedExpressionListIR } (from recordExpressionIR)
   | record { namedExpressionListIR , ... } (from recordExpressionIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:117:1-119:23:
syntax dataExpressionIR = 
   | {#} (from invalidHeaderExpression)
   | seq { typedExpressionListIR } (from sequenceExpressionIR)
   | seq { typedExpressionListIR , ... } (from sequenceExpressionIR)
   | record { namedExpressionListIR } (from recordExpressionIR)
   | record { namedExpressionListIR , ... } (from recordExpressionIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:128:3-128:18:
syntax errorAccessExpressionIR = 
   | error . nameIR (from errorAccessExpressionIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:131:3-131:31:
syntax memberAccessExpressionIR = 
   | memberAccessBaseIR . nameIR (from memberAccessExpressionIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:134:3-134:43:
syntax indexAccessExpressionIR = 
   | typedExpressionIR [ typedExpressionIR ] (from indexAccessExpressionIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:137:1-138:67:
syntax sliceAccessExpressionIR = 
   | typedExpressionIR [ typedExpressionIR : typedExpressionIR ] (from sliceAccessExpressionIR)
   | typedExpressionIR [ typedExpressionIR + : typedExpressionIR ] (from sliceAccessExpressionIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:141:1-144:28:
syntax accessExpressionIR = 
   | error . nameIR (from errorAccessExpressionIR)
   | memberAccessBaseIR . nameIR (from memberAccessExpressionIR)
   | typedExpressionIR [ typedExpressionIR ] (from indexAccessExpressionIR)
   | typedExpressionIR [ typedExpressionIR : typedExpressionIR ] (from sliceAccessExpressionIR)
   | typedExpressionIR [ typedExpressionIR + : typedExpressionIR ] (from sliceAccessExpressionIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:155:1-158:26:
syntax callableTargetIR = 
   | ` nameIR (from prefixedNameIR) hint(print %0)
   | . nameIR (from prefixedNameIR)
   | typedExpressionIR . nameIR (from callableTargetIR)
   | type prefixedNameIR . nameIR (from callableTargetIR)
   | ( callableTargetIR ) (from callableTargetIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:160:30-160:68:
syntax constructorTargetIR = 
   | prefixedNameIR < typeArgumentListIR > (from constructorTargetIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:163:1-164:65:
syntax callExpressionIR = 
   | constructorTargetIR ( argumentListIR ) (from callExpressionIR)
   | callableTargetIR < typeArgumentListIR > ( argumentListIR ) (from callExpressionIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:170:36-170:58:
syntax parenthesizedExpressionIR = 
   | ( typedExpressionIR ) (from parenthesizedExpressionIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:177:1-187:30:
syntax expressionIR = 
   | true (from booleanLiteral)
   | false (from booleanLiteral)
   | d int (from integerLiteral) hint(print %)
   | nat w int (from integerLiteral) hint(print %#W#%)
   | nat s int (from integerLiteral) hint(print %#S#%)
   | " text " (from stringLiteral) hint(print "#%#")
   | ` nameIR (from prefixedNameIR) hint(print %0)
   | . nameIR (from prefixedNameIR)
   | ... (from defaultExpression)
   | unop typedExpressionIR (from unaryExpressionIR)
   | typedExpressionIR binop typedExpressionIR (from binaryExpressionIR)
   | typedExpressionIR ? typedExpressionIR : typedExpressionIR (from ternaryExpressionIR)
   | ( typeIR ) typedExpressionIR (from castExpressionIR)
   | {#} (from invalidHeaderExpression)
   | seq { typedExpressionListIR } (from sequenceExpressionIR)
   | seq { typedExpressionListIR , ... } (from sequenceExpressionIR)
   | record { namedExpressionListIR } (from recordExpressionIR)
   | record { namedExpressionListIR , ... } (from recordExpressionIR)
   | error . nameIR (from errorAccessExpressionIR)
   | memberAccessBaseIR . nameIR (from memberAccessExpressionIR)
   | typedExpressionIR [ typedExpressionIR ] (from indexAccessExpressionIR)
   | typedExpressionIR [ typedExpressionIR : typedExpressionIR ] (from sliceAccessExpressionIR)
   | typedExpressionIR [ typedExpressionIR + : typedExpressionIR ] (from sliceAccessExpressionIR)
   | constructorTargetIR ( argumentListIR ) (from callExpressionIR)
   | callableTargetIR < typeArgumentListIR > ( argumentListIR ) (from callExpressionIR)
   | ( typedExpressionIR ) (from parenthesizedExpressionIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:189:27-191:54:
syntax expressionNoteIR = 
   | ( typeIR ctk ) (from expressionNoteIR) hint(prose "a pair of type" %0 "and compile-time known-ness" %1) hint(prose_fields "type" "compile-time known-ness")

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:194:3-197:41:
syntax typedExpressionIR = 
   | expressionIR # expressionNoteIR (from typedExpressionIR) hint(print %0) hint(prose %0 "annotated with" %1) hint(prose_fields "expression" "note")

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:199:32-199:50:
syntax typedExpressionListIR = typedExpressionIR*

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:202:1-203:22:
syntax memberAccessBaseIR = 
   | type prefixedNameIR (from memberAccessBaseIR)
   | expressionIR # expressionNoteIR (from typedExpressionIR) hint(print %0) hint(prose %0 "annotated with" %1) hint(prose_fields "expression" "note")

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:205:1-206:34:
def $type_of_typedExpressionIR(typedExpressionIR) : typeIR =

   ;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:207:1-208:47:
   clause 0(typedExpressionIR) = typeIR
      -- let _expressionIR # ( typeIR _ctk ) = typedExpressionIR

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:210:1-211:53:
def $ctk_of_typedExpressionIR(typedExpressionIR) : ctk =

   ;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:212:1-213:44:
   clause 0(typedExpressionIR) = ctk
      -- let _expressionIR # ( _typeIR ctk ) = typedExpressionIR

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:220:1-224:7:
syntax simpleKeysetExpressionIR = 
   | expressionIR # expressionNoteIR (from typedExpressionIR) hint(print %0) hint(prose %0 "annotated with" %1) hint(prose_fields "expression" "note")
   | typedExpressionIR &&& typedExpressionIR (from simpleKeysetExpressionIR)
   | typedExpressionIR .. typedExpressionIR (from simpleKeysetExpressionIR)
   | default (from simpleKeysetExpressionIR)
   | _ (from simpleKeysetExpressionIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:226:39-226:64:
syntax simpleKeysetExpressionListIR = simpleKeysetExpressionIR*

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:228:34-228:67:
syntax tupleKeysetExpressionIR = 
   | ( simpleKeysetExpressionListIR ) (from tupleKeysetExpressionIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:231:1-232:28:
syntax keysetExpressionIR = 
   | expressionIR # expressionNoteIR (from typedExpressionIR) hint(print %0) hint(prose %0 "annotated with" %1) hint(prose_fields "expression" "note")
   | typedExpressionIR &&& typedExpressionIR (from simpleKeysetExpressionIR)
   | typedExpressionIR .. typedExpressionIR (from simpleKeysetExpressionIR)
   | default (from simpleKeysetExpressionIR)
   | _ (from simpleKeysetExpressionIR)
   | ( simpleKeysetExpressionListIR ) (from tupleKeysetExpressionIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:234:1-236:63:
def $flatten_keysetExpressionIR(keysetExpressionIR) : simpleKeysetExpressionListIR =

   ;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:238:1-239:33:
   clause 0(keysetExpressionIR) = [simpleKeysetExpressionIR]
      -- if keysetExpressionIR <: simpleKeysetExpressionIR
      -- let simpleKeysetExpressionIR = keysetExpressionIR as simpleKeysetExpressionIR

   ;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:240:1-241:33:
   clause 1(keysetExpressionIR) = simpleKeysetExpressionListIR
      -- if keysetExpressionIR <: tupleKeysetExpressionIR
      -- let ( simpleKeysetExpressionListIR ) = keysetExpressionIR as tupleKeysetExpressionIR

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:247:29-247:44:
syntax typeArgumentListIR = typeArgumentIR*

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:254:1-257:7:
syntax argumentIR = 
   | expressionIR # expressionNoteIR (from typedExpressionIR) hint(print %0) hint(prose %0 "annotated with" %1) hint(prose_fields "expression" "note")
   | nameIR = typedExpressionIR (from argumentIR)
   | nameIR = _ (from argumentIR)
   | _ (from argumentIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:259:25-259:36:
syntax argumentListIR = argumentIR*

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:266:1-271:23:
syntax lvalueIR = 
   | ` nameIR (from prefixedNameIR) hint(print %0)
   | . nameIR (from prefixedNameIR)
   | typedLvalueIR . nameIR (from lvalueIR)
   | typedLvalueIR [ typedExpressionIR ] (from lvalueIR)
   | typedLvalueIR [ typedExpressionIR : typedExpressionIR ] (from lvalueIR)
   | typedLvalueIR [ typedExpressionIR + : typedExpressionIR ] (from lvalueIR)
   | ( typedLvalueIR ) (from lvalueIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:273:23-273:34:
syntax lvalueNoteIR = 
   | ( typeIR ) (from lvalueNoteIR)

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:275:24-278:37:
syntax typedLvalueIR = 
   | lvalueIR # lvalueNoteIR (from typedLvalueIR) hint(print %0) hint(prose %0 "with note" %1) hint(prose_fields "lvalue" "note")

;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:280:1-281:41:
def $type_of_typedLvalueIR(typedLvalueIR) : typeIR =

   ;; ../../../../../spectec/examples/p4-concrete/4-p4-ir/4.0-ir-syntax.spectec:282:1-283:41:
   clause 0(typedLvalueIR) = typeIR
      -- let _lvalueIR # ( typeIR ) = typedLvalueIR

