def $contains(text, text) : bool =

   ;; ../../../../../spectec/examples/p4-concrete/0-aux/0.0-stdlib.spectec:136:1-136:51:
   clause 0(t, t_c) = $contains'(0, |t|, t, t_c)

;; ../../../../../spectec/examples/p4-concrete/0-aux/0.0-stdlib.spectec:135:1-135:44:
def $contains'(nat, nat, text, text) : bool =

   ;; ../../../../../spectec/examples/p4-concrete/0-aux/0.0-stdlib.spectec:137:1-137:45:
   clause 0(n_len, n_len', t, t_c) = false
      -- if (n_len = n_len')

   ;; ../../../../../spectec/examples/p4-concrete/0-aux/0.0-stdlib.spectec:138:1-140:19:
   clause 1(n, n_len, t, t_c) = true
      -- if (n < n_len)
      -- if (t[n] = t_c)

   ;; ../../../../../spectec/examples/p4-concrete/0-aux/0.0-stdlib.spectec:141:1-144:21:
   clause 2(n, n_len, t, t_c) = $contains'((n + 1), n_len, t, t_c)
      -- if (n < n_len)
      -- if (t[n] =/= t_c)

