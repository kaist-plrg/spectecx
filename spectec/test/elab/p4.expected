      -- let expression_base = $expressionNonBrace_as_expression(expressionNonBrace_base)

   ;; ../../../../../spectec/examples/p4-concrete/1-p4-surface/1-syntax.spectec:507:1-511:67:
   clause 10(expressionNonBrace) = expression_base [ expression_hi : expression_lo ] as expression
